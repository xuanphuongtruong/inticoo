<script src="/js/dashboard.js"></script>
<script>
// ── Filter tabs ──────────────────────────────────────────────────────
document.getElementById('ftabs')?.addEventListener('click', function (e) {
    const btn = e.target.closest('.db-ftab');
    if (!btn) return;
    this.querySelectorAll('.db-ftab').forEach(b => b.classList.remove('on'));
    btn.classList.add('on');
    const filter = btn.dataset.f;
    // dashboard.js exposes dbFilterTable(filter)
    if (typeof dbFilterTable === 'function') dbFilterTable(filter);
});
</script>
