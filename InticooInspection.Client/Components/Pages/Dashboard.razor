@page "/dashboard"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin,Inspector,Customer")]
@inject IConfiguration Configuration

<PageTitle>Dashboard — Inticoo Inspection</PageTitle>
<span id="blazor-api-base" data-url="@(Configuration["ApiBaseUrl"])" style="display:none"></span>

<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet"/>

<!-- ══ PAGE CONTENT ══ -->
<div class="db-wrap">

    <!-- ── API Config Banner ── -->
    <div class="cfg-banner" id="cfg-banner" style="display:none">
        <div style="font-size:18px">⚙️</div>
        <div style="flex:1;min-width:140px">
            <div style="font-weight:700;color:var(--db-amber);margin-bottom:3px">Connect API Server</div>
            <div style="font-size:12px;color:var(--db-muted)">Enter Base URL — e.g. <code style="color:var(--db-text)">http://localhost:5000</code></div>
        </div>
        <input type="text" id="api-input" placeholder="https://your-api.inticoo.com" />
        <button class="cfg-btn" onclick="dbSaveUrl()">Connect →</button>
    </div>

    <!-- ── Page Header ── -->
    <div class="db-ph">
        <div class="db-ph-left">
            <h1>Overview</h1>
            <p>
                <span class="db-ldot-live"></span>Live data from API ·
                <span id="last-upd">Not connected</span>
                <button class="db-ref-btn" title="Refresh" onclick="dbLoadAll()" id="ref-btn">
                    <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                    </svg>
                </button>
            </p>
        </div>
    </div>

    <!-- ══════════════════════════════════════════
         ROW 1 — KPI CARDS (6 cards: 3+3)
    ══════════════════════════════════════════ -->
    <div class="db-kgrid">
        <!-- Card 1: Total Inspections -->
        <div class="db-kcard c1">
            <div class="db-ktop">
                <div class="db-kico i1">
                    <svg width="19" height="19" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
                    </svg>
                </div>
                <span class="db-kdelta up" id="d1">—</span>
            </div>
            <div class="db-kval" id="k1">—</div>
            <div class="db-klbl">Total Inspections</div>
        </div>

        <!-- Card 2: Pending -->
        <div class="db-kcard c2">
            <div class="db-ktop">
                <div class="db-kico i2">
                    <svg width="19" height="19" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
                    </svg>
                </div>
                <span class="db-kdelta" id="d2">—</span>
            </div>
            <div class="db-kval" id="k2">—</div>
            <div class="db-klbl">Pending</div>
        </div>

        <!-- Card 3: Customers -->
        <div class="db-kcard c3">
            <div class="db-ktop">
                <div class="db-kico i3">
                    <svg width="19" height="19" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0"/>
                    </svg>
                </div>
                <span class="db-kdelta up" id="d3">—</span>
            </div>
            <div class="db-kval" id="k3">—</div>
            <div class="db-klbl">Customers</div>
        </div>

        <!-- Card 4: Vendors -->
        <div class="db-kcard c4">
            <div class="db-ktop">
                <div class="db-kico i4">
                    <svg width="19" height="19" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0H5m14 0h2M5 21H3M9 7h1m-1 4h1m4-4h1m-1 4h1"/>
                    </svg>
                </div>
                <span class="db-kdelta up" id="d4">—</span>
            </div>
            <div class="db-kval" id="k4">—</div>
            <div class="db-klbl">Vendors</div>
        </div>

        <!-- Card 5: Products -->
        <div class="db-kcard c5">
            <div class="db-ktop">
                <div class="db-kico i5">
                    <svg width="19" height="19" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10"/>
                    </svg>
                </div>
                <span class="db-kdelta up" id="d5">—</span>
            </div>
            <div class="db-kval" id="k5">—</div>
            <div class="db-klbl">Products</div>
        </div>

        <!-- Card 6: Inspectors -->
        <div class="db-kcard c6">
            <div class="db-ktop">
                <div class="db-kico i6">
                    <svg width="19" height="19" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                </div>
                <span class="db-kdelta up" id="d6">—</span>
            </div>
            <div class="db-kval" id="k6">—</div>
            <div class="db-klbl">Inspectors</div>
        </div>
    </div>

    <!-- ══════════════════════════════════════════
         ROW 2 — Inspections by Month + Status Donut
    ══════════════════════════════════════════ -->
    <div class="db-g31">

        <!-- Inspections by Month -->
        <div class="db-panel" style="animation-delay:.2s">
            <div class="db-ph2">
                <div>
                    <div class="db-ptitle">Inspections by Month</div>
                    <div class="db-psub">Last 12 months</div>
                </div>
                <div style="display:flex;gap:12px;align-items:center">
                    <span class="db-legend-item"><span class="db-legend-dot" style="background:var(--db-accent)"></span>Completed</span>
                    <span class="db-legend-item"><span class="db-legend-dot" style="background:var(--db-blue)"></span>Created</span>
                </div>
            </div>
            <div class="db-pbody">
                <div class="db-bchart" id="bar-chart-month">
                    <div class="db-sk" style="height:100%;width:100%;border-radius:4px"></div>
                </div>
                <div class="db-bar-lbls" id="bar-lbls-month"></div>
            </div>
            <div class="db-mstats" id="mstats-month">
                <div class="db-ms">
                    <div class="db-msv" id="ms-completed" style="color:var(--db-accent)">—</div>
                    <div class="db-msl">Completed</div>
                </div>
                <div class="db-ms">
                    <div class="db-msv" id="ms-thismonth">—</div>
                    <div class="db-msl">This month</div>
                </div>
                <div class="db-ms">
                    <div class="db-msv" id="ms-pending" style="color:var(--db-amber)">—</div>
                    <div class="db-msl">Pending</div>
                </div>
            </div>
        </div>

        <!-- Status Donut -->
        <div class="db-panel" style="animation-delay:.24s">
            <div class="db-ph2">
                <div>
                    <div class="db-ptitle">Status</div>
                    <div class="db-psub">Current distribution</div>
                </div>
            </div>
            <div class="db-pbody">
                <div class="db-dwrap" id="donut-wrap">
                    <div class="db-sk" style="width:90px;height:90px;border-radius:50%;flex-shrink:0"></div>
                    <div style="flex:1;display:flex;flex-direction:column;gap:8px">
                        <div class="db-sk" style="height:12px"></div>
                        <div class="db-sk" style="height:12px"></div>
                        <div class="db-sk" style="height:12px"></div>
                        <div class="db-sk" style="height:12px"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ══════════════════════════════════════════
         ROW 3 — Inspections by Year
    ══════════════════════════════════════════ -->
    <div class="db-panel db-panel-full" style="animation-delay:.26s;margin-bottom:18px">
        <div class="db-ph2">
            <div>
                <div class="db-ptitle">Inspections by Year</div>
                <div class="db-psub">Annual overview</div>
            </div>
            <div style="display:flex;gap:12px;align-items:center">
                <span class="db-legend-item"><span class="db-legend-dot" style="background:var(--db-accent)"></span>Completed</span>
                <span class="db-legend-item"><span class="db-legend-dot" style="background:var(--db-blue)"></span>Created</span>
            </div>
        </div>
        <div class="db-pbody">
            <div class="db-bchart" id="bar-chart-year" style="height:100px">
                <div class="db-sk" style="height:100%;width:100%;border-radius:4px"></div>
            </div>
            <div class="db-bar-lbls" id="bar-lbls-year"></div>
        </div>
    </div>

    <!-- ══════════════════════════════════════════
         ROW 4 — Inspection Types (Month + Year side by side)
    ══════════════════════════════════════════ -->
    <div class="db-g2" style="margin-bottom:18px">

        <!-- Inspection Types by Month -->
        <div class="db-panel" style="animation-delay:.28s">
            <div class="db-ph2">
                <div>
                    <div class="db-ptitle">Inspection Types by Month</div>
                    <div class="db-psub">PPT · DPI · PST</div>
                </div>
            </div>
            <div class="db-pbody" id="tbreak-month">
                <div class="db-sk" style="height:130px;width:100%;border-radius:8px"></div>
            </div>
            <div class="db-mstats">
                <div class="db-ms">
                    <div class="db-msv" id="ms-ppt" style="color:var(--db-blue)">—</div>
                    <div class="db-msl">Pre-Production</div>
                </div>
                <div class="db-ms">
                    <div class="db-msv" id="ms-dpi" style="color:var(--db-accent)">—</div>
                    <div class="db-msl">During Prod.</div>
                </div>
                <div class="db-ms">
                    <div class="db-msv" id="ms-pst" style="color:var(--db-amber)">—</div>
                    <div class="db-msl">Pre-Shipment</div>
                </div>
            </div>
        </div>

        <!-- Inspection Types by Year -->
        <div class="db-panel" style="animation-delay:.30s">
            <div class="db-ph2">
                <div>
                    <div class="db-ptitle">Inspection Types by Year</div>
                    <div class="db-psub">PPT · DPI · PST</div>
                </div>
            </div>
            <div class="db-pbody" id="tbreak-year">
                <div class="db-sk" style="height:130px;width:100%;border-radius:8px"></div>
            </div>
            <div class="db-mstats">
                <div class="db-ms">
                    <div class="db-msv" id="ms-vendors" style="color:var(--db-blue)">—</div>
                    <div class="db-msl">Vendors active</div>
                </div>
                <div class="db-ms">
                    <div class="db-msv" id="ms-users" style="color:var(--db-accent)">—</div>
                    <div class="db-msl">System Users</div>
                </div>
            </div>
        </div>
    </div>

    <!-- ══════════════════════════════════════════
         ROW 5 — Recent Inspections + Right column
    ══════════════════════════════════════════ -->
    <div class="db-g2">

        <!-- Recent Inspections Table -->
        <div class="db-panel" style="animation-delay:.32s">
            <div class="db-ftabs" id="ftabs">
                <button class="db-ftab on" data-f="all">All</button>
                <button class="db-ftab" data-f="completed">Completed</button>
                <button class="db-ftab" data-f="pending">Pending</button>
                <button class="db-ftab" data-f="cancelled">Cancelled</button>
            </div>
            <div class="db-ph2" style="padding-top:10px">
                <div>
                    <div class="db-ptitle">Recent Inspections</div>
                    <div class="db-psub" id="tbl-sub">—</div>
                </div>
                <a class="db-pact" href="/inspections">View all →</a>
            </div>
            <div class="db-twrap">
                <table>
                    <thead>
                        <tr>
                            <th>Job #</th>
                            <th>Customer / Category</th>
                            <th>Inspector Name</th>
                            <th>Status / Date</th>
                        </tr>
                    </thead>
                    <tbody id="tbody">
                        <tr>
                            <td colspan="4">
                                <div class="db-errmsg">
                                    <div class="db-ei">⚙️</div>
                                    Configure API URL to view data
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Right column: Quick Actions + Top Customers + Top Inspectors -->
        <div style="display:flex;flex-direction:column;gap:18px">

            <!-- Quick Actions -->
            <div class="db-panel" style="animation-delay:.36s">
                <div class="db-ph2">
                    <div class="db-ptitle">Quick Actions</div>
                </div>
                <div class="db-pbody">
                    <div class="db-qgrid">
                        <a class="db-qbtn" href="/inspections/new">
                            <div class="db-qico" style="background:rgba(0,212,170,.1)">📋</div>
                            <div><div class="db-qlbl">New Inspection</div><div class="db-qdesc">New job</div></div>
                        </a>
                        <a class="db-qbtn" href="/customers">
                            <div class="db-qico" style="background:rgba(59,130,246,.1)">🏢</div>
                            <div><div class="db-qlbl">Add Customer</div><div class="db-qdesc">Register client</div></div>
                        </a>
                        <a class="db-qbtn" href="/products">
                            <div class="db-qico" style="background:rgba(245,158,11,.1)">📦</div>
                            <div><div class="db-qlbl">Add Product</div><div class="db-qdesc">New SKU</div></div>
                        </a>
                        <a class="db-qbtn" href="#">
                            <div class="db-qico" style="background:rgba(239,68,68,.1)">📊</div>
                            <div><div class="db-qlbl">Export Report</div><div class="db-qdesc">PDF / Excel</div></div>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Top Customers -->
            <div class="db-panel" style="animation-delay:.38s">
                <div class="db-ph2">
                    <div>
                        <div class="db-ptitle">Top Customers</div>
                        <div class="db-psub">Most Inspection</div>
                    </div>
                    <a class="db-pact" href="/customers">All →</a>
                </div>
                <div class="db-pbody">
                    <div class="db-ilist" id="clist">
                        <div class="db-sk" style="height:130px;width:100%;border-radius:8px"></div>
                    </div>
                </div>
            </div>

            <!-- Top Inspectors -->
            <div class="db-panel" style="animation-delay:.40s">
                <div class="db-ph2">
                    <div>
                        <div class="db-ptitle">Top Inspectors</div>
                        <div class="db-psub">Most Jobs</div>
                    </div>
                    <a class="db-pact" href="/users">All →</a>
                </div>
                <div class="db-pbody">
                    <div class="db-ilist" id="ilist">
                        <div class="db-sk" style="height:130px;width:100%;border-radius:8px"></div>
                    </div>
                </div>
            </div>

        </div>
    </div>

</div>

@* ══════════════════════════════════════════════════════════════════════
   CSS  — prefix "db-" to avoid collisions with MainLayout
══════════════════════════════════════════════════════════════════════ *@
<style>
    :root {
        --db-card:    #ffffff;
        --db-border:  #e2e8f0;
        --db-surface: #f8fafc;
        --db-accent:  #00a884;
        --db-blue:    #2563eb;
        --db-amber:   #d97706;
        --db-red:     #dc2626;
        --db-purple:  #7c3aed;
        --db-text:    #0f172a;
        --db-muted:   #64748b;
        --db-r:       12px;
    }

    /* ── WRAP ── */
    .db-wrap {
        font-family: 'DM Sans', sans-serif;
        color: var(--db-text);
        padding: 24px;
        background: #f1f5f9;
        border-radius: 8px;
        min-height: 100vh;
    }

    /* ── CONFIG BANNER ── */
    .cfg-banner {
        background: rgba(245,158,11,.07);
        border: 1px solid rgba(245,158,11,.2);
        border-radius: 10px;
        padding: 14px 18px;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 14px;
        flex-wrap: wrap;
    }
    .cfg-banner input {
        background: var(--db-surface);
        border: 1px solid var(--db-border);
        border-radius: 7px;
        padding: 7px 12px;
        font-size: 13px;
        color: var(--db-text);
        font-family: inherit;
        width: 280px;
        outline: none;
        flex: 1;
        min-width: 180px;
    }
    .cfg-banner input:focus { border-color: var(--db-accent); }
    .cfg-btn {
        background: var(--db-accent);
        color: #fff;
        font-size: 12px;
        font-weight: 700;
        border: none;
        border-radius: 7px;
        padding: 8px 16px;
        cursor: pointer;
        font-family: inherit;
        white-space: nowrap;
    }
    .cfg-btn:hover { opacity: .85; }

    /* ── PAGE HEADER ── */
    .db-ph {
        margin-bottom: 22px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .db-ph h1 {
        font-family: 'Syne', sans-serif;
        font-weight: 800;
        font-size: 26px;
        color: var(--db-text);
        margin: 0;
    }
    .db-ph p {
        font-size: 13px;
        color: var(--db-muted);
        margin-top: 4px;
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .db-ref-btn {
        background: none;
        border: none;
        cursor: pointer;
        color: var(--db-muted);
        padding: 2px 4px;
        border-radius: 4px;
        transition: color .15s;
        display: inline-flex;
    }
    .db-ref-btn:hover { color: var(--db-accent); }

    /* ── KPI GRID — 6 cards ── */
    .db-kgrid {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: 14px;
        margin-bottom: 20px;
    }
    .db-kcard {
        background: var(--db-card);
        border: 1px solid var(--db-border);
        border-radius: var(--db-r);
        padding: 18px;
        position: relative;
        overflow: hidden;
        transition: transform .2s, box-shadow .2s;
        animation: dbUp .5s ease both;
    }
    .db-kcard:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 32px rgba(0,0,0,.08);
    }
    .db-kcard::after {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
    }
    .db-kcard.c1::after { background: linear-gradient(90deg, var(--db-accent), #00d4aa); }
    .db-kcard.c2::after { background: linear-gradient(90deg, var(--db-amber), #f97316); }
    .db-kcard.c3::after { background: linear-gradient(90deg, var(--db-blue), #6366f1); }
    .db-kcard.c4::after { background: linear-gradient(90deg, var(--db-red), #ec4899); }
    .db-kcard.c5::after { background: linear-gradient(90deg, var(--db-purple), #a78bfa); }
    .db-kcard.c6::after { background: linear-gradient(90deg, #0891b2, #06b6d4); }
    .db-kcard:nth-child(1){animation-delay:.04s}
    .db-kcard:nth-child(2){animation-delay:.08s}
    .db-kcard:nth-child(3){animation-delay:.12s}
    .db-kcard:nth-child(4){animation-delay:.16s}
    .db-kcard:nth-child(5){animation-delay:.20s}
    .db-kcard:nth-child(6){animation-delay:.24s}
    .db-ktop {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 12px;
    }
    .db-kico {
        width: 40px; height: 40px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .db-kico.i1 { background: rgba(0,168,132,.12);  color: var(--db-accent); }
    .db-kico.i2 { background: rgba(217,119,6,.12);   color: var(--db-amber); }
    .db-kico.i3 { background: rgba(37,99,235,.12);   color: var(--db-blue); }
    .db-kico.i4 { background: rgba(220,38,38,.12);   color: var(--db-red); }
    .db-kico.i5 { background: rgba(124,58,237,.12);  color: var(--db-purple); }
    .db-kico.i6 { background: rgba(8,145,178,.12);   color: #0891b2; }
    .db-kdelta {
        font-size: 10px;
        font-weight: 700;
        padding: 2px 7px;
        border-radius: 999px;
    }
    .db-kdelta.up   { background: rgba(0,168,132,.1); color: var(--db-accent); }
    .db-kdelta.down { background: rgba(220,38,38,.1); color: var(--db-red); }
    .db-kval {
        font-family: 'Syne', sans-serif;
        font-size: 28px;
        font-weight: 800;
        line-height: 1;
        min-height: 28px;
    }
    .db-klbl {
        font-size: 12px;
        color: var(--db-muted);
        margin-top: 5px;
    }

    /* ── GRID LAYOUTS ── */
    .db-g2  { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin-bottom: 18px; }
    .db-g31 { display: grid; grid-template-columns: 2fr 1fr; gap: 18px; margin-bottom: 18px; }
    .db-panel-full { width: 100%; }

    /* ── PANEL ── */
    .db-panel {
        background: var(--db-card);
        border: 1px solid var(--db-border);
        border-radius: var(--db-r);
        animation: dbUp .55s ease both;
    }
    .db-ph2 {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 18px 12px;
        border-bottom: 1px solid var(--db-border);
    }
    .db-ptitle {
        font-family: 'Syne', sans-serif;
        font-weight: 700;
        font-size: 14px;
    }
    .db-psub {
        font-size: 11px;
        color: var(--db-muted);
        margin-top: 2px;
    }
    .db-pact {
        font-size: 12px;
        color: var(--db-accent);
        font-weight: 600;
        cursor: pointer;
        border: none;
        background: none;
        transition: opacity .2s;
        font-family: inherit;
        text-decoration: none;
    }
    .db-pact:hover { opacity: .7; }
    .db-pbody { padding: 18px; }

    /* ── SKELETON ── */
    .db-sk {
        background: linear-gradient(90deg, var(--db-border) 25%, var(--db-surface) 50%, var(--db-border) 75%);
        background-size: 200% 100%;
        animation: dbShimmer 1.5s infinite;
        border-radius: 6px;
    }
    @@keyframes dbShimmer { from{background-position:200% 0} to{background-position:-200% 0} }

    /* ── LEGEND ── */
    .db-legend-item {
        display: flex;
        align-items: center;
        gap: 4px;
        font-size: 10px;
        color: var(--db-muted);
    }
    .db-legend-dot {
        width: 8px; height: 3px;
        border-radius: 2px;
        display: inline-block;
    }

    /* ── BAR CHART ── */
    .db-bchart {
        display: flex;
        align-items: flex-end;
        gap: 5px;
        height: 120px;
    }
    .db-bar-lbls {
        display: flex;
        justify-content: space-between;
        margin-top: 6px;
    }
    .bcol {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    .bwrap {
        flex: 1;
        width: 100%;
        display: flex;
        align-items: flex-end;
        gap: 2px;
    }
    .bar {
        flex: 1;
        border-radius: 3px 3px 0 0;
        transition: height 1s cubic-bezier(.4,0,.2,1);
        cursor: pointer;
        min-height: 2px;
        position: relative;
    }
    .bar:hover::after {
        content: attr(data-v);
        position: absolute;
        top: -22px; left: 50%;
        transform: translateX(-50%);
        background: var(--db-text);
        color: #fff;
        font-size: 9px;
        padding: 2px 6px;
        border-radius: 3px;
        white-space: nowrap;
        z-index: 10;
    }
    .bar-lbl {
        font-size: 9px;
        color: var(--db-muted);
        margin-top: 4px;
        text-align: center;
        flex: 1;
    }

    /* ── DONUT ── */
    .db-dwrap { display: flex; align-items: center; gap: 16px; }
    .dleg { flex: 1; }
    .li { display: flex; align-items: center; gap: 8px; margin-bottom: 9px; }
    .ldot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
    .lname { font-size: 11.5px; color: var(--db-muted); }
    .lval { font-size: 13px; font-weight: 600; }
    .lpct { font-size: 11px; color: var(--db-muted); margin-left: auto; }

    /* ── TYPE BREAKDOWN BARS ── */
    .tbar-row { margin-bottom: 14px; }
    .tbar-row:last-child { margin-bottom: 0; }
    .tbar-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 5px;
    }
    .tbar-lbl { font-size: 12.5px; font-weight: 500; }
    .tbar-cnt { font-size: 12px; font-weight: 700; }
    .tbar-bg {
        height: 6px;
        background: var(--db-border);
        border-radius: 999px;
        overflow: hidden;
    }
    .tbar-fill {
        height: 100%;
        border-radius: 999px;
        transition: width 1.2s ease;
    }
    .tbar-pct { font-size: 10px; color: var(--db-muted); margin-top: 4px; }

    /* ── TABLE ── */
    .db-twrap { overflow-x: auto; }
    .db-twrap table { width: 100%; border-collapse: collapse; }
    .db-twrap thead th {
        text-align: left;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .8px;
        color: var(--db-muted);
        padding: 0 14px 10px;
        white-space: nowrap;
    }
    .db-twrap tbody tr {
        border-top: 1px solid var(--db-border);
        transition: background .12s;
    }
    .db-twrap tbody tr:hover { background: rgba(0,0,0,.02); }
    .db-twrap tbody td { padding: 11px 14px; font-size: 13px; }
    .tmain { font-weight: 600; color: var(--db-text); }
    .tsub { font-size: 11px; color: var(--db-muted); margin-top: 2px; }

    /* ── BADGE ── */
    .badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 10px;
        font-weight: 700;
        padding: 3px 8px;
        border-radius: 999px;
        text-transform: uppercase;
        letter-spacing: .3px;
    }
    .badge::before {
        content: '';
        width: 5px; height: 5px;
        border-radius: 50%;
        flex-shrink: 0;
    }
    .b-completed { background:rgba(0,168,132,.1);  color:var(--db-accent); }
    .b-completed::before { background: var(--db-accent); }
    .b-ongoing   { background:rgba(37,99,235,.1);   color:var(--db-blue); }
    .b-ongoing::before   { background: var(--db-blue); }
    .b-pending, .b-new { background:rgba(217,119,6,.1); color:var(--db-amber); }
    .b-pending::before, .b-new::before { background: var(--db-amber); }
    .b-cancelled, .b-cancel { background:rgba(220,38,38,.1); color:var(--db-red); }
    .b-cancelled::before, .b-cancel::before { background: var(--db-red); }

    /* ── FILTER TABS ── */
    .db-ftabs {
        display: flex;
        gap: 3px;
        padding: 14px 16px 0;
        flex-wrap: wrap;
    }
    .db-ftab {
        font-size: 11px;
        font-weight: 600;
        padding: 5px 12px;
        border-radius: 6px;
        cursor: pointer;
        background: none;
        border: none;
        color: var(--db-muted);
        transition: all .15s;
        font-family: inherit;
    }
    .db-ftab.on  { background: rgba(0,168,132,.1); color: var(--db-accent); }
    .db-ftab:hover:not(.on) { color: var(--db-text); }

    /* ── MINI STATS STRIP ── */
    .db-mstats { display: flex; border-top: 1px solid var(--db-border); }
    .db-ms {
        flex: 1;
        padding: 12px 16px;
        border-right: 1px solid var(--db-border);
    }
    .db-ms:last-child { border-right: none; }
    .db-msv {
        font-family: 'Syne', sans-serif;
        font-size: 18px;
        font-weight: 800;
    }
    .db-msl { font-size: 10px; color: var(--db-muted); margin-top: 2px; }

    /* ── RANKED LIST (Customers & Inspectors) ── */
    .db-ilist { display: flex; flex-direction: column; gap: 10px; }
    .irow { display: flex; align-items: center; gap: 10px; }
    .irank {
        width: 18px;
        font-size: 11px;
        font-weight: 700;
        color: var(--db-muted);
        text-align: center;
        flex-shrink: 0;
    }
    .iav {
        width: 32px; height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 700;
        color: #fff;
        flex-shrink: 0;
    }
    .iname  { font-size: 12.5px; font-weight: 600; color: var(--db-text); }
    .iid    { font-size: 10px; color: var(--db-muted); }
    .ibg    { height: 4px; background: var(--db-border); border-radius: 999px; overflow: hidden; width: 60px; }
    .ifill  { height: 100%; border-radius: 999px; }
    .inum   { font-size: 13px; font-weight: 700; min-width: 24px; text-align: right; color: var(--db-text); }

    /* ── QUICK ACTIONS ── */
    .db-qgrid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
    .db-qbtn {
        background: var(--db-surface);
        border: 1px solid var(--db-border);
        border-radius: 9px;
        padding: 12px;
        cursor: pointer;
        transition: all .15s;
        display: flex;
        align-items: center;
        gap: 9px;
        text-decoration: none;
        color: inherit;
    }
    .db-qbtn:hover { border-color: var(--db-accent); background: rgba(0,168,132,.03); }
    .db-qico {
        width: 32px; height: 32px;
        border-radius: 7px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 15px;
        flex-shrink: 0;
    }
    .db-qlbl  { font-size: 12px; font-weight: 600; }
    .db-qdesc { font-size: 10px; color: var(--db-muted); margin-top: 1px; }

    /* ── MISC ── */
    .db-ldot-live {
        display: inline-block;
        width: 7px; height: 7px;
        border-radius: 50%;
        background: var(--db-accent);
        animation: dbPulse 1.8s ease infinite;
    }
    .db-errmsg { text-align: center; padding: 28px; color: var(--db-muted); font-size: 13px; }
    .db-ei { font-size: 26px; margin-bottom: 8px; }

    /* ── ANIMATIONS ── */
    @@keyframes dbUp {
        from { opacity: 0; transform: translateY(14px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    @@keyframes dbPulse { 0%,100%{opacity:1} 50%{opacity:.3} }

    /* ── RESPONSIVE ── */
    @@media (max-width: 1400px) {
        .db-kgrid { grid-template-columns: repeat(3, 1fr); }
    }
    @@media (max-width: 1100px) {
        .db-g31  { grid-template-columns: 1fr; }
        .db-g2   { grid-template-columns: 1fr; }
    }
    @@media (max-width: 768px) {
        .db-kgrid  { grid-template-columns: repeat(2, 1fr); }
        .db-qgrid  { grid-template-columns: repeat(4, 1fr); }
        .db-wrap   { padding: 14px; }
    }
    @@media (max-width: 480px) {
        .db-kgrid { grid-template-columns: 1fr 1fr; }
        .db-qgrid { grid-template-columns: 1fr 1fr; }
    }
</style>

