@page "/dashboard"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@using System.Net.Http.Json
@using System.Text.Json.Serialization
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Dashboard - Inticoo</PageTitle>

@if (_loading)
{
    <div class="db-loading">
        <div class="db-spinner"></div>
        <span>Loading dashboard...</span>
    </div>
}
else if (_error != null)
{
    <div class="db-error">⚠ @_error</div>
}
else if (_data != null)
{
    <div class="db-page">

        <!-- ── Header ── -->
        <div class="db-header">
            <div>
                <h1 class="db-title">Overview</h1>
                <div class="db-subtitle">
                    <span class="db-live-dot"></span>
                    Live data from API
                    <span class="db-update-time">· Update @_data.UpdatedAt.ToLocalTime().ToString("hh:mmtt")</span>
                    <button class="db-refresh-btn" @onclick="LoadData" title="Refresh">
                        <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                            <path d="M4 4a8 8 0 0 1 12 0M16 16a8 8 0 0 1-12 0M4 4v4h4M16 16v-4h-4"/>
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        <!-- ── Summary Cards ── -->
        <div class="db-cards-grid">
            <div class="db-card" style="--accent:#3b82f6;">
                <div class="db-card-icon" style="background:#eff6ff;">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="1.8">
                        <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/>
                        <rect x="9" y="3" width="6" height="4" rx="1"/>
                        <path d="M9 12l2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <div class="db-card-badge" style="background:#dbeafe;color:#1d4ed8;">@_data.TotalInspections jobs</div>
                <div class="db-card-value">@_data.TotalInspections</div>
                <div class="db-card-label">Total Inspections</div>
            </div>

            <div class="db-card" style="--accent:#f59e0b;">
                <div class="db-card-icon" style="background:#fffbeb;">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="1.8">
                        <circle cx="12" cy="12" r="10"/>
                        <path d="M12 6v6l4 2" stroke-linecap="round"/>
                    </svg>
                </div>
                <div class="db-card-badge" style="background:#fef3c7;color:#b45309;">@_data.PendingInspections active</div>
                <div class="db-card-value">@_data.PendingInspections</div>
                <div class="db-card-label">Pending</div>
            </div>

            <div class="db-card" style="--accent:#8b5cf6;">
                <div class="db-card-icon" style="background:#f5f3ff;">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="1.8">
                        <circle cx="8" cy="7" r="4"/><path d="M2 21c0-4.418 2.686-8 6-8"/>
                        <circle cx="17" cy="7" r="3"/><path d="M14 21c0-3.314 1.343-6 3-6s3 2.686 3 6"/>
                    </svg>
                </div>
                <div class="db-card-value">@_data.CustomerCount</div>
                <div class="db-card-label">Customers</div>
            </div>

            <div class="db-card" style="--accent:#ef4444;">
                <div class="db-card-icon" style="background:#fef2f2;">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.8">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                        <polyline points="9 22 9 12 15 12 15 22"/>
                    </svg>
                </div>
                <div class="db-card-value">@_data.VendorCount</div>
                <div class="db-card-label">Vendors</div>
            </div>

            <div class="db-card" style="--accent:#10b981;">
                <div class="db-card-icon" style="background:#ecfdf5;">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="1.8">
                        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                    </svg>
                </div>
                <div class="db-card-value">@_data.ProductCount</div>
                <div class="db-card-label">Products</div>
            </div>

            <div class="db-card" style="--accent:#06b6d4;">
                <div class="db-card-icon" style="background:#ecfeff;">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#06b6d4" stroke-width="1.8">
                        <circle cx="12" cy="8" r="4"/>
                        <path d="M4 20c0-4 3.582-7 8-7s8 3 8 7"/>
                        <path d="M16 11l2 2 3-3" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <div class="db-card-value">@_data.InspectorCount</div>
                <div class="db-card-label">Inspectors</div>
            </div>
        </div>

        <!-- ── Inspections by Month ── -->
        <div class="db-section-title">Inspections (Monthly)</div>
        <div class="db-row">
            <div class="db-chart-card" style="flex:1;">
                <div class="db-mini-stats">
                    <div class="db-mini-stat">
                        <span class="db-mini-val" style="color:#3b82f6;">@_data.MonthCompleted</span>
                        <span class="db-mini-lbl">Completed</span>
                    </div>
                    <div class="db-mini-divider"></div>
                    <div class="db-mini-stat">
                        <span class="db-mini-val" style="color:#f59e0b;">@_data.MonthPending</span>
                        <span class="db-mini-lbl">Pending</span>
                    </div>
                </div>
                <!-- Bar chart by month -->
                <div class="db-barchart">
                    @{var maxVal = _data.ByMonth.Max(m => m.Completed + m.Pending);}
                    @{var months = new[]{"JAN","FEB","MAR","APR","MAY","JUN","JUL","AUG","SEP","OCT","NOV","DEC"};}
                    @foreach (var m in _data.ByMonth)
                    {
                        var total2 = m.Completed + m.Pending;
                        var heightPct = maxVal > 0 ? (double)total2 / maxVal * 100 : 0;
                        var compPct   = total2 > 0 ? (double)m.Completed / total2 * 100 : 0;
                        <div class="db-bar-col">
                            @if (total2 > 0)
                            {
                                <div class="db-bar-num">@total2</div>
                                <div class="db-bar-wrap" style="height:@((int)heightPct)%">
                                    <div class="db-bar-seg completed" style="height:@((int)compPct)%;"></div>
                                    <div class="db-bar-seg pending" style="height:@((int)(100-compPct))%;"></div>
                                </div>
                            }
                            else
                            {
                                <div class="db-bar-num" style="opacity:0">0</div>
                                <div class="db-bar-wrap" style="height:4px;background:#e5e7eb;border-radius:2px;"></div>
                            }
                            <div class="db-bar-label">@months[m.Month - 1]</div>
                        </div>
                    }
                </div>
                <div class="db-legend">
                    <span class="db-leg-item"><span class="db-leg-dot" style="background:#3b82f6;"></span>Completed</span>
                    <span class="db-leg-item"><span class="db-leg-dot" style="background:#f59e0b;"></span>Pending</span>
                </div>
            </div>
        </div>

        <!-- ── Inspection Types by Month ── -->
        <div class="db-section-title">Inspection Types (Monthly)
            <span class="db-section-sub">PPT &nbsp;·&nbsp; DPI &nbsp;·&nbsp; PST</span>
        </div>
        <div class="db-row">
            <div class="db-chart-card" style="flex:1;">
                <div class="db-mini-stats">
                    <div class="db-mini-stat">
                        <span class="db-mini-val" style="color:#3b82f6;">@_data.MonthPpt</span>
                        <span class="db-mini-lbl">Pre-Production</span>
                    </div>
                    <div class="db-mini-divider"></div>
                    <div class="db-mini-stat">
                        <span class="db-mini-val" style="color:#f59e0b;">@_data.MonthDpi</span>
                        <span class="db-mini-lbl">During Production</span>
                    </div>
                    <div class="db-mini-divider"></div>
                    <div class="db-mini-stat">
                        <span class="db-mini-val" style="color:#10b981;">@_data.MonthPst</span>
                        <span class="db-mini-lbl">Pre-Shipment</span>
                    </div>
                </div>
                <!-- Type bar chart by month -->
                <div class="db-barchart">
                    @{var maxType = _data.TypeByMonth.Max(m => m.Ppt + m.Dpi + m.Pst);}
                    @foreach (var m in _data.TypeByMonth)
                    {
                        var total3 = m.Ppt + m.Dpi + m.Pst;
                        var hp = maxType > 0 ? (double)total3 / maxType * 100 : 0;
                        <div class="db-bar-col">
                            @if (total3 > 0)
                            {
                                <div class="db-bar-num">@total3</div>
                                <div class="db-bar-wrap" style="height:@((int)hp)%">
                                    @if (m.Ppt > 0) { <div class="db-bar-seg" style="height:@((int)((double)m.Ppt/total3*100))%;background:#3b82f6;"></div> }
                                    @if (m.Dpi > 0) { <div class="db-bar-seg" style="height:@((int)((double)m.Dpi/total3*100))%;background:#f59e0b;"></div> }
                                    @if (m.Pst > 0) { <div class="db-bar-seg" style="height:@((int)((double)m.Pst/total3*100))%;background:#10b981;"></div> }
                                </div>
                            }
                            else
                            {
                                <div class="db-bar-num" style="opacity:0">0</div>
                                <div class="db-bar-wrap" style="height:4px;background:#e5e7eb;border-radius:2px;"></div>
                            }
                            <div class="db-bar-label">@months[m.Month - 1]</div>
                        </div>
                    }
                </div>
                <div class="db-legend">
                    <span class="db-leg-item"><span class="db-leg-dot" style="background:#3b82f6;"></span>PPT</span>
                    <span class="db-leg-item"><span class="db-leg-dot" style="background:#f59e0b;"></span>DPI</span>
                    <span class="db-leg-item"><span class="db-leg-dot" style="background:#10b981;"></span>PST</span>
                </div>
            </div>
        </div>

        <!-- ── Bottom Row: Recent Inspections full width ── -->
        <div class="db-row" style="align-items:flex-start;gap:20px;flex-wrap:wrap;">

            <!-- Recent Inspections — full width on mobile, 2/3 on desktop -->
            <div class="db-table-card db-main-col" style="flex:2;min-width:300px;">
                <div class="db-table-header">
                    <span class="db-table-title">Recent Inspections</span>
                    <div class="db-tab-group">
                        @foreach (var tab in new[]{"All","Completed","Pending","Cancelled"})
                        {
                            <button class="db-tab @(_activeTab == tab ? "active" : "")"
                                    @onclick="() => _activeTab = tab">@tab</button>
                        }
                    </div>
                    <span class="db-table-count">@FilteredInspections.Count()/@(_data.RecentInspections.Count) records</span>
                </div>
                <div class="db-table-wrap">
                    <table class="db-table">
                        <thead>
                            <tr>
                                <th>JOB#</th>
                                <th>CUSTOMERS / CATEGORY</th>
                                <th>INSPECTOR NAME</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in FilteredInspections)
                            {
                                <tr @onclick="() => GoToReport(r.JobNumber)" style="cursor:pointer;">
                                    <td>
                                        <span class="db-type-badge @r.InspType.ToLower()">@r.InspType</span>
                                        <div class="db-job-num">@(r.JobNumber ?? "—")</div>
                                        <span class="db-status-badge @r.Status.ToLower()">@r.Status</span>
                                    </td>
                                    <td>
                                        <div class="db-cust-name">@(r.CustomerName ?? "—")</div>
                                        <div class="db-cust-cat">@(r.ProductCategory ?? "—")</div>
                                    </td>
                                    <td>
                                        <div class="db-inspector">@(r.InspectorName ?? "—")</div>
                                        <div class="db-date">@r.Date.ToString("d MMM yyyy")</div>
                                    </td>
                                </tr>
                            }
                            @if (!FilteredInspections.Any())
                            {
                                <tr><td colspan="4" style="text-align:center;padding:24px;color:#9ca3af;">No records</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Right column: Quick Actions + Top Lists -->
            <div class="db-side-col" style="flex:1;min-width:0;display:flex;flex-direction:column;gap:16px;">

                <!-- Quick Actions -->
                <div class="db-action-card">
                    <div class="db-action-title">Quick Actions</div>
                    <NavLink href="/inspections/new" class="db-action-btn primary">
                        <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 4v12M4 10h12" stroke-linecap="round"/></svg>
                        New Inspection
                    </NavLink>
                    <NavLink href="/customers" class="db-action-btn">
                        <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="8" cy="7" r="3"/><path d="M2 17c0-3.314 2.686-6 6-6s6 2.686 6 6"/></svg>
                        New Customer
                    </NavLink>
                    <NavLink href="/suppliers" class="db-action-btn">
                        <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 9l7-6 7 6v9a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1z"/></svg>
                        Register New Vendor
                    </NavLink>
                    <NavLink href="/users" class="db-action-btn">
                        <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="10" cy="7" r="3.5"/><path d="M3 18c0-3.866 3.134-7 7-7s7 3.134 7 7"/></svg>
                        Register New Inspector
                    </NavLink>
                </div>

                <!-- Top Customers -->
                <div class="db-rank-card">
                    <div class="db-rank-header">
                        <span class="db-rank-title">Top Customers</span>
                        <span class="db-rank-sub">Most Inspection</span>
                    </div>
                    @{ int ci = 1; }
                    @foreach (var c in _data.TopCustomers)
                    {
                        <div class="db-rank-row">
                            <span class="db-rank-num">@ci</span>
                            <div class="db-rank-info">
                                <div class="db-rank-name">@c.CustomerName</div>
                                <div class="db-rank-id">@c.CustomerId</div>
                            </div>
                            <span class="db-rank-count">@c.Count</span>
                        </div>
                        ci++;
                    }
                    @if (!_data.TopCustomers.Any())
                    { <div style="text-align:center;padding:12px;color:#9ca3af;font-size:13px;">No data</div> }
                </div>

                <!-- Top Inspectors -->
                <div class="db-rank-card">
                    <div class="db-rank-header">
                        <span class="db-rank-title">Top Inspectors</span>
                        <span class="db-rank-sub">Most Jobs</span>
                    </div>
                    @{ int ii = 1; }
                    @foreach (var insp in _data.TopInspectors)
                    {
                        <div class="db-rank-row">
                            <span class="db-rank-num">@ii</span>
                            <div class="db-rank-info">
                                <div class="db-rank-name">@insp.InspectorName</div>
                                <div class="db-rank-id">@insp.InspectorId</div>
                            </div>
                            <span class="db-rank-count">@insp.Count</span>
                        </div>
                        ii++;
                    }
                    @if (!_data.TopInspectors.Any())
                    { <div style="text-align:center;padding:12px;color:#9ca3af;font-size:13px;">No data</div> }
                </div>

            </div>
        </div>

    </div>
}

@code {
    private DashboardDto? _data;
    private bool _loading = true;
    private string? _error;
    private string _activeTab = "All";

    protected override async Task OnInitializedAsync() => await LoadData();

    void GoToReport(string? jobNumber)
    {
        if (!string.IsNullOrEmpty(jobNumber))
            Navigation.NavigateTo("/inspection-report/" + jobNumber);
    }

    async Task LoadData()
    {
        _loading = true;
        _error   = null;
        try
        {
            _data = await Http.GetFromJsonAsync<DashboardDto>("api/inspections/dashboard",
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
        }
        catch (Exception ex) { _error = ex.Message; }
        _loading = false;
    }

    IEnumerable<RecentInspectionDto> FilteredInspections => _activeTab switch
    {
        "Completed" => _data!.RecentInspections.Where(r => r.Status == "Completed"),
        "Pending"   => _data!.RecentInspections.Where(r => r.Status == "Pending"),
        "Cancelled" => _data!.RecentInspections.Where(r => r.Status == "Cancelled"),
        _           => _data!.RecentInspections
    };

    // ── DTOs ──────────────────────────────────────────────────────────────────
    class DashboardDto
    {
        public DateTime UpdatedAt           { get; set; }
        public int  TotalInspections        { get; set; }
        public int  PendingInspections      { get; set; }
        public int  CompletedInspections    { get; set; }
        public int  CustomerCount           { get; set; }
        public int  VendorCount             { get; set; }
        public int  ProductCount            { get; set; }
        public int  InspectorCount          { get; set; }
        public int  MonthCompleted          { get; set; }
        public int  MonthPending            { get; set; }
        public int  MonthPpt                { get; set; }
        public int  MonthDpi                { get; set; }
        public int  MonthPst                { get; set; }
        public int  YearPpt                 { get; set; }
        public int  YearDpi                 { get; set; }
        public int  YearPst                 { get; set; }
        public List<MonthStatDto>       ByMonth          { get; set; } = new();
        public List<TypeMonthDto>       TypeByMonth      { get; set; } = new();
        public List<RecentInspectionDto> RecentInspections { get; set; } = new();
        public List<TopCustomerDto>     TopCustomers     { get; set; } = new();
        public List<TopInspectorDto>    TopInspectors    { get; set; } = new();
    }

    class MonthStatDto
    {
        public int Month     { get; set; }
        public int Completed { get; set; }
        public int Pending   { get; set; }
    }

    class TypeMonthDto
    {
        public int Month { get; set; }
        public int Ppt   { get; set; }
        public int Dpi   { get; set; }
        public int Pst   { get; set; }
    }

    class RecentInspectionDto
    {
        public string? JobNumber       { get; set; }
        public string? CustomerName    { get; set; }
        public string? CustomerId      { get; set; }
        public string? ProductCategory { get; set; }
        public string? InspectorName   { get; set; }
        public string? InspectorId     { get; set; }
        public string  Status          { get; set; } = "";
        public string  InspType        { get; set; } = "";
        public string? FinalResult     { get; set; }
        public DateTime Date           { get; set; }
    }

    class TopCustomerDto
    {
        public string? CustomerId    { get; set; }
        public string? CustomerName  { get; set; }
        public int     Count         { get; set; }
    }

    class TopInspectorDto
    {
        public string? InspectorId   { get; set; }
        public string? InspectorName { get; set; }
        public int     Count         { get; set; }
    }
}

<style>
    /* ── Page ── */
    .db-page { max-width: 100%; width: 100%; box-sizing: border-box; font-family: "DM Sans", sans-serif; color: #1a2d5a; }
    .db-loading { display:flex; align-items:center; gap:12px; padding:60px; justify-content:center; color:#ffffff; }
    .db-spinner { width:24px;height:24px;border:3px solid rgba(255,255,255,0.3);border-top-color:#ffffff;border-radius:50%;animation:spin .7s linear infinite; }
    .db-error { background:#fff5f5;border:1px solid #fecaca;border-radius:12px;padding:16px 20px;color:#dc2626;margin:20px 0; }
    @@keyframes spin { to { transform:rotate(360deg); } }

    /* ── Header ── */
    .db-header { display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:24px; }
    .db-title  { font-size:28px; font-weight:800; color:#ffffff; margin:0 0 4px; letter-spacing:-.02em; }
    .db-subtitle { display:flex; align-items:center; gap:6px; font-size:13px; color:rgba(255,255,255,0.75); }
    .db-live-dot { width:8px;height:8px;border-radius:50%;background:#22c55e;animation:pulse 2s infinite; }
    @@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }
    .db-update-time { color:rgba(255,255,255,0.55); }
    .db-refresh-btn { background:rgba(255,255,255,0.15);border:1px solid rgba(255,255,255,0.3);border-radius:6px;padding:3px 6px;cursor:pointer;color:#ffffff;transition:all .15s; }
    .db-refresh-btn:hover { background:rgba(255,255,255,0.25);border-color:rgba(255,255,255,0.5); }

    /* ── Summary Cards ── */
    .db-cards-grid { display:grid; grid-template-columns:repeat(6,1fr); gap:14px; margin-bottom:28px; }
    .db-card { background:#fff; border-radius:14px; padding:18px; border:1px solid #e5e7eb; position:relative; overflow:hidden; transition:box-shadow .2s,transform .2s; }
    .db-card::before { content:''; position:absolute; top:0;left:0;right:0;height:3px; background:var(--accent); }
    .db-card:hover { box-shadow:0 8px 24px rgba(0,0,0,0.08); transform:translateY(-2px); }
    .db-card-icon { width:44px;height:44px;border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:10px; }
    .db-card-badge { position:absolute;top:14px;right:14px;font-size:10px;font-weight:600;padding:2px 8px;border-radius:20px; }
    .db-card-value { font-size:28px;font-weight:800;color:#1a2d5a;line-height:1;margin-bottom:4px; }
    .db-card-label { font-size:12.5px;color:#6b7280;font-weight:500; }

    /* ── Section ── */
    .db-section-title { font-size:16px;font-weight:700;color:#ffffff;margin:8px 0 14px;display:flex;align-items:center;gap:10px; }
    .db-section-sub { font-size:12px;font-weight:500;color:rgba(255,255,255,0.6);letter-spacing:.05em; }

    /* ── Row layout ── */
    .db-row { display:flex; gap:16px; margin-bottom:24px; }

    /* ── Chart cards ── */
    .db-chart-card { background:#fff;border-radius:14px;border:1px solid #e5e7eb;padding:20px; }
    .db-mini-stats { display:flex;align-items:center;gap:0;margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid #f3f4f6; }
    .db-mini-stat { flex:1;text-align:center; }
    .db-mini-val { display:block;font-size:26px;font-weight:800;line-height:1; }
    .db-mini-lbl { font-size:11.5px;color:#6b7280;margin-top:2px;display:block; }
