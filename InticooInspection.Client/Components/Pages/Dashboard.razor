@page "/dashboard"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin,Inspector,Customer")]
@inject IConfiguration Configuration

<PageTitle>Dashboard — Inticoo Inspection</PageTitle>
<span id="blazor-api-base" data-url="@(Configuration["ApiBaseUrl"])" style="display:none"></span>

<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet"/>

<!-- ══ PAGE CONTENT ══ -->
<div class="db-wrap">

    <!-- API Config Banner -->
    <div class="cfg-banner" id="cfg-banner" style="display:none">
        <div style="font-size:18px">⚙️</div>
        <div style="flex:1;min-width:140px">
            <div style="font-weight:700;color:var(--db-amber);margin-bottom:3px">Kết nối API Server</div>
            <div style="font-size:12px;color:var(--db-muted)">Nhập Base URL — ví dụ: <code style="color:var(--db-text)">http://localhost:5000</code></div>
        </div>
        <input type="text" id="api-input" placeholder="https://your-api.inticoo.com" />
        <button class="cfg-btn" onclick="dbSaveUrl()">Kết nối →</button>
    </div>

    <!-- Page header -->
    <div class="db-ph">
        <div class="db-bc"><span>Home</span><span style="color:var(--db-border);margin:0 4px">/</span><span class="db-cur">Dashboard</span></div>
        <h1>Overview</h1>
        <p><span class="db-ldot-live"></span>Dữ liệu thực từ API · <span id="last-upd">Chưa kết nối</span>
            <button class="db-ref-btn" title="Làm mới" onclick="dbLoadAll()" id="ref-btn">
                <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
            </button>
        </p>
    </div>

    <!-- KPIs -->
    <div class="db-kgrid">
        <div class="db-kcard c1">
            <div class="db-ktop">
                <div class="db-kico i1"><svg width="19" height="19" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2"/></svg></div>
                <span class="db-kdelta up" id="d1">—</span>
            </div>
            <div class="db-kval" id="k1">—</div>
            <div class="db-klbl">Tổng Inspections</div>
        </div>
        <div class="db-kcard c2">
            <div class="db-ktop">
                <div class="db-kico i2"><svg width="19" height="19" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg></div>
                <span class="db-kdelta up" id="d2">—</span>
            </div>
            <div class="db-kval" id="k2">—</div>
            <div class="db-klbl">Đang thực hiện</div>
        </div>
        <div class="db-kcard c3">
            <div class="db-ktop">
                <div class="db-kico i3"><svg width="19" height="19" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0"/></svg></div>
                <span class="db-kdelta up" id="d3">—</span>
            </div>
            <div class="db-kval" id="k3">—</div>
            <div class="db-klbl">Khách hàng</div>
        </div>
        <div class="db-kcard c4">
            <div class="db-ktop">
                <div class="db-kico i4"><svg width="19" height="19" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16"/></svg></div>
                <span class="db-kdelta up" id="d4">—</span>
            </div>
            <div class="db-kval" id="k4">—</div>
            <div class="db-klbl">Nhà cung cấp</div>
        </div>
        <div class="db-kcard c5">
            <div class="db-ktop">
                <div class="db-kico i5"><svg width="19" height="19" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10"/></svg></div>
                <span class="db-kdelta up" id="d5">—</span>
            </div>
            <div class="db-kval" id="k5">—</div>
            <div class="db-klbl">Sản phẩm</div>
        </div>
    </div>

    <!-- Charts -->
    <div class="db-g31">
        <div class="db-panel" style="animation-delay:.2s">
            <div class="db-ph2">
                <div>
                    <div class="db-ptitle">Inspections theo tháng</div>
                    <div class="db-psub">12 tháng gần nhất</div>
                </div>
                <div style="display:flex;gap:10px">
                    <span style="display:flex;align-items:center;gap:4px;font-size:10px;color:var(--db-muted)"><span style="width:8px;height:3px;border-radius:2px;background:var(--db-accent);display:inline-block"></span>Hoàn thành</span>
                    <span style="display:flex;align-items:center;gap:4px;font-size:10px;color:var(--db-muted)"><span style="width:8px;height:3px;border-radius:2px;background:var(--db-blue);display:inline-block"></span>Tạo mới</span>
                </div>
            </div>
            <div class="db-pbody">
                <div class="db-bchart" id="bar-chart"><div class="db-sk" style="height:100%;width:100%;border-radius:4px"></div></div>
                <div style="display:flex;justify-content:space-between;margin-top:6px" id="bar-lbls"></div>
            </div>
            <div class="db-mstats" id="mstats">
                <div class="db-ms"><div class="db-sk" style="height:18px;width:40px;margin-bottom:4px"></div><div class="db-msl">Hoàn thành</div></div>
                <div class="db-ms"><div class="db-sk" style="height:18px;width:40px;margin-bottom:4px"></div><div class="db-msl">Tháng này</div></div>
                <div class="db-ms"><div class="db-sk" style="height:18px;width:40px;margin-bottom:4px"></div><div class="db-msl">Chờ duyệt</div></div>
            </div>
        </div>

        <div class="db-panel" style="animation-delay:.24s">
            <div class="db-ph2">
                <div><div class="db-ptitle">Trạng thái</div><div class="db-psub">Phân bổ hiện tại</div></div>
            </div>
            <div class="db-pbody">
                <div class="db-dwrap" id="donut-wrap">
                    <div class="db-sk" style="width:90px;height:90px;border-radius:50%;flex-shrink:0"></div>
                    <div style="flex:1;display:flex;flex-direction:column;gap:8px">
                        <div class="db-sk" style="height:12px"></div>
                        <div class="db-sk" style="height:12px"></div>
                        <div class="db-sk" style="height:12px"></div>
                        <div class="db-sk" style="height:12px"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Table + actions -->
    <div class="db-g2">
        <div class="db-panel" style="animation-delay:.28s">
            <div class="db-ftabs" id="ftabs">
                <button class="db-ftab on" data-f="all">Tất cả</button>
                <button class="db-ftab" data-f="ongoing">Đang chạy</button>
                <button class="db-ftab" data-f="completed">Hoàn thành</button>
                <button class="db-ftab" data-f="pending">Chờ</button>
                <button class="db-ftab" data-f="cancelled">Huỷ</button>
            </div>
            <div class="db-ph2" style="padding-top:10px">
                <div><div class="db-ptitle">Inspection gần đây</div><div class="db-psub" id="tbl-sub">—</div></div>
                <button class="db-pact">Xem tất cả →</button>
            </div>
            <div class="db-twrap">
                <table>
                    <thead><tr><th>Job #</th><th>Khách hàng / Sản phẩm</th><th>Inspector</th><th>Trạng thái</th><th>Ngày</th></tr></thead>
                    <tbody id="tbody"><tr><td colspan="5"><div class="db-errmsg"><div class="db-ei">⚙️</div>Cấu hình API URL để xem dữ liệu</div></td></tr></tbody>
                </table>
            </div>
        </div>

        <div style="display:flex;flex-direction:column;gap:18px">
            <div class="db-panel" style="animation-delay:.32s">
                <div class="db-ph2"><div class="db-ptitle">Thao tác nhanh</div></div>
                <div class="db-pbody">
                    <div class="db-qgrid">
                        <a class="db-qbtn" href="/inspections/new"><div class="db-qico" style="background:rgba(0,212,170,.1)">📋</div><div><div class="db-qlbl">Tạo Inspection</div><div class="db-qdesc">Job mới</div></div></a>
                        <a class="db-qbtn" href="/customers"><div class="db-qico" style="background:rgba(59,130,246,.1)">🏢</div><div><div class="db-qlbl">Thêm KH</div><div class="db-qdesc">Đăng ký client</div></div></a>
                        <a class="db-qbtn" href="/products"><div class="db-qico" style="background:rgba(245,158,11,.1)">📦</div><div><div class="db-qlbl">Thêm SP</div><div class="db-qdesc">SKU mới</div></div></a>
                        <a class="db-qbtn" href="#"><div class="db-qico" style="background:rgba(239,68,68,.1)">📊</div><div><div class="db-qlbl">Xuất báo cáo</div><div class="db-qdesc">PDF / Excel</div></div></a>
                    </div>
                </div>
            </div>

            <div class="db-panel" style="animation-delay:.36s">
                <div class="db-ph2">
                    <div><div class="db-ptitle">Top Inspectors</div><div class="db-psub">Nhiều job nhất</div></div>
                    <button class="db-pact">Tất cả →</button>
                </div>
                <div class="db-pbody"><div class="db-ilist" id="ilist"><div class="db-sk" style="height:130px;width:100%;border-radius:8px"></div></div></div>
            </div>
        </div>
    </div>

    <!-- Activity + Type -->
    <div class="db-g2">
        <div class="db-panel" style="animation-delay:.4s">
            <div class="db-ph2"><div><div class="db-ptitle">Hoạt động gần đây</div><div class="db-psub">Từ inspections thực</div></div></div>
            <div class="db-pbody"><div class="db-afeed" id="afeed"><div class="db-sk" style="height:180px;width:100%;border-radius:8px"></div></div></div>
        </div>

        <div class="db-panel" style="animation-delay:.44s">
            <div class="db-ph2"><div><div class="db-ptitle">Phân loại Inspection</div><div class="db-psub">DPI · PPT · PST</div></div></div>
            <div class="db-pbody"><div id="tbreak"><div class="db-sk" style="height:130px;width:100%;border-radius:8px"></div></div></div>
            <div class="db-mstats">
                <div class="db-ms"><div class="db-msv" id="ms1" style="color:var(--db-blue)">—</div><div class="db-msl">Vendors active</div></div>
                <div class="db-ms"><div class="db-msv" id="ms2" style="color:var(--db-accent)">—</div><div class="db-msl">Users hệ thống</div></div>
            </div>
        </div>
    </div>

</div>

@* ══════════════ CSS — dùng prefix "db-" tránh xung đột với MainLayout ══════════════ *@
<style>
    :root {
        --db-card: #161d2e; --db-border: #1e293b; --db-surface: #111827;
        --db-accent: #00d4aa; --db-blue: #3b82f6; --db-amber: #f59e0b;
        --db-red: #ef4444; --db-purple: #8b5cf6;
        --db-text: #e2e8f0; --db-muted: #64748b; --db-r: 12px;
    }

    .db-wrap { font-family: 'DM Sans', sans-serif; color: var(--db-text); padding: 8px 0; }

    /* ── CONFIG BANNER ── */
    .cfg-banner { background: rgba(245,158,11,.07); border: 1px solid rgba(245,158,11,.2);
        border-radius: 10px; padding: 14px 18px; margin-bottom: 20px;
        display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
    .cfg-banner input { background: var(--db-surface); border: 1px solid var(--db-border);
        border-radius: 7px; padding: 7px 12px; font-size: 13px; color: var(--db-text);
        font-family: inherit; width: 280px; outline: none; flex: 1; min-width: 180px; }
    .cfg-banner input:focus { border-color: var(--db-accent); }
    .cfg-btn { background: var(--db-accent); color: #000; font-size: 12px; font-weight: 700;
        border: none; border-radius: 7px; padding: 8px 16px; cursor: pointer;
        font-family: inherit; white-space: nowrap; }
    .cfg-btn:hover { opacity: .85; }

    /* ── PAGE HEADER ── */
    .db-ph { margin-bottom: 22px; }
    .db-ph h1 { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 24px; color: var(--db-text); }
    .db-ph p { font-size: 13px; color: var(--db-muted); margin-top: 3px; display: flex; align-items: center; gap: 6px; }
    .db-bc { display: flex; align-items: center; gap: 6px; font-size: 11px; color: var(--db-muted); margin-bottom: 6px; }
    .db-cur { color: var(--db-accent); }
    .db-ref-btn { background: none; border: none; cursor: pointer; color: var(--db-muted); padding: 2px 4px; border-radius: 4px; transition: color .15s; }
    .db-ref-btn:hover { color: var(--db-accent); }

    /* ── KPI ── */
    .db-kgrid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 14px; margin-bottom: 20px; }
    .db-kcard { background: var(--db-card); border: 1px solid var(--db-border); border-radius: var(--db-r);
        padding: 18px; position: relative; overflow: hidden; transition: transform .2s, box-shadow .2s;
        animation: dbUp .5s ease both; }
    .db-kcard:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(0,0,0,.4); }
    .db-kcard::after { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; }
    .db-kcard.c1::after { background: linear-gradient(90deg, var(--db-accent), #00a884); }
    .db-kcard.c2::after { background: linear-gradient(90deg, var(--db-blue), #6366f1); }
    .db-kcard.c3::after { background: linear-gradient(90deg, var(--db-amber), #f97316); }
    .db-kcard.c4::after { background: linear-gradient(90deg, var(--db-red), #ec4899); }
    .db-kcard.c5::after { background: linear-gradient(90deg, var(--db-purple), #a78bfa); }
    .db-kcard:nth-child(1){animation-delay:.04s} .db-kcard:nth-child(2){animation-delay:.08s}
    .db-kcard:nth-child(3){animation-delay:.12s} .db-kcard:nth-child(4){animation-delay:.16s}
    .db-kcard:nth-child(5){animation-delay:.20s}
    .db-ktop { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 12px; }
    .db-kico { width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; }
    .db-kico.i1{background:rgba(0,212,170,.12);color:var(--db-accent)}
    .db-kico.i2{background:rgba(59,130,246,.12);color:var(--db-blue)}
    .db-kico.i3{background:rgba(245,158,11,.12);color:var(--db-amber)}
    .db-kico.i4{background:rgba(239,68,68,.12);color:var(--db-red)}
    .db-kico.i5{background:rgba(139,92,246,.12);color:var(--db-purple)}
    .db-kdelta { font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 999px; }
    .db-kdelta.up { background: rgba(0,212,170,.1); color: var(--db-accent); }
    .db-kval { font-family: 'Syne', sans-serif; font-size: 28px; font-weight: 800; line-height: 1; min-height: 28px; }
    .db-klbl { font-size: 12px; color: var(--db-muted); margin-top: 5px; }

    /* ── GRID ── */
    .db-g2 { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin-bottom: 18px; }
    .db-g31 { display: grid; grid-template-columns: 2fr 1fr; gap: 18px; margin-bottom: 18px; }

    /* ── PANEL ── */
    .db-panel { background: var(--db-card); border: 1px solid var(--db-border); border-radius: var(--db-r); animation: dbUp .55s ease both; }
    .db-ph2 { display: flex; align-items: center; justify-content: space-between; padding: 16px 18px 12px; border-bottom: 1px solid var(--db-border); }
    .db-ptitle { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 14px; }
    .db-psub { font-size: 11px; color: var(--db-muted); margin-top: 2px; }
    .db-pact { font-size: 12px; color: var(--db-accent); font-weight: 600; cursor: pointer; border: none; background: none; transition: opacity .2s; font-family: inherit; }
    .db-pact:hover { opacity: .7; }
    .db-pbody { padding: 18px; }

    /* ── SKELETON ── */
    .db-sk { background: linear-gradient(90deg, var(--db-border) 25%, var(--db-surface) 50%, var(--db-border) 75%);
        background-size: 200% 100%; animation: dbShimmer 1.5s infinite; border-radius: 6px; }
    @@keyframes dbShimmer { from{background-position:200% 0} to{background-position:-200% 0} }

    /* ── BAR CHART ── */
    .db-bchart { display: flex; align-items: flex-end; gap: 5px; height: 120px; }
    .bcol { flex: 1; display: flex; flex-direction: column; align-items: center; }
    .bwrap { flex: 1; width: 100%; display: flex; align-items: flex-end; gap: 2px; }
    .bar { flex: 1; border-radius: 3px 3px 0 0; transition: height 1s cubic-bezier(.4,0,.2,1); cursor: pointer; min-height: 2px; position: relative; }
    .bar:hover::after { content: attr(data-v); position: absolute; top: -20px; left: 50%; transform: translateX(-50%);
        background: var(--db-surface); color: var(--db-text); font-size: 9px; padding: 2px 5px;
        border-radius: 3px; white-space: nowrap; z-index: 10; border: 1px solid var(--db-border); }

    /* ── DONUT ── */
    .db-dwrap { display: flex; align-items: center; gap: 16px; }
    .dleg { flex: 1; }
    .li { display: flex; align-items: center; gap: 8px; margin-bottom: 9px; }
    .ldot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
    .lname { font-size: 11.5px; color: var(--db-muted); }
    .lval { font-size: 13px; font-weight: 600; }
    .lpct { font-size: 11px; color: var(--db-muted); margin-left: auto; }

    /* ── TABLE ── */
    .db-twrap { overflow-x: auto; }
    .db-twrap table { width: 100%; border-collapse: collapse; }
    .db-twrap thead th { text-align: left; font-size: 10px; font-weight: 600; text-transform: uppercase;
        letter-spacing: .8px; color: var(--db-muted); padding: 0 14px 10px; }
    .db-twrap tbody tr { border-top: 1px solid var(--db-border); transition: background .12s; }
    .db-twrap tbody tr:hover { background: rgba(255,255,255,.025); }
    .db-twrap tbody td { padding: 11px 14px; font-size: 13px; color: var(--db-text); }
    .tmain { font-weight: 500; }
    .tsub { font-size: 11px; color: var(--db-muted); margin-top: 1px; }
    .tnum { font-size: 11px; color: var(--db-muted); }

    /* ── BADGE ── */
    .badge { display: inline-flex; align-items: center; gap: 4px; font-size: 10px; font-weight: 700;
        padding: 3px 8px; border-radius: 999px; text-transform: uppercase; letter-spacing: .3px; }
    .badge::before { content: ''; width: 5px; height: 5px; border-radius: 50%; flex-shrink: 0; }
    .b-completed{background:rgba(0,212,170,.1);color:var(--db-accent)}.b-completed::before{background:var(--db-accent)}
    .b-ongoing{background:rgba(59,130,246,.1);color:var(--db-blue)}.b-ongoing::before{background:var(--db-blue)}
    .b-pending,.b-new{background:rgba(245,158,11,.1);color:var(--db-amber)}.b-pending::before,.b-new::before{background:var(--db-amber)}
    .b-cancelled,.b-cancel{background:rgba(239,68,68,.1);color:var(--db-red)}.b-cancelled::before,.b-cancel::before{background:var(--db-red)}

    /* ── ACTIVITY ── */
    .db-afeed { display: flex; flex-direction: column; gap: 0; }
    .aitem { display: flex; gap: 10px; padding-bottom: 15px; position: relative; }
    .aitem:not(:last-child)::after { content: ''; position: absolute; left: 13px; top: 27px; bottom: 0; width: 1px; background: var(--db-border); }
    .aico { width: 27px; height: 27px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 11px; }
    .atxt { font-size: 12.5px; line-height: 1.45; flex: 1; }
    .atxt strong { color: var(--db-text); }
    .atime { font-size: 10px; color: var(--db-muted); margin-top: 2px; }

    /* ── INSPECTOR LIST ── */
    .db-ilist { display: flex; flex-direction: column; gap: 10px; }
    .irow { display: flex; align-items: center; gap: 10px; }
    .iav { width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center;
        font-size: 11px; font-weight: 700; color: #fff; flex-shrink: 0; }
    .iname { font-size: 12.5px; font-weight: 500; }
    .iid { font-size: 10px; color: var(--db-muted); }
    .ibg { height: 4px; background: var(--db-border); border-radius: 999px; overflow: hidden; width: 70px; }
    .ifill { height: 100%; border-radius: 999px; }
    .inum { font-size: 12px; font-weight: 700; min-width: 20px; text-align: right; }

    /* ── QUICK ACTIONS ── */
    .db-qgrid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
    .db-qbtn { background: var(--db-surface); border: 1px solid var(--db-border); border-radius: 9px;
        padding: 12px; cursor: pointer; transition: all .15s; display: flex; align-items: center;
        gap: 9px; text-decoration: none; color: inherit; }
    .db-qbtn:hover { border-color: var(--db-accent); background: rgba(0,212,170,.04); }
    .db-qico { width: 32px; height: 32px; border-radius: 7px; display: flex; align-items: center; justify-content: center; font-size: 15px; flex-shrink: 0; }
    .db-qlbl { font-size: 12px; font-weight: 600; }
    .db-qdesc { font-size: 10px; color: var(--db-muted); margin-top: 1px; }

    /* ── FILTER TABS ── */
    .db-ftabs { display: flex; gap: 3px; padding: 14px 16px 0; }
    .db-ftab { font-size: 11px; font-weight: 600; padding: 5px 12px; border-radius: 6px; cursor: pointer;
        background: none; border: none; color: var(--db-muted); transition: all .15s; font-family: inherit; }
    .db-ftab.on { background: rgba(0,212,170,.1); color: var(--db-accent); }
    .db-ftab:hover:not(.on) { color: var(--db-text); }

    /* ── MINI STATS ── */
    .db-mstats { display: flex; border-top: 1px solid var(--db-border); }
    .db-ms { flex: 1; padding: 12px 16px; border-right: 1px solid var(--db-border); }
    .db-ms:last-child { border-right: none; }
    .db-msv { font-family: 'Syne', sans-serif; font-size: 18px; font-weight: 800; }
    .db-msl { font-size: 10px; color: var(--db-muted); margin-top: 2px; }

    /* ── TYPE BREAKDOWN ── */
    .tbar-row { margin-bottom: 14px; }
    .tbar-row:last-child { margin-bottom: 0; }
    .tbar-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px; }
    .tbar-lbl { font-size: 12.5px; font-weight: 500; }
    .tbar-cnt { font-size: 12px; font-weight: 700; }
    .tbar-bg { height: 6px; background: var(--db-border); border-radius: 999px; overflow: hidden; }
    .tbar-fill { height: 100%; border-radius: 999px; transition: width 1.2s ease; }
    .tbar-pct { font-size: 10px; color: var(--db-muted); margin-top: 4px; }

    /* ── MISC ── */
    .db-ldot-live { display: inline-block; width: 7px; height: 7px; border-radius: 50%;
        background: var(--db-accent); margin-right: 5px; animation: dbPulse 1.8s ease infinite; }
    .db-errmsg { text-align: center; padding: 28px; color: var(--db-muted); font-size: 13px; }
    .db-ei { font-size: 26px; margin-bottom: 8px; }

    /* ── ANIMATIONS ── */
    @@keyframes dbUp { from{opacity:0;transform:translateY(14px)} to{opacity:1;transform:translateY(0)} }
    @@keyframes dbPulse { 0%,100%{opacity:1} 50%{opacity:.3} }
    @@keyframes dbSpin { to{transform:rotate(360deg)} }

    /* ── RESPONSIVE ── */
    @@media (max-width: 1300px) {
        .db-kgrid { grid-template-columns: repeat(3, 1fr); }
        .db-g31 { grid-template-columns: 1fr; }
    }
    @@media (max-width: 960px) {
        .db-g2 { grid-template-columns: 1fr; }
        .db-kgrid { grid-template-columns: repeat(2, 1fr); }
        .db-qgrid { grid-template-columns: repeat(4, 1fr); }
    }
    @@media (max-width: 480px) {
        .db-kgrid { grid-template-columns: 1fr; }
        .db-qgrid { grid-template-columns: repeat(2, 1fr); }
    }
</style>

@* ══════════════ JAVASCRIPT ══════════════ *@
<script>
    (function () {
        let BASE = '';
        let allItems = [], activeFilter = 'all';

        // Lấy ApiBaseUrl từ Blazor config (appsettings.json)
        function dbGetBaseUrl() {
            const el = document.getElementById('blazor-api-base');
            if (el) {
                const url = (el.getAttribute('data-url') || '').trim().replace(/\/$/, '');
                if (url) return url;
            }
            // Fallback: localStorage nếu config không có
            return localStorage.getItem('ic_base') || '';
        }

        // Auto-init sau khi DOM sẵn sàng
        function dbInit() {
            BASE = dbGetBaseUrl();
            if (BASE) {
                document.getElementById('cfg-banner').style.display = 'none';
                dbLoadAll();
            } else {
                // Chỉ hiện banner nếu không có config
                document.getElementById('cfg-banner').style.display = 'flex';
            }
        }

        window.dbSaveUrl = function () {
            const v = (document.getElementById('api-input').value || '').trim().replace(/\/$/, '');
            if (!v) { alert('Vui lòng nhập URL'); return; }
            BASE = v;
            localStorage.setItem('ic_base', v);
            document.getElementById('cfg-banner').style.display = 'none';
            dbLoadAll();
        };

        // Chờ Blazor render xong rồi mới init
        setTimeout(dbInit, 100);

        window.dbLoadAll = async function () {
            if (!BASE) return;
            dbSpin(true);
            document.getElementById('last-upd').textContent = 'Đang tải…';

            const [iR, cR, vR, pR, uR] = await Promise.allSettled([
                dbGet('/api/inspections?pageSize=500'),
                dbGet('/api/customers?pageSize=1'),
                dbGet('/api/vendors?pageSize=1'),
                dbGet('/api/products?pageSize=1'),
                dbGet('/api/users?pageSize=200'),
            ]);

            if (iR.status === 'fulfilled') {
                allItems = iR.value.items || [];
                const total  = iR.value.total || allItems.length;
                const onCnt  = allItems.filter(x => dbNorm(x.status) === 'ongoing').length;
                const cmpCnt = allItems.filter(x => dbNorm(x.status) === 'completed').length;
                const penCnt = allItems.filter(x => ['pending','new'].includes(dbNorm(x.status))).length;
                const canCnt = allItems.filter(x => ['cancelled','cancel'].includes(dbNorm(x.status))).length;
                const thisMo = dbThisMonth(allItems).length;
                dbSetKpi('k1', total, 'd1', total + ' jobs');
                dbSetKpi('k2', onCnt, 'd2', onCnt + ' active');
                dbRenderTable('all');
                dbRenderDonut(cmpCnt, onCnt, penCnt, canCnt, total);
                dbRenderBarChart(allItems);
                dbRenderActivity(allItems);
                dbRenderTypes(allItems);
                dbRenderInspectors(allItems);
                document.getElementById('mstats').innerHTML =
                    `<div class="db-ms"><div class="db-msv" style="color:var(--db-accent)">${cmpCnt}</div><div class="db-msl">Hoàn thành</div></div>
                     <div class="db-ms"><div class="db-msv" style="color:var(--db-blue)">${thisMo}</div><div class="db-msl">Tháng này</div></div>
                     <div class="db-ms"><div class="db-msv" style="color:var(--db-amber)">${penCnt}</div><div class="db-msl">Chờ duyệt</div></div>`;
            } else {
                dbErrTable('Không thể tải từ ' + BASE + '<br><small>' + iR.reason.message + '</small>');
            }
            if (cR.status === 'fulfilled') dbSetKpi('k3', cR.value.total || 0, 'd3', (cR.value.total||0) + ' clients');
            if (vR.status === 'fulfilled') { const t = vR.value.total||0; dbSetKpi('k4', t, 'd4', t+' vendors'); document.getElementById('ms1').textContent = t; }
            if (pR.status === 'fulfilled') dbSetKpi('k5', pR.value.total||0, 'd5', (pR.value.total||0)+' SKUs');
            if (uR.status === 'fulfilled') { const t = uR.value.total||(uR.value.items||[]).length; document.getElementById('ms2').textContent = t; }

            const now = new Date();
            document.getElementById('last-upd').textContent = 'Cập nhật ' + now.toLocaleTimeString('vi-VN',{hour:'2-digit',minute:'2-digit'});
            dbSpin(false);
        };

        async function dbGet(path) {
            const r = await fetch(BASE + path, { headers: { Accept: 'application/json' } });
            if (!r.ok) throw new Error('HTTP ' + r.status);
            return r.json();
        }

        function dbNorm(s) {
            if (!s) return 'new';
            const l = s.toLowerCase().replace(/[\s-]/g,'');
            if (l==='ongoing'||l==='inprogress') return 'ongoing';
            if (l==='completed') return 'completed';
            if (l==='cancelled'||l==='cancel') return 'cancelled';
            return 'pending';
        }
        const statusVI = { ongoing:'Đang chạy', completed:'Hoàn thành', pending:'Chờ', cancelled:'Huỷ', new:'Mới' };

        function dbRenderTable(filter) {
            activeFilter = filter;
            let rows = allItems;
            if (filter !== 'all') rows = rows.filter(r => dbNorm(r.status) === filter);
            const show = rows.slice(0, 10);
            document.getElementById('tbl-sub').textContent = show.length + ' / ' + rows.length + ' records';
            if (!show.length) { document.getElementById('tbody').innerHTML = `<tr><td colspan="5"><div class="db-errmsg"><div class="db-ei">📭</div>Không có dữ liệu</div></td></tr>`; return; }
            document.getElementById('tbody').innerHTML = show.map(r => {
                const n = dbNorm(r.status);
                const d = (r.inspectionDate||r.createdAt) ? new Date(r.inspectionDate||r.createdAt).toLocaleDateString('vi-VN',{day:'2-digit',month:'2-digit'}) : '—';
                return `<tr>
                    <td><div class="tnum">${dbEsc(r.jobNumber||'#'+r.id)}</div></td>
                    <td><div class="tmain">${dbEsc(r.customerName||'—')}</div><div class="tsub">${dbEsc(r.productName||r.productCategory||'—')}</div></td>
                    <td><div style="font-size:12px">${dbEsc(r.inspectorName||r.inspectorId||'—')}</div></td>
                    <td><span class="badge b-${n}">${statusVI[n]||n}</span></td>
                    <td><div style="font-size:11px;color:var(--db-muted)">${d}</div></td>
                </tr>`;
            }).join('');
        }
        function dbErrTable(msg) { document.getElementById('tbody').innerHTML = `<tr><td colspan="5"><div class="db-errmsg"><div class="db-ei">⚠️</div>${msg}</div></td></tr>`; }

        // Filter tabs
        document.getElementById('ftabs').addEventListener('click', e => {
            const b = e.target.closest('.db-ftab'); if (!b) return;
            document.querySelectorAll('.db-ftab').forEach(x => x.classList.remove('on'));
            b.classList.add('on');
            dbRenderTable(b.dataset.f);
        });

        function dbRenderDonut(cmp, on, pen, can, total) {
            const C = 2 * Math.PI * 38;
            const segs = [
                { label:'Hoàn thành', count:cmp, color:'var(--db-accent)' },
                { label:'Đang chạy',  count:on,  color:'var(--db-blue)'   },
                { label:'Chờ',         count:pen, color:'var(--db-amber)'  },
                { label:'Huỷ',         count:can, color:'var(--db-red)'    },
            ].filter(s => s.count > 0);
            let cum = 0;
            const circles = (total > 0 ? segs : []).map(s => {
                const pct = s.count/total, dash = C*pct, gap = C-dash, rotate = -90+cum*360;
                cum += pct;
                return `<circle cx="50" cy="50" r="38" fill="none" stroke="${s.color}" stroke-width="11" stroke-dasharray="${dash.toFixed(2)} ${gap.toFixed(2)}" transform="rotate(${rotate.toFixed(2)} 50 50)"/>`;
            }).join('');
            const legend = segs.map(s => `<div class="li"><span class="ldot" style="background:${s.color}"></span><div style="flex:1"><div class="lname">${s.label}</div><div class="lval">${s.count}</div></div><span class="lpct">${total>0?Math.round(s.count/total*100):0}%</span></div>`).join('');
            document.getElementById('donut-wrap').innerHTML = `
                <svg width="100" height="100" viewBox="0 0 100 100" style="flex-shrink:0">
                    <circle cx="50" cy="50" r="38" fill="none" stroke="var(--db-border)" stroke-width="11"/>
                    ${circles||'<circle cx="50" cy="50" r="38" fill="none" stroke="var(--db-border)" stroke-width="11"/>'}
                    <text x="50" y="46" text-anchor="middle" fill="var(--db-text)" font-size="13" font-weight="800" font-family="Syne,sans-serif">${total}</text>
                    <text x="50" y="57" text-anchor="middle" fill="var(--db-muted)" font-size="7.5">total</text>
                </svg>
                <div class="dleg">${legend||'<div style="color:var(--db-muted);font-size:12px">Chưa có dữ liệu</div>'}</div>`;
        }

        function dbRenderBarChart(items) {
            const now = new Date();
            const mos = Array.from({length:12}, (_,i) => { const d = new Date(now.getFullYear(), now.getMonth()-11+i, 1); return {y:d.getFullYear(),m:d.getMonth(),lbl:d.toLocaleDateString('vi-VN',{month:'short'})}; });
            const cmpArr = mos.map(mo => items.filter(x => { const d=x.completedAt?new Date(x.completedAt):null; return d&&d.getFullYear()===mo.y&&d.getMonth()===mo.m&&dbNorm(x.status)==='completed'; }).length);
            const newArr = mos.map(mo => items.filter(x => { const d=x.createdAt?new Date(x.createdAt):null; return d&&d.getFullYear()===mo.y&&d.getMonth()===mo.m; }).length);
            const maxV = Math.max(...cmpArr,...newArr,1);
            document.getElementById('bar-chart').innerHTML = mos.map((mo,i) => {
                const hC = ((cmpArr[i]/maxV)*100).toFixed(1), hN = ((newArr[i]/maxV)*100).toFixed(1);
                return `<div class="bcol"><div class="bwrap"><div class="bar" style="background:var(--db-accent);opacity:.8;height:2px" data-h="${hC}" data-v="${cmpArr[i]}"></div><div class="bar" style="background:var(--db-blue);opacity:.7;height:2px" data-h="${hN}" data-v="${newArr[i]}"></div></div></div>`;
            }).join('');
            document.getElementById('bar-lbls').innerHTML = mos.map(mo => `<span style="font-size:8.5px;color:var(--db-muted);flex:1;text-align:center">${mo.lbl}</span>`).join('');
            requestAnimationFrame(() => setTimeout(() => { document.querySelectorAll('.bar').forEach(b => { b.style.height = b.dataset.h + '%'; }); }, 50));
        }

        function dbRenderActivity(items) {
            const sorted = [...items].sort((a,b)=>new Date(b.createdAt||0)-new Date(a.createdAt||0)).slice(0,7);
            const ico = { completed:['✅','rgba(0,212,170,.12)'], ongoing:['🔄','rgba(59,130,246,.12)'], pending:['⏳','rgba(245,158,11,.12)'], cancelled:['❌','rgba(239,68,68,.12)'], new:['📋','rgba(139,92,246,.12)'] };
            document.getElementById('afeed').innerHTML = sorted.length
                ? sorted.map(r => { const n=dbNorm(r.status),[ic,bg]=ico[n]||['📋','rgba(100,116,139,.12)']; return `<div class="aitem"><div class="aico" style="background:${bg}">${ic}</div><div class="atxt"><strong>${dbEsc(r.jobNumber||'#'+r.id)}</strong> — ${dbEsc(r.customerName||'N/A')} <span class="badge b-${n}" style="font-size:9px;padding:1px 6px;margin-left:4px">${statusVI[n]||n}</span><div class="atime">${dbEsc(r.inspectorName||r.inspectorId||'—')} · ${dbAgo(r.createdAt)}</div></div></div>`; }).join('')
                : '<div class="db-errmsg"><div class="db-ei">📭</div>Không có hoạt động</div>';
        }

        function dbRenderTypes(items) {
            const total=items.length||1, cnt={DPI:0,PPT:0,PST:0};
            items.forEach(r => { const t=(r.inspectionType||'DPI').toUpperCase(); if(cnt[t]!==undefined) cnt[t]++; });
            const cols={DPI:'var(--db-accent)',PPT:'var(--db-blue)',PST:'var(--db-amber)'};
            const lbls={DPI:'DPI — During Production',PPT:'PPT — Pre-Production',PST:'PST — Pre-Shipment'};
            document.getElementById('tbreak').innerHTML = ['DPI','PPT','PST'].map(t => {
                const p=Math.round(cnt[t]/total*100);
                return `<div class="tbar-row"><div class="tbar-top"><span class="tbar-lbl">${lbls[t]}</span><span class="tbar-cnt" style="color:${cols[t]}">${cnt[t]}</span></div><div class="tbar-bg"><div class="tbar-fill" style="width:0%;background:${cols[t]}" data-w="${p}"></div></div><div class="tbar-pct">${p}% tổng số</div></div>`;
            }).join('');
            requestAnimationFrame(() => setTimeout(() => { document.querySelectorAll('.tbar-fill').forEach(f => { f.style.width = f.dataset.w + '%'; }); }, 80));
        }

        function dbRenderInspectors(items) {
            const map={};
            items.forEach(r => { const k=r.inspectorName||r.inspectorId; if(!k) return; if(!map[k]) map[k]={name:k,id:r.inspectorId||'',n:0}; map[k].n++; });
            const list=Object.values(map).sort((a,b)=>b.n-a.n).slice(0,6);
            const maxN=Math.max(...list.map(x=>x.n),1);
            const pal=['#00d4aa','#3b82f6','#f59e0b','#ef4444','#8b5cf6','#ec4899'];
            document.getElementById('ilist').innerHTML = list.length
                ? list.map((p,i) => { const c=pal[i%pal.length],ini=p.name.split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2); return `<div class="irow"><div class="iav" style="background:${c}">${ini}</div><div style="flex:1;min-width:0"><div class="iname">${dbEsc(p.name)}</div><div class="iid">${p.id}</div></div><div class="ibg"><div class="ifill" style="width:${Math.round(p.n/maxN*100)}%;background:${c}"></div></div><div class="inum" style="color:${c}">${p.n}</div></div>`; }).join('')
                : '<div class="db-errmsg"><div class="db-ei">👤</div>Chưa có inspector</div>';
        }

        function dbThisMonth(items) { const n=new Date(); return items.filter(r => { const d=r.createdAt?new Date(r.createdAt):null; return d&&d.getMonth()===n.getMonth()&&d.getFullYear()===n.getFullYear(); }); }
        function dbAgo(ts) { if(!ts) return '—'; const m=Math.floor((Date.now()-new Date(ts))/60000); if(m<1) return 'Vừa xong'; if(m<60) return m+' phút trước'; const h=Math.floor(m/60); if(h<24) return h+' giờ trước'; const d=Math.floor(h/24); if(d<30) return d+' ngày trước'; return new Date(ts).toLocaleDateString('vi-VN'); }
        function dbEsc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
        function dbSetKpi(id, val, did, delta) { let c=0; const el=document.getElementById(id); const t=setInterval(()=>{ c=Math.min(c+Math.max(1,Math.floor(val/40)),val); el.textContent=c.toLocaleString('vi-VN'); if(c>=val) clearInterval(t); },20); document.getElementById(did).textContent=delta; }
        function dbSpin(on) { document.getElementById('ref-btn').style.animation = on ? 'dbSpin 1s linear infinite' : ''; }

        // Auto-refresh mỗi 2 phút
        setInterval(() => { if (BASE) dbLoadAll(); }, 120000);
    })();
</script>
