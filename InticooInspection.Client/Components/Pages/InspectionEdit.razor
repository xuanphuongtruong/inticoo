    private static string NormalizeAqlKey(string aql) => aql switch
    {
        "0"=>"0","0.065"=>"0.065","0.1"=>"0.10","0.10"=>"0.10","0.15"=>"0.15",
        "0.25"=>"0.25","0.4"=>"0.40","0.40"=>"0.40","0.65"=>"0.65",
        "1.0"=>"1.0","1.5"=>"1.5","2.5"=>"2.5","4.0"=>"4.0","6.5"=>"6.5",_=>"2.5"
    };

    private static (int sampleSize, int ac, int re) LookupTableB(string codeLetter, string aqlKey)
    {
        if (aqlKey == "0") return (_codeSizes.GetValueOrDefault(codeLetter, 0), 0, 0);
        var letters = new[]{"A","B","C","D","E","F","G","H","J","K","L","M","N","P","Q","R"};
        int idx = Array.IndexOf(letters, codeLetter);
        if (idx < 0) return (0, 0, 0);
        if (!_tableB.ContainsKey(codeLetter) || !_tableB[codeLetter].ContainsKey(aqlKey))
            return (_codeSizes.GetValueOrDefault(codeLetter, 0), 0, 1);
        var (ac0, re0) = _tableB[codeLetter][aqlKey];
        if (ac0 == -1) {
            for (int i = idx-1; i >= 0; i--) { var l=letters[i]; if (!_tableB.ContainsKey(l)||!_tableB[l].ContainsKey(aqlKey)) continue; var (a,r)=_tableB[l][aqlKey]; if (a>=0) return (_codeSizes.GetValueOrDefault(l,0),a,r); }
            return (_codeSizes.GetValueOrDefault(codeLetter, 0), 0, 1);
        }
        if (ac0 == -2) {
            for (int i = idx+1; i < letters.Length; i++) { var l=letters[i]; if (!_tableB.ContainsKey(l)||!_tableB[l].ContainsKey(aqlKey)) continue; var (a,r)=_tableB[l][aqlKey]; if (a>=0) return (_codeSizes.GetValueOrDefault(l,0),a,r); }
            return (_codeSizes.GetValueOrDefault(codeLetter, 0), 0, 1);
        }
        return (_codeSizes.GetValueOrDefault(codeLetter, 0), ac0, re0);
    }

    private void RecalcAql()
    {
        if (AqlQuantity <= 0) {
            CriticalSampleSize=CriticalAccept=CriticalReject=MajorSampleSize=MajorAccept=MajorReject=MinorSampleSize=MinorAccept=MinorReject=0;
            return;
        }
        var cl = GetCodeLetter(AqlQuantity, AqlInspectionLevel);
        _currentCodeLetter = cl;
        if (CriticalAql == "0") { CriticalSampleSize=_codeSizes.GetValueOrDefault(cl,0); CriticalAccept=CriticalReject=0; }
        else { var (sz,ac,re)=LookupTableB(cl,NormalizeAqlKey(CriticalAql)); CriticalSampleSize=sz;CriticalAccept=ac;CriticalReject=re; }
        var (szM,acM,reM) = LookupTableB(cl, NormalizeAqlKey(MajorAql)); MajorSampleSize=szM;MajorAccept=acM;MajorReject=reM;
        var (szN,acN,reN) = LookupTableB(cl, NormalizeAqlKey(MinorAql)); MinorSampleSize=szN;MinorAccept=acN;MinorReject=reN;
    }

