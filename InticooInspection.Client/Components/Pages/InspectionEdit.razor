    private async Task SaveProductReference(int idx)
    {
        if (_currentProductId <= 0 || idx >= References.Count) return;
        var row = References[idx];
        row.IsSaving = true;
        _mSaveRefError = "";
        StateHasChanged();
        try
        {
            var prod = _allProducts.FirstOrDefault(p => p.Id == _currentProductId);
            if (prod == null)
            {
                _mSaveRefError = "Product not found.";
                return;
            }

            var allRefs = References
                .Where(r => r.FromProduct || r == row)
                .Select((r, i) => new
                {
                    SortOrder = i + 1,
                    Name      = r.ReferenceName,
                    FileUrl   = r.FileUrl,
                    FileName  = r.FileName
                })
                .ToList();

            var resp = await Http.PutAsJsonAsync($"api/products/{_currentProductId}", new
            {
                customerId   = prod.CustomerId,
                vendorId     = prod.VendorId,
                category     = prod.Category,
                productType  = prod.ProductType,
                productName  = prod.ProductName,
                productCode  = prod.ProductCode,
                itemNumber   = prod.ItemNumber,
                sizeL        = prod.SizeL,
                sizeW        = prod.SizeW,
                sizeH        = prod.SizeH,
                weight       = prod.Weight,
                photoUrl     = prod.PhotoUrl,
                references   = allRefs
            });

            if (resp.IsSuccessStatusCode)
            {
                row.FromProduct = true;
                await LoadProductReferences(_currentProductId);
            }
            else
            {
                var err = await resp.Content.ReadAsStringAsync();
                _mSaveRefError = $"Save failed: {err}";
            }
        }
        catch (Exception ex) { _mSaveRefError = ex.Message; }
        finally { row.IsSaving = false; StateHasChanged(); }
    }

