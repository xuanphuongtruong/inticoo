    private async Task OnReferenceFileSelected(InputFileChangeEventArgs e, int idx)
    {
        if (idx >= References.Count) return;

        // 1. Lấy file ra TRƯỚC khi làm bất cứ điều gì khác
        var file = e.File;
        if (file == null) return;

        var refItem = References[idx];
        refItem.FileName    = file.Name;
        refItem.UploadError = "";
        refItem.FileUrl     = "";

        // 2. Copy vào MemoryStream NGAY LẬP TỨC — cắt đứt liên kết với DOM trình duyệt
        //    Phải làm TRƯỚC StateHasChanged() để tránh lỗi _blazorFilesById
        var ms = new System.IO.MemoryStream();
        try
        {
            await file.OpenReadStream(maxAllowedSize: 20 * 1024 * 1024).CopyToAsync(ms);
        }
        catch (Exception ex)
        {
            refItem.UploadError = $"Không đọc được file: {ex.Message}";
            StateHasChanged();
            return;
        }
        ms.Position = 0;

        // 3. Bây giờ đã an toàn — gọi StateHasChanged sau khi đã có dữ liệu trong memory
        refItem.IsUploading = true;
        Waiting.Show($"Uploading: {file.Name}");
        StateHasChanged();

        try
        {
            using var content = new MultipartFormDataContent();
            var sc = new ByteArrayContent(ms.ToArray());
            sc.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(SafeContentType(file.ContentType));
            content.Add(sc, "file", file.Name);

            var token = await SessionStorage.GetItemAsync<string>("auth_token");
            if (!string.IsNullOrEmpty(token))
                Http.DefaultRequestHeaders.Authorization =
                    new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            var resp = await Http.PostAsync("api/files/upload", content);
            if (resp.IsSuccessStatusCode)
            {
                var rawBody = await resp.Content.ReadAsStringAsync();
                try
                {
                    using var doc = System.Text.Json.JsonDocument.Parse(rawBody);
                    string? url = null;
                    string? fileName = null;
                    foreach (var prop in doc.RootElement.EnumerateObject())
                    {
                        if (prop.Name.Equals("url", StringComparison.OrdinalIgnoreCase) ||
                            prop.Name.Equals("fileUrl", StringComparison.OrdinalIgnoreCase))
                            url = prop.Value.GetString();
                        if (prop.Name.Equals("fileName", StringComparison.OrdinalIgnoreCase) ||
                            prop.Name.Equals("name", StringComparison.OrdinalIgnoreCase))
                            fileName = prop.Value.GetString();
                    }
                    refItem.FileUrl     = url      ?? "";
                    refItem.FileName    = fileName ?? file.Name;
                    refItem.UploadError = string.IsNullOrEmpty(url)
                        ? $"Upload OK nhưng server không trả URL. Body: {rawBody}"
                        : "";
                }
                catch (Exception parseEx)
                {
                    refItem.UploadError = $"Parse error: {parseEx.Message}";
                }
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                refItem.UploadError = $"{(int)resp.StatusCode}: {body}";
            }
        }
        catch (Exception ex)
        {
            refItem.UploadError = ex.Message;
        }
        finally
        {
            refItem.IsUploading = false;
            Waiting.Hide();
            await ms.DisposeAsync();
            StateHasChanged();
        }
    }

