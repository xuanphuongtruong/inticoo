@page "/inspections/{Id:int}/edit"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using InticooInspection.Client.Services
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using Microsoft.AspNetCore.Components.Forms
@inject HttpClient Http
@inject NavigationManager Navigation
@inject Blazored.SessionStorage.ISessionStorageService SessionStorage
@inject WaitingService Waiting

<PageTitle>Edit Inspection - Inticoo</PageTitle>

<div class="ni-page">

    @if (_pageLoading)
    {
        <div class="loading-state">
            <div class="spinner-lg"></div>
            <span>Loading inspection...</span>
        </div>
    }
    else if (!string.IsNullOrEmpty(_loadError))
    {
        <div class="alert-err">⚠ @_loadError</div>
    }
    else if (!_canEdit)
    {
        <!-- Không được phép chỉnh sửa -->
        <div class="ni-header">
            <button class="ni-back-btn" @onclick="GoBack">
                <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M13 4l-6 6 6 6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </button>
            <div class="ni-title-block">
                <span class="ni-breadcrumb">Inspections</span>
                <h1 class="ni-title" style="color:#ffffff;">Edit Inspection</h1>
            </div>
        </div>
        <div class="ni-card" style="text-align:center; padding:48px 24px;">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="1.5" style="margin-bottom:16px;">
                <circle cx="12" cy="12" r="10"/>
                <path d="M12 8v4M12 16h.01" stroke-linecap="round"/>
            </svg>
            <h3 style="font-family:'Sora',sans-serif;font-size:18px;color:#1a2d5a;margin:0 0 10px;">Cannot Edit This Inspection</h3>
            <p style="color:#7a8fad;font-size:14px;margin:0 0 24px;">
                Only inspections with status <strong>New</strong>, <strong>On Going</strong>, or <strong>Pending</strong> can be edited.<br/>
                Current status: <span class="@GetBadgeClass(_currentStatus)" style="display:inline-block;margin-top:6px;">@GetStatusLabel(_currentStatus)</span>
            </p>
            <button class="btn-cancel" @onclick="GoBack">← Back to List</button>
        </div>
    }
    else
    {
        <!-- Header -->
        <div class="ni-header">
            <button class="ni-back-btn" @onclick="GoBack">
                <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M13 4l-6 6 6 6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </button>
            <div class="ni-title-block">
                <span class="ni-breadcrumb">Inspections / @_jobNumber</span>
                <h1 class="ni-title" style="color:#ffffff;">Edit Inspection</h1>
            </div>
            <div class="ni-header-actions">
                <span class="@GetBadgeClass(_currentStatus)" style="font-size:12px;padding:5px 14px;">@GetStatusLabel(_currentStatus)</span>
            </div>
        </div>

        <div class="ni-body">

            <!-- General Information + Photo -->
            <div class="ni-card">
                <div class="ni-section-title">General Information</div>
                <div class="gi-layout">

                    <!-- Cột trái: Photo -->
                    <div class="gi-photo-col">
                        <label class="photo-slot @(string.IsNullOrEmpty(PhotoPreview1) ? "" : "photo-slot--filled")">
                            @if (_photoUploading)
                            {
                                <div class="photo-placeholder">
                                    <div class="spinner-lg" style="border-top-color:#1e90d6;width:32px;height:32px;"></div>
                                    <span style="color:#1e90d6;font-size:12px;margin-top:8px;">Uploading...</span>
                                </div>
                            }
                            else if (!string.IsNullOrEmpty(PhotoPreview1))
                            {
                                <img src="@PhotoPreview1" alt="Photo" />
                                <button class="photo-remove-btn" type="button"
                                        @onclick:stopPropagation="true" @onclick="RemovePhoto">
                                    <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5">
                                        <path d="M5 5l10 10M15 5L5 15" stroke-linecap="round"/>
                                    </svg>
                                </button>
                            }
                            else
                            {
                                <div class="photo-placeholder">
                                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                        <rect x="3" y="3" width="18" height="18" rx="3"/>
                                        <circle cx="8.5" cy="8.5" r="1.5"/>
                                        <path d="M21 15l-5-5L5 21"/>
                                    </svg>
                                    <span>Click to upload photo</span>
                                    <span class="photo-hint">JPG, PNG, WEBP · max 5 MB</span>
                                </div>
                            }
                            <InputFile OnChange="OnPhotoSelected" accept="image/*" style="display:none" />
                        </label>
                        @if (!string.IsNullOrEmpty(_photoError))
                        {
                            <div style="color:#dc2626;font-size:11.5px;margin-top:6px;background:#fff5f5;border:1px solid #fecaca;border-radius:7px;padding:6px 10px;">
                                ⚠ @_photoError
                            </div>
                        }
                    </div>

                    <!-- Cột phải: Fields -->
                    <div class="gi-fields-col">
                    <div class="ni-grid-2">
                    <div class="field-group">
                        <label>Customer ID <span class="field-required">*</span></label>
                        @if (_loadingCustomers)
                        {
                            <div class="field-loading">Loading...</div>
                        }
                        else
                        {
                            <select value="@Model.CustomerId" @onchange="OnCustomerChanged">
                                <option value="">-- Select Customer --</option>
                                @foreach (var c in _customers)
                                {
                                    <option value="@c.CustomerId">@c.CustomerId — @c.CompanyName</option>
                                }
                            </select>
                        }
                    </div>
                    <div class="field-group">
                        <label>Customer Name</label>
                        <div class="readonly-field @(string.IsNullOrEmpty(Model.CustomerName) ? "" : "accent")">
                            @(string.IsNullOrEmpty(Model.CustomerName) ? "Auto-filled when selecting ID" : Model.CustomerName)
                        </div>
                    </div>
                    <div class="field-group">
                        <label>Vendor ID</label>
                        @if (_loadingVendors)
                        {
                            <div class="field-loading">Loading...</div>
                        }
                        else
                        {
                            <select value="@Model.VendorId" @onchange="OnVendorChanged">
                                <option value="">-- Select Vendor --</option>
                                @foreach (var v in _vendors)
                                {
                                    <option value="@v.Code">@v.Code — @v.Name</option>
                                }
                            </select>
                        }
                    </div>
                    <div class="field-group">
                        <label>Vendor Name</label>
                        <div class="readonly-field @(string.IsNullOrEmpty(Model.VendorName) ? "" : "accent")">
                            @(string.IsNullOrEmpty(Model.VendorName) ? "Auto-filled when selecting ID" : Model.VendorName)
                        </div>
                    </div>
                    <div class="field-group">
                        <label>Inspection Location</label>
                        @if (_loadingCountries)
                        {
                            <div class="field-loading">Loading countries...</div>
                        }
                        else
                        {
                            <select value="@_selectedCountryId" @onchange="OnCountryChanged">
                                <option value="">-- Select Country --</option>
                                @foreach (var co in _countries)
                                {
                                    <option value="@co.Id">@co.Name</option>
                                }
                            </select>
                        }
                    </div>
                    <div class="field-group">
                        <label>P.O. Number</label>
                        <input @bind="Model.PoNumber" placeholder="Enter PO number" />
                    </div>
                    <div class="field-group">
                        <label>Inspection Date</label>
                        <input type="date" @bind="Model.InspectionDate" />
                    </div>
                    <div class="field-group">
                        <label>Inspection Type</label>
                        <div class="radio-group">
                            <label class="radio-label">
                                <input type="radio" name="inspType" value="PPT"
                                       checked="@(Model.InspectionType == InspectionTypeEnum.PPT)"
                                       @onchange="() => Model.InspectionType = InspectionTypeEnum.PPT" />
                                <span>PPI: Pre-Production Inspection</span>
                            </label>
                            <label class="radio-label">
                                <input type="radio" name="inspType" value="DPI"
                                       checked="@(Model.InspectionType == InspectionTypeEnum.DPI)"
                                       @onchange="() => Model.InspectionType = InspectionTypeEnum.DPI" />
                                <span>DPI: During-Production Inspection</span>
                            </label>
                            <label class="radio-label">
                                <input type="radio" name="inspType" value="PST"
                                       checked="@(Model.InspectionType == InspectionTypeEnum.PST)"
                                       @onchange="() => Model.InspectionType = InspectionTypeEnum.PST" />
                                <span>PST: Pre-Shipment Inspection</span>
                            </label>
                        </div>
                    </div>
                    <div class="field-group">
                        <label>Item Number</label>
                        <input value="@Model.ItemNumber" @onchange="OnItemNumberChanged" placeholder="Enter item number" class="highlight-field" />
                    </div>
                    <div class="field-group">
                        <label>Product Name</label>
                        @if (_loadingProducts)
                        {
                            <div class="field-loading">Loading...</div>
                        }
                        else
                        {
                            <select value="@Model.ProductCode" @onchange="OnProductChanged">
                                <option value="">-- Select Product --</option>
                                @foreach (var p in _products)
                                {
                                    <option value="@p.ProductCode">@p.ProductCode — @p.ProductName</option>
                                }
                            </select>
                        }
                    </div>
                    <div class="field-group">
                        <label>Product Type</label>
                        <div class="readonly-field @(string.IsNullOrEmpty(Model.ProductType) ? "" : "accent")">
                            @(string.IsNullOrEmpty(Model.ProductType) ? "Auto-filled from Product" : Model.ProductType)
                        </div>
                    </div>
                    <div class="field-group">
                        <label>Inspection Reference</label>
                        <div class="toggle-group">
                            <button class="@ToggleCss(Model.InspectionReference)" @onclick="() => Model.InspectionReference = true">Yes</button>
                            <button class="@ToggleCss(!Model.InspectionReference)" @onclick="() => Model.InspectionReference = false">No</button>
                        </div>
                    </div>
                    <div class="field-group">
                        <label>Total Shipment Quantity</label>
                        <input type="number" value="@Model.TotalShipmentQty" @onchange="OnTotalShipmentQtyChanged" placeholder="0" />
                    </div>
                    <div class="field-group">
                        <label>Product Category</label>
                        <div class="readonly-field @(string.IsNullOrEmpty(Model.ProductCategory) ? "" : "accent")">
                            @(string.IsNullOrEmpty(Model.ProductCategory) ? "Auto-filled from Product ID" : Model.ProductCategory)
                        </div>
                    </div>
                    <div class="field-group">
                        <label>Total Carton Boxes</label>
                        <input type="number" @bind="Model.TotalCartonBoxes" placeholder="0" />
                    </div>
                    </div>
                    <!-- Remark row spanning full width -->
                    <div class="field-group" style="margin-top:4px;">
                        <label>Remark</label>
                        <textarea @bind="Model.GeneralRemark" placeholder="Enter remark (e.g. Combine SKU number xxx, xxx &amp; xxxx)" rows="2"
                                  style="width:100%;resize:vertical;border:1px solid #d0daea;border-radius:8px;padding:9px 12px;font-size:13px;font-family:inherit;color:#1a2d5a;outline:none;transition:border-color .15s;box-sizing:border-box;"
                                  onfocus="this.style.borderColor='#1e90d6'" onblur="this.style.borderColor='#d0daea'"></textarea>
                    </div>
                    </div><!-- gi-fields-col -->
                </div><!-- gi-layout -->
            </div>

            <!-- Overall Conclusion -->
            <div class="ni-card">
                <div class="ni-section-title">Inspection Results</div>
                <table class="oc-table">
                    <thead>
                        <tr>
                            <th class="oc-th-label">OVERALL CONCLUSION</th>
                            <th class="oc-th-compliance">COMPLIANCE</th>
                            <th class="oc-th-remark">REMARK</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in OverallConclusions)
                        {
                            var r = row;
                            <tr class="oc-row">
                                <td class="oc-td-label">@r.Letter. @r.Label</td>
                                <td class="oc-td-compliance">
                                    <button class="@(r.Compliance == "Pass" ? "oc-btn oc-yes active" : "oc-btn oc-yes")"
                                            @onclick="@(() => ToggleCompliance(r, "Pass"))">YES</button>
                                    <span class="oc-sep">/</span>
                                    <button class="@(r.Compliance == "Fail" ? "oc-btn oc-no active" : "oc-btn oc-no")"
                                            @onclick="@(() => ToggleCompliance(r, "Fail"))">NO</button>
                                </td>
                                <td class="oc-td-remark">
                                    <input class="oc-remark-input" @bind="r.Remark" placeholder="Remark..." />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- AQL Sampling Simulator -->
            <div class="ni-card">
                <div class="ni-section-title">AQL Sampling Simulator</div>
                @if (!string.IsNullOrEmpty(_currentCodeLetter))
                {
                    <div style="margin-bottom:12px;font-size:13px;color:#4a6080;">
                        Lot Size <strong>@AqlQuantity</strong> · Level <strong>@AqlInspectionLevel</strong>
                        → Code Letter: <span style="font-size:16px;font-weight:700;color:#1e90d6;background:#e6f1fb;padding:2px 10px;border-radius:6px;">@_currentCodeLetter</span>
                    </div>
                }
                <div class="ni-grid-2" style="margin-bottom:20px;">
                    <div class="field-group">
                        <label>Quantity</label>
                        <input type="number" value="@AqlQuantity" @onchange="OnAqlQuantityChanged" placeholder="Enter quantity" />
                    </div>
                    <div class="field-group">
                        <label>Inspection Level</label>
                        <select value="@AqlInspectionLevel" @onchange="OnAqlLevelChanged">
                            <optgroup label="General Inspection">
                                <option value="I">Level I</option>
                                <option value="II">Level II</option>
                                <option value="III">Level III</option>
                            </optgroup>
                            <optgroup label="Special Inspection">
                                <option value="S1">S1</option>
                                <option value="S2">S2</option>
                                <option value="S3">S3</option>
                                <option value="S4">S4</option>
                            </optgroup>
                        </select>
                    </div>
                </div>
                <div class="aql-defects-row">
                    <div class="aql-defect-card critical">
                        <div class="aql-defect-header">Critical Defects</div>
                        <div class="field-group">
                            <label>Select AQL</label>
                            <select value="@CriticalAql" @onchange="OnCriticalAqlChanged">
                                <option value="0">Not Allowed</option>
                                <option value="0.065">0.065</option>
                                <option value="0.10">0.10</option>
                                <option value="0.15">0.15</option>
                                <option value="0.25">0.25</option>
                                <option value="0.40">0.40</option>
                                <option value="0.65">0.65</option>
                                <option value="1.0">1.0</option>
                                <option value="1.5">1.5</option>
                                <option value="2.5">2.5</option>
                                <option value="4.0">4.0</option>
                                <option value="6.5">6.5</option>
                            </select>
                        </div>
                        <div class="aql-stats">
                            <div class="aql-stat"><span>Sample Size</span><strong>@CriticalSampleSize</strong></div>
                            <div class="aql-stat"><span>Accept Point</span><strong class="accent-ok">@CriticalAccept</strong></div>
                            <div class="aql-stat"><span>Reject Point</span><strong class="accent-err">@CriticalReject</strong></div>
                        </div>
                    </div>
                    <div class="aql-defect-card major">
                        <div class="aql-defect-header">Major Defects</div>
                        <div class="field-group">
                            <label>Select AQL</label>
                            <select value="@MajorAql" @onchange="OnMajorAqlChanged">
                                <option value="0">Not Allowed</option>
                                <option value="0.065">0.065</option>
                                <option value="0.10">0.10</option>
                                <option value="0.15">0.15</option>
                                <option value="0.25">0.25</option>
                                <option value="0.40">0.40</option>
                                <option value="0.65">0.65</option>
                                <option value="1.0">1.0</option>
                                <option value="1.5">1.5</option>
                                <option value="2.5">2.5</option>
                                <option value="4.0">4.0</option>
                                <option value="6.5">6.5</option>
                            </select>
                        </div>
                        <div class="aql-stats">
                            <div class="aql-stat"><span>Sample Size</span><strong>@MajorSampleSize</strong></div>
                            <div class="aql-stat"><span>Accept Point</span><strong class="accent-ok">@MajorAccept</strong></div>
                            <div class="aql-stat"><span>Reject Point</span><strong class="accent-err">@MajorReject</strong></div>
                        </div>
                    </div>
                    <div class="aql-defect-card minor">
                        <div class="aql-defect-header">Minor Defects</div>
                        <div class="field-group">
                            <label>Select AQL</label>
                            <select value="@MinorAql" @onchange="OnMinorAqlChanged">
                                <option value="0">Not Allowed</option>
                                <option value="0.065">0.065</option>
                                <option value="0.10">0.10</option>
                                <option value="0.15">0.15</option>
                                <option value="0.25">0.25</option>
                                <option value="0.40">0.40</option>
                                <option value="0.65">0.65</option>
                                <option value="1.0">1.0</option>
                                <option value="1.5">1.5</option>
                                <option value="2.5">2.5</option>
                                <option value="4.0">4.0</option>
                                <option value="6.5">6.5</option>
                            </select>
                        </div>
                        <div class="aql-stats">
                            <div class="aql-stat"><span>Sample Size</span><strong>@MinorSampleSize</strong></div>
                            <div class="aql-stat"><span>Accept Point</span><strong class="accent-ok">@MinorAccept</strong></div>
                            <div class="aql-stat"><span>Reject Point</span><strong class="accent-err">@MinorReject</strong></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- A. Quantity Conformity -->
            <div class="ni-card">
                <div class="ni-section-title"><span class="section-alpha">A</span> Quantity Conformity</div>
                <div class="ni-grid-2">
                    <div class="field-group">
                        <label>Total Shipment Quantity</label>
                        <div class="readonly-field">@(Model.TotalShipmentQty > 0 ? Model.TotalShipmentQty.ToString() : "Auto")</div>
                    </div>
                    <div class="field-group">
                        <label>Total Carton Boxes</label>
                        <div class="readonly-field">@(Model.TotalCartonBoxes > 0 ? Model.TotalCartonBoxes.ToString() : "Auto")</div>
                    </div>
                </div>
            </div>

            <!-- B. Packaging & Identification -->
            <div class="ni-card">
                <div class="ni-section-title"><span class="section-alpha">B</span> Packaging &amp; Identification</div>

                <div class="ni-grid-2" style="margin-bottom:14px;">
                    <div class="field-group">
                        <label>Item Number</label>
                        <input @bind="Packaging.ItemNumber" placeholder="Enter item number" />
                    </div>
                    <div class="field-group">
                        <label>Carton Number</label>
                        <input @bind="Packaging.CartonNumber" placeholder="Enter carton number" />
                    </div>
                </div>

                <div class="pkg-grid">
                    <div class="pkg2-row">
                        <span class="pkg2-label">Type of Packaging</span>
                        <div class="pkg2-options">
                            <label class="radio-label"><input type="radio" name="pkgType" checked="@(Packaging.PackagingType == PkgFsc)" @onchange="() => Packaging.PackagingType = PkgFsc" /><span>FSC Carton</span></label>
                            <label class="radio-label"><input type="radio" name="pkgType" checked="@(Packaging.PackagingType == PkgNonFsc)" @onchange="() => Packaging.PackagingType = PkgNonFsc" /><span>Non-FSC Carton</span></label>
                        </div>
                    </div>
                    <div class="pkg2-row">
                        <span class="pkg2-label">Shipping Mark</span>
                        <div class="pkg2-options">
                            <label class="radio-label"><input type="radio" name="shippingMark" checked="@(Packaging.ShippingMark == SmColorLabel)" @onchange="() => Packaging.ShippingMark = SmColorLabel" /><span>Color Label</span></label>
                            <label class="radio-label"><input type="radio" name="shippingMark" checked="@(Packaging.ShippingMark == SmPrinting)" @onchange="() => Packaging.ShippingMark = SmPrinting" /><span>Printing</span></label>
                        </div>
                    </div>
                    <div class="pkg2-row">
                        <span class="pkg2-label">Color of Carton</span>
                        <div class="pkg2-options">
                            <label class="radio-label"><input type="radio" name="cartonColor" checked="@(Packaging.CartonColor == ColWhite)" @onchange="() => Packaging.CartonColor = ColWhite" /><span>White</span></label>
                            <label class="radio-label"><input type="radio" name="cartonColor" checked="@(Packaging.CartonColor == ColBrown)" @onchange="() => Packaging.CartonColor = ColBrown" /><span>Brown</span></label>
                        </div>
                    </div>
                    <div class="pkg2-row">
                        <span class="pkg2-label">Barcode / QR Code</span>
                        <div class="pkg2-options">
                            <div class="toggle-group">
                                <button class="@ToggleCss(Packaging.HasBarcode)" @onclick="() => Packaging.HasBarcode = true">Yes</button>
                                <button class="@ToggleCss(!Packaging.HasBarcode)" @onclick="() => Packaging.HasBarcode = false">No</button>
                            </div>
                        </div>
                    </div>
                    <div class="pkg2-row">
                        <span class="pkg2-label">Type of Cardboard</span>
                        <div class="pkg2-options">
                            <label class="radio-label"><input type="radio" name="cardboard" checked="@(Packaging.CardboardType == CbSingleFace)" @onchange="() => Packaging.CardboardType = CbSingleFace" /><span>Single face</span></label>
                            <label class="radio-label"><input type="radio" name="cardboard" checked="@(Packaging.CardboardType == CbSingleWall)" @onchange="() => Packaging.CardboardType = CbSingleWall" /><span>Single Wall</span></label>
                            <label class="radio-label"><input type="radio" name="cardboard" checked="@(Packaging.CardboardType == CbDoubleWall)" @onchange="() => Packaging.CardboardType = CbDoubleWall" /><span>Double Wall</span></label>
                        </div>
                    </div>
                    <div class="pkg2-row">
                        <span class="pkg2-label">Assembly Instruction</span>
                        <div class="pkg2-options">
                            <div class="toggle-group">
                                <button class="@ToggleCss(Packaging.AssemblyInstruction)" @onclick="() => Packaging.AssemblyInstruction = true">Yes</button>
                                <button class="@ToggleCss(!Packaging.AssemblyInstruction)" @onclick="() => Packaging.AssemblyInstruction = false">No</button>
                            </div>
                        </div>
                    </div>
                    <div class="pkg2-row pkg2-span2">
                        <span class="pkg2-label">Hardware</span>
                        <div class="pkg2-options">
                            <div class="toggle-group">
                                <button class="@ToggleCss(Packaging.Hardware)" @onclick="() => Packaging.Hardware = true">Yes</button>
                                <button class="@ToggleCss(!Packaging.Hardware)" @onclick="() => Packaging.Hardware = false">No</button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="pkg-sub-section">
                    <span class="pkg-sub-title">Inner Packing</span>
                    <div class="ni-grid-6">
                        <div class="field-group"><label>Quantity</label><input type="number" @bind="Packaging.InnerPackingQty" placeholder="0" /></div>
                        <div class="field-group"><label>L (mm)</label><input type="number" @bind="Packaging.InnerL" placeholder="0" /></div>
                        <div class="field-group"><label>W (mm)</label><input type="number" @bind="Packaging.InnerW" placeholder="0" /></div>
                        <div class="field-group"><label>H (mm)</label><input type="number" @bind="Packaging.InnerH" placeholder="0" /></div>
                        <div class="field-group"><label>Weight (Kgs)</label><input type="number" step="0.01" @bind="Packaging.InnerWeight" placeholder="0.00" /></div>
                        <div class="field-group"><label>Remark</label><input @bind="Packaging.InnerPackingRemark" placeholder="Remark..." /></div>
                    </div>
                </div>

                <div class="pkg-sub-section">
                    <span class="pkg-sub-title">Outer Packing</span>
                    <div class="ni-grid-4">
                        <div class="field-group"><label>L (mm)</label><input type="number" @bind="Packaging.OuterL" placeholder="0" /></div>
                        <div class="field-group"><label>W (mm)</label><input type="number" @bind="Packaging.OuterW" placeholder="0" /></div>
                        <div class="field-group"><label>H (mm)</label><input type="number" @bind="Packaging.OuterH" placeholder="0" /></div>
                        <div class="field-group"><label>Weight (Kgs)</label><input type="number" step="0.01" @bind="Packaging.OuterWeight" placeholder="0.00" /></div>
                    </div>
                </div>
            </div>

            <!-- C. Product Specification -->
            <div class="ni-card">
                <div class="ni-section-title"><span class="section-alpha">C</span> Product Specification</div>
                <div class="sub-section-label">i. Product Size</div>
                <div class="ni-grid-4" style="margin-bottom:20px;">
                    <div class="field-group"><label>L (mm)</label><input type="number" @bind="ProductSpec.SizeL" placeholder="0" /></div>
                    <div class="field-group"><label>W (mm)</label><input type="number" @bind="ProductSpec.SizeW" placeholder="0" /></div>
                    <div class="field-group"><label>H (mm)</label><input type="number" @bind="ProductSpec.SizeH" placeholder="0" /></div>
                    <div class="field-group"><label>Weight (Kgs)</label><input type="number" step="0.01" @bind="ProductSpec.Weight" placeholder="0.00" /></div>
                </div>
                <div class="compare-golden-row">
                    <div class="sub-section-label" style="margin-bottom:0;">ii. Compare Golden Sample</div>
                    <div class="toggle-group">
                        <button class="@ToggleCss(ProductSpec.CompareGoldenSample)" @onclick="() => ProductSpec.CompareGoldenSample = true">Yes</button>
                        <button class="@ToggleCss(!ProductSpec.CompareGoldenSample)" @onclick="() => ProductSpec.CompareGoldenSample = false">No</button>
                    </div>
                </div>
                <div class="sub-section-label" style="margin-top:20px;">iii. Colour Swatch Comparison</div>
                <div class="data-table">
                    <div class="data-table-header">
                        <div class="col-no">No</div>
                        <div class="col-flex">Material</div>
                    </div>
                    @for (int i = 0; i < ColourSwatches.Count; i++)
                    {
                        var idx = i;
                        <div class="data-table-row">
                            <div class="col-no">@(idx + 1)</div>
                            <div class="col-flex"><input @bind="ColourSwatches[idx]" placeholder="Enter material..." class="table-input" /></div>
                        </div>
                    }
                    <button class="add-row-btn" @onclick="AddColourSwatch">+ Add Row</button>
                </div>
            </div>

            <!-- D. Performance Testing -->
            <div class="ni-card">
                <div class="ni-section-title"><span class="section-alpha">D</span> Performance Testing</div>
                @if (_loadingPerfMaster)
                {
                    <div class="field-loading">Loading test master data...</div>
                }
                else if (!string.IsNullOrEmpty(_perfMasterError))
                {
                    <div style="color:#dc2626;font-size:12px;background:#fff5f5;border:1px solid #fecaca;border-radius:8px;padding:10px 14px;margin-bottom:12px;">
                        ⚠ @_perfMasterError
                    </div>
                    <div class="data-table">
                        <div class="data-table-header">
                            <div class="col-no">No</div>
                            <div class="col-flex">Category</div>
                            <div class="col-flex">Test Item</div>
                            <div class="col-flex2">Test Requirement</div>
                            <div class="col-flex">Remark</div>
                        </div>
                        @for (int i = 0; i < PerformanceTests.Count; i++)
                        {
                            var idx  = i;
                            var test = PerformanceTests[idx];
                            <div class="data-table-row">
                                <div class="col-no">@(idx + 1)</div>
                                <div class="col-flex"><input @bind="test.Category" placeholder="Category..." class="table-input" /></div>
                                <div class="col-flex"><input @bind="test.TestItem" placeholder="Test item..." class="table-input" /></div>
                                <div class="col-flex2"><input @bind="test.TestRequirement" placeholder="Requirement..." class="table-input" /></div>
                                <div class="col-flex"><input @bind="test.Remark" placeholder="Remark..." class="table-input" /></div>
                            </div>
                        }
                        <button class="add-row-btn" @onclick="AddPerformanceTest">+ Add Row</button>
                    </div>
                }
                else
                {
                    <div class="data-table">
                        <div class="data-table-header">
                            <div class="col-no">No</div>
                            <div class="col-flex">Category</div>
                            <div class="col-flex">Test Item</div>
                            <div class="col-flex2">Test Requirement</div>
                            <div class="col-flex">Remark</div>
                        </div>
                        @for (int i = 0; i < PerformanceTests.Count; i++)
                        {
                            var idx  = i;
                            var test = PerformanceTests[idx];
                            var testItems = GetPerfTestItems(test.Category);
                            <div class="data-table-row">
                                <div class="col-no">@(idx + 1)</div>
                                <div class="col-flex">
                                    <select class="table-select"
                                            value="@test.Category"
                                            @onchange="e => OnPerfCategoryChanged(e, idx)">
                                        <option value="">Category...</option>
                                        @foreach (var cat in _perfCategories)
                                        {
                                            <option value="@cat">@cat</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-flex">
                                    @if (string.IsNullOrEmpty(test.Category))
                                    {
                                        <select class="table-select" disabled>
                                            <option value="">Select category first...</option>
                                        </select>
                                    }
                                    else
                                    {
                                        <select class="table-select"
                                                value="@test.TestItem"
                                                @onchange="e => OnPerfTestItemChanged(e, idx)">
                                            <option value="">Test item...</option>
                                            @foreach (var item in testItems)
                                            {
                                                <option value="@item.ProtocolName">@item.ProtocolName</option>
                                            }
                                        </select>
                                    }
                                </div>
                                <div class="col-flex2">
                                    <textarea @bind="test.TestRequirement"
                                              placeholder="Requirement auto-filled..."
                                              class="table-textarea"
                                              rows="2"></textarea>
                                </div>
                                <div class="col-flex">
                                    <input @bind="test.Remark" placeholder="Remark..." class="table-input" />
                                </div>
                            </div>
                        }
                        <button class="add-row-btn" @onclick="AddPerformanceTest">+ Add Row</button>
                    </div>
                }
            </div>

            <!-- E. Reference -->
            <div class="ni-card">
                <div class="ni-section-title"><span class="section-alpha">E</span> Reference</div>
                @if (!string.IsNullOrEmpty(_mSaveRefError))
                {
                    <div style="color:#dc2626;font-size:12px;margin-bottom:8px;">@_mSaveRefError</div>
                }
                <div class="data-table">
                    <div class="data-table-header">
                        <div class="col-no">No</div>
                        <div class="col-flex2">Reference</div>
                        <div class="col-flex">Attached File</div>
                        <div class="col-flex">Remark</div>
                        <div style="width:80px;flex-shrink:0;"></div>
                    </div>
                    @for (int i = 0; i < References.Count; i++)
                    {
                        var idx = i;
                        var refItem = References[idx];
                        <div class="data-table-row" @key="refItem.Id">
                            <div class="col-no">@(idx + 1)</div>
                            <div class="col-flex2">
                                @if (refItem.FromProduct)
                                {
                                    <span class="table-input" style="color:#1a2d5a;display:block;padding:5px 4px;">@refItem.ReferenceName</span>
                                }
                                else
                                {
                                    <input @bind="refItem.ReferenceName" placeholder="Reference name..." class="table-input" />
                                }
                            </div>
                            <div class="col-flex">
                                <span class="file-uploading" style="display:@(refItem.IsUploading ? "inline-flex" : "none")">⏳ Uploading...</span>
                                <div style="display:@(!refItem.IsUploading && !string.IsNullOrEmpty(refItem.UploadError) ? "flex" : "none");align-items:center;gap:6px;">
                                    <span style="color:#dc2626;font-size:11.5px;max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@refItem.UploadError">⚠ @refItem.UploadError</span>
                                    <label class="file-attach-btn" style="padding:3px 8px;font-size:11px;" title="Retry">
                                        Retry
                                        <InputFile OnChange="@(async e => await OnReferenceFileSelected(e, idx))" style="display:none;" />
                                    </label>
                                </div>
                                <div style="display:@(!refItem.IsUploading && string.IsNullOrEmpty(refItem.UploadError) && !string.IsNullOrEmpty(refItem.FileUrl) ? "flex" : "none");align-items:center;gap:6px;">
                                    @{ var fn = refItem.FileName ?? ""; }
                                    @{ var absFileUrl = (refItem.FileUrl?.StartsWith("http") == true)
                                            ? refItem.FileUrl
                                            : (Http.BaseAddress?.ToString().TrimEnd('/') ?? "") + (refItem.FileUrl?.StartsWith('/') == true ? refItem.FileUrl : "/" + refItem.FileUrl); }
                                    <a href="@absFileUrl" target="_blank" class="file-link-btn" title="@refItem.FileName">
                                        <svg width="12" height="12" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 17h12M10 3v10M6 13l4 4 4-4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                        @(fn.Length > 20 ? fn[..20] + "…" : (fn.Length > 0 ? fn : "(file)"))
                                    </a>
                                    @if (!refItem.FromProduct)
                                    {
                                        <label class="file-reupload-btn" title="Change file">
                                            <svg width="11" height="11" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 3v10M6 7l4-4 4 4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                            <InputFile OnChange="@(async e => await OnReferenceFileSelected(e, idx))" style="display:none;" />
                                        </label>
                                    }
                                </div>
                                @if (!refItem.FromProduct)
                                {
                                    <label class="file-attach-btn" style="display:@(!refItem.IsUploading && string.IsNullOrEmpty(refItem.UploadError) && string.IsNullOrEmpty(refItem.FileUrl) ? "inline-flex" : "none");">
                                        <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 3v10M6 7l4-4 4 4" stroke-linecap="round" stroke-linejoin="round"/><path d="M4 17h12" stroke-linecap="round"/></svg>
                                        Attach File
                                        <InputFile OnChange="@(async e => await OnReferenceFileSelected(e, idx))" style="display:none;" />
                                    </label>
                                }
                                else if (string.IsNullOrEmpty(refItem.FileUrl))
                                {
                                    <span style="font-size:11px;color:#b0bdd4;font-style:italic;">No file</span>
                                }
                            </div>
                            <div class="col-flex">
                                @if (refItem.FromProduct)
                                {
                                    <span style="font-size:12.5px;color:#4a6080;">@refItem.Remark</span>
                                }
                                else
                                {
                                    <input @bind="refItem.Remark" placeholder="Remark..." class="table-input" />
                                }
                            </div>
                            <div style="width:80px;flex-shrink:0;display:flex;align-items:center;justify-content:center;">
                                @if (!refItem.FromProduct && _currentProductId > 0)
                                {
                                    <button class="btn-ref-save" @onclick="() => SaveProductReference(idx)" disabled="@refItem.IsSaving">
                                        @(refItem.IsSaving ? "..." : "Save")
                                    </button>
                                }
                                else if (refItem.FromProduct)
                                {
                                    <span style="font-size:10px;color:#9baac8;">Product</span>
                                }
                            </div>
                        </div>
                    }
                    <button class="add-row-btn" @onclick="AddReference">+ Add Row</button>
                </div>
            </div>

            <!-- Office Use -->
            <div class="ni-card office-card">
                <div class="ni-section-title">Office Use</div>
                <div class="office-inline-row">
                    <div class="field-group">
                        <label>Inspector ID</label>
                        @if (_loadingInspectors)
                        {
                            <div class="field-loading">Loading...</div>
                        }
                        else
                        {
                            <select value="@OfficeUse.InspectorId" @onchange="OnInspectorChanged" class="highlight-field">
                                <option value="">-- Select Inspector --</option>
                                @foreach (var u in _inspectors)
                                {
                                    var key = !string.IsNullOrEmpty(u.InspectorId) ? u.InspectorId : u.Id;
                                    <option value="@key">@(string.IsNullOrEmpty(u.InspectorId) ? u.FullName : $"{u.InspectorId} — {u.FullName}")</option>
                                }
                            </select>
                        }
                    </div>
                    <div class="field-group">
                        <label>Inspector Name</label>
                        <div class="readonly-field @(string.IsNullOrEmpty(OfficeUse.InspectorName) ? "" : "accent")">
                            @(string.IsNullOrEmpty(OfficeUse.InspectorName) ? "Auto-filled from ID" : OfficeUse.InspectorName)
                        </div>
                    </div>
                    <div class="field-group">
                        <label>Job Number</label>
                        <div class="readonly-field accent">@_jobNumber</div>
                    </div>
                </div>
            </div>

            <!-- Submit row -->
            <div class="ni-submit-row">
                <button class="btn-cancel" @onclick="GoBack">Cancel</button>
                @if (_validationErrors.Count > 0)
                {
                    <div class="ni-save-error">
                        <strong>Please fix the following errors:</strong>
                        <ul style="margin:6px 0 0 0;padding-left:18px;">
                            @foreach (var err in _validationErrors)
                            {
                                <li>@err</li>
                            }
                        </ul>
                    </div>
                }
                else if (!string.IsNullOrEmpty(_saveError))
                {
                    <div class="ni-save-error">@_saveError</div>
                }
                <button class="btn-save large" @onclick="HandleSave" disabled="@_saving">
                    @if (_saving)
                    {
                        <span class="ni-spinner"></span>
                        <span>Saving...</span>
                    }
                    else
                    {
                        <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M5 10l4 4 8-8" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        <span>Save Changes</span>
                    }
                </button>
            </div>

        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    // ── String constants ──
    private const string PkgFsc       = "FSC Carton";
    private const string PkgNonFsc    = "Non-FSC Carton";
    private const string ColWhite     = "White";
    private const string ColBrown     = "Brown";
    private const string CbSingleFace = "Single face";
    private const string CbSingleWall = "Single Wall";
    private const string CbDoubleWall = "Double Wall";
    private const string SmColorLabel = "Color Label";
    private const string SmPrinting   = "Printing";

    private static string ToggleCss(bool active) => active ? "toggle-btn active" : "toggle-btn";

    // ── Page state ──
    private bool   _pageLoading   = true;
    private string _loadError     = "";
    private bool   _canEdit       = false;
    private string _currentStatus = "";
    private string _jobNumber     = "";

    // ── Form state ──
    private InspectionModel  Model       = new();
    private PackagingModel   Packaging   = new();
    private ProductSpecModel ProductSpec = new();
    private OfficeUseModel   OfficeUse   = new();

    private List<string>             ColourSwatches   = new() { "", "", "" };
    private List<PerformanceTestRow> PerformanceTests = new() { new(), new(), new() };
    private List<ReferenceRow>       References       = new() { new(), new(), new(), new(), new() };

    private List<OverallConclusionRow> OverallConclusions = new()
    {
        new() { Letter = "A", Label = "Quantity Conformity" },
        new() { Letter = "B", Label = "Packaging & Identification" },
        new() { Letter = "C", Label = "Product Specification Compliance" },
        new() { Letter = "D", Label = "Performance Testing" },
        new() { Letter = "E", Label = "Appearance & Craftsmanship" },
        new() { Letter = "F", Label = "Details of Defect Found" },
    };

    // ── Photos ──
    // PhotoPreview1  : data URL base64 hoặc server URL — dùng cho <img src>
    // Photo1ServerUrl : server URL sau upload — dùng để lưu DB
    private string? PhotoPreview1   = null;
    private string? Photo1ServerUrl = null;
    private bool    _photoUploading = false;
    private string? _photoError     = null;

    // ── Dropdowns ──
    private List<CustomerDropdownDto>  _customers   = new();
    private List<VendorDropdownDto>    _vendors     = new();
    private List<ProductDropdownDto>   _allProducts = new();
    private List<ProductDropdownDto>   _products    = new();
    private List<InspectorDropdownDto> _inspectors  = new();
    private bool _loadingCustomers  = true;
    private bool _loadingVendors    = true;
    private bool _loadingProducts   = true;
    private bool _loadingInspectors = true;

    private List<CountryDto> _countries         = new();
    private int              _selectedCountryId = 0;
    private bool             _loadingCountries  = true;

    // ── Performance Test Master ──
    private List<PerformanceTestMasterDto> _perfMaster        = new();
    private List<string>                   _perfCategories    = new();
    private bool                           _loadingPerfMaster = true;
    private string                         _perfMasterError   = "";
    private int    AqlQuantity        = 0;
    private string AqlInspectionLevel = "II";
    private string CriticalAql        = "0";
    private string MajorAql           = "2.5";
    private string MinorAql           = "4.0";

    private int CriticalSampleSize, CriticalAccept, CriticalReject;
    private int MajorSampleSize,    MajorAccept,    MajorReject;
    private int MinorSampleSize,    MinorAccept,    MinorReject;
    private string _currentCodeLetter = "";

    // ── Save state ──
    private bool   _saving = false;
    private string? _saveError;
    private string _mSaveRefError = "";
    private List<string> _validationErrors = new();

    // ─────────────────────────────────────────────────────────────
    //  STATUS MAPPING  (0=New, 1=OnGoing, 2=Completed, 3=Pending, 4=Cancel)
    // ─────────────────────────────────────────────────────────────
    private static string MapStatusFromInt(int statusInt) => statusInt switch
    {
        0 => "New",
        1 => "OnGoing",
        2 => "Completed",
        3 => "Pending",
        4 => "Cancel",
        _ => "New"
    };

    private static string MapStatusFromString(string status) => status?.ToLower() switch
    {
        "new"       => "New",
        "ongoing"   => "OnGoing",
        "completed" => "Completed",
        "pending"   => "Pending",
        "cancel"    => "Cancel",
        "cancelled" => "Cancel",
        _           => "New"
    };

    /// <summary>Chỉ New(0), OnGoing(1), Pending(3) mới được phép chỉnh sửa.</summary>
    private static bool IsEditable(string status) => status switch
    {
        "New"     => true,
        "OnGoing" => true,
        "Pending" => true,
        _         => false
    };

    private string GetStatusLabel(string status) => status switch
    {
        "New"       => "New",
        "OnGoing"   => "On Going",
        "Completed" => "Completed",
        "Pending"   => "Pending",
        "Cancel"    => "Cancel",
        _           => status
    };

    private string GetBadgeClass(string status) => status switch
    {
        "New"       => "badge s-new",
        "OnGoing"   => "badge s-progress",
        "Completed" => "badge s-active",
        "Pending"   => "badge s-pending",
        "Cancel"    => "badge s-inactive",
        _           => "badge s-new"
    };

    // ─────────────────────────────────────────────────────────────
    //  LIFECYCLE
    // ─────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        // Load song song: inspection + tất cả dropdowns cùng lúc → nhanh hơn nhiều
        await Task.WhenAll(
            LoadInspection(),
            LoadCustomers(),
            LoadVendors(),
            LoadProducts(),
            LoadInspectors(),
            LoadCountries(),
            LoadPerformanceMaster()
        );

        // Sau khi có đủ data, set selectedCountryId và filter products
        if (!string.IsNullOrEmpty(Model.InspectionLocation))
        {
            var match = _countries.FirstOrDefault(c =>
                c.Name.Equals(Model.InspectionLocation, StringComparison.OrdinalIgnoreCase));
            if (match != null) _selectedCountryId = match.Id;
        }
        FilterProducts();

        // Set _currentProductId từ ProductCode để nút Save trong References hoạt động
        if (!string.IsNullOrEmpty(Model.ProductCode))
        {
            var prod = _allProducts.FirstOrDefault(p =>
                p.ProductCode.Equals(Model.ProductCode, StringComparison.OrdinalIgnoreCase));
            if (prod != null)
                _currentProductId = prod.Id;
        }

        _pageLoading = false;
    }

    private async Task LoadInspection()
    {
        try
        {
            var token = await SessionStorage.GetItemAsync<string>("auth_token");
            if (!string.IsNullOrEmpty(token))
                Http.DefaultRequestHeaders.Authorization =
                    new AuthenticationHeaderValue("Bearer", token);

            var opts = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var resp = await Http.GetAsync($"api/inspections/{Id}");

            if (!resp.IsSuccessStatusCode)
            {
                _loadError = $"Cannot load inspection ({(int)resp.StatusCode}).";
                return;
            }

            var json = await resp.Content.ReadAsStringAsync();
            var data = System.Text.Json.JsonSerializer.Deserialize<InspectionDetailDto>(json, opts);
            if (data == null)
            {
                _loadError = "Invalid response from server.";
                return;
            }

            // Parse InspectionReference từ JsonElement (API có thể trả bool, int 0/1, hoặc string)
            if (data.InspectionReferenceRaw.HasValue)
            {
                var irProp = data.InspectionReferenceRaw.Value;
                data.InspectionReference = irProp.ValueKind switch
                {
                    System.Text.Json.JsonValueKind.True   => true,
                    System.Text.Json.JsonValueKind.False  => false,
                    System.Text.Json.JsonValueKind.Number => irProp.GetInt32() != 0,
                    System.Text.Json.JsonValueKind.String => irProp.GetString()?.ToLower() is "true" or "1" or "yes",
                    _ => true
                };
            }
            else
            {
                data.InspectionReference = true;
            }

            // Map status
            _currentStatus = MapStatusFromString(data.Status);
            _jobNumber      = data.JobNumber ?? $"#{data.Id}";
            _canEdit        = IsEditable(_currentStatus);

            if (!_canEdit) return;

            // Map fields vào form model
            Model.CustomerId         = data.CustomerId   ?? "";
            Model.CustomerName       = data.CustomerName ?? "";
            Model.VendorId           = data.VendorId     ?? "";
            Model.VendorName         = data.VendorName   ?? "";
            Model.InspectionLocation = data.InspectionLocation ?? "";
            Model.PoNumber           = data.PoNumber     ?? "";
            Model.InspectionDate     = data.InspectionDate;
            Model.ItemNumber         = data.ItemNumber   ?? "";
            Model.ProductCode        = data.ProductCode  ?? "";
            Model.ProductName        = data.ProductName  ?? "";
            Model.ProductType        = data.ProductType  ?? "";
            Model.ProductCategory    = data.ProductCategory ?? "";
            Model.TotalShipmentQty   = data.TotalShipmentQty;
            Model.TotalCartonBoxes   = data.TotalCartonBoxes;
            Model.GeneralRemark      = data.GeneralRemark;
            Model.InspectionReference = data.InspectionReference;
            if (Enum.TryParse<InspectionTypeEnum>(data.InspectionType, true, out var it))
                Model.InspectionType = it;

            // AQL
            AqlQuantity        = data.AqlQuantity;
            AqlInspectionLevel = data.AqlLevel ?? "II";
            CriticalAql        = data.AqlCritical ?? "0";
            MajorAql           = data.AqlMajor    ?? "2.5";
            MinorAql           = data.AqlMinor     ?? "4.0";
            CriticalSampleSize = data.AqlCriticalSampleSize;
            CriticalAccept     = data.AqlCriticalAccept;
            CriticalReject     = data.AqlCriticalReject;
            MajorSampleSize    = data.AqlMajorSampleSize;
            MajorAccept        = data.AqlMajorAccept;
            MajorReject        = data.AqlMajorReject;
            MinorSampleSize    = data.AqlMinorSampleSize;
            MinorAccept        = data.AqlMinorAccept;
            MinorReject        = data.AqlMinorReject;
            // Nếu AqlQuantity chưa được set, sync từ TotalShipmentQty
            if (AqlQuantity <= 0 && Model.TotalShipmentQty > 0)
                AqlQuantity = Model.TotalShipmentQty;
            if (AqlQuantity > 0)
                _currentCodeLetter = GetCodeLetter(AqlQuantity, AqlInspectionLevel);

            // Packaging
            if (data.Packaging != null)
            {
                Packaging.ItemNumber         = data.Packaging.ItemNumber         ?? "";
                Packaging.CartonNumber       = data.Packaging.CartonNumber       ?? "";
                Packaging.PackagingType      = data.Packaging.PackagingType      ?? "";
                Packaging.CartonColor        = data.Packaging.CartonColor        ?? "";
                Packaging.CardboardType      = data.Packaging.CardboardType      ?? "";
                Packaging.ShippingMark       = data.Packaging.ShippingMark       ?? "";
                Packaging.HasBarcode         = data.Packaging.HasBarcode;
                Packaging.InnerPackingQty    = data.Packaging.InnerPackingQty;
                Packaging.InnerL             = data.Packaging.InnerL;
                Packaging.InnerW             = data.Packaging.InnerW;
                Packaging.InnerH             = data.Packaging.InnerH;
                Packaging.InnerWeight        = data.Packaging.InnerWeight;
                Packaging.InnerPackingRemark = data.Packaging.InnerPackingRemark ?? "";
                Packaging.OuterL             = data.Packaging.OuterL;
                Packaging.OuterW             = data.Packaging.OuterW;
                Packaging.OuterH             = data.Packaging.OuterH;
                Packaging.OuterWeight        = data.Packaging.OuterWeight;
                Packaging.AssemblyInstruction= data.Packaging.AssemblyInstruction;
                Packaging.Hardware           = data.Packaging.Hardware;
            }

            // Product Spec
            if (data.ProductSpec != null)
            {
                ProductSpec.SizeL               = data.ProductSpec.SizeL;
                ProductSpec.SizeW               = data.ProductSpec.SizeW;
                ProductSpec.SizeH               = data.ProductSpec.SizeH;
                ProductSpec.Weight              = data.ProductSpec.Weight;
                ProductSpec.CompareGoldenSample = data.ProductSpec.CompareGoldenSample;
            }

            // Colour Swatches
            if (data.ColourSwatches?.Count > 0)
                ColourSwatches = data.ColourSwatches.ToList();

            // Performance Tests
            if (data.PerformanceTests?.Count > 0)
                PerformanceTests = data.PerformanceTests.Select(t => new PerformanceTestRow
                {
                    Category        = t.Category        ?? "",
                    TestItem        = t.TestItem        ?? "",
                    TestRequirement = t.TestRequirement ?? "",
                    Remark          = t.Remark          ?? ""
                }).ToList();

            // References
            if (data.References?.Count > 0)
            {
                var baseUrlRef = Http.BaseAddress?.ToString().TrimEnd('/') ?? "";
                References = data.References.Select(r => new ReferenceRow
                {
                    ReferenceName = r.ReferenceName ?? "",
                    FileName      = r.FileName      ?? "",
                    FileUrl       = (!string.IsNullOrEmpty(r.FileUrl) && !r.FileUrl.StartsWith("http"))
                                    ? $"{baseUrlRef}{(r.FileUrl.StartsWith('/') ? r.FileUrl : "/" + r.FileUrl)}"
                                    : r.FileUrl ?? "",
                    Remark        = r.Remark        ?? "",
                    FromProduct   = true
                }).ToList();
            }

            // Overall Conclusions
            if (data.OverallConclusions?.Count > 0)
                OverallConclusions = data.OverallConclusions.Select(o => new OverallConclusionRow
                {
                    Letter     = o.Letter     ?? "",
                    Label      = o.Label      ?? "",
                    Compliance = o.Compliance ?? "",
                    Remark     = o.Remark     ?? ""
                }).ToList();

            // Photo
            if (!string.IsNullOrEmpty(data.Photo1Url))
            {
                Photo1ServerUrl = data.Photo1Url;
                // Nếu đã là URL tuyệt đối thì dùng thẳng, ngược lại mới ghép base URL
                if (data.Photo1Url.StartsWith("http://") || data.Photo1Url.StartsWith("https://"))
                {
                    PhotoPreview1 = data.Photo1Url;
                }
                else
                {
                    var baseUrl = Http.BaseAddress?.ToString().TrimEnd('/') ?? "";
                    var relUrl  = data.Photo1Url.StartsWith('/') ? data.Photo1Url : "/" + data.Photo1Url;
                    PhotoPreview1 = baseUrl + relUrl;
                }
            }

            // Office Use
            OfficeUse.InspectorId   = data.InspectorId   ?? "";
            OfficeUse.InspectorName = data.InspectorName ?? "";
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
    }

