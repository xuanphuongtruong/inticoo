    private void ApplyProductToForm(ProductDropdownDto p)
    {
        _currentProductId     = p.Id;
        Model.ProductCode     = p.ProductCode;
        Model.ProductName     = p.ProductName;
        Model.ProductType     = p.ProductType;
        Model.ProductCategory = p.Category;
        if (string.IsNullOrEmpty(Model.ItemNumber) && !string.IsNullOrEmpty(p.ItemNumber))
            Model.ItemNumber = p.ItemNumber;
        Packaging.ItemNumber = Model.ItemNumber;
        ProductSpec.SizeL    = p.SizeL   ?? 0;
        ProductSpec.SizeW    = p.SizeW   ?? 0;
        ProductSpec.SizeH    = p.SizeH   ?? 0;
        ProductSpec.Weight   = p.Weight  ?? 0;
        if (!string.IsNullOrEmpty(p.PhotoUrl))
        {
            var baseUrl = Http.BaseAddress?.ToString().TrimEnd('/') ?? "";
            PhotoPreview1   = p.PhotoUrl.StartsWith("http") ? p.PhotoUrl : $"{baseUrl}{p.PhotoUrl}";
            Photo1ServerUrl = PhotoPreview1;
