    // Helper: tránh ContentType null/empty làm MediaTypeHeaderValue throw
    private static string SafeContentType(string? ct) =>
        string.IsNullOrWhiteSpace(ct) ? "application/octet-stream" : ct;

    private async Task OnPhotoSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        _photoError      = null;
        Photo1ServerUrl  = null;

        // 1. Đọc bytes — giới hạn 5 MB
        byte[] bytes;
        try
        {
            using var s  = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var ms = new System.IO.MemoryStream();
            await s.CopyToAsync(ms);
            bytes = ms.ToArray();
        }
        catch (Exception ex)
        {
            _photoError = $"File quá lớn hoặc không đọc được: {ex.Message}";
            StateHasChanged();
            return;
        }

        // 2. Preview ngay bằng data URL — không cần chờ upload
        var mime      = SafeContentType(file.ContentType);
        PhotoPreview1 = $"data:{mime};base64,{Convert.ToBase64String(bytes)}";
        _photoUploading = true;
        Waiting.Show("Uploading photo...");
        StateHasChanged();

        // 3. Upload lên server
        try
        {
            using var content = new MultipartFormDataContent();
            var sc = new ByteArrayContent(bytes);
            sc.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(mime);
            content.Add(sc, "file", file.Name);

            var token = await SessionStorage.GetItemAsync<string>("auth_token");
            if (!string.IsNullOrEmpty(token))
                Http.DefaultRequestHeaders.Authorization =
                    new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            var resp = await Http.PostAsync("api/files/upload-photo", content);
            if (resp.IsSuccessStatusCode)
            {
                var rawBody = await resp.Content.ReadAsStringAsync();
                using var doc = System.Text.Json.JsonDocument.Parse(rawBody);
                foreach (var prop in doc.RootElement.EnumerateObject())
                {
                    if (prop.Name.Equals("url", StringComparison.OrdinalIgnoreCase) ||
                        prop.Name.Equals("fileUrl", StringComparison.OrdinalIgnoreCase))
                    {
                        Photo1ServerUrl = prop.Value.GetString() ?? "";
                        break;
                    }
                }
                if (string.IsNullOrEmpty(Photo1ServerUrl))
                    _photoError = "Upload OK nhưng server không trả URL.";
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                _photoError = $"Upload thất bại ({(int)resp.StatusCode}): {body}";
            }
        }
        catch (Exception ex)
        {
            _photoError = $"Lỗi kết nối: {ex.Message}";
        }
        finally
        {
            _photoUploading = false;
            Waiting.Hide();
            StateHasChanged();
        }
    }

