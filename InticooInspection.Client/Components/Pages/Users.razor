@page "/users"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@using System.Net.Http.Json
@using System.Net.Http.Headers
@inject HttpClient Http
@inject NavigationManager Navigation
@inject Blazored.SessionStorage.ISessionStorageService SessionStorage
@using InticooInspection.Client.Services
@inject WaitingService Waiting

<PageTitle>Inspector Profile - Inticoo</PageTitle>

<div class="top-bar">
    <div class="title-block">
        <h1 class="page-title">Inspector Profile</h1>
        <span class="page-sub">Manage inspector accounts and permissions</span>
    </div>
    <div class="tb-divider"></div>
    <div class="search-wrap">
        <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="9" cy="9" r="5.5"/><path d="M15 15l-2.5-2.5" stroke-linecap="round"/>
        </svg>
        <input class="search-input" type="text" placeholder="Search by name, ID, email, mobile..."
               @bind="_search" @bind:event="oninput" @onkeyup="OnSearchKey" />
    </div>
    <span class="total-count">@_total accounts</span>
    <button class="btn-new" @onclick="async () => await OpenCreate()">
        <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M10 4v12M4 10h12"/></svg>
        New Account
    </button>
</div>

@if (_loading)
{
    <div class="loading-wrap"><div class="spinner"></div><span>Loading...</span></div>
}
else if (_users.Count == 0)
{
    <div class="empty-state"><p>No accounts found.</p></div>
}
else
{
    <div class="table-wrap">
        <table class="ptable">
            <thead>
                <tr class="thead-top">
                    <th rowspan="2" class="th-c th-no">No</th>
                    <th rowspan="2" class="tc">Inspector Name</th>
                    <th rowspan="2" class="tc">Inspector ID</th>
                    <th rowspan="2" class="tc">Category</th>
                    <th colspan="3" class="th-c th-group-header">Home Address</th>
                    <th rowspan="2" class="tc">Mobile</th>
                    <th rowspan="2" class="tc">Email</th>
                    <th rowspan="2" class="tc">Date Joined</th>
                    <th rowspan="2" class="tc">Status</th>
                    <th rowspan="2" class="tc">Personal Profile</th>
                    <th rowspan="2" class="tc">Actions</th>
                </tr>
                <tr class="thead-sub">
                    <th class="tc">Address</th>
                    <th class="tc">City</th>
                    <th class="th-c th-country">Country</th>
                </tr>
            </thead>
            <tbody>
                @{ int rowNo = (_page - 1) * _pageSize; }
                @foreach (var user in _users)
                {
                    var u = user;
                    rowNo++;
                    <tr class="table-row @(rowNo % 2 == 0 ? "tr-alt" : "")">
                        <td class="td-c td-no">@rowNo</td>
                        <td>
                            <div class="user-cell">
                                <div class="user-avatar">@GetInitials(u.FullName ?? u.Username)</div>
                                <span class="user-fullname">@(string.IsNullOrEmpty(u.FullName) ? u.Username : u.FullName)</span>
                            </div>
                        </td>
                        <td class="td-c mono-sm">@(string.IsNullOrEmpty(u.InspectorId) ? "—" : u.InspectorId)</td>
                        <td class="tc">
                            @if (!string.IsNullOrEmpty(u.Category))
                            {
                                <span class="cat-badge">@u.Category</span>
                            }
                            else { <span class="dim">—</span> }
                        </td>
                        <td class="dim sm">@(string.IsNullOrEmpty(u.Address)  ? "—" : u.Address)</td>
                        <td class="dim sm">@(string.IsNullOrEmpty(u.City)     ? "—" : u.City)</td>
                        <td class="dim sm td-country">@(string.IsNullOrEmpty(u.Country) ? "—" : u.Country)</td>
                        <td class="dim sm">@(string.IsNullOrEmpty(u.Mobile)   ? "—" : u.Mobile)</td>
                        <td class="dim sm">@(string.IsNullOrEmpty(u.Email)    ? "—" : u.Email)</td>
                        <td class="td-c dim sm">@u.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td class="tc">
                            <button class="status-toggle @(u.IsActive ? "s-active" : "s-inactive")"
                                    @onclick="() => ToggleActive(u)">
                                @(u.IsActive ? "Active" : "Inactive")
                            </button>
                        </td>
                        <td class="tc">
                            @if (!string.IsNullOrEmpty(u.CvUrl))
                            {
                                var fullCvUrl = u.CvUrl.StartsWith("http") ? u.CvUrl
                                              : (Http.BaseAddress?.ToString().TrimEnd('/') + "/" + u.CvUrl.TrimStart('/'));
                                <a class="cv-link" href="@fullCvUrl" target="_blank">&#128196; CV</a>
                            }
                            else { <span class="dim sm">—</span> }
                        </td>
                        <td class="tc">
                            <div class="action-btns">
                                <button class="bico bedit"   @onclick="async () => await OpenEdit(u)"      title="Edit">
                                        <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14 2l4 4-10 10H4v-4L14 2z" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
                                <button class="bico bdel" @onclick="() => ConfirmDelete(u)" title="Delete"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 6h14M8 6V4h4v2M5 6l1 11h8l1-11" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (_total > _pageSize)
    {
        <div class="pagination">
            <button class="page-btn" disabled="@(_page == 1)" @onclick="PrevPage">&#8592; Prev</button>
            <span class="page-info">Page @_page of @TotalPages()</span>
            <button class="page-btn" disabled="@(_page >= TotalPages())" @onclick="NextPage">Next &#8594;</button>
        </div>
    }
}

@* ── Create / Edit Modal ── *@
@if (_showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-card" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2>@(_editId == null ? "New Inspector" : "Edit Inspector")</h2>
                <button class="modal-close" @onclick="CloseModal">&#x2715;</button>
            </div>

            @if (!string.IsNullOrEmpty(_formError))
            {
                <div class="error-alert">@_formError</div>
            }

            @* ── Inspector ID + Status ── *@
            <div class="frow">
                <div class="fcell">
                    <label class="flabel">Inspector ID</label>
                    @if (_editId == null)
                    {
                        <div class="form-input form-input-auto" style="background:#e6f1fb;color:#1e90d6;font-weight:700;font-family:monospace;border-color:#b5d4f4;">@_formInspectorId</div>
                    }
                    else
                    {
                        <input class="form-input" type="text" @bind="_formInspectorId" @bind:event="oninput" />
                    }
                </div>
                <div class="fcell">
                    <label class="flabel">Status</label>
                    <label class="check-label" style="margin-top:6px;">
                        <input type="checkbox" @bind="_formIsActive" />
                        <span>@(_formIsActive ? "Active" : "Inactive")</span>
                    </label>
                </div>
            </div>

            @* ── Section: Inspector Details ── *@
            <div class="fsection-title">Inspector Details</div>
            <div class="frow">
                <div class="fcell">
                    <label class="flabel">Full Name <span class="req">*</span></label>
                    <input class="form-input" type="text" placeholder="Enter full name"
                           @bind="_formFullName" @bind:event="oninput" />
                </div>
                <div class="fcell">
                    <label class="flabel">Short Name</label>
                    <input class="form-input" type="text" placeholder="Enter short name"
                           @bind="_formShortName" @bind:event="oninput" />
                </div>
            </div>
            <div class="frow">
                <div class="fcell">
                    <label class="flabel">Date of Birth</label>
                    <input class="form-input" type="date"
                           value="@(_formDateOfBirth?.ToString("yyyy-MM-dd"))"
                           @onchange="e => _formDateOfBirth = DateTime.TryParse(e.Value?.ToString(), out var d) ? d : null" />
                </div>
                <div class="fcell">
                    <label class="flabel">Gender</label>
                    <div class="btype-group">
                        @foreach (var g in new[] { "Male", "Female", "Other" })
                        {
                            var gv = g;
                            <label class="btype-label @(_formGender == gv ? "btype-active" : "")"
                                   @onclick="() => _formGender = gv">@gv</label>
                        }
                    </div>
                </div>
            </div>
            <div class="frow">
                <div class="fcell">
                    <label class="flabel">Nationality</label>
                    @if (_loadingCountries)
                    {
                        <div class="form-input" style="color:#9baac8;font-style:italic;">Loading...</div>
                    }
                    else
                    {
                        <select class="form-input" @bind="_formNationality">
                            <option value="">-- Select Nationality --</option>
                            @foreach (var c in _countries)
                            {
                                <option value="@c.Name">@c.Name</option>
                            }
                        </select>
                    }
                </div>
                <div class="fcell">
                    <label class="flabel">Type of Identification</label>
                    <div class="frow-inline" style="gap:8px;">
                        <div class="btype-group" style="flex:0 0 auto;">
                            @foreach (var t in new[] { "ID", "Passport" })
                            {
                                var tv = t;
                                <label class="btype-label @(_formIdType == tv ? "btype-active" : "")"
                                       @onclick="() => _formIdType = tv">@tv</label>
                            }
                        </div>
                        <input class="form-input" type="text" placeholder="Number"
                               style="flex:1;"
                               @bind="_formIdNumber" @bind:event="oninput" />
                    </div>
                </div>
            </div>
            <div class="frow">
                <div class="fcell">
                    <label class="flabel">Mobile</label>
                    <input class="form-input" type="tel" placeholder="Enter mobile number"
                           @bind="_formMobile" @bind:event="oninput" />
                </div>
                <div class="fcell">
                    <label class="flabel">Email</label>
                    <input class="form-input" type="email" placeholder="Enter email"
                           @bind="_formEmail" @bind:event="oninput" />
                </div>
            </div>
            <div class="frow">
                <div class="fcell">
                    <label class="flabel">Category</label>
                    <select class="form-input" @bind="_formCategory">
                        <option value="">-- Select Category --</option>
                        <option value="Mechanical">Mechanical</option>
                        <option value="Electrical">Electrical</option>
                        <option value="Chemical">Chemical</option>
                        <option value="Textile">Textile</option>
                        <option value="Furniture">Furniture</option>
                        <option value="Electronics">Electronics</option>
                        <option value="Packaging">Packaging</option>
                        <option value="Food &amp; Beverage">Food &amp; Beverage</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <div class="fcell">
                    <label class="flabel">Inspection Start Year</label>
                    <input class="form-input" type="number" placeholder="e.g. 2015" min="1990" max="2099"
                           value="@_formInspectionStartYear"
                           @onchange="e => _formInspectionStartYear = int.TryParse(e.Value?.ToString(), out var y) ? y : null" />
                </div>
            </div>
            <div class="frow">
                <div class="fcell fcell-full">
                    <label class="flabel">Language</label>
                    <div class="btype-group" style="flex-wrap:wrap;">
                        @foreach (var lang in new[] { "English","Chinese","Vietnamese","Indonesian","Thai","Filipino","Malay","Hindi","Arabic","Bengali","Russian","Japanese","Korean" })
                        {
                            var lv = lang;
                            <label class="btype-label @(_formLanguages.Contains(lv) ? "btype-active" : "")"
                                   @onclick="() => ToggleLanguage(lv)">@lv</label>
                        }
                    </div>
                </div>
            </div>

            @* ── Section: Inspector Address ── *@
            <div class="fsection-title">Inspector Address</div>
            <div class="frow">
                <div class="fcell fcell-full">
                    <label class="flabel">Address 1</label>
                    <input class="form-input" type="text" placeholder="Street address line 1"
                           @bind="_formAddress1" @bind:event="oninput" />
                </div>
            </div>
            <div class="frow">
                <div class="fcell fcell-full">
                    <label class="flabel">Address 2</label>
                    <input class="form-input" type="text" placeholder="Street address line 2 (optional)"
                           @bind="_formAddress2" @bind:event="oninput" />
                </div>
            </div>
            <div class="frow">
                <div class="fcell">
                    <label class="flabel">City</label>
                    @if (_loadingCities)
                    {
                        <div class="form-input" style="color:#9baac8;font-style:italic;">Loading cities...</div>
                    }
                    else
                    {
                        <select class="form-input" @bind="_formCity" disabled="@(string.IsNullOrEmpty(_formCountry))">
                            <option value="">-- Select City --</option>
                            @foreach (var ct in _cities)
                            {
                                <option value="@ct.Name">@ct.Name</option>
                            }
                        </select>
                    }
                </div>
                <div class="fcell">
                    <label class="flabel">State / Province</label>
                    <input class="form-input" type="text" placeholder="State or province"
                           @bind="_formState" @bind:event="oninput" />
                </div>
            </div>
            <div class="frow">
                <div class="fcell">
                    <label class="flabel">Country</label>
                    @if (_loadingCountries)
                    {
                        <div class="form-input" style="color:#9baac8;font-style:italic;">Loading...</div>
                    }
                    else
                    {
                        <select class="form-input" value="@_formCountry" @onchange="OnCountryChanged">
                            <option value="">-- Select Country --</option>
                            @foreach (var c in _countries)
                            {
                                <option value="@c.Name">@c.Name</option>
                            }
                        </select>
                    }
                </div>
                <div class="fcell">
                    <label class="flabel">Postal / ZIP</label>
                    <input class="form-input" type="text" placeholder="Postal code"
                           @bind="_formPostalCode" @bind:event="oninput" />
                </div>
            </div>

            @* ── Section: Login ── *@
            <div class="fsection-title">Login</div>
            <div class="frow">
                <div class="fcell">
                    <label class="flabel">User Name <span class="req">*</span></label>
                    <input class="form-input" type="text" placeholder="Enter username"
                           @bind="_formUsername" @bind:event="oninput" />
                </div>
                <div class="fcell">
                    <label class="flabel">@(_editId == null ? "Password *" : "New Password")<span class="label-hint"> @(_editId != null ? "(leave blank to keep)" : "")</span></label>
                    <input class="form-input" type="password"
                           placeholder="@(_editId == null ? "Enter password" : "Leave blank to keep current")"
                           @bind="_formPassword" @bind:event="oninput" />
                </div>
            </div>

            @* ── Section: Profile Photo ── *@
            <div class="fsection-title">
                Profile Photo
                @if (_editId == null) { <span class="req">*</span> }
                else { <span class="label-hint">(leave blank to keep existing)</span> }
            </div>
            <div class="frow">
                <div class="fcell fcell-full">
                    <div class="photo-upload-area">
                        @if (_photoFile != null)
                        {
                            <div class="photo-preview-wrap">
                                <div class="photo-preview-icon">&#128247;</div>
                                <div class="photo-preview-info">
                                    <span class="photo-file-name">@_photoFile.Name</span>
                                    <span class="photo-file-size">@FormatFileSize(_photoFile.Size)</span>
                                </div>
                                <button class="cv-remove-btn" @onclick="() => _photoFile = null" type="button">&#x2715;</button>
                            </div>
                        }
                        else if (_editId != null && !string.IsNullOrEmpty(_existingPhotoUrl))
                        {
                            var fullPhotoUrl = _existingPhotoUrl.StartsWith("http") ? _existingPhotoUrl
                                            : (Http.BaseAddress?.ToString().TrimEnd('/') + "/" + _existingPhotoUrl.TrimStart('/'));
                            <div class="photo-existing-wrap">
                                <img class="photo-existing-thumb" src="@fullPhotoUrl" alt="Profile Photo" />
                                <div class="photo-preview-info">
                                    <span class="photo-file-name">Current photo on file</span>
                                    <label class="cv-replace-btn" for="photoFileInput">Replace</label>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="photo-placeholder">
                                <span class="photo-upload-icon">&#128247;</span>
                                <span class="photo-upload-text">Drag &amp; drop or <label class="cv-browse-link" for="photoFileInput">browse</label></span>
                                <span class="photo-upload-hint">JPG, PNG, WEBP — max 5 MB</span>
                            </div>
                        }
                        <InputFile id="photoFileInput" OnChange="OnPhotoFileSelected" accept=".jpg,.jpeg,.png,.webp"
                                   style="position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;" />
                    </div>
                    @if (!string.IsNullOrEmpty(_photoError))
                    {
                        <div class="cv-error">@_photoError</div>
                    }
                </div>
            </div>

            @* ── Section: Role ── *@
            <div class="fsection-title">Role <span class="req">*</span></div>
            <div class="form-group">
                @if (_availableRoles.Count == 0)
                {
                    <p style="color:rgba(255,255,255,0.4);font-size:13px;">Loading roles...</p>
                }
                else
                {
                    <div class="roles-picker">
                        @foreach (var role in _availableRoles)
                        {
                            var r = role;
                            <label class="role-check @(_formRoles.Contains(r) ? "checked" : "")"
                                   @onclick="() => SelectRole(r)" style="cursor:pointer;">
                                <span class="role-badge role-@r.ToLower()">@r</span>
                            </label>
                        }
                    </div>
                }
            </div>

            @if (_formRoles.Contains("Customer"))
            {
                <div class="form-group">
                    @if (_loadingCustomers)
                    {
                        <div class="form-input" style="color:#9baac8;font-style:italic;">Loading customers...</div>
                    }
                    else
                    {
                        <select class="form-input" @bind="_formCustomerId">
                            <option value="">-- Select Customer --</option>
                            @foreach (var c in _customers)
                            {
                                <option value="@c.CustomerId">@c.CustomerId — @c.CompanyName</option>
                            }
                        </select>
                    }
                </div>
            }

            @* ── Section: Personal Profile / CV ── *@
            @if (!_formRoles.Contains("Customer"))
            {
                <div class="fsection-title">
                    Personal Profile (CV)
                    @if (_editId == null) { <span class="req">*</span> }
                    else { <span class="label-hint">(leave blank to keep existing)</span> }
                </div>
                <div class="form-group">
                    <div class="cv-upload-box @(_cvDragOver ? "drag-over" : "")"
                         @ondragover:preventDefault="true"
                         @ondragover="() => _cvDragOver = true"
                         @ondragleave="() => _cvDragOver = false"
                         @ondrop:preventDefault="true"
                         @ondrop="OnCvDrop">

                        @if (_cvFile != null)
                        {
                            <div class="cv-selected">
                                <span class="cv-file-icon">&#128196;</span>
                                <div class="cv-file-info">
                                    <span class="cv-file-name">@_cvFile.Name</span>
                                    <span class="cv-file-size">@FormatFileSize(_cvFile.Size)</span>
                                </div>
                                <button class="cv-remove-btn" @onclick="RemoveCv" type="button">&#x2715;</button>
                            </div>
                        }
                        else if (_editId != null && !string.IsNullOrEmpty(_existingCvUrl))
                        {
                            var fullExistingUrl = _existingCvUrl.StartsWith("http") ? _existingCvUrl
                                                : (Http.BaseAddress?.ToString().TrimEnd('/') + "/" + _existingCvUrl.TrimStart('/'));
                            <div class="cv-existing">
                                <span class="cv-file-icon">&#128196;</span>
                                <div class="cv-file-info">
                                    <span class="cv-file-name">Current CV on file</span>
                                    <a class="cv-view-link" href="@fullExistingUrl" target="_blank">View &#8599;</a>
                                </div>
                                <label class="cv-replace-btn" for="cvFileInput">Replace</label>
                            </div>
                        }
                        else
                        {
                            <div class="cv-placeholder">
                                <span class="cv-upload-icon">&#8613;</span>
                                <span class="cv-upload-text">Drag &amp; drop or <label class="cv-browse-link" for="cvFileInput">browse</label></span>
                                <span class="cv-upload-hint">PDF, DOC, DOCX — max 10 MB</span>
                            </div>
                        }

                        <InputFile id="cvFileInput" OnChange="OnCvFileSelected" accept=".pdf,.doc,.docx"
                                   style="position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;" />
                    </div>
                    @if (!string.IsNullOrEmpty(_cvError))
                    {
                        <div class="cv-error">@_cvError</div>
                    }
                </div>
            }

            <div class="modal-footer">
                <button class="btn-cancel" @onclick="CloseModal">Cancel</button>
                <button class="btn-submit" @onclick="SaveUser" disabled="@_saving">
                    @if (_saving) { <span class="spinner"></span> }
                    else { <span>@(_editId == null ? "Create Account" : "Save Changes")</span> }
                </button>
            </div>
        </div>
    </div>
}

@* ── Delete Confirm ── *@
@if (_deleteUser != null)
{
    <div class="modal-overlay" @onclick="() => _deleteUser = null">
        <div class="modal-card confirm-card" @onclick:stopPropagation="true">
            <div class="confirm-icon">&#9888;</div>
            <h2>Delete Account</h2>
            <p>Are you sure you want to delete <strong>@_deleteUser.Username</strong>?<br/>This action cannot be undone.</p>
            <div class="modal-footer">
                <button class="btn-cancel" @onclick="() => _deleteUser = null">Cancel</button>
                <button class="btn-delete" @onclick="DeleteUser" disabled="@_saving">
                    @if (_saving) { <span class="spinner"></span> } else { <span>Delete</span> }
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<UserDto> _users = new();
    private bool   _loading = true;
    private string _search  = "";
    private int    _page = 1, _pageSize = 20, _total = 0;

    // Modal state
    private bool    _showModal    = false;
    private string? _editId       = null;
    private string  _formUsername = "", _formFullName = "", _formShortName = "", _formEmail = "", _formPassword = "";
    private string  _formInspectorId = "", _formCategory = "", _formMobile = "";
    private DateTime? _formDateOfBirth = null;
    private string  _formGender = "", _formNationality = "", _formIdType = "", _formIdNumber = "";
    private int?    _formInspectionStartYear = null;
    private List<string> _formLanguages = new();
    private string  _formAddress  = "", _formAddress1 = "", _formAddress2 = "";
    private string  _formCity = "", _formState = "", _formCountry = "", _formPostalCode = "";
    private string  _formCustomerId = "";  // khi role = Customer
    // Country/City dropdowns
    private List<CountryItem>    _countries        = new();
    private List<CityItem>       _cities           = new();
    private bool                 _loadingCountries = true;
    private bool                 _loadingCities    = false;
    // Customer dropdown
    private List<CustomerDropdownItem> _customers      = new();
    private bool                       _loadingCustomers = false;

    private bool    _formIsActive = true;
    private List<string> _formRoles      = new();
    private List<string> _availableRoles = new();
    private string  _formError = "";
    private bool    _saving    = false;

    // CV state
    private IBrowserFile? _cvFile        = null;
    private string        _cvError       = "";
    private bool          _cvDragOver    = false;
    private string?       _existingCvUrl = null;

    // Photo state
    private IBrowserFile? _photoFile        = null;
    private string        _photoError       = "";
    private string?       _existingPhotoUrl = null;
    private static readonly long MaxPhotoBytes = 5 * 1024 * 1024;

    private UserDto? _deleteUser = null;
    private static readonly long MaxCvBytes = 10 * 1024 * 1024;

    protected override async Task OnInitializedAsync()
    {
        await SetAuthHeader();
        await Task.WhenAll(LoadRoles(), LoadPage(1), LoadCountries(), LoadCustomers());
    }

    private async Task SetAuthHeader()
    {
        try
        {
            var token = await SessionStorage.GetItemAsync<string>("auth_token");
            if (!string.IsNullOrEmpty(token))
                Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
        }
        catch { }
    }

    private async Task LoadRoles()
    {
        try { _availableRoles = await Http.GetFromJsonAsync<List<string>>("api/users/all-roles") ?? new(); }
        catch { _availableRoles = new List<string> { "Admin", "Inspector", "User" }; }
    }

    private async Task LoadPage(int page)
    {
        _loading = true; _page = page;
        try
        {
            var url = $"api/users?page={page}&pageSize={_pageSize}&search={Uri.EscapeDataString(_search)}";
            var result = await Http.GetFromJsonAsync<UserPageResult>(url);
            if (result != null) { _users = result.Items; _total = result.Total; }
        }
        catch { }
        finally { _loading = false; }
    }

    private async Task OnSearchKey(KeyboardEventArgs e) { if (e.Key == "Enter") await LoadPage(1); }
    private async Task PrevPage() => await LoadPage(_page - 1);
    private async Task NextPage() => await LoadPage(_page + 1);
    private int TotalPages() => (_total + _pageSize - 1) / _pageSize;

    private void ResetForm()
    {
        _formUsername = ""; _formFullName = ""; _formShortName = ""; _formEmail = ""; _formPassword = "";
        _formInspectorId = ""; _formCategory = ""; _formMobile = "";
        _formDateOfBirth = null; _formGender = ""; _formNationality = "";
        _formIdType = ""; _formIdNumber = ""; _formInspectionStartYear = null;
        _formLanguages = new();
        _formAddress = ""; _formAddress1 = ""; _formAddress2 = "";
        _formCity = ""; _formState = ""; _formCountry = ""; _formPostalCode = "";
        _formCustomerId = "";
        _cities = new();
        _formIsActive = true; _formRoles = new(); _formError = "";
        _cvFile = null; _cvError = ""; _existingCvUrl = null;
        _photoFile = null; _photoError = ""; _existingPhotoUrl = null;
    }

    private async Task OpenCreate()
    {
        _editId = null;
        ResetForm();
        // Tự sinh Inspector ID
        try
        {
            var opts = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var json = await Http.GetStringAsync("api/users/nextid");
            var res  = System.Text.Json.JsonSerializer.Deserialize<NextIdResult>(json, opts);
            _formInspectorId = res?.InspectorId ?? "";
        }
        catch { _formInspectorId = ""; }
        _showModal = true;
    }

    private class NextIdResult { public string InspectorId { get; set; } = ""; }

    private async Task OpenEdit(UserDto u)
    {
        _editId                  = u.Id;
        _formUsername            = u.Username;
        _formFullName            = u.FullName           ?? "";
        _formShortName           = u.ShortName          ?? "";
        _formEmail               = u.Email              ?? "";
        _formPassword            = "";
        _formInspectorId         = u.InspectorId        ?? "";
        _formCategory            = u.Category           ?? "";
        _formMobile              = u.Mobile             ?? "";
        _formDateOfBirth         = u.DateOfBirth;
        _formGender              = u.Gender             ?? "";
        _formNationality         = u.Nationality        ?? "";
        _formIdType              = u.IdType             ?? "";
        _formIdNumber            = u.IdNumber           ?? "";
        _formInspectionStartYear = u.InspectionStartYear;
        _formLanguages           = string.IsNullOrEmpty(u.Language)
                                   ? new() : u.Language.Split(',').Select(x => x.Trim()).ToList();
        _formAddress             = u.Address            ?? "";
        _formAddress1            = u.Address1           ?? "";
        _formAddress2            = u.Address2           ?? "";
        _formCity                = "";
        _formState               = u.State              ?? "";
        _formCountry             = u.Country            ?? "";
        _formPostalCode          = u.PostalCode         ?? "";
        _formCustomerId          = u.CustomerId         ?? "";
        _formIsActive            = u.IsActive;
        _formRoles               = u.Roles.ToList();
        _formError               = "";
        _cvFile                  = null;
        _cvError                 = "";
        _existingCvUrl           = u.CvUrl;
        _photoFile               = null;
        _photoError              = "";
        _existingPhotoUrl        = u.PhotoUrl;
        _showModal               = true;
        await LoadCitiesForCountry(u.Country ?? "", u.City ?? "");
    }

    private void CloseModal() => _showModal = false;

    // Single-select role (chỉ chọn 1 trong Admin/Inspector/Customer)
    private void SelectRole(string role)
    {
        _formRoles = new List<string> { role };
        if (role != "Customer") _formCustomerId = "";
        StateHasChanged();
    }

    private void ToggleLanguage(string lang)
    {
        if (_formLanguages.Contains(lang)) _formLanguages.Remove(lang);
        else _formLanguages.Add(lang);
    }

    private async Task LoadCustomers()
    {
        _loadingCustomers = true;
        try
        {
            _customers = await Http.GetFromJsonAsync<List<CustomerDropdownItem>>("api/customers/dropdown") ?? new();
        }
        catch { _customers = new(); }
        finally { _loadingCustomers = false; }
    }

    // ── CV ────────────────────────────────────────────────────────────────────

    private void OnCvFileSelected(InputFileChangeEventArgs e)
    {
        _cvError = "";
        var file = e.File;
        if (!ValidateCvFile(file)) return;
        _cvFile = file;
    }

    private void OnCvDrop(DragEventArgs e) => _cvDragOver = false;

    private void RemoveCv() { _cvFile = null; _cvError = ""; }

    private void OnPhotoFileSelected(InputFileChangeEventArgs e)
    {
        _photoError = "";
        var file = e.File;
        if (!ValidatePhotoFile(file)) return;
        _photoFile = file;
    }

    private bool ValidatePhotoFile(IBrowserFile file)
    {
        var allowed = new[] { ".jpg", ".jpeg", ".png", ".webp" };
        var ext = System.IO.Path.GetExtension(file.Name).ToLowerInvariant();
        if (!allowed.Contains(ext)) { _photoError = "Only JPG, PNG or WEBP files are allowed."; return false; }
        if (file.Size > MaxPhotoBytes) { _photoError = "Photo size must not exceed 5 MB."; return false; }
        return true;
    }

    private async Task<string?> UploadPhotoAsync()
    {
        if (_photoFile == null) return null;
        try
        {
            using var content = new MultipartFormDataContent();
            var stream      = _photoFile.OpenReadStream(MaxPhotoBytes);
            var fileContent = new StreamContent(stream);
            fileContent.Headers.ContentType = new MediaTypeHeaderValue(_photoFile.ContentType);
            content.Add(fileContent, "file", _photoFile.Name);
            var response = await Http.PostAsync("api/files/upload-photo", content);
            if (!response.IsSuccessStatusCode) { _formError = "Photo upload failed. Please try again."; return null; }
            var result = await response.Content.ReadFromJsonAsync<UploadResult>();
            return result?.Url;
        }
        catch { _formError = "Photo upload error. Please try again."; return null; }
    }

    private bool ValidateCvFile(IBrowserFile file)
    {
        var allowed = new[] { ".pdf", ".doc", ".docx" };
        var ext = System.IO.Path.GetExtension(file.Name).ToLowerInvariant();
        if (!allowed.Contains(ext)) { _cvError = "Only PDF, DOC or DOCX files are allowed."; return false; }
        if (file.Size > MaxCvBytes) { _cvError = "File size must not exceed 10 MB."; return false; }
        return true;
    }

    private string FormatFileSize(long bytes)
    {
        if (bytes < 1024)         return $"{bytes} B";
        if (bytes < 1024 * 1024)  return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024):F1} MB";
    }

    private async Task<string?> UploadCvAsync()
    {
        if (_cvFile == null) return null;
        try
        {
            using var content = new MultipartFormDataContent();
            var stream      = _cvFile.OpenReadStream(MaxCvBytes);
            var fileContent = new StreamContent(stream);
            fileContent.Headers.ContentType = new MediaTypeHeaderValue(_cvFile.ContentType);
            content.Add(fileContent, "file", _cvFile.Name);
            var response = await Http.PostAsync("api/files/upload-cv", content);
            if (!response.IsSuccessStatusCode) { _formError = "CV upload failed. Please try again."; return null; }
            var result = await response.Content.ReadFromJsonAsync<UploadResult>();
            return result?.Url;
        }
        catch { _formError = "CV upload error. Please try again."; return null; }
    }

    // ── Save ──────────────────────────────────────────────────────────────────

    private async Task SaveUser()
    {
        _formError = ""; _cvError = "";
        if (string.IsNullOrWhiteSpace(_formUsername))                       { _formError = "Username is required."; return; }
        if (_editId == null && string.IsNullOrWhiteSpace(_formPassword))    { _formError = "Password is required."; return; }
        if (_formRoles.Count == 0)                                          { _formError = "Please select a role."; return; }
        if (_formRoles.Contains("Customer") && string.IsNullOrEmpty(_formCustomerId)) { _formError = "Please select a Customer to link this account."; return; }
        if (_editId == null && _cvFile == null && !_formRoles.Contains("Customer"))    { _cvError   = "CV / Resume is required when creating a new account."; return; }

        _saving = true;
        Waiting.Show(_editId == null ? "Creating user..." : "Saving user...");
        try
        {
            string? cvUrl = _existingCvUrl;
            if (_cvFile != null)
            {
                Waiting.Show("Uploading CV...");
                cvUrl = await UploadCvAsync();
                if (cvUrl == null) { _saving = false; Waiting.Hide(); return; }
                Waiting.Show(_editId == null ? "Creating user..." : "Saving user...");
            }

            string? photoUrl = _existingPhotoUrl;
            if (_photoFile != null)
            {
                Waiting.Show("Uploading photo...");
                photoUrl = await UploadPhotoAsync();
                if (photoUrl == null) { _saving = false; Waiting.Hide(); return; }
                Waiting.Show(_editId == null ? "Creating user..." : "Saving user...");
            }

            HttpResponseMessage response;
            if (_editId == null)
            {
                var payload = new {
                    username            = _formUsername,
                    password            = _formPassword,
                    email               = _formEmail,
                    fullName            = _formFullName,
                    shortName           = _formShortName,
                    dateOfBirth         = _formDateOfBirth,
                    gender              = _formGender,
                    nationality         = _formNationality,
                    idType              = _formIdType,
                    idNumber            = _formIdNumber,
                    category            = _formCategory,
                    inspectionStartYear = _formInspectionStartYear,
                    language            = string.Join(",", _formLanguages),
                    isActive            = _formIsActive,
                    roles               = _formRoles,
                    cvUrl               = cvUrl,
                    photoUrl            = photoUrl,
                    inspectorId         = _formInspectorId,
                    mobile              = _formMobile,
                    address             = _formAddress,
                    address1            = _formAddress1,
                    address2            = _formAddress2,
                    city                = _formCity,
                    state               = _formState,
                    country             = _formCountry,
                    postalCode          = _formPostalCode,
                    customerId          = _formCustomerId
                };
                response = await Http.PostAsJsonAsync("api/users", payload);
            }
            else
            {
                var payload = new {
                    username            = _formUsername,
                    newPassword         = _formPassword,
                    email               = _formEmail,
                    fullName            = _formFullName,
                    shortName           = _formShortName,
                    dateOfBirth         = _formDateOfBirth,
                    gender              = _formGender,
                    nationality         = _formNationality,
                    idType              = _formIdType,
                    idNumber            = _formIdNumber,
                    category            = _formCategory,
                    inspectionStartYear = _formInspectionStartYear,
                    language            = string.Join(",", _formLanguages),
                    isActive            = _formIsActive,
                    roles               = _formRoles,
                    cvUrl               = cvUrl,
                    photoUrl            = photoUrl,
                    inspectorId         = _formInspectorId,
                    mobile              = _formMobile,
                    address             = _formAddress,
                    address1            = _formAddress1,
                    address2            = _formAddress2,
                    city                = _formCity,
                    state               = _formState,
                    country             = _formCountry,
                    postalCode          = _formPostalCode,
                    customerId          = _formCustomerId
                };
                response = await Http.PutAsJsonAsync($"api/users/{_editId}", payload);
            }

            if (response.IsSuccessStatusCode) { _showModal = false; await LoadPage(_page); }
            else
            {
                var err = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                _formError = err?.Message ?? "An error occurred.";
            }
        }
        catch { _formError = "Connection error."; }
        finally { _saving = false; Waiting.Hide(); }
    }

    private async Task ToggleActive(UserDto user)
    {
        var response = await Http.PutAsJsonAsync($"api/users/{user.Id}/toggle-active", new { });
        if (response.IsSuccessStatusCode) { user.IsActive = !user.IsActive; StateHasChanged(); }
    }

    private void ConfirmDelete(UserDto user) => _deleteUser = user;

    private async Task DeleteUser()
    {
        if (_deleteUser == null) return;
        _saving = true;
        Waiting.Show("Deleting user...");
        var response = await Http.DeleteAsync($"api/users/{_deleteUser.Id}");
        _saving = false;
        Waiting.Hide();
        if (response.IsSuccessStatusCode) { _deleteUser = null; await LoadPage(_page); }
    }

    private string GetInitials(string name)
        => string.Concat(name.Split(" ").Take(2).Select(w => w.Length > 0 ? w[0].ToString().ToUpper() : ""));

    // ── DTOs ──────────────────────────────────────────────────────────────────

    private class UserDto
    {
        public string   Id                  { get; set; } = "";
        public string   Username            { get; set; } = "";
        public string?  FullName            { get; set; }
        public string?  ShortName           { get; set; }
        public string?  Email               { get; set; }
        public DateTime? DateOfBirth        { get; set; }
        public string?  Gender              { get; set; }
        public string?  Nationality         { get; set; }
        public string?  IdType              { get; set; }
        public string?  IdNumber            { get; set; }
        public string?  Category            { get; set; }
        public int?     InspectionStartYear { get; set; }
        public string?  Language            { get; set; }
        public bool     IsActive            { get; set; }
        public List<string> Roles           { get; set; } = new();
        public DateTime CreatedAt           { get; set; }
        public string?  CvUrl               { get; set; }
        public string?  PhotoUrl            { get; set; }
        public string?  InspectorId         { get; set; }
        public string?  Address             { get; set; }
        public string?  Address1            { get; set; }
        public string?  Address2            { get; set; }
        public string?  City                { get; set; }
        public string?  State               { get; set; }
        public string?  Country             { get; set; }
        public string?  PostalCode          { get; set; }
        public string?  Mobile              { get; set; }
        public string?  CustomerId          { get; set; }
    }

    private class CustomerDropdownItem
    {
        public string CustomerId   { get; set; } = "";
        public string CompanyName  { get; set; } = "";
    }

    private class UserPageResult { public int Total { get; set; } public List<UserDto> Items { get; set; } = new(); }
    private class ErrorResponse  { public string? Message { get; set; } }
    private class UploadResult   { public string? Url     { get; set; } }
    private async Task LoadCountries()
    {
        try
        {
            var opts = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var json = await Http.GetStringAsync("api/geo/countries");
            _countries = System.Text.Json.JsonSerializer.Deserialize<List<CountryItem>>(json, opts) ?? new();
        }
        catch { }
        finally { _loadingCountries = false; }
    }

    private async Task OnCountryChanged(ChangeEventArgs e)
    {
        _formCountry = e.Value?.ToString() ?? "";
        _formCity    = "";
        _cities      = new();
        if (string.IsNullOrEmpty(_formCountry)) return;

        _loadingCities = true;
        try
        {
            var country = _countries.FirstOrDefault(c => c.Name == _formCountry);
            if (country == null) return;
            var opts = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var json = await Http.GetStringAsync($"api/geo/cities?countryId={country.Id}");
            _cities = System.Text.Json.JsonSerializer.Deserialize<List<CityItem>>(json, opts) ?? new();
        }
        catch { }
        finally { _loadingCities = false; }
    }

    private async Task LoadCitiesForCountry(string countryName, string cityName)
    {
        if (string.IsNullOrEmpty(countryName)) return;
        var country = _countries.FirstOrDefault(c => c.Name == countryName);
        if (country == null) return;
        _loadingCities = true;
        try
        {
            var opts = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var json = await Http.GetStringAsync($"api/geo/cities?countryId={country.Id}");
            _cities = System.Text.Json.JsonSerializer.Deserialize<List<CityItem>>(json, opts) ?? new();
            _formCity = cityName;
        }
        catch { }
        finally { _loadingCities = false; }
    }

    private class CountryItem
    {
        public int    Id     { get; set; }
        public string Name   { get; set; } = "";
        public string Code   { get; set; } = "";
        public string Region { get; set; } = "";
    }

    private class CityItem
    {
        public int    Id        { get; set; }
        public string Name      { get; set; } = "";
        public bool   IsCapital { get; set; }
    }

}

