    @@keyframes spin { to { transform: rotate(360deg); } }

    .rpt-error {
        display: flex; flex-direction: column;
        align-items: center; gap: 12px;
        padding: 48px 24px;
        font-size: 14px; color: #555;
    }

    /* ══════════════════════════════════════════
       PRINT STYLES
    ══════════════════════════════════════════ */
    @@media print {
        @@page {
            size: A4 portrait;
            margin: 0;
        }

        html, body {
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
            margin: 0 !important;
            padding: 0 !important;
        }

        .no-print { display: none !important; }

        /* Xóa background xanh khi in — tránh trang trắng bị xanh */
        .rpt-page { background: white !important; padding-bottom: 0 !important; }

        nav, header, .navbar, .sidebar,
        .top-bar, .main-nav, .nav-bar, .app-nav,
        .top-menu, .side-menu, .menu-bar,
        [class*="nav"], [class*="header"]:not(.rpt-cover-header):not(.rpt-section-header) { display: none !important; }

        .rpt-page { background: white !important; padding: 0 !important; }
        .rpt-paper {
            max-width: 100%;
            margin: 0;
            counter-reset: page-counter;
        }

        /*
         * Mỗi .rpt-section = 1 trang A4 (297mm x 210mm).
         * height cố định thay min-height — tránh tràn sang trang kế.
         * padding-bottom: 16mm nhường chỗ cho footer absolute.
         */
        .rpt-section {
            border-radius: 0 !important;
            box-shadow: none !important;
            margin: 0 !important;
            width: 210mm !important;
            height: 297mm !important;
            min-height: unset !important;
            padding: 10mm 12mm 16mm !important;
            overflow: hidden !important;
            counter-increment: page-counter;
            position: relative !important;
            box-sizing: border-box !important;
        }

        .page-break-after {
            break-after: page;
            page-break-after: always;
        }

        /* Trang cuối: không cố định height, không break-after — tránh trang trắng thừa */
        .rpt-section-final {
            height: auto !important;
            min-height: unset !important;
            overflow: visible !important;
            break-after: avoid !important;
            page-break-after: avoid !important;
        }

        table { break-inside: avoid; page-break-inside: avoid; }
        tr    { break-inside: avoid; page-break-inside: avoid; }

        /* Overview photo */
        .rpt-overview-photo-cell,
        .rpt-page .rpt-overview-photo-cell .rpt-overview-img,
        .rpt-overview-img {
            height: 120px !important;
        }

        /* 2-column photo grid */
        .rpt-photo-cell,
        .rpt-page .rpt-photo-cell img,
        .rpt-page .rpt-photo-cell .rpt-photo {
            height: 220px !important;
        }

        /* Qty photo grid (Section A) */
        .rpt-qty-photo-cell,
        .rpt-qty-photo-img {
            height: 220px !important;
        }

        /* Defect photos (Section F) */
        .rpt-defect-photo-wrap { height: 220px !important; min-height: unset !important; }
        .rpt-defect-photo      { height: 220px !important; min-height: unset !important; }
        .rpt-defect-no-photo   { height: 220px !important; min-height: unset !important; }

        /* Generic .rpt-photo */
        .rpt-photo { height: 220px !important; max-width: 100%; object-fit: contain; }

        .rpt-overview-photo-wrap,
        .rpt-overview-photo-cell,
        .rpt-qty-photo-grid,
        .rpt-qty-photo-cell,
        .rpt-photo-grid-2,
        .rpt-photo-cell,
        .rpt-perf-block,
        .rpt-defect-item,
        .rpt-sig-row,
        .rpt-aql-grid    { break-inside: avoid; page-break-inside: avoid; }

        .rpt-aql-grid    { grid-template-columns: 1fr 1fr 1fr; }

        /* Footer cố định đáy trang */
        .rpt-footer {
            position: absolute !important;
            bottom: 0 !important;
            left: 0 !important;
            right: 0 !important;
            padding: 4px 12mm 6px !important;
            background: white !important;
        }

        .rpt-footer-page { display: none; }
        .rpt-footer-inner::after {
            content: counter(page-counter);
            font-size: 11px;
            font-weight: 700;
            color: #aaa;
            white-space: nowrap;
            flex-shrink: 0;
            align-self: flex-end;
            padding-left: 12px;
            border-left: 1px solid #e0e0e0;
        }
    }
    @@media (max-width: 640px) {
        .rpt-section { padding: 18px 16px; }
        .rpt-aql-grid { grid-template-columns: 1fr; }
        .rpt-cover-header { flex-direction: column; gap: 8px; }
        .rpt-title-block { text-align: left; }
    }
</style>

<script>
    /**
     * waitImagesAndPrint(rootId)
     * ─────────────────────────
     * 1. Tìm tất cả <img> bên trong rootId
     * 2. Với mỗi ảnh chưa load xong → gán src lại (kích hoạt re-fetch nếu cần)
     *    và chờ sự kiện load / error
     * 3. Sau khi TẤT CẢ ảnh đã resolve → gọi window.print()
     *
     * Tại sao cần gán lại src?
     *   Blazor render ảnh bằng <img src="…"> thông thường, nhưng khi section bị
     *   overflow:hidden (trong print CSS height=297mm) trình duyệt đôi khi bỏ
     *   qua việc decode ảnh ngoài viewport.  Gán src lại ép browser load lại.
     */
    window.waitImagesAndPrint = function (rootId) {
        return new Promise(function (resolve) {
            var root = rootId ? document.getElementById(rootId) : document;
            var imgs = Array.from((root || document).querySelectorAll('img'));

            if (imgs.length === 0) {
                window.print();
                resolve();
                return;
            }

            var pending = 0;

            function done() {
                pending--;
                if (pending <= 0) {
                    // Thêm delay nhỏ để browser kịp paint
                    setTimeout(function () {
                        window.print();
                        resolve();
                    }, 300);
                }
            }

            imgs.forEach(function (img) {
                // Bỏ qua ảnh không có src
                if (!img.src && !img.getAttribute('src')) return;

                if (img.complete && img.naturalWidth > 0) {
                    // Đã load xong — không cần chờ
                    return;
                }

                pending++;

                // Nếu ảnh đang bị lỗi hoặc chưa load, refresh src để ép tải lại
                var originalSrc = img.src;
                img.addEventListener('load',  done, { once: true });
                img.addEventListener('error', done, { once: true });

                // Ép re-fetch bằng cách gán lại src (thêm cache-bust nếu cần)
                if (!img.complete || img.naturalWidth === 0) {
                    img.src = '';
                    img.src = originalSrc;
                }
            });

            if (pending <= 0) {
                setTimeout(function () {
                    window.print();
                    resolve();
                }, 300);
            }
        });
    };

    // Giữ lại hàm cũ để không break nếu còn nơi nào gọi trực tiếp
    window.printReportOnly = function () {
        return window.waitImagesAndPrint('rpt-root');
    };
</script>
