@page "/inspection-report/{InspectionId:int}"
@using System.Net.Http.Json
@using System.Text.Json
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

@if (_loading)
{
    <div class="rpt-loading">
        <div class="rpt-spinner"></div>
        <span>Loading report…</span>
    </div>
}
else if (_error != null)
{
    <div class="rpt-error">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#e53e3e" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
        <p>@_error</p>
        <button class="rpt-back-btn" @onclick="GoBack">← Back</button>
    </div>
}
else if (_data != null)
{
    <div class="rpt-page" id="rpt-root">

        <!-- ══════ TOOLBAR ══════ -->
        <div class="rpt-toolbar no-print">
            <button class="rpt-back-btn" @onclick="GoBack">
                <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M12 15l-5-5 5-5"/></svg>
                Back
            </button>
            <button class="rpt-print-btn" @onclick="PrintReport">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
                Print / Save PDF
            </button>
        </div>

        <!-- ══════ REPORT CONTENT ══════ -->
        <div class="rpt-paper">

            <!-- PAGE 1: COVER -->
            <div class="rpt-section page-break-after">

                <!-- Header -->
                <div class="rpt-cover-header">
                    <div class="rpt-logo-wrap">
                        <img src="/logo.png" class="rpt-logo-img" alt="inticoo logo"/>
                    </div>
                    <div class="rpt-title-block">
                        <div class="rpt-main-title">INSPECTION REPORT</div>
                        <div class="rpt-job-no">Job No: @(_data.JobNumber ?? "—")</div>
                    </div>
                </div>

                <!-- Product Overview photo -->
                <div class="rpt-section-title">Product Overview</div>
                <div class="rpt-overview-photo-wrap">
                    @if (!string.IsNullOrEmpty(_data.Photo1Url))
                    {
                        <div class="rpt-overview-photo-cell">
                            <img src="@NormalizeUrl(_data.Photo1Url)" class="rpt-overview-img" alt="Product Photo" loading="eager"/>
                            <div class="rpt-photo-label">Product Photo</div>
                        </div>
                    }
                    else
                    {
                        <div class="rpt-overview-photo-cell rpt-photo-empty-lg">No Photo</div>
                    }
                </div>

                <!-- General Information -->
                <div class="rpt-section-title">General Information</div>
                <table class="rpt-info-table">
                    <tbody>
                        <tr>
                            <td class="rpt-info-label">Customer Name</td>
                            <td class="rpt-info-val">@(_data.CustomerName ?? "—")</td>
                            <td class="rpt-info-label">Customer ID</td>
                            <td class="rpt-info-val">@(_data.CustomerId ?? "—")</td>
                        </tr>
                        <tr>
                            <td class="rpt-info-label">Vendor Name</td>
                            <td class="rpt-info-val">@(_data.VendorName ?? "—")</td>
                            <td class="rpt-info-label">Vendor ID</td>
                            <td class="rpt-info-val">@(_data.VendorId ?? "—")</td>
                        </tr>
                        <tr>
                            <td class="rpt-info-label">Inspection Location</td>
                            <td class="rpt-info-val">@(_data.InspectionLocation ?? "—")</td>
                            <td class="rpt-info-label">P.O. Number</td>
                            <td class="rpt-info-val">@(_data.PoNumber ?? "—")</td>
                        </tr>
                        <tr>
                            <td class="rpt-info-label">Inspection Date &amp; Time</td>
                            <td class="rpt-info-val">
                                @(_data.InspectionDate.HasValue ? _data.InspectionDate.Value.ToString("d MMM yyyy HH:mm") : "—")
                            </td>
                            <td class="rpt-info-label">Item Number</td>
                            <td class="rpt-info-val">@(_data.ItemNumber ?? "—")</td>
                        </tr>
                        <tr>
                            <td class="rpt-info-label">Inspection Type</td>
                            <td class="rpt-info-val">@(_data.InspectionType ?? "—")</td>
                            <td class="rpt-info-label">Product Name</td>
                            <td class="rpt-info-val">@(_data.ProductName ?? "—")</td>
                        </tr>
                        <tr>
                            <td class="rpt-info-label">Inspection Reference</td>
                            <td class="rpt-info-val">@(string.IsNullOrEmpty(_data.InspectionReference) ? "—" : _data.InspectionReference)</td>
                            <td class="rpt-info-label">Total Shipment Qty</td>
                            <td class="rpt-info-val">@(_data.TotalShipmentQty > 0 ? _data.TotalShipmentQty.ToString() : "—")</td>
                        </tr>
                        <tr>
                            <td class="rpt-info-label">Product Category</td>
                            <td class="rpt-info-val">@(_data.ProductCategory ?? "—")</td>
                            <td class="rpt-info-label">Total Carton Boxes</td>
                            <td class="rpt-info-val">@(_data.TotalCartonBoxes > 0 ? _data.TotalCartonBoxes.ToString() : "—")</td>
                        </tr>
                        @if (!string.IsNullOrWhiteSpace(_data.GeneralRemark))
                        {
                        <tr>
                            <td class="rpt-info-label" style="color:#e53935;font-weight:700;text-align:center;">Remark</td>
                            <td class="rpt-info-val" colspan="3" style="color:#e53935;font-weight:500;">@_data.GeneralRemark</td>
                        </tr>
                        }
                    </tbody>
                </table>

                <!-- Inspection Results Summary -->
                <div class="rpt-section-title">Inspection Results</div>
                <table class="rpt-result-table">
                    <thead>
                        <tr>
                            <th class="rpt-th-label">OVERALL CONCLUSION</th>
                            <th class="rpt-th-comp">COMPLIANCE</th>
                            <th class="rpt-th-remark">REMARK</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (_qcData?.OverallConclusions?.Any() == true)
                        {
                            @foreach (var oc in _qcData!.OverallConclusions)
                            {
                                <tr>
                                    <td>@oc.Letter. @oc.Label</td>
                                    <td class="rpt-td-center">
                                        <span class="rpt-compliance-badge comp-@(oc.Compliance?.ToLower() ?? "na")">
                                            @(oc.Compliance switch { "Pass" => "Yes", "Fail" => "No", _ => oc.Compliance ?? "NA" })
                                        </span>
                                    </td>
                                    <td>@(oc.Remark ?? "")</td>
                                </tr>
                            }
                        }
                        else if (_data.OverallConclusions?.Any() == true)
                        {
                            @foreach (var oc in _data.OverallConclusions)
                            {
                                <tr>
                                    <td>@oc.Letter. @oc.Label</td>
                                    <td class="rpt-td-center">
                                        <span class="rpt-compliance-badge comp-@(oc.Compliance?.ToLower() ?? "na")">
                                            @(oc.Compliance switch { "Pass" => "Yes", "Fail" => "No", _ => oc.Compliance ?? "NA" })
                                        </span>
                                    </td>
                                    <td>@(oc.Remark ?? "")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            string[] defaultRows = { "A. Quantity Conformity", "B. Packaging & Identification",
                                "C. Product Specification Compliance", "D. Performance Testing",
                                "E. Appearance & Craftsmanship", "F. Details of Defect Found" };
                            @foreach (var row in defaultRows)
                            {
                                <tr><td>@row</td><td class="rpt-td-center">—</td><td></td></tr>
                            }
                        }
                    </tbody>
                </table>

                <!-- Footer -->
                <div class="rpt-footer">
                    <div class="rpt-footer-inner">
                        <span class="rpt-footer-text">www.inticoo.com<br/>The results presented herein reflect our findings at the time and place of inspection. This report does not release the seller or manufacturer from their contractual obligations, nor does it prejudice the buyer's right to seek compensation for any apparent or latent defects not identified during our random inspection or arising thereafter. This document does not constitute evidence of shipment. Final approval from the client is required prior to the release of the goods.</span>
                        <span class="rpt-footer-page">@(1) / @TotalPages</span>
                    </div>
                </div>
            </div>

            <!-- ══ SECTION A: Quantity Conformity ══ -->
            <div class="rpt-section page-break-after">
                <div class="rpt-section-title rpt-section-title-lg">A. Quantity Conformity</div>

                @{
                    var qc = _qcData?.QuantityConformity;
                }

                <!-- Bảng luôn hiển thị theo mẫu PDF -->
                <table class="rpt-qty-table">
                    <thead>
                        <tr>
                            <th rowspan="2">P.O. No</th>
                            <th rowspan="2">Item Number</th>
                            <th rowspan="2">Item per Carton</th>
                            <th rowspan="2">Shipment Qty</th>
                            <th colspan="2">Presented Qty for Inspection</th>
                            <th colspan="2">Number of Cartons</th>
                            <th rowspan="2">Qty Not Finished</th>
                        </tr>
                        <tr>
                            <th>Packed</th><th>Not Packed</th>
                            <th>Packed</th><th>Not Packed</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="rpt-qty-data-row">
                            <td>@(_data.PoNumber ?? "")</td>
                            <td>@(_data.ItemNumber ?? "")</td>
                            <td>@(qc?.ItemPerCarton > 0 ? qc.ItemPerCarton.ToString() : "")</td>
                            <td>@(_data.TotalShipmentQty > 0 ? _data.TotalShipmentQty.ToString() : "")</td>
                            <td>@(qc?.PresentedPacked > 0 ? qc.PresentedPacked.ToString() : "")</td>
                            <td>@(qc?.PresentedNotPacked > 0 ? qc.PresentedNotPacked.ToString() : "")</td>
                            <td>@(qc?.CartonsPacked > 0 ? qc.CartonsPacked.ToString() : "")</td>
                            <td>@(qc?.CartonsNotPacked > 0 ? qc.CartonsNotPacked.ToString() : "")</td>
                            <td>@(qc?.QtyNotFinished > 0 ? qc.QtyNotFinished.ToString() : "")</td>
                        </tr>
                        <tr class="rpt-total-row">
                            <td colspan="3" class="rpt-total-label">Total</td>
                            <td>@(_data.TotalShipmentQty > 0 ? _data.TotalShipmentQty.ToString() : "")</td>
                            <td>@(qc?.PresentedPacked > 0 ? qc.PresentedPacked.ToString() : "")</td>
                            <td>@(qc?.PresentedNotPacked > 0 ? qc.PresentedNotPacked.ToString() : "")</td>
                            <td>@(qc?.CartonsPacked > 0 ? qc.CartonsPacked.ToString() : "")</td>
                            <td>@(qc?.CartonsNotPacked > 0 ? qc.CartonsNotPacked.ToString() : "")</td>
                            <td>@(qc?.QtyNotFinished > 0 ? qc.QtyNotFinished.ToString() : "")</td>
                        </tr>
                    </tbody>
                </table>

                <!-- Photo grid 3 cột × 2 hàng — luôn hiển thị theo mẫu PDF -->
                @{
                    var qcPhotos = (qc?.Photos ?? new List<string>()).Where(p => !string.IsNullOrWhiteSpace(p)).ToList();
                    // Đảm bảo đủ 6 slot (3 cột × 2 hàng)
                    var photoSlots = qcPhotos.Cast<string?>().Concat(Enumerable.Repeat<string?>(null, Math.Max(0, 4 - qcPhotos.Count))).Take(4).ToList();
                }
                <div class="rpt-qty-photo-grid">
                    @foreach (var slot in photoSlots)
                    {
                        <div class="rpt-qty-photo-cell">
                            @if (!string.IsNullOrEmpty(slot))
                            {
                                <img src="@NormalizeUrl(slot)" class="rpt-qty-photo-img" alt="Quantity photo" loading="eager"/>
                            }
                        </div>
                    }
                </div>

                <div class="rpt-footer">
                    <div class="rpt-footer-inner">
                        <span class="rpt-footer-text">www.inticoo.com<br/>The results presented herein reflect our findings at the time and place of inspection. This report does not release the seller or manufacturer from their contractual obligations, nor does it prejudice the buyer's right to seek compensation for any apparent or latent defects not identified during our random inspection or arising thereafter. This document does not constitute evidence of shipment. Final approval from the client is required prior to the release of the goods.</span>
                        <span class="rpt-footer-page">@(2) / @TotalPages</span>
                    </div>
                </div>
            </div>

            <!-- ══ SECTION B: Packaging & Identification ══ -->
            @{
                var pr = _qcData?.Packaging;
                // Lấy CartonDataList — nếu có thì lặp theo carton, không thì dùng legacy single
                var cartonDataList = pr?.CartonDataList;
                int cartonCount = cartonDataList?.Count > 0 ? cartonDataList.Count : 1;
            }

            @for (int ci = 0; ci < cartonCount; ci++)
            {
                var cIdx = ci;
                var cd = cartonDataList != null && cIdx < cartonDataList.Count ? cartonDataList[cIdx] : null;
                var cartonSuffix = cartonCount > 1 ? $" — Carton {cIdx + 1}" : "";

                // ── Trang B: Header + Info table + i. Carton Size ──
                <div class="rpt-section page-break-after">
                    <div class="rpt-section-title rpt-section-title-lg">B. Packaging &amp; Identification@cartonSuffix</div>

                    @if (_data.Packaging != null)
                    {
                        var pkg = _data.Packaging;
                        <table class="rpt-info-table rpt-pkg-table">
                            <tbody>
                                <tr>
                                    <td class="rpt-info-label">Item Number</td>
                                    <td class="rpt-info-val">@(pkg.ItemNumber ?? "—")</td>
                                    <td class="rpt-info-label">Carton Number</td>
                                    <td class="rpt-info-val">@(cartonCount > 1 ? (cIdx + 1).ToString() : (pkg.CartonNumber ?? "—"))</td>
                                </tr>
                                <tr>
                                    <td class="rpt-info-label">Type of Packaging</td>
                                    <td class="rpt-info-val" colspan="3">@(pkg.PackagingType ?? "—")</td>
                                </tr>
                                <tr>
                                    <td class="rpt-info-label">Color of Carton</td>
                                    <td class="rpt-info-val">@(pkg.CartonColor ?? "—")</td>
                                    <td class="rpt-info-label">Type of Cardboard</td>
                                    <td class="rpt-info-val">@(pkg.CardboardType ?? "—")</td>
                                </tr>
                                <tr>
                                    <td class="rpt-info-label">Shipping Mark</td>
                                    <td class="rpt-info-val">@(pkg.ShippingMark ?? "—")</td>
                                    <td class="rpt-info-label">Barcode / QR Code</td>
                                    <td class="rpt-info-val">@(pkg.HasBarcode ? "Yes" : "No")</td>
                                </tr>
                                <tr>
                                    <td class="rpt-info-label">Inner Packing</td>
                                    <td class="rpt-info-val">Qty: @pkg.InnerPackingQty — @(pkg.InnerPackingRemark ?? "")</td>
                                    <td class="rpt-info-label">Outer Packing (mm)</td>
                                    <td class="rpt-info-val">
                                        @if (cd != null && (cd.SizeL > 0 || cd.SizeW > 0 || cd.SizeH > 0))
                                        { @($"L: {cd.SizeL}  W: {cd.SizeW}  H: {cd.SizeH}  Wt: {cd.Weight} kg") }
                                        else
                                        { @($"L: {pkg.OuterL}  W: {pkg.OuterW}  H: {pkg.OuterH}  Wt: {pkg.OuterWeight} kg") }
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    }

                    <!-- i. Carton Size -->
                    <div class="rpt-sub-title">i. Carton Size</div>
                    @{
                        var _pCartonSize = (cd?.SizePhotos ?? pr?.CartonSizePhotos ?? new List<string>())
                            .Where(p => !string.IsNullOrWhiteSpace(p)).ToList();
                        var _sCartonSize = _pCartonSize.Cast<string?>()
                            .Concat(Enumerable.Repeat<string?>(null, Math.Max(0, 4 - _pCartonSize.Count)))
                            .Take(4).ToList();
                    }
                    <div class="rpt-photo-grid-2">
                        @foreach (var _u in _sCartonSize)
                        {
                            <div class="rpt-photo-cell">
                                @if (!string.IsNullOrEmpty(_u))
                                { <img src="@NormalizeUrl(_u)" class="rpt-photo" alt="Carton size" loading="eager"/> }
                            </div>
                        }
                    </div>
                    @{ var _csResult = cd?.CartonSizeResult ?? pr?.CartonSizeResult; }
                    @if (!string.IsNullOrEmpty(_csResult))
                    {
                        <div style="text-align:right;margin-top:4px">
                            <span class="rpt-compliance-badge comp-@(_csResult.ToLower())">@_csResult</span>
                        </div>
                    }

                    <div class="rpt-footer">
                        <div class="rpt-footer-inner">
                            <span class="rpt-footer-text">www.inticoo.com<br/>The results presented herein reflect our findings at the time and place of inspection. This report does not release the seller or manufacturer from their contractual obligations, nor does it prejudice the buyer's right to seek compensation for any apparent or latent defects not identified during our random inspection or arising thereafter. This document does not constitute evidence of shipment. Final approval from the client is required prior to the release of the goods.</span>
                            <span class="rpt-footer-page">@(3 + cIdx * 4) / @TotalPages</span>
                        </div>
                    </div>
                </div>

                <!-- ── Trang ii+iii. Shipping Mark + Carton Weight (gộp chung 1 trang) ── -->
                <div class="rpt-section page-break-after">
                    <div class="rpt-section-title rpt-section-title-lg">B. Packaging &amp; Identification@cartonSuffix</div>

                    <div class="rpt-sub-title">ii. Shipping Mark / Labeling / Barcode</div>
                    @{
                        var _pShipping = (cd?.ShippingMarkPhotos ?? pr?.ShippingMarkPhotos ?? new List<string>())
                            .Where(p => !string.IsNullOrWhiteSpace(p)).ToList();
                        var _sShipping = _pShipping.Cast<string?>()
                            .Concat(Enumerable.Repeat<string?>(null, Math.Max(0, 4 - _pShipping.Count)))
                            .Take(4).ToList();
                    }
                    <div class="rpt-photo-grid-2">
                        @foreach (var _u in _sShipping)
                        {
                            <div class="rpt-photo-cell">
                                @if (!string.IsNullOrEmpty(_u))
                                { <img src="@NormalizeUrl(_u)" class="rpt-photo" alt="Shipping mark" loading="eager"/> }
                            </div>
                        }
                    </div>
                    @{ var _smResult = cd?.ShippingMarkResult ?? pr?.ShippingMarkResult; }
                    @if (!string.IsNullOrEmpty(_smResult))
                    {
                        <div style="text-align:right;margin-top:4px">
                            <span class="rpt-compliance-badge comp-@(_smResult.ToLower())">@_smResult</span>
                        </div>
                    }

                    <div class="rpt-sub-title" style="margin-top:16px;">iii. Carton Weight</div>
                    @if (cd != null && cd.Weight > 0)
                    {
                        <div style="font-size:12px;color:#555;margin-bottom:8px">Actual Weight: <strong>@cd.Weight kg</strong></div>
                    }
                    @{
                        var _pWeight = (cd?.SizePhotos ?? pr?.WeightPhotos ?? new List<string>())
                            .Where(p => !string.IsNullOrWhiteSpace(p)).ToList();
                        var _sWeight = _pWeight.Cast<string?>()
                            .Concat(Enumerable.Repeat<string?>(null, Math.Max(0, 4 - _pWeight.Count)))
                            .Take(4).ToList();
                    }
                    <div class="rpt-photo-grid-2">
                        @foreach (var _u in _sWeight)
                        {
                            <div class="rpt-photo-cell">
                                @if (!string.IsNullOrEmpty(_u))
                                { <img src="@NormalizeUrl(_u)" class="rpt-photo" alt="Carton weight" loading="eager"/> }
                            </div>
                        }
                    </div>
                    @{ var _cwResult = cd?.CartonWeightResult ?? pr?.CartonWeightResult; }
                    @if (!string.IsNullOrEmpty(_cwResult))
                    {
                        <div style="text-align:right;margin-top:4px">
                            <span class="rpt-compliance-badge comp-@(_cwResult.ToLower())">@_cwResult</span>
                        </div>
                    }

                    <div class="rpt-footer">
                        <div class="rpt-footer-inner">
                            <span class="rpt-footer-text">www.inticoo.com<br/>The results presented herein reflect our findings at the time and place of inspection. This report does not release the seller or manufacturer from their contractual obligations, nor does it prejudice the buyer's right to seek compensation for any apparent or latent defects not identified during our random inspection or arising thereafter. This document does not constitute evidence of shipment. Final approval from the client is required prior to the release of the goods.</span>
                            <span class="rpt-footer-page">@(3 + cIdx * 4 + 1) / @TotalPages</span>
                        </div>
                    </div>
                </div>

                <!-- ── Trang iv+v. Packaging & Labeling + Assembly Instruction (gộp chung 1 trang) ── -->
                <div class="rpt-section page-break-after">
                    <div class="rpt-section-title rpt-section-title-lg">B. Packaging &amp; Identification@cartonSuffix</div>

                    <div class="rpt-sub-title">iv. Packaging &amp; Labeling Specifications</div>
                    @{
                        var _pPkgLabel = (cd?.PkgLabelPhotos ?? pr?.PkgLabelPhotos ?? new List<string>())
                            .Where(p => !string.IsNullOrWhiteSpace(p)).ToList();
                        var _sPkgLabel = _pPkgLabel.Cast<string?>()
                            .Concat(Enumerable.Repeat<string?>(null, Math.Max(0, 4 - _pPkgLabel.Count)))
                            .Take(4).ToList();
                    }
                    <div class="rpt-photo-grid-2">
                        @foreach (var _u in _sPkgLabel)
                        {
                            <div class="rpt-photo-cell">
                                @if (!string.IsNullOrEmpty(_u))
                                { <img src="@NormalizeUrl(_u)" class="rpt-photo" alt="Pkg label" loading="eager"/> }
                            </div>
                        }
                    </div>
                    @{ var _plResult = cd?.PkgLabelResult ?? pr?.PkgLabelResult; }
                    @if (!string.IsNullOrEmpty(_plResult))
                    {
                        <div style="text-align:right;margin-top:4px">
                            <span class="rpt-compliance-badge comp-@(_plResult.ToLower())">@_plResult</span>
                        </div>
                    }

                    <div class="rpt-sub-title" style="margin-top:16px;">v. Assembly Instruction Specifications</div>
                    @{
                        var _pAssembly = (cd?.AssemblyPhotos ?? pr?.AssemblyPhotos ?? new List<string>())
                            .Where(p => !string.IsNullOrWhiteSpace(p)).ToList();
                        var _sAssembly = _pAssembly.Cast<string?>()
                            .Concat(Enumerable.Repeat<string?>(null, Math.Max(0, 4 - _pAssembly.Count)))
                            .Take(4).ToList();
                    }
                    <div class="rpt-photo-grid-2">
                        @foreach (var _u in _sAssembly)
                        {
                            <div class="rpt-photo-cell">
                                @if (!string.IsNullOrEmpty(_u))
                                { <img src="@NormalizeUrl(_u)" class="rpt-photo" alt="Assembly" loading="eager"/> }
                            </div>
                        }
                    </div>
                    @{ var _asResult = cd?.AssemblyResult ?? pr?.AssemblyResult; }
                    @if (!string.IsNullOrEmpty(_asResult))
                    {
                        <div style="text-align:right;margin-top:4px">
                            <span class="rpt-compliance-badge comp-@(_asResult.ToLower())">@_asResult</span>
                        </div>
                    }
                    <div class="rpt-footer">
                        <div class="rpt-footer-inner">
                            <span class="rpt-footer-text">www.inticoo.com<br/>The results presented herein reflect our findings at the time and place of inspection. This report does not release the seller or manufacturer from their contractual obligations, nor does it prejudice the buyer's right to seek compensation for any apparent or latent defects not identified during our random inspection or arising thereafter. This document does not constitute evidence of shipment. Final approval from the client is required prior to the release of the goods.</span>
                            <span class="rpt-footer-page">@(3 + cIdx * 4 + 2) / @TotalPages</span>
                        </div>
                    </div>
                </div>

                <!-- ── Trang vi. Hardware ── -->
                <div class="rpt-section page-break-after">
                    <div class="rpt-section-title rpt-section-title-lg">B. Packaging &amp; Identification@cartonSuffix</div>
                    <div class="rpt-sub-title">vi. Hardware Specifications</div>
                    @{
                        var _pHardware = (cd?.HardwarePhotos ?? pr?.HardwarePhotos ?? new List<string>())
                            .Where(p => !string.IsNullOrWhiteSpace(p)).ToList();
                        var _sHardware = _pHardware.Cast<string?>()
                            .Concat(Enumerable.Repeat<string?>(null, Math.Max(0, 4 - _pHardware.Count)))
                            .Take(4).ToList();
                    }
                    <div class="rpt-photo-grid-2">
                        @foreach (var _u in _sHardware)
                        {
                            <div class="rpt-photo-cell">
                                @if (!string.IsNullOrEmpty(_u))
                                { <img src="@NormalizeUrl(_u)" class="rpt-photo" alt="Hardware" loading="eager"/> }
                            </div>
                        }
                    </div>
                    @{ var _hwResult = cd?.HardwareResult ?? pr?.HardwareResult; }
                    @if (!string.IsNullOrEmpty(_hwResult))
                    {
                        <div style="text-align:right;margin-top:4px">
                            <span class="rpt-compliance-badge comp-@(_hwResult.ToLower())">@_hwResult</span>
                        </div>
                    }
                    <div class="rpt-footer">
                        <div class="rpt-footer-inner">
                            <span class="rpt-footer-text">www.inticoo.com<br/>The results presented herein reflect our findings at the time and place of inspection. This report does not release the seller or manufacturer from their contractual obligations, nor does it prejudice the buyer's right to seek compensation for any apparent or latent defects not identified during our random inspection or arising thereafter. This document does not constitute evidence of shipment. Final approval from the client is required prior to the release of the goods.</span>
                            <span class="rpt-footer-page">@(3 + cIdx * 4 + 3) / @TotalPages</span>
                        </div>
                    </div>
                </div>
            }

            <!-- ══ SECTION C (1/2): Product Specification Compliance — Size + Golden ══ -->
            <div class="rpt-section page-break-after">
                <div class="rpt-section-title rpt-section-title-lg">C. Product Specification Compliance (1/2)</div>

                @if (_data.ProductSpec != null || _qcData?.ProductSpec != null)
                {
                    <!-- i. Product Size -->
                    <div class="rpt-sub-title">i. Product Size</div>
                    @if (_data.ProductSpec != null)
                    {
                        <table class="rpt-spec-table">
                            <thead>
                                <tr>
                                    <th colspan="3">Product Size (mm)</th>
                                    <th>Additional</th>
                                </tr>
                                <tr><th>L</th><th>W</th><th>H</th><th></th></tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>@_data.ProductSpec.SizeL</td>
                                    <td>@_data.ProductSpec.SizeW</td>
                                    <td>@_data.ProductSpec.SizeH</td>
                                    <td>@(_qcData?.ProductSpec?.AdditionalText ?? "")</td>
                                </tr>
                            </tbody>
                        </table>
                    }
                    @if (_qcData?.ProductSpec?.SizeRows?.Any() == true)
                    {
                        <div class="rpt-photo-grid-2">
                            @foreach (var row in _qcData.ProductSpec.SizeRows)
                            {
                                var url = row.GetProperty("photoUrl").GetString();
                                if (!string.IsNullOrEmpty(url))
                                {
                                    <div class="rpt-photo-cell"><img src="@NormalizeUrl(url)" class="rpt-photo" alt="Product size photo" loading="eager"/></div>
                                }
                            }
                        </div>
                    }

                    <!-- ii. Compare Golden Sample -->
                    <div class="rpt-sub-title">ii. Compare Golden Sample</div>
                    <div class="rpt-photo-grid-2">
                        @foreach (var _gu in (_qcData?.ProductSpec?.GoldenPhotos?.Where(p => !string.IsNullOrWhiteSpace(p)).ToList() ?? new List<string>()).Cast<string?>().Concat(Enumerable.Repeat<string?>(null, Math.Max(0, 4 - (_qcData?.ProductSpec?.GoldenPhotos?.Count(p => !string.IsNullOrWhiteSpace(p)) ?? 0)))).Take(4))
                        {
                            <div class="rpt-photo-cell">
                                @if (!string.IsNullOrEmpty(_gu))
                                { <img src="@NormalizeUrl(_gu)" class="rpt-photo" alt="Golden sample photo" loading="eager"/> }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="rpt-no-data">No product specification data recorded.</div>
                }

                <div class="rpt-footer">
                    <div class="rpt-footer-inner">
                        <span class="rpt-footer-text">www.inticoo.com<br/>The results presented herein reflect our findings at the time and place of inspection. This report does not release the seller or manufacturer from their contractual obligations, nor does it prejudice the buyer's right to seek compensation for any apparent or latent defects not identified during our random inspection or arising thereafter. This document does not constitute evidence of shipment. Final approval from the client is required prior to the release of the goods.</span>
                        <span class="rpt-footer-page">@(2 + CartonPageCount + 1) / @TotalPages</span>
                    </div>
                </div>
            </div>

            <!-- ══ SECTION C (2/2): Product Specification Compliance — Colour Swatch ══ -->
            <div class="rpt-section page-break-after">
                <div class="rpt-section-title rpt-section-title-lg">C. Product Specification Compliance (2/2)</div>

                <!-- iii. Colour Swatch Comparison -->
                <div class="rpt-sub-title">iii. Colour Swatch Comparison</div>
                @if (_qcData?.ProductSpec?.ColourSwatches?.Any() == true)
                {
                    <table class="rpt-swatch-table">
                        <thead>
                            <tr>
                                <th style="width:10%">No</th>
                                <th style="width:55%">Material</th>
                                <th style="width:35%">Result</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sw in _qcData.ProductSpec.ColourSwatches)
                            {
                                <tr>
                                    <td>@sw.No</td>
                                    <td>@(sw.Material ?? "—")</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(sw.Result))
                                        {
                                            <span class="rpt-compliance-badge comp-@sw.Result.ToLower()">@sw.Result</span>
                                        }
                                        else
                                        {
                                            <span style="color:#bbb">Passed / Failed / NA</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                <div class="rpt-photo-grid-2">
                    @foreach (var _sw in (_qcData?.ProductSpec?.SwatchPhotos?.Where(p => !string.IsNullOrWhiteSpace(p)).ToList() ?? new List<string>()).Cast<string?>().Concat(Enumerable.Repeat<string?>(null, Math.Max(0, 4 - (_qcData?.ProductSpec?.SwatchPhotos?.Count(p => !string.IsNullOrWhiteSpace(p)) ?? 0)))).Take(4))
                    {
                        <div class="rpt-photo-cell">
                            @if (!string.IsNullOrEmpty(_sw))
                            { <img src="@NormalizeUrl(_sw)" class="rpt-photo" alt="Swatch photo" loading="eager"/> }
                        </div>
                    }
                </div>

                <div class="rpt-footer">
                    <div class="rpt-footer-inner">
                        <span class="rpt-footer-text">www.inticoo.com<br/>The results presented herein reflect our findings at the time and place of inspection. This report does not release the seller or manufacturer from their contractual obligations, nor does it prejudice the buyer's right to seek compensation for any apparent or latent defects not identified during our random inspection or arising thereafter. This document does not constitute evidence of shipment. Final approval from the client is required prior to the release of the goods.</span>
                        <span class="rpt-footer-page">@(2 + CartonPageCount + 2) / @TotalPages</span>
                    </div>
                </div>
            </div>

            <!-- ══ SECTION D: Performance Testing — mỗi test 1 trang riêng ══ -->
            @{
                var _qcPerf     = _qcData?.PerformanceTests?.Any() == true ? _qcData.PerformanceTests : null;
                var _legacyPerf = _data.PerformanceTests?.Any() == true ? _data.PerformanceTests : null;
            }
            @if (_qcPerf != null)
            {
                @for (int di = 0; di < _qcPerf.Count; di++)
                {
                    var dIdx  = di;
                    var test  = _qcPerf[dIdx];
                    var dSuffix = _qcPerf.Count > 1 ? $" ({dIdx + 1}/{_qcPerf.Count})" : "";
                    var dPhotos = test.Photos?.Where(p => !string.IsNullOrWhiteSpace(p)).ToList() ?? new();
                    // Fallback TestRequirement từ _data.PerformanceTests nếu QcResult không có
                    var dTestReq = !string.IsNullOrWhiteSpace(test.TestRequirement)
                        ? test.TestRequirement
                        : (_data?.PerformanceTests?.ElementAtOrDefault(dIdx)?.TestRequirement ?? null);
                    <div class="rpt-section page-break-after">
                        <div class="rpt-section-title rpt-section-title-lg">D. Performance Testing@(dSuffix)</div>
                        <table class="rpt-perf-table">
                            <tbody>
                                <tr>
                                    <td class="rpt-info-label">Test Item</td>
                                    <td class="rpt-info-val" colspan="3">@(test.TestItem ?? "—")</td>
                                </tr>
                                <tr>
                                    <td class="rpt-info-label">Test Requirement</td>
                                    <td class="rpt-info-val" colspan="3">@(dTestReq ?? "—")</td>
                                </tr>
                                <tr>
                                    <td class="rpt-info-label">Test Quantity</td>
                                    <td class="rpt-info-val" colspan="3">@test.TestQuantity</td>
                                </tr>
                                <tr>
                                    <td class="rpt-info-label">Remark</td>
                                    <td class="rpt-info-val" colspan="3">@(test.Remark ?? "—")</td>
                                </tr>
                                @if (!string.IsNullOrEmpty(test.Result))
                                {
                                    <tr>
                                        <td class="rpt-info-label">Result</td>
                                        <td class="rpt-info-val" colspan="3">
                                            <span class="rpt-compliance-badge comp-@(test.Result.ToLower())">@test.Result</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        @{
                            var _dSlots = dPhotos.Cast<string?>().Concat(Enumerable.Repeat<string?>(null, Math.Max(0, 4 - dPhotos.Count))).Take(4).ToList();
                        }
                        <div class="rpt-photo-grid-2">
                            @foreach (var _du in _dSlots)
                            {
                                <div class="rpt-photo-cell">
                                    @if (!string.IsNullOrEmpty(_du))
                                    { <img src="@NormalizeUrl(_du)" class="rpt-photo" alt="Performance test photo" loading="eager"/> }
                                </div>
                            }
                        </div>
                        <div class="rpt-footer">
                            <div class="rpt-footer-inner">
                                <span class="rpt-footer-text">www.inticoo.com<br/>The results presented herein reflect our findings at the time and place of inspection. This report does not release the seller or manufacturer from their contractual obligations, nor does it prejudice the buyer's right to seek compensation for any apparent or latent defects not identified during our random inspection or arising thereafter. This document does not constitute evidence of shipment. Final approval from the client is required prior to the release of the goods.</span>
                                <span class="rpt-footer-page">@(2 + CartonPageCount + 2 + dIdx) / @TotalPages</span>
                            </div>
                        </div>
                    </div>
                }
            }
            else if (_legacyPerf != null)
            {
                @for (int di = 0; di < _legacyPerf.Count; di++)
                {
                    var dIdx    = di;
                    var t       = _legacyPerf[dIdx];
                    var dSuffix = _legacyPerf.Count > 1 ? $" ({dIdx + 1}/{_legacyPerf.Count})" : "";
                    <div class="rpt-section page-break-after">
                        <div class="rpt-section-title rpt-section-title-lg">D. Performance Testing@(dSuffix)</div>
                        <table class="rpt-perf-table">
                            <tbody>
                                <tr><td class="rpt-info-label">Test Item</td><td class="rpt-info-val">@(t.TestItem ?? "—")</td></tr>
                                <tr><td class="rpt-info-label">Test Requirement</td><td class="rpt-info-val">@(t.TestRequirement ?? "—")</td></tr>
                                <tr><td class="rpt-info-label">Remark</td><td class="rpt-info-val">@(t.Remark ?? "—")</td></tr>
                            </tbody>
                        </table>
                        <div class="rpt-footer">
                            <div class="rpt-footer-inner">
                                <span class="rpt-footer-text">www.inticoo.com<br/>The results presented herein reflect our findings at the time and place of inspection. This report does not release the seller or manufacturer from their contractual obligations, nor does it prejudice the buyer's right to seek compensation for any apparent or latent defects not identified during our random inspection or arising thereafter. This document does not constitute evidence of shipment. Final approval from the client is required prior to the release of the goods.</span>
                                <span class="rpt-footer-page">@(2 + CartonPageCount + 2 + dIdx) / @TotalPages</span>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="rpt-section page-break-after">
                    <div class="rpt-section-title rpt-section-title-lg">D. Performance Testing</div>
                    <div class="rpt-no-data">No performance testing data recorded.</div>
                    <div class="rpt-footer">
                        <div class="rpt-footer-inner">
                            <span class="rpt-footer-text">www.inticoo.com<br/>The results presented herein reflect our findings at the time and place of inspection. This report does not release the seller or manufacturer from their contractual obligations, nor does it prejudice the buyer's right to seek compensation for any apparent or latent defects not identified during our random inspection or arising thereafter. This document does not constitute evidence of shipment. Final approval from the client is required prior to the release of the goods.</span>
                            <span class="rpt-footer-page">@(2 + CartonPageCount + 2) / @TotalPages</span>
                        </div>
                    </div>
                </div>
            }

            <!-- ══ SECTION E: Appearance & Craftsmanship (AQL) ══ -->
            <div class="rpt-section page-break-after">
                <div class="rpt-section-title rpt-section-title-lg">E. Appearance &amp; Craftsmanship</div>

                @{
                    // DB values cho SampleSize/Accept/Reject (chính xác từ AQL table)
                    var aqlQty     = _data.AqlQuantity > 0 ? _data.AqlQuantity : (_qcData?.Aql?.Quantity ?? 0);
                    var aqlLvl     = _data.AqlLevel    ?? _qcData?.Aql?.InspectionLevel ?? "II";
                    var aqlCritAql = _data.AqlCritical ?? _qcData?.Aql?.CriticalAql ?? "Not Allowed";
                    var aqlMajAql  = _data.AqlMajor    ?? _qcData?.Aql?.MajorAql    ?? "2.5";
                    var aqlMinAql  = _data.AqlMinor    ?? _qcData?.Aql?.MinorAql    ?? "4.0";
                    var critSample = _data.AqlCriticalSampleSize > 0 ? _data.AqlCriticalSampleSize : (_qcData?.Aql?.CriticalSampleSize ?? 0);
                    var critAccept = _data.AqlCriticalAccept     > 0 ? _data.AqlCriticalAccept     : (_qcData?.Aql?.CriticalAccept     ?? 0);
                    var critReject = _data.AqlCriticalReject     > 0 ? _data.AqlCriticalReject     : (_qcData?.Aql?.CriticalReject     ?? 0);
                    var majSample  = _data.AqlMajorSampleSize    > 0 ? _data.AqlMajorSampleSize    : (_qcData?.Aql?.MajorSampleSize    ?? 0);
                    var majAccept  = _data.AqlMajorAccept        > 0 ? _data.AqlMajorAccept        : (_qcData?.Aql?.MajorAccept        ?? 0);
                    var majReject  = _data.AqlMajorReject        > 0 ? _data.AqlMajorReject        : (_qcData?.Aql?.MajorReject        ?? 0);
                    var minSample  = _data.AqlMinorSampleSize    > 0 ? _data.AqlMinorSampleSize    : (_qcData?.Aql?.MinorSampleSize    ?? 0);
                    var minAccept  = _data.AqlMinorAccept        > 0 ? _data.AqlMinorAccept        : (_qcData?.Aql?.MinorAccept        ?? 0);
                    var minReject  = _data.AqlMinorReject        > 0 ? _data.AqlMinorReject        : (_qcData?.Aql?.MinorReject        ?? 0);
                    var critFound  = _qcData?.Aql?.CriticalFound ?? 0;
                    var majFound   = _qcData?.Aql?.MajorFound    ?? 0;
                    var minFound   = _qcData?.Aql?.MinorFound    ?? 0;
                }
                @if (aqlQty > 0 || critSample > 0 || _qcData?.Aql != null)
                {
                    <div class="rpt-aql-label">AQL Sampling Simulator</div>
                    <div class="rpt-aql-row">
                        <div class="rpt-aql-item"><span class="rpt-aql-key">Quantity</span><span class="rpt-aql-val">@aqlQty</span></div>
                        <div class="rpt-aql-item"><span class="rpt-aql-key">Inspection Level</span><span class="rpt-aql-val">@aqlLvl</span></div>
                    </div>
                    <div class="rpt-aql-grid">
                        <div class="rpt-aql-box aql-critical">
                            <div class="rpt-aql-box-title">Critical Defects</div>
                            <div class="rpt-aql-box-row"><span>Select AQL</span><span>@aqlCritAql</span></div>
                            <div class="rpt-aql-box-row"><span>Sample Size</span><span>@critSample</span></div>
                            <div class="rpt-aql-box-row"><span>Accept Point</span><span>@critAccept</span></div>
                            <div class="rpt-aql-box-row"><span>Reject Point</span><span>@critReject</span></div>
                        </div>
                        <div class="rpt-aql-box aql-major">
                            <div class="rpt-aql-box-title">Major Defects</div>
                            <div class="rpt-aql-box-row"><span>Select AQL</span><span>@aqlMajAql</span></div>
                            <div class="rpt-aql-box-row"><span>Sample Size</span><span>@majSample</span></div>
                            <div class="rpt-aql-box-row"><span>Accept Point</span><span>@majAccept</span></div>
                            <div class="rpt-aql-box-row"><span>Reject Point</span><span>@majReject</span></div>
                        </div>
                        <div class="rpt-aql-box aql-minor">
                            <div class="rpt-aql-box-title">Minor Defects</div>
                            <div class="rpt-aql-box-row"><span>Select AQL</span><span>@aqlMinAql</span></div>
                            <div class="rpt-aql-box-row"><span>Sample Size</span><span>@minSample</span></div>
                            <div class="rpt-aql-box-row"><span>Accept Point</span><span>@minAccept</span></div>
                            <div class="rpt-aql-box-row"><span>Reject Point</span><span>@minReject</span></div>
                        </div>
                    </div>
                    <div class="rpt-aql-label" style="margin-top:16px;">RESULT</div>
                    <table class="rpt-result-table">
                        <thead>
                            <tr>
                                <th class="rpt-th-label">Details of Defect Found</th>
                                <th class="rpt-th-comp" style="color:#c0392b">Critical</th>
                                <th class="rpt-th-comp" style="color:#e67e22">Major</th>
                                <th class="rpt-th-comp" style="color:#27ae60">Minor</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Total Found</td>
                                <td class="rpt-td-center">@critFound</td>
                                <td class="rpt-td-center">@majFound</td>
                                <td class="rpt-td-center">@minFound</td>
                            </tr>
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="rpt-no-data">No AQL data recorded.</div>
                }

                <!-- Critical defects gộp vào cuối trang E -->
                @{
                    var _critDefects = _qcData?.Defects?.Where(d => d.Type == "Critical").ToList() ?? new();
                    var _critItems = _critDefects.SelectMany(def => {
                        var urls = (def.Photos?.Where(p => !string.IsNullOrWhiteSpace(p)).ToList())
                                   ?? (def.PhotoUrl != null ? new List<string> { def.PhotoUrl } : new List<string>());
                        return urls.Select((url, i) => new { Url = url, Remark = def.Remarks?.ElementAtOrDefault(i) ?? def.Remark ?? "" });
                    }).ToList();
                    int _critMin = Math.Max(4, _critItems.Count % 2 == 0 ? _critItems.Count : _critItems.Count + 1);
                    var _critSlots = _critItems.Select(p => (string?)p.Url)
                        .Concat(Enumerable.Repeat<string?>(null, _critMin - _critItems.Count))
                        .Zip(_critItems.Select(p => p.Remark).Concat(Enumerable.Repeat("", _critMin - _critItems.Count)),
                             (url, remark) => (Url: url, Remark: remark)).ToList();
                }
                <div class="rpt-section-title rpt-section-title-lg" style="margin-top:20px;">F. Details of Defect Found</div>
                <div class="rpt-defect-type-title defect-critical">Critical</div>
                <div class="rpt-photo-grid-2">
                    @foreach (var slot in _critSlots)
                    {
                        <div class="rpt-defect-cell">
                            <div class="rpt-defect-photo-wrap">
                                @if (!string.IsNullOrEmpty(slot.Url))
                                { <img src="@NormalizeUrl(slot.Url)" class="rpt-defect-photo" alt="Critical defect photo" loading="eager"/> }
                                else
                                { <div class="rpt-defect-no-photo">No Photo</div> }
                            </div>
                            <div class="rpt-defect-remark">Remark: @(string.IsNullOrEmpty(slot.Remark) ? "—" : slot.Remark)</div>
                        </div>
                    }
                </div>

                <div class="rpt-footer">
                    <div class="rpt-footer-inner">
                        <span class="rpt-footer-text">www.inticoo.com<br/>The results presented herein reflect our findings at the time and place of inspection. This report does not release the seller or manufacturer from their contractual obligations, nor does it prejudice the buyer's right to seek compensation for any apparent or latent defects not identified during our random inspection or arising thereafter. This document does not constitute evidence of shipment. Final approval from the client is required prior to the release of the goods.</span>
                        <span class="rpt-footer-page">@(2 + CartonPageCount + PerfPageCount + 2) / @TotalPages</span>
                    </div>
                </div>
            </div>

            <!-- ══ SECTION F: Major + Minor Defects ══ -->
            <div class="rpt-section page-break-after">
                <div class="rpt-section-title rpt-section-title-lg">F. Details of Defect Found (cont.)</div>

                @foreach (var defType in new[] { "Major", "Minor" })
                {
                    var typeDefects = _qcData?.Defects?.Where(d => d.Type == defType).ToList() ?? new();
                    var photoItems = typeDefects
                        .SelectMany(def =>
                        {
                            var urls = (def.Photos?.Where(p => !string.IsNullOrWhiteSpace(p)).ToList())
                                       ?? (def.PhotoUrl != null ? new List<string> { def.PhotoUrl } : new List<string>());
                            return urls.Select((url, i) => new {
                                Url    = url,
                                Remark = def.Remarks?.ElementAtOrDefault(i) ?? def.Remark ?? ""
                            });
                        })
                        .ToList();

                    int minSlots = Math.Max(4, photoItems.Count % 2 == 0 ? photoItems.Count : photoItems.Count + 1);
                    var slots = photoItems
                        .Select(p => (string?)p.Url)
                        .Concat(Enumerable.Repeat<string?>(null, minSlots - photoItems.Count))
                        .Zip(
                            photoItems.Select(p => p.Remark)
                                      .Concat(Enumerable.Repeat("", minSlots - photoItems.Count)),
                            (url, remark) => (Url: url, Remark: remark)
                        )
                        .ToList();

                    <div class="rpt-defect-type-title defect-@defType.ToLower()">@defType</div>
                    <div class="rpt-photo-grid-2">
                        @foreach (var slot in slots)
                        {
                            <div class="rpt-defect-cell">
                                <div class="rpt-defect-photo-wrap">
                                    @if (!string.IsNullOrEmpty(slot.Url))
                                    { <img src="@NormalizeUrl(slot.Url)" class="rpt-defect-photo" alt="@defType defect photo" loading="eager"/> }
                                    else
                                    { <div class="rpt-defect-no-photo">No Photo</div> }
                                </div>
                                <div class="rpt-defect-remark">Remark: @(string.IsNullOrEmpty(slot.Remark) ? "—" : slot.Remark)</div>
                            </div>
                        }
                    </div>
                }

                <div class="rpt-footer">
                    <div class="rpt-footer-inner">
                        <span class="rpt-footer-text">www.inticoo.com<br/>The results presented herein reflect our findings at the time and place of inspection. This report does not release the seller or manufacturer from their contractual obligations, nor does it prejudice the buyer's right to seek compensation for any apparent or latent defects not identified during our random inspection or arising thereafter. This document does not constitute evidence of shipment. Final approval from the client is required prior to the release of the goods.</span>
                        <span class="rpt-footer-page">@(2 + CartonPageCount + PerfPageCount + 3) / @TotalPages</span>
                    </div>
                </div>
            </div>

            <!-- ══ FINAL PAGE: Conclusion & Signature ══ -->
            <div class="rpt-section rpt-section-final">
                <div class="rpt-logo-wrap" style="margin-bottom:28px;">
                    <img src="/logo.png" class="rpt-logo-img" alt="inticoo logo"/>
                </div>

                <!-- Inspector Comments -->
                <table class="rpt-sign-table">
                    <tbody>
                        <tr>
                            <td class="rpt-sign-label">Inspector Comments</td>
                            <td class="rpt-sign-val rpt-comments-cell">
                                @(_data.InspectorComments ?? "")
                            </td>
                        </tr>
                    </tbody>
                </table>

                <!-- Final Result -->
                <div class="rpt-final-result-wrap">
                    <span class="rpt-final-label">FINAL RESULT</span>
                    <span class="rpt-final-badge @GetFinalBadgeClass(_data.FinalResult)">
                        @(_data.FinalResult?.ToUpper() ?? "N/A")
                    </span>
                </div>

                <!-- Compliance clause -->
                <div class="rpt-compliance-clause">
                    <strong>Compliance &amp; Integrity Clause</strong>
                    <p><em>All inspections follow the customer protocol, and any attempt to bribe, pressure, or threaten the inspector will render the inspection invalid and may lead to termination of the agreement and legal consequences.</em></p>
                </div>

                <!-- Signatures -->
                <table class="rpt-sign-table" style="margin-top:16px;">
                    <tbody>
                        <tr>
                            <td class="rpt-sign-label">Inspection by</td>
                            <td class="rpt-sign-val rpt-sign-cell">
                                <span class="rpt-sign-name">@(_data.InspectorName ?? "—")</span>
                                @if (!string.IsNullOrEmpty(_data.InspectorId))
                                {
                                    <span class="rpt-sign-id">ID: @_data.InspectorId</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td class="rpt-sign-label">Confirmed by</td>
                            <td class="rpt-sign-val rpt-sign-cell">
                                @if (!string.IsNullOrEmpty(_data.SignatureUrl))
                                {
                                    <img src="@NormalizeUrl(_data.SignatureUrl)" class="rpt-signature" alt="Signature" loading="eager"/>
                                }
                            </td>
                        </tr>
                    </tbody>
                </table>

                <div class="rpt-end-line">
                    <hr/>
                    <span>End</span>
                    <hr/>
                </div>

                <div class="rpt-footer">
                    <div class="rpt-footer-inner">
                        <span class="rpt-footer-text">www.inticoo.com<br/>The results presented herein reflect our findings at the time and place of inspection. This report does not release the seller or manufacturer from their contractual obligations, nor does it prejudice the buyer's right to seek compensation for any apparent or latent defects not identified during our random inspection or arising thereafter. This document does not constitute evidence of shipment. Final approval from the client is required prior to the release of the goods.</span>
                        <span class="rpt-footer-page">@(2 + CartonPageCount + PerfPageCount + 4) / @TotalPages</span>
                    </div>
                </div>
            </div>

        </div>
    </div>
}

@code {
    private RenderFragment _Footer =>
        @<div class="rpt-footer">www.inticoo.com<br/>
        The results presented herein reflect our findings at the time and place of inspection. This report does not release the seller or manufacturer from <br/>
        their contractual obligations, nor does it prejudice the buyer’s right to seek compensation for any apparent or latent defects not identified during <br/>
        our random inspection or arising thereafter. This document does not constitute evidence of shipment. Final approval from the client is required <br/>
        prior to the release of the goods.
</div>;

    [Parameter] public int InspectionId { get; set; }

    private bool    _loading = true;
    private string? _error;
    private InspectionDetailDto? _data;
    private QcResultDto?         _qcData;

    // ─── Lifecycle ───
    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        _loading = false;
    }

    private async Task LoadData()
    {
        try
        {
            var opts = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };

            // Load inspection detail (General info, Packaging, ProductSpec, etc.)
            _data = await Http.GetFromJsonAsync<InspectionDetailDto>(
                $"api/inspections/{InspectionId}", opts);

            if (_data == null)
            {
                _error = "Inspection not found.";
                return;
            }

            // Parse QcResultJson từ response (không cần endpoint riêng)
            if (!string.IsNullOrWhiteSpace(_data.QcResultJson))
            {
                try
                {
                    _qcData = JsonSerializer.Deserialize<QcResultDto>(
                        _data.QcResultJson, opts);
                }
                catch
                {
                    _qcData = null;
                }
            }
        }
        catch (Exception ex)
        {
            _error = $"Failed to load report: {ex.Message}";
        }
    }

    private void GoBack() => Navigation.NavigateTo("/inspection-schedule");

    // Chuẩn hóa URL ảnh: prefix ApiBaseUrl cho relative path, encode ký tự đặc biệt
    private string NormalizeUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url)) return "";
        // Full URL hoặc base64 data: → giữ nguyên
        if (url.StartsWith("http://") || url.StartsWith("https://") || url.StartsWith("data:"))
            return url;
        // Relative path → gắn BaseAddress của API (từ ApiBaseUrl trong appsettings)
        var baseUrl = Http.BaseAddress?.ToString().TrimEnd('/') ?? "";
        // Encode từng segment để xử lý tên file có khoảng trắng/ký tự đặc biệt
        var parts = url.TrimStart('/').Split('/');
        for (int i = 0; i < parts.Length; i++)
            parts[i] = Uri.EscapeDataString(parts[i]);
        return $"{baseUrl}/{string.Join("/", parts)}";
    }

    private async Task PrintReport()
    {
        await JS.InvokeVoidAsync("waitImagesAndPrint", "rpt-root");
    }

    private static string GetFinalBadgeClass(string? result) => result?.ToUpper() switch
    {
        "PASSED" or "PASS" => "final-pass",
        "FAILED" or "FAIL" => "final-fail",
        _                  => "final-na"
    };

    // ── Computed page count properties ──
    // Layout: 1(Cover) + 1(A) + cartonCount×4(B) + 2(C1+C2) + perfCount(D) + 3(E,F,Final)
    int CartonPageCount => (_qcData?.Packaging?.CartonDataList?.Count > 0
        ? _qcData.Packaging.CartonDataList.Count : 1) * 4;
    int PerfPageCount   => _qcData?.PerformanceTests?.Count > 0
        ? _qcData.PerformanceTests.Count
        : (_data?.PerformanceTests?.Count > 0 ? _data.PerformanceTests.Count : 1);
    int TotalPages => 2 + CartonPageCount + 2 + PerfPageCount + 3;

