    // ─── Lifecycle ───
    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        _loading = false;
    }

    private async Task LoadData()
    {
        try
        {
            var opts = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };

            // Load inspection detail (General info, Packaging, ProductSpec, etc.)
            _data = await Http.GetFromJsonAsync<InspectionDetailDto>(
                $"api/inspections/{InspectionId}", opts);

            if (_data == null)
            {
                _error = "Inspection not found.";
                return;
            }

            // Parse QcResultJson từ response (không cần endpoint riêng)
            if (!string.IsNullOrWhiteSpace(_data.QcResultJson))
            {
                try
                {
                    _qcData = JsonSerializer.Deserialize<QcResultDto>(
                        _data.QcResultJson, opts);
                }
                catch
                {
                    _qcData = null;
                }
            }
        }
        catch (Exception ex)
        {
            _error = $"Failed to load report: {ex.Message}";
        }
    }

    private void GoBack() => Navigation.NavigateTo("/inspection-schedule");

    // Chuẩn hóa URL ảnh: prefix ApiBaseUrl cho relative path, encode ký tự đặc biệt
    private string NormalizeUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url)) return "";
        // Full URL hoặc base64 data: → giữ nguyên
        if (url.StartsWith("http://") || url.StartsWith("https://") || url.StartsWith("data:"))
            return url;
        // Relative path → gắn BaseAddress của API (từ ApiBaseUrl trong appsettings)
        var baseUrl = Http.BaseAddress?.ToString().TrimEnd('/') ?? "";
        // Encode từng segment để xử lý tên file có khoảng trắng/ký tự đặc biệt
        var parts = url.TrimStart('/').Split('/');
        for (int i = 0; i < parts.Length; i++)
            parts[i] = Uri.EscapeDataString(parts[i]);
        return $"{baseUrl}/{string.Join("/", parts)}";
    }

    // Trạng thái đang xử lý (để disable nút tránh user click liên tục)
    private bool _isPrinting;

    /// <summary>
    /// Trigger trình duyệt mở dialog Print. User chọn "Save as PDF" trong
    /// dialog để xuất PDF với tên file = "{JobNumber}_{ddMMyyyy}".
    ///
    /// Cách này hoạt động ở mọi môi trường (Local, Azure Windows, Azure Static
    /// Apps) — không phụ thuộc browser headless / Chromium / Puppeteer.
    /// </summary>
    private async Task PrintReport()
    {
        if (_isPrinting) return;
        _isPrinting = true;
        StateHasChanged();

        try
        {
            // Đặt tên file PDF mặc định = "{JobNumber}_{ddMMyyyy}".
            // Browser dùng document.title làm tên file mặc định khi Save as PDF.
            var jobNumber = !string.IsNullOrWhiteSpace(_data?.JobNumber)
                ? _data!.JobNumber!
                : $"Inspection-{InspectionId}";

            var inspDate = _data?.InspectionDate ?? DateTime.Today;
            var dateStr  = inspDate.ToString("ddMMyyyy",
                System.Globalization.CultureInfo.InvariantCulture);

            var rawFileName  = $"{jobNumber}_{dateStr}";
            var safeFileName = System.Text.RegularExpressions.Regex.Replace(
                rawFileName, @"[\\/:*?""<>|]", "_").Trim();

            try
            {
                // Lưu title hiện tại để restore sau khi in xong
                var originalTitle = await JS.InvokeAsync<string>("eval", "document.title");

                // Set title = file name → tên file PDF mặc định
                await JS.InvokeVoidAsync("eval",
                    $"document.title = {System.Text.Json.JsonSerializer.Serialize(safeFileName)};");

                // Trước khi print: gỡ class page-break-after khỏi section cuối cùng
                // có class này (tránh trang trắng cuối khi các section sau bị skip
                // vì IsPass=false).
                await JS.InvokeVoidAsync("eval", @"
                    (function(){
                        var sections = document.querySelectorAll('#rpt-root .rpt-section.page-break-after');
                        if (!sections.length) return;
                        var last = sections[sections.length - 1];
                        var next = last.nextElementSibling;
                        while (next && !next.classList.contains('rpt-section')) {
                            next = next.nextElementSibling;
                        }
                        if (!next || next.classList.contains('rpt-section-final')) {
                            last.classList.remove('page-break-after');
                            last.setAttribute('data-pba-removed', '1');
                        }
                    })();
                ");

                // Trigger print (waitImagesAndPrint đợi ảnh load xong rồi mới in)
                await JS.InvokeVoidAsync("waitImagesAndPrint", "rpt-root");

                // Sau print: phục hồi class page-break-after đã gỡ tạm thời
                await JS.InvokeVoidAsync("eval", @"
                    setTimeout(function(){
                        var el = document.querySelector('#rpt-root .rpt-section[data-pba-removed]');
                        if (el) {
                            el.classList.add('page-break-after');
                            el.removeAttribute('data-pba-removed');
                        }
                    }, 1500);
                ");

                // Restore title sau 1s (đợi dialog Print hiện hoàn toàn)
                await JS.InvokeVoidAsync("eval",
                    $"setTimeout(function(){{ document.title = {System.Text.Json.JsonSerializer.Serialize(originalTitle ?? "Inspection Report")}; }}, 1000);");
            }
            catch
            {
                // Fallback: print không đổi title
                await JS.InvokeVoidAsync("waitImagesAndPrint", "rpt-root");
            }
        }
        finally
        {
            _isPrinting = false;
            StateHasChanged();
        }
    }

    private static string GetFinalBadgeClass(string? result) => result?.ToUpper() switch
    {
        "PASSED" or "PASS" => "final-pass",
        "FAILED" or "FAIL" => "final-fail",
        _                  => "final-na"
    };

    // Helper: kiểm tra Overall Conclusion letter có Compliance = Pass không
    bool IsPass(string letter)
    {
        // Ưu tiên _qcData, fallback _data
        var qcOc   = _qcData?.OverallConclusions?.FirstOrDefault(o => o.Letter == letter);
        if (qcOc != null) return qcOc.Compliance == "Pass";
        var dataOc = _data?.OverallConclusions?.FirstOrDefault(o => o.Letter == letter);
        return dataOc?.Compliance == "Pass";
    }

    // ── Computed page count properties ──
    // Layout: 1(Cover) + 1(A) + cartonCount×5(B: i, ii+iii, iv, v, vi) + 2(C1+C2) + perfCount(D) + 3(E,F,Final)
    int CartonPageCount => (_qcData?.Packaging?.CartonDataList?.Count > 0
        ? _qcData.Packaging.CartonDataList.Count : 1) * 5;
    int PerfPageCount   => _qcData?.PerformanceTests?.Count > 0
        ? _qcData.PerformanceTests.Count
        : (_data?.PerformanceTests?.Count > 0 ? _data.PerformanceTests.Count : 1);
    int TotalPages => 2 + CartonPageCount + 2 + PerfPageCount + 3;

