        text-align: right; flex: 1 1 auto; min-width: 0;
    }
    .rpt-main-title {
        font-size: 26px; font-weight: 800;
        color: var(--text); letter-spacing: .04em; line-height: 1.1;
    }
    .rpt-job-no {
        font-size: 14px; font-weight: 600;
        color: var(--brand); margin-top: 6px;
    }

    /* ══════════════════════════════════════════
       SECTION TITLES
    ══════════════════════════════════════════ */
    .rpt-section-title {
        font-size: 13px; font-weight: 700;
        color: var(--text); text-align: center;
        letter-spacing: .08em; text-transform: uppercase;
        margin: 18px 0 10px;
    }
    .rpt-section-title-lg {
        font-size: 16px; text-align: left;
        padding-bottom: 8px;
        border-bottom: 2px solid var(--brand);
        color: var(--brand-dark); margin-top: 0;
    }
    .rpt-sub-title {
        font-size: 13px; font-weight: 700;
        color: var(--text); margin: 14px 0 6px;
        display: flex; align-items: center; gap: 12px;
    }
    .rpt-result-inline { display: none; }

    /* ══════════════════════════════════════════
       GENERAL INFO TABLE
    ══════════════════════════════════════════ */
    .rpt-info-table {
        width: 100%; border-collapse: collapse;
        font-size: 12px; margin-bottom: 6px;
    }
    .rpt-info-table td { padding: 7px 10px; border: 1px solid var(--border); }
    .rpt-info-label {
        background: #f4f7fc; font-weight: 600;
        color: var(--text); width: 150px; white-space: nowrap;
    }
    .rpt-info-val { color: var(--text); }

    /* ══════════════════════════════════════════
       RESULT TABLE
    ══════════════════════════════════════════ */
    .rpt-result-table {
        width: 100%; border-collapse: collapse;
        font-size: 12px; margin-top: 6px;
    }
    .rpt-result-table th, .rpt-result-table td {
        border: 1px solid var(--border);
        padding: 7px 10px; color: var(--text);
    }
    .rpt-result-table tbody td { color: #1a1a2e; background: white; }
    .rpt-result-table tbody tr:nth-child(even) td { background: #fafbfc; }
    .rpt-result-table thead th {
        background: #1a2a4a; color: white !important;
        font-weight: 700; font-size: 11px;
        text-transform: uppercase; letter-spacing: .04em;
    }
    .rpt-th-label  { width: 38%; }
    .rpt-th-comp   { width: 14%; text-align: center; }
    .rpt-th-remark { width: 48%; }
    .rpt-td-center { text-align: center; }

    /* ══════════════════════════════════════════
       COMPLIANCE BADGE
    ══════════════════════════════════════════ */
    .rpt-compliance-badge {
        display: inline-block;
        font-size: 10px; font-weight: 700;
        padding: 2px 9px; border-radius: 10px;
        text-transform: uppercase; letter-spacing: .04em;
    }
    .comp-passed, .comp-pass   { background: #e8f5e9; color: #2e7d32; }
    .comp-failed, .comp-fail   { background: #fce4ec; color: #c62828; }
    .comp-na, .comp-none, .comp- { background: #f0f0f0; color: #555; }
    .comp-yes                  { background: #e8f5e9; color: #2e7d32; }
    .comp-no                   { background: #fce4ec; color: #c62828; }
    .rpt-compliance-badge      { color: #333; }

    /* ══════════════════════════════════════════
       PHOTO GRID — ★ FIX CHÍNH ★
       Đổi từ display:grid sang flex-wrap. Lý do:
       - Safari KHÔNG honor break-inside:avoid trên grid item
         → ảnh bị cắt giữa trang khi xuất PDF.
       - Chrome khi cell quá cao gặp cuối trang sẽ đẩy 1 ảnh/dòng.
       - Flex item handle break-inside đúng trên cả 2 engine.
    ══════════════════════════════════════════ */
    .rpt-photo-grid-2 {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin: 10px 0;
    }
    .rpt-photo-cell {
        flex: 0 0 calc(50% - 6px);
        max-width: calc(50% - 6px);
        box-sizing: border-box;
        border: 1px solid var(--border);
        border-radius: 6px;
        overflow: hidden;
        background: #fafbfc;
        height: 350px;
        display: block;
        break-inside: avoid;
        page-break-inside: avoid;
        -webkit-column-break-inside: avoid;
    }
    .rpt-photo-cell img.rpt-photo {
        width: 100%;
        height: 100% !important;
        object-fit: contain;
        display: block;
    }
    .rpt-photo {
        width: 100%; height: 350px;
        object-fit: contain; object-position: center;
        display: block; vertical-align: top;
        flex-shrink: 0;
    }

    /* Overview photo */
    .rpt-overview-photo-wrap { margin: 10px 0; }
    .rpt-overview-photo-cell {
        border: 1px solid var(--border);
        border-radius: 8px; overflow: hidden;
        background: #fafbfc; display: block;
    }
    .rpt-overview-img {
        width: 100%; height: 350px;
        object-fit: contain; object-position: center;
        display: block; vertical-align: top;
        background: #fafbfc;
    }
    .rpt-photo-empty-lg {
        height: 350px;
        display: flex; align-items: center; justify-content: center;
        font-size: 13px; color: #bbb;
        background: #fafbfc;
        border-radius: 8px;
        border: 1px dashed #ddd;
    }
    .rpt-photo-label {
        padding: 6px 10px;
        font-size: 11px; color: var(--text-muted);
        background: #f9f9f9;
        border-top: 1px solid var(--border);
    }
    .rpt-photo-remark {
        padding: 6px 10px;
        font-size: 11px; color: #555;
        background: #f9f9f9;
        border-top: 1px solid var(--border);
    }
    .rpt-photo-empty {
        height: 210px;
        display: flex; align-items: center; justify-content: center;
        font-size: 12px; color: #bbb;
        background: #fafbfc;
        border-radius: 6px;
        border: 1px dashed #ddd;
    }
    .rpt-photo-placeholder { background: transparent; border: none; }

    /* ══════════════════════════════════════════
       QTY TABLE & PHOTO GRID (Section A)
    ══════════════════════════════════════════ */
    .rpt-qty-table {
        width: 100%; border-collapse: collapse;
        font-size: 11px; margin-bottom: 14px;
        border: 1px solid #b8c8de;
    }
    .rpt-qty-table th, .rpt-qty-table td {
        border: 1px solid #b8c8de;
        padding: 6px 7px; text-align: center;
        color: #1a1a2e;
    }
    .rpt-qty-table thead th {
        background: white; color: #1a1a2e !important;
        font-weight: 700; font-size: 10px;
        border-bottom: 1px solid #b8c8de;
    }
    .rpt-qty-table tbody td { color: #1a1a2e; background: white; height: 32px; }
    .rpt-qty-data-row td { height: 36px; }
    .rpt-total-row td {
        font-weight: 700; background: white;
        color: #1a1a2e; border-top: 1px solid #b8c8de;
    }
    .rpt-total-label { text-align: right; font-weight: 700; }

    /* ★ Quantity photo grid: cũng dùng flex-wrap ★ */
    .rpt-qty-photo-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 12px;
    }
    .rpt-qty-photo-cell {
        flex: 0 0 calc(50% - 6px);
        max-width: calc(50% - 6px);
        box-sizing: border-box;
        border: 1px solid #b8c8de;
        height: 350px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: white;
        overflow: hidden;
        break-inside: avoid;
        page-break-inside: avoid;
        -webkit-column-break-inside: avoid;
    }
    .rpt-qty-photo-img {
        width: 100%; height: 350px;
        object-fit: contain; display: block;
        vertical-align: top;
    }

    /* ══════════════════════════════════════════
       PACKAGING / SPEC / SWATCH / PERF TABLES
    ══════════════════════════════════════════ */
    .rpt-pkg-table { margin-bottom: 16px; }

    .rpt-spec-table {
        width: 100%; border-collapse: collapse;
        font-size: 12px; margin-bottom: 10px;
    }
    .rpt-spec-table th, .rpt-spec-table td {
        border: 1px solid var(--border);
        padding: 7px 10px; text-align: center;
    }
    .rpt-spec-table thead th { background: #f4f7fc; font-weight: 700; color: #1a1a2e; }
    .rpt-spec-table td { color: #1a1a2e; background: white; }

    .rpt-swatch-table {
        width: 100%; border-collapse: collapse;
        font-size: 12px; margin-bottom: 10px;
    }
    .rpt-swatch-table th, .rpt-swatch-table td {
        border: 1px solid var(--border); padding: 7px 10px;
    }
    .rpt-swatch-table thead th { background: #f4f7fc; font-weight: 700; color: #1a1a2e; }
    .rpt-swatch-table td { color: #1a1a2e; background: white; }

    .rpt-perf-table {
        width: 100%; border-collapse: collapse;
        font-size: 12px; margin-bottom: 14px;
    }
    .rpt-perf-table td {
        border: 1px solid var(--border); padding: 7px 10px;
        color: #1a1a2e; background: white;
    }
    .rpt-perf-table-h th {
        border: 1px solid var(--border);
        padding: 8px 10px;
        font-size: 11px; font-weight: 700;
        color: var(--text); background: #f3f6fb;
        text-align: center; text-transform: uppercase;
        letter-spacing: .3px;
    }
    .rpt-perf-table-h td { vertical-align: middle; }
    .rpt-perf-table .tc { text-align: center; }

    /* ══════════════════════════════════════════
       AQL SECTION
    ══════════════════════════════════════════ */
    .rpt-aql-label {
        font-size: 12px; font-weight: 700;
        color: var(--text); margin-bottom: 8px;
    }
    .rpt-aql-row {
        display: flex; gap: 24px;
        margin-bottom: 12px;
    }
    .rpt-aql-item {
        display: flex; align-items: center; gap: 8px;
        font-size: 12px;
    }
    .rpt-aql-key { font-weight: 600; color: var(--text-muted); }
    .rpt-aql-val { font-weight: 700; color: var(--text); }

    .rpt-aql-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 12px;
        margin-bottom: 12px;
    }
    .rpt-aql-box {
        border-radius: 8px;
        padding: 12px;
        font-size: 12px;
        color: #333;
    }
    .aql-critical { background: #fff3f3; border: 1px solid #ffc0c0; }
    .aql-major    { background: #fff8ee; border: 1px solid #ffd99f; }
    .aql-minor    { background: #f0fff4; border: 1px solid #a3e4b7; }

    .rpt-aql-box-title {
        font-size: 11px; font-weight: 800;
        text-transform: uppercase; letter-spacing: .05em;
        margin-bottom: 8px;
    }
    .aql-critical .rpt-aql-box-title { color: #c0392b; }
    .aql-major    .rpt-aql-box-title { color: #e67e22; }
    .aql-minor    .rpt-aql-box-title { color: #27ae60; }

    .rpt-aql-box-row {
        display: grid;
        grid-template-columns: 1fr auto;
        align-items: baseline;
        gap: 8px;
        padding: 3px 0;
        border-bottom: 1px solid rgba(0,0,0,.06);
        font-size: 11px;
        color: #333;
    }
    .rpt-aql-box-row > span:last-child {
        font-weight: 700;
        color: #1a1a2e;
        text-align: right;
        white-space: nowrap;
    }
    .rpt-aql-box-row:last-child { border-bottom: none; }

    /* ══════════════════════════════════════════
       DEFECT SECTION — ★ cũng đổi sang flex item ★
    ══════════════════════════════════════════ */
    .rpt-defect-type-title {
        font-size: 13px; font-weight: 800;
        padding: 4px 12px; border-radius: 6px;
        margin: 14px 0 8px;
        display: inline-block;
    }
    .defect-critical { background: #fce4ec; color: #c62828; }
    .defect-major    { background: #fff3e0; color: #e65100; }
    .defect-minor    { background: #e8f5e9; color: #2e7d32; }

    .rpt-defect-cell {
        flex: 0 0 calc(50% - 6px);
        max-width: calc(50% - 6px);
        box-sizing: border-box;
        border: 1px solid var(--border);
        border-radius: 6px;
        overflow: hidden;
        background: #fafbfc;
        display: flex;
        flex-direction: column;
        height: 350px;
        break-inside: avoid;
        page-break-inside: avoid;
        -webkit-column-break-inside: avoid;
    }
    .rpt-defect-photo-wrap {
        flex: 1 1 auto;
        min-height: 0;
        overflow: hidden;
        background: #f5f7fb;
        position: relative;
    }
    .rpt-defect-photo {
        width: 100%; height: 100%;
        object-fit: contain; display: block;
        vertical-align: top;
    }
    .rpt-defect-no-photo {
        width: 100%; height: 100%;
        display: flex; align-items: center; justify-content: center;
        font-size: 12px; color: #bbb;
        background: #f5f7fb;
        border: 1px dashed #ddd;
        border-radius: 4px;
        box-sizing: border-box;
    }
    .rpt-defect-empty {
        padding: 14px 16px; margin-bottom: 10px;
        background: #f5f7fb;
        border: 1px dashed #d0d7e2;
        border-radius: 6px;
        font-size: 12px; color: #6b7c93;
        font-style: italic; text-align: center;
    }
    .rpt-no-defects {
        padding: 18px 20px; margin: 8px 0 16px;
        background: #f5f9f5;
        border: 1px dashed #c8d8c8;
        border-radius: 6px;
        font-size: 13px; color: #5a8a5a;
        font-style: italic; text-align: center;
    }
    .rpt-defect-remark {
        padding: 5px 10px;
        font-size: 11px; color: #555;
        background: #f9f9f9;
        border-top: 1px solid var(--border);
        height: 36px;
        flex: 0 0 36px;
        line-height: 26px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        box-sizing: border-box;
    }

    /* ══════════════════════════════════════════
       FINAL RESULT & SIGNATURE
    ══════════════════════════════════════════ */
    .rpt-sign-table {
        width: 100%; border-collapse: collapse;
        font-size: 13px; margin-bottom: 16px;
    }
    .rpt-sign-table td {
        border: 1px solid var(--border); padding: 14px 16px;
        color: #1a1a2e !important; background: white;
    }
    .rpt-sign-label {
        background: #f4f7fc !important; font-weight: 600;
        color: #1a1a2e !important;
        width: 160px; white-space: nowrap;
    }
    .rpt-comments-cell { min-height: 80px; }
    .rpt-sign-cell { height: 90px; vertical-align: middle; }
    .rpt-signature { max-height: 70px; max-width: 200px; object-fit: fill; }
    .rpt-sign-name { font-size: 13px; font-weight: 600; color: #333 !important; display: block; margin-bottom: 4px; }
    .rpt-sign-id   { font-size: 11px; color: #888 !important; display: block; }
    .rpt-sign-placeholder { color: #bbb; font-size: 12px; }

    .rpt-final-result-wrap {
        display: flex; align-items: center; gap: 16px;
        justify-content: flex-end;
        margin: 12px 0 20px;
        font-size: 14px; font-weight: 700; color: var(--text);
    }
    .rpt-final-label { font-size: 13px; color: var(--text-muted); }
    .rpt-final-badge {
        font-size: 14px; font-weight: 800;
        padding: 6px 22px; border-radius: 8px;
        letter-spacing: .06em; text-transform: uppercase;
        -webkit-print-color-adjust: exact !important;
        print-color-adjust: exact !important;
        color-adjust: exact !important;
    }
    .final-pass { background: #e8f5e9; color: #2e7d32; border: 2px solid #a5d6a7; }
    .final-fail { background: #fce4ec; color: #c62828; border: 2px solid #ef9a9a; }
    .final-na   { background: #f5f5f5; color: #888;    border: 2px solid #e0e0e0; }

    .rpt-compliance-clause {
        background: #f9f9f9; border-radius: 6px;
        padding: 12px 16px; font-size: 11px; color: #555;
        border-left: 3px solid var(--border);
    }
    .rpt-compliance-clause strong { font-size: 12px; color: var(--text); display: block; margin-bottom: 6px; }

    .rpt-end-line {
        display: flex; align-items: center; gap: 12px;
        margin: 20px 0 4px;
        font-size: 13px; color: var(--text-muted); font-weight: 600;
    }
    .rpt-end-line hr { flex: 1; border: none; border-top: 1px solid var(--border); }

    /* ══════════════════════════════════════════
       FOOTER
    ══════════════════════════════════════════ */
    .rpt-footer {
        position: absolute;
        bottom: 0; left: 0; right: 0;
        padding: 8px 32px 10px;
        border-top: 1px solid #f0f0f0;
        background: white;
    }
    .rpt-footer-inner {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 12px;
    }
    .rpt-footer-text {
        font-size: 9px; color: #bbb;
        line-height: 1.5; flex: 1; text-align: center;
    }
    .rpt-footer-page {
        font-size: 11px; font-weight: 700;
        color: #aaa; white-space: nowrap;
        flex-shrink: 0; align-self: flex-end;
        padding-left: 12px;
        border-left: 1px solid #e0e0e0;
    }

    /* ══════════════════════════════════════════
       EMPTY / ERROR STATES
    ══════════════════════════════════════════ */
    .rpt-no-data {
        font-size: 12px; color: var(--text-muted);
        padding: 16px; background: #fafbfc;
        border-radius: 6px; border: 1px dashed #ddd;
        text-align: center;
    }
    .rpt-loading {
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        gap: 14px; min-height: 50vh;
        color: #888; font-size: 14px;
    }
    .rpt-spinner {
        width: 36px; height: 36px;
        border: 3px solid #e0e7ef;
        border-top-color: var(--brand);
        border-radius: 50%;
        animation: spin .8s linear infinite;
    }
    @@keyframes spin { to { transform: rotate(360deg); } }
    .rpt-error {
        display: flex; flex-direction: column;
        align-items: center; gap: 12px;
        padding: 48px 24px;
        font-size: 14px; color: #555;
    }

    /* ══════════════════════════════════════════════════════════════
       PRINT STYLES — ★★★ FIX: 6 ẢNH/TRANG ĐOÁN ĐỊNH ★★★
       ═══════════════════════════════════════════════════════════════
       Chiến lược mới (giải quyết triệt để vấn đề trang trắng):
       - Mỗi sub-section được pre-chunked ở Razor: max 6 ảnh/trang.
       - Trang có table phía trên (A, B-i, C, D) → trang đầu max 4 ảnh.
       - Mỗi chunk = 1 .rpt-section riêng → page-break-after: always vừa khít.
       - Layout đoán định 100%, không phụ thuộc browser.

       Math A4: 297mm cao - 12mm top - 14mm bottom = 271mm vùng print
                Heading lg ~10mm + sub-title ~7mm + 3 hàng ảnh (3 x 75mm + 2 x 6mm gap = 237mm)
                ~ 254mm — vừa đúng 1 trang.
    ══════════════════════════════════════════════════════════════ */
    @@media print {
        @@page {
            size: A4 portrait;
            margin: 0;
        }

        html, body {
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
            margin: 0 !important;
            padding: 0 !important;
        }

        .rpt-final-badge,
        .rpt-aql-box,
        .rpt-aql-box-title,
        .rpt-defect-type-title,
        .rpt-section-title,
        .rpt-result-pass,
        .rpt-result-fail,
        .final-pass, .final-fail, .final-na,
        .aql-critical, .aql-major, .aql-minor,
        .defect-critical, .defect-major, .defect-minor {
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
            color-adjust: exact !important;
        }

        .no-print { display: none !important; }
        nav, header, .navbar, .sidebar,
        .top-bar, .main-nav, .nav-bar, .app-nav,
        .top-menu, .side-menu, .menu-bar,
        [class*="nav"], [class*="header"]:not(.rpt-cover-header):not(.rpt-section-header) {
            display: none !important;
        }

        html, body { background: white !important; }
        .rpt-page {
            background: white !important;
            min-height: 0 !important;
            padding: 0 !important;
            margin: 0 !important;
        }

        .rpt-paper {
            max-width: 210mm !important;
            width: 210mm !important;
            min-width: 210mm !important;
            margin: 0 auto !important;
            padding: 0 !important;
            background: white !important;
            box-sizing: border-box !important;
        }

        .rpt-section {
            background: white !important;
            border-radius: 0 !important;
            box-shadow: none !important;
            margin: 0 !important;
            width: 100% !important;
            min-height: 0 !important;
            height: auto !important;
            max-height: none !important;
            overflow: hidden !important;
            padding: 12mm 14mm 14mm !important;
            counter-increment: page-counter;
            position: relative !important;
            box-sizing: border-box !important;
            /* ★ Section đã pre-chunked ≤ 6 ảnh = vừa 1 trang.
               break-inside:avoid để section LUÔN nằm gọn trong 1 trang. */
            break-inside: avoid !important;
            page-break-inside: avoid !important;
        }

        .page-break-after {
            break-after: page !important;
            page-break-after: always !important;
        }
        .page-break-after:last-child,
        .page-break-after:last-of-type {
            break-after: auto !important;
            page-break-after: auto !important;
        }
        .rpt-section.page-break-after + .rpt-section-final {
            break-before: page !important;
            page-break-before: always !important;
        }

        .rpt-section-final {
            height: auto !important;
            min-height: 0 !important;
            overflow: visible !important;
            break-before: page !important;
            page-break-before: always !important;
            break-after: avoid !important;
