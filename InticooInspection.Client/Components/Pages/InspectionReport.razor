                                        <td class="rpt-info-val" style="white-space:pre-wrap;line-height:1.6">@dTestProto</td>
                                    </tr>
                                </tbody>
                            </table>
                        }
                        @{
                            // Trang đầu D có table + protocol → chỉ chứa được ~2 ảnh
                            var _dFirst = dPhotos.Take(2).Cast<string?>().ToList();
                            if (_dFirst.Count > 0 && _dFirst.Count % 2 != 0) _dFirst.Add(null);
                            if (_dFirst.Count == 0) _dFirst = new List<string?> { null, null };
                            var _dRest = dPhotos.Count > 2 ? ChunkPhotosForPages(dPhotos.Skip(2)) : new List<List<string?>>();
                        }
                        <div class="rpt-photo-grid-2">
                            @foreach (var _du in _dFirst)
                            {
                                <div class="rpt-photo-cell">
                                    @if (!string.IsNullOrEmpty(_du))
                                    { <img src="@NormalizeUrl(_du)" class="rpt-photo" alt="Performance test photo" loading="eager"/> }
                                </div>
                            }
                        </div>
                        <div class="rpt-footer">
                            <div class="rpt-footer-inner">
                                <span class="rpt-footer-text">www.inticoo.com<br/>The results presented herein reflect our findings at the time and place of inspection. This report does not release the seller or manufacturer from their contractual obligations, nor does it prejudice the buyer's right to seek compensation for any apparent or latent defects not identified during our random inspection or arising thereafter. This document does not constitute evidence of shipment. Final approval from the client is required prior to the release of the goods.</span>
                                <span class="rpt-footer-page">@(2 + CartonPageCount + 2 + dIdx) / @TotalPages</span>
                            </div>
                        </div>
                    </div>

                    @* Trang Performance Testing tiếp theo (nếu > 2 ảnh) *@
                    @foreach (var _dPage in _dRest)
                    {
                        <div class="rpt-section page-break-after">
                            <div class="rpt-section-title rpt-section-title-lg">D. Performance Testing@(dSuffix) (cont.)</div>
                            <div class="rpt-photo-grid-2">
                                @foreach (var _du in _dPage)
                                {
                                    <div class="rpt-photo-cell">
                                        @if (!string.IsNullOrEmpty(_du))
                                        { <img src="@NormalizeUrl(_du)" class="rpt-photo" alt="Performance test photo" loading="eager"/> }
                                    </div>
                                }
                            </div>
                            <div class="rpt-footer">
                                <div class="rpt-footer-inner">
                                    <span class="rpt-footer-text">www.inticoo.com<br/>The results presented herein reflect our findings at the time and place of inspection. This report does not release the seller or manufacturer from their contractual obligations, nor does it prejudice the buyer's right to seek compensation for any apparent or latent defects not identified during our random inspection or arising thereafter. This document does not constitute evidence of shipment. Final approval from the client is required prior to the release of the goods.</span>
                                </div>
                            </div>
                        </div>
                    }
                }
            }
            else if (_legacyPerf != null)
            {
                @for (int di = 0; di < _legacyPerf.Count; di++)
                {
                    var dIdx    = di;
                    var t       = _legacyPerf[dIdx];
                    var dSuffix = _legacyPerf.Count > 1 ? $" ({dIdx + 1}/{_legacyPerf.Count})" : "";
                    <div class="rpt-section page-break-after">
                        <div class="rpt-section-title rpt-section-title-lg">D. Performance Testing@(dSuffix)</div>
                        <table class="rpt-perf-table rpt-perf-table-h">
                            <thead>
                                <tr>
                                    <th style="width:48px">NO</th>
                                    <th>TEST ITEM</th>
                                    <th>TEST REQUIREMENT</th>
                                    <th style="width:90px">TEST QUANTITY</th>
                                    <th>REMARK</th>
                                    <th style="width:90px">RESULT</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="tc">@(dIdx + 1)</td>
                                    <td>@(t.TestItem ?? "—")</td>
                                    <td>@(t.TestRequirement ?? "—")</td>
                                    <td class="tc">—</td>
                                    <td>@(string.IsNullOrWhiteSpace(t.Remark) ? "—" : t.Remark)</td>
                                    <td class="tc">—</td>
                                </tr>
                            </tbody>
                        </table>
                        @if (!string.IsNullOrWhiteSpace(t.TestProtocol))
                        {
                            <table class="rpt-perf-table" style="margin-top:6px">
                                <tbody>
                                    <tr>
                                        <td class="rpt-info-label" style="vertical-align:top;width:140px">Test Protocol</td>
                                        <td class="rpt-info-val" style="white-space:pre-wrap;line-height:1.6">@t.TestProtocol</td>
                                    </tr>
                                </tbody>
                            </table>
                        }
                        <div class="rpt-footer">
                            <div class="rpt-footer-inner">
                                <span class="rpt-footer-text">www.inticoo.com<br/>The results presented herein reflect our findings at the time and place of inspection. This report does not release the seller or manufacturer from their contractual obligations, nor does it prejudice the buyer's right to seek compensation for any apparent or latent defects not identified during our random inspection or arising thereafter. This document does not constitute evidence of shipment. Final approval from the client is required prior to the release of the goods.</span>
                                <span class="rpt-footer-page">@(2 + CartonPageCount + 2 + dIdx) / @TotalPages</span>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="rpt-section page-break-after">
                    <div class="rpt-section-title rpt-section-title-lg">D. Performance Testing</div>
                    <div class="rpt-no-data">No performance testing data recorded.</div>
                    <div class="rpt-footer">
                        <div class="rpt-footer-inner">
                            <span class="rpt-footer-text">www.inticoo.com<br/>The results presented herein reflect our findings at the time and place of inspection. This report does not release the seller or manufacturer from their contractual obligations, nor does it prejudice the buyer's right to seek compensation for any apparent or latent defects not identified during our random inspection or arising thereafter. This document does not constitute evidence of shipment. Final approval from the client is required prior to the release of the goods.</span>
                            <span class="rpt-footer-page">@(2 + CartonPageCount + 2) / @TotalPages</span>
                        </div>
                    </div>
                </div>
            }
            } @* end IsPass("D") *@

            <!-- ══ SECTION E: Appearance & Craftsmanship (AQL) ══ -->
            @if (IsPass("E"))
            {
            <div class="rpt-section page-break-after">
                <div class="rpt-section-title rpt-section-title-lg">E. Appearance &amp; Craftsmanship</div>

                @{
                    // DB values cho SampleSize/Accept/Reject (chính xác từ AQL table)
                    var aqlQty     = _data.AqlQuantity > 0 ? _data.AqlQuantity : (_qcData?.Aql?.Quantity ?? 0);
                    var aqlLvl     = _data.AqlLevel    ?? _qcData?.Aql?.InspectionLevel ?? "II";
                    var aqlCritAql = _data.AqlCritical ?? _qcData?.Aql?.CriticalAql ?? "Not Allowed";
                    var aqlMajAql  = _data.AqlMajor    ?? _qcData?.Aql?.MajorAql    ?? "2.5";
                    var aqlMinAql  = _data.AqlMinor    ?? _qcData?.Aql?.MinorAql    ?? "4.0";
                    var critSample = _data.AqlCriticalSampleSize > 0 ? _data.AqlCriticalSampleSize : (_qcData?.Aql?.CriticalSampleSize ?? 0);
                    var critAccept = _data.AqlCriticalAccept     > 0 ? _data.AqlCriticalAccept     : (_qcData?.Aql?.CriticalAccept     ?? 0);
                    var critReject = _data.AqlCriticalReject     > 0 ? _data.AqlCriticalReject     : (_qcData?.Aql?.CriticalReject     ?? 0);
                    var majSample  = _data.AqlMajorSampleSize    > 0 ? _data.AqlMajorSampleSize    : (_qcData?.Aql?.MajorSampleSize    ?? 0);
                    var majAccept  = _data.AqlMajorAccept        > 0 ? _data.AqlMajorAccept        : (_qcData?.Aql?.MajorAccept        ?? 0);
                    var majReject  = _data.AqlMajorReject        > 0 ? _data.AqlMajorReject        : (_qcData?.Aql?.MajorReject        ?? 0);
                    var minSample  = _data.AqlMinorSampleSize    > 0 ? _data.AqlMinorSampleSize    : (_qcData?.Aql?.MinorSampleSize    ?? 0);
                    var minAccept  = _data.AqlMinorAccept        > 0 ? _data.AqlMinorAccept        : (_qcData?.Aql?.MinorAccept        ?? 0);
                    var minReject  = _data.AqlMinorReject        > 0 ? _data.AqlMinorReject        : (_qcData?.Aql?.MinorReject        ?? 0);
                    var critFound  = _qcData?.Aql?.CriticalFound ?? 0;
                    var majFound   = _qcData?.Aql?.MajorFound    ?? 0;
                    var minFound   = _qcData?.Aql?.MinorFound    ?? 0;
                }
                @if (aqlQty > 0 || critSample > 0 || _qcData?.Aql != null)
                {
                    <div class="rpt-aql-label">AQL Sampling Simulator</div>
                    <div class="rpt-aql-row">
                        <div class="rpt-aql-item"><span class="rpt-aql-key">Quantity</span><span class="rpt-aql-val">@aqlQty</span></div>
                        <div class="rpt-aql-item"><span class="rpt-aql-key">Inspection Level</span><span class="rpt-aql-val">@aqlLvl</span></div>
                    </div>
                    <div class="rpt-aql-grid">
                        <div class="rpt-aql-box aql-critical">
                            <div class="rpt-aql-box-title">Critical Defects</div>
                            <div class="rpt-aql-box-row"><span>Select AQL</span><span>@(string.IsNullOrEmpty(aqlCritAql) ? "—" : aqlCritAql)</span></div>
                            <div class="rpt-aql-box-row"><span>Sample Size</span><span>@(critSample > 0 ? critSample.ToString() : "—")</span></div>
                            <div class="rpt-aql-box-row"><span>Accept Point</span><span>@(critAccept >= 0 && critSample > 0 ? critAccept.ToString() : "—")</span></div>
                            <div class="rpt-aql-box-row"><span>Reject Point</span><span>@(critReject > 0 ? critReject.ToString() : "—")</span></div>
                        </div>
                        <div class="rpt-aql-box aql-major">
                            <div class="rpt-aql-box-title">Major Defects</div>
                            <div class="rpt-aql-box-row"><span>Select AQL</span><span>@(string.IsNullOrEmpty(aqlMajAql) ? "—" : aqlMajAql)</span></div>
                            <div class="rpt-aql-box-row"><span>Sample Size</span><span>@(majSample > 0 ? majSample.ToString() : "—")</span></div>
                            <div class="rpt-aql-box-row"><span>Accept Point</span><span>@(majAccept >= 0 && majSample > 0 ? majAccept.ToString() : "—")</span></div>
                            <div class="rpt-aql-box-row"><span>Reject Point</span><span>@(majReject > 0 ? majReject.ToString() : "—")</span></div>
                        </div>
                        <div class="rpt-aql-box aql-minor">
                            <div class="rpt-aql-box-title">Minor Defects</div>
                            <div class="rpt-aql-box-row"><span>Select AQL</span><span>@(string.IsNullOrEmpty(aqlMinAql) ? "—" : aqlMinAql)</span></div>
                            <div class="rpt-aql-box-row"><span>Sample Size</span><span>@(minSample > 0 ? minSample.ToString() : "—")</span></div>
                            <div class="rpt-aql-box-row"><span>Accept Point</span><span>@(minAccept >= 0 && minSample > 0 ? minAccept.ToString() : "—")</span></div>
                            <div class="rpt-aql-box-row"><span>Reject Point</span><span>@(minReject > 0 ? minReject.ToString() : "—")</span></div>
                        </div>
                    </div>
                    <div class="rpt-aql-label" style="margin-top:16px;">RESULT</div>
                    <table class="rpt-result-table">
                        <thead>
                            <tr>
                                <th class="rpt-th-label">Details of Defect Found</th>
                                <th class="rpt-th-comp" style="color:#c0392b">Critical</th>
                                <th class="rpt-th-comp" style="color:#e67e22">Major</th>
                                <th class="rpt-th-comp" style="color:#27ae60">Minor</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Total Found</td>
                                <td class="rpt-td-center">@critFound</td>
                                <td class="rpt-td-center">@majFound</td>
                                <td class="rpt-td-center">@minFound</td>
                            </tr>
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="rpt-no-data">No AQL data recorded.</div>
                }

                <!-- Critical defects: tách thành các trang riêng, mỗi trang max 6 ảnh.
                     Trang đầu chỉ chứa AQL + Result (đã chiếm gần hết) — Critical
                     header + ảnh đầu tiên đặt ở trang đầu nếu có ≤ 2 defect, ngược
                     lại sang trang sau. -->
                @{
                    var _critDefects = _qcData?.Defects?.Where(d => d.Type == "Critical").ToList() ?? new();
                    var _critItems = _critDefects.SelectMany(def => {
                        var urls = (def.Photos?.Where(p => !string.IsNullOrWhiteSpace(p)).ToList())
                                   ?? (def.PhotoUrl != null ? new List<string> { def.PhotoUrl } : new List<string>());
                        return urls.Select((url, i) => (Url: (string?)url, Remark: def.Remarks?.ElementAtOrDefault(i) ?? def.Remark ?? ""));
                    }).ToList();
                    // Trang E đã đầy với AQL + Result → critical defects đặt cuối nếu còn chỗ
                    // (chỉ 0 ảnh trên trang E để an toàn)
                    bool _critOnSamePage = _critItems.Count == 0;  // chỉ render heading + 2 khung trống nếu rỗng
                    var _critPagesAll = _critItems.Count > 0
                        ? ChunkDefectsForPages(_critItems)
                        : new List<List<(string? Url, string Remark)>>();
                }
                <!-- Heading F + Critical luôn render ở cuối trang E (chỉ heading + 2 khung trống) -->
                <div class="rpt-section-title rpt-section-title-lg" style="margin-top:20px;">F. Details of Defect Found</div>
                <div class="rpt-defect-type-title defect-critical">Critical</div>
                @if (_critOnSamePage)
                {
                    <!-- Không có critical → 2 khung trống cho cân đối -->
                    <div class="rpt-photo-grid-2">
                        <div class="rpt-defect-cell">
                            <div class="rpt-defect-photo-wrap">
                                <div class="rpt-defect-no-photo">No Photo</div>
                            </div>
                            <div class="rpt-defect-remark">Remark: —</div>
                        </div>
                        <div class="rpt-defect-cell">
                            <div class="rpt-defect-photo-wrap">
                                <div class="rpt-defect-no-photo">No Photo</div>
                            </div>
                            <div class="rpt-defect-remark">Remark: —</div>
                        </div>
                    </div>
                }
                else
                {
                    <!-- Có critical defects → ghi chú "see next page" và đặt ảnh ở trang sau -->
                    <div style="text-align:center;color:#888;font-size:11px;padding:12px;">
                        See critical defect photos on the following page(s).
                    </div>
                }

                <div class="rpt-footer">
                    <div class="rpt-footer-inner">
                        <span class="rpt-footer-text">www.inticoo.com<br/>The results presented herein reflect our findings at the time and place of inspection. This report does not release the seller or manufacturer from their contractual obligations, nor does it prejudice the buyer's right to seek compensation for any apparent or latent defects not identified during our random inspection or arising thereafter. This document does not constitute evidence of shipment. Final approval from the client is required prior to the release of the goods.</span>
                        <span class="rpt-footer-page">@(2 + CartonPageCount + PerfPageCount + 2) / @TotalPages</span>
                    </div>
                </div>
            </div>

            @* Trang riêng cho Critical defects (mỗi trang max 6 ảnh) *@
            @foreach (var _critPage in _critPagesAll)
            {
                <div class="rpt-section page-break-after">
                    <div class="rpt-section-title rpt-section-title-lg">F. Details of Defect Found (cont.)</div>
                    <div class="rpt-defect-type-title defect-critical">Critical</div>
                    <div class="rpt-photo-grid-2">
                        @foreach (var slot in _critPage)
                        {
                            <div class="rpt-defect-cell">
                                <div class="rpt-defect-photo-wrap">
                                    @if (!string.IsNullOrEmpty(slot.Url))
                                    { <img src="@NormalizeUrl(slot.Url)" class="rpt-defect-photo" alt="Critical defect photo" loading="eager"/> }
                                    else
                                    { <div class="rpt-defect-no-photo">No Photo</div> }
                                </div>
                                <div class="rpt-defect-remark">Remark: @(string.IsNullOrEmpty(slot.Remark) ? "—" : slot.Remark)</div>
                            </div>
                        }
                    </div>
                    <div class="rpt-footer">
                        <div class="rpt-footer-inner">
                            <span class="rpt-footer-text">www.inticoo.com<br/>The results presented herein reflect our findings at the time and place of inspection. This report does not release the seller or manufacturer from their contractual obligations, nor does it prejudice the buyer's right to seek compensation for any apparent or latent defects not identified during our random inspection or arising thereafter. This document does not constitute evidence of shipment. Final approval from the client is required prior to the release of the goods.</span>
                        </div>
                    </div>
                </div>
            }
            } @* end IsPass("E") *@

            <!-- ══ SECTION F: Major + Minor Defects ══ -->
            @if (IsPass("F"))
            {
                @* Major + Minor defects: mỗi defect type chia thành các trang, mỗi trang max 6 ảnh.
                   Major và Minor không gộp chung 1 trang (đảm bảo layout rõ ràng). *@
                @foreach (var defType in new[] { "Major", "Minor" })
                {
                    var typeDefects = _qcData?.Defects?.Where(d => d.Type == defType).ToList() ?? new();
                    var photoItems = typeDefects
                        .SelectMany(def =>
                        {
                            var urls = (def.Photos?.Where(p => !string.IsNullOrWhiteSpace(p)).ToList())
                                       ?? (def.PhotoUrl != null ? new List<string> { def.PhotoUrl } : new List<string>());
                            return urls.Select((url, i) => (
                                Url: (string?)url,
                                Remark: def.Remarks?.ElementAtOrDefault(i) ?? def.Remark ?? ""
                            ));
                        })
                        .ToList();

                    var defectPages = ChunkDefectsForPages(photoItems);

                    @for (int _dpPi = 0; _dpPi < defectPages.Count; _dpPi++)
                    {
                        var defectPage = defectPages[_dpPi];
                        var defSuffix = defectPages.Count > 1 && _dpPi > 0 ? " (cont.)" : "";
                        <div class="rpt-section page-break-after">
                            <div class="rpt-section-title rpt-section-title-lg">F. Details of Defect Found (cont.)</div>
                            <div class="rpt-defect-type-title defect-@defType.ToLower()">@defType@defSuffix</div>
                            <div class="rpt-photo-grid-2">
                                @foreach (var slot in defectPage)
                                {
                                    <div class="rpt-defect-cell">
                                        <div class="rpt-defect-photo-wrap">
                                            @if (!string.IsNullOrEmpty(slot.Url))
                                            { <img src="@NormalizeUrl(slot.Url)" class="rpt-defect-photo" alt="@defType defect photo" loading="eager"/> }
                                            else
                                            { <div class="rpt-defect-no-photo">No Photo</div> }
                                        </div>
                                        <div class="rpt-defect-remark">Remark: @(string.IsNullOrEmpty(slot.Remark) ? "—" : slot.Remark)</div>
                                    </div>
                                }
                            </div>
                            <div class="rpt-footer">
                                <div class="rpt-footer-inner">
                                    <span class="rpt-footer-text">www.inticoo.com<br/>The results presented herein reflect our findings at the time and place of inspection. This report does not release the seller or manufacturer from their contractual obligations, nor does it prejudice the buyer's right to seek compensation for any apparent or latent defects not identified during our random inspection or arising thereafter. This document does not constitute evidence of shipment. Final approval from the client is required prior to the release of the goods.</span>
                                </div>
                            </div>
                        </div>
                    }
                }
            } @* end IsPass("F") *@

            <!-- ══ FINAL PAGE: Conclusion & Signature ══ -->
            <div class="rpt-section rpt-section-final">
                <div class="rpt-logo-wrap" style="margin-bottom:28px;">
                    <img src="/logo.png" class="rpt-logo-img" alt="inticoo logo"/>
                </div>

                <!-- Inspector Comments -->
                <table class="rpt-sign-table">
                    <tbody>
                        <tr>
                            <td class="rpt-sign-label">Inspector Comments</td>
                            <td class="rpt-sign-val rpt-comments-cell">
                                @(string.IsNullOrWhiteSpace(_data.InspectorComments) ? "—" : _data.InspectorComments)
                            </td>
                        </tr>
                    </tbody>
                </table>

                <!-- Final Result -->
                <div class="rpt-final-result-wrap">
                    <span class="rpt-final-label">FINAL RESULT</span>
                    <span class="rpt-final-badge @GetFinalBadgeClass(_data.FinalResult)">
                        @(_data.FinalResult?.ToUpper() ?? "N/A")
                    </span>
                </div>

                <!-- Compliance clause -->
                <div class="rpt-compliance-clause">
                    <strong>Compliance &amp; Integrity Clause</strong>
                    <p><em>All inspections follow the customer protocol, and any attempt to bribe, pressure, or threaten the inspector will render the inspection invalid and may lead to termination of the agreement and legal consequences.</em></p>
                </div>

                <!-- Signatures -->
                <table class="rpt-sign-table" style="margin-top:16px;">
                    <tbody>
                        <tr>
                            <td class="rpt-sign-label">Inspection by</td>
                            <td class="rpt-sign-val rpt-sign-cell">
                                <span class="rpt-sign-name">@(_data.InspectorName ?? "—")</span>
                                @if (!string.IsNullOrEmpty(_data.InspectorId))
                                {
                                    <span class="rpt-sign-id">ID: @_data.InspectorId</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td class="rpt-sign-label">Confirmed by</td>
                            <td class="rpt-sign-val rpt-sign-cell">
                                @if (!string.IsNullOrEmpty(_data.SignatureUrl))
                                {
                                    <img src="@NormalizeUrl(_data.SignatureUrl)" class="rpt-signature" alt="Signature" loading="eager"/>
                                }
                            </td>
                        </tr>
                    </tbody>
                </table>

                <div class="rpt-end-line">
                    <hr/>
                    <span>End</span>
                    <hr/>
                </div>

                <div class="rpt-footer">
                    <div class="rpt-footer-inner">
                        <span class="rpt-footer-text">www.inticoo.com<br/>The results presented herein reflect our findings at the time and place of inspection. This report does not release the seller or manufacturer from their contractual obligations, nor does it prejudice the buyer's right to seek compensation for any apparent or latent defects not identified during our random inspection or arising thereafter. This document does not constitute evidence of shipment. Final approval from the client is required prior to the release of the goods.</span>
                        <span class="rpt-footer-page">@(2 + CartonPageCount + PerfPageCount + 4) / @TotalPages</span>
                    </div>
                </div>
            </div>

        </div>

        <!-- Print-only running footer: position: fixed trong @@media print
             để xuất hiện ở đáy MỌI trang PDF. Ẩn trên màn hình. -->
        <div class="rpt-print-footer">
            <div class="rpt-print-footer-text">
                www.inticoo.com<br/>
                The results presented herein reflect our findings at the time and place of inspection. This report does not release the seller or manufacturer from their contractual obligations, nor does it prejudice the buyer&apos;s right to seek compensation for any apparent or latent defects not identified during our random inspection or arising thereafter. This document does not constitute evidence of shipment. Final approval from the client is required prior to the release of the goods.
            </div>
        </div>
    </div>
}

@code {
    /// <summary>
    /// Lấy danh sách ảnh, lọc URL hợp lệ, pad chẵn cho grid 2 cột.
    /// Show TẤT CẢ ảnh có thật (không giới hạn 4):
    /// - Nếu có ảnh: pad lẻ → chẵn cho grid 2 cột không lệch hàng cuối.
    /// - Nếu KHÔNG có ảnh nào: trả về 2 slot trống để vẫn hiển thị 2 khung
    ///   placeholder (giúp section không bị "rỗng tuếch").
    /// Trả về list nullable string: null = ô trống, có giá trị = ô có ảnh.
    /// </summary>
    private static List<string?> PadEvenForGrid(IEnumerable<string>? photos)
    {
        var list = (photos ?? Enumerable.Empty<string>())
            .Where(p => !string.IsNullOrWhiteSpace(p))
            .ToList();
        // Không có ảnh → 2 khung trống (1 hàng × 2 cột)
        if (list.Count == 0) return new List<string?> { null, null };
        // Có ảnh → pad lẻ thành chẵn cho grid 2 cột
        var slots = list.Cast<string?>().ToList();
        if (slots.Count % 2 != 0) slots.Add(null);
        return slots;
    }

    // ★ Giới hạn ảnh/trang: 3 hàng × 2 cột = 6 ảnh.
    //   Layout vừa khít A4: 6×75mm + heading + padding ≈ 260mm < 271mm.
    //   Đoán định được — KHÔNG bao giờ tạo trang trắng do tràn.
    private const int MAX_PHOTOS_PER_PAGE = 6;

    // Chia photos thành các "chunk" tối đa 6 ảnh/trang (đã pad chẵn).
    // Trả về List<List<>> — mỗi inner list = 1 trang.
    // - Không có ảnh → 1 chunk gồm 2 khung trống.
    private static List<List<string?>> ChunkPhotosForPages(IEnumerable<string>? photos)
    {
        var list = (photos ?? Enumerable.Empty<string>())
            .Where(p => !string.IsNullOrWhiteSpace(p))
            .ToList();

        var pages = new List<List<string?>>();
        if (list.Count == 0)
        {
            pages.Add(new List<string?> { null, null });
            return pages;
        }
        for (int i = 0; i < list.Count; i += MAX_PHOTOS_PER_PAGE)
        {
            var chunk = list.Skip(i).Take(MAX_PHOTOS_PER_PAGE).Cast<string?>().ToList();
            if (chunk.Count % 2 != 0) chunk.Add(null);
            pages.Add(chunk);
        }
        return pages;
    }

    // Tương tự nhưng cho defects (Url + Remark).
    private static List<List<(string? Url, string Remark)>> ChunkDefectsForPages(
        List<(string? Url, string Remark)>? items)
    {
        var pages = new List<List<(string?, string)>>();
        var list = items ?? new List<(string?, string)>();
        if (list.Count == 0)
        {
            pages.Add(new List<(string?, string)> { (null, ""), (null, "") });
            return pages;
        }
        for (int i = 0; i < list.Count; i += MAX_PHOTOS_PER_PAGE)
        {
            var chunk = list.Skip(i).Take(MAX_PHOTOS_PER_PAGE).ToList();
            if (chunk.Count % 2 != 0) chunk.Add((null, ""));
            pages.Add(chunk);
        }
        return pages;
    }

