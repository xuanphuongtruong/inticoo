        margin: 10px 0;
    }
    .rpt-overview-photo-cell {
        border: 1px solid var(--border);
        border-radius: 8px;
        overflow: hidden;
        background: #fafbfc;
        display: block;
    }
    .rpt-overview-img {
        width: 100%;
        height: 330px;
        object-fit: contain;
        object-position: center;
        display: block;
        vertical-align: top;
    }
    .rpt-photo-empty-lg {
        height: 330px;
        display: flex; align-items: center; justify-content: center;
        font-size: 13px; color: #bbb;
        background: #fafbfc;
        border-radius: 8px;
        border: 1px dashed #ddd;
    }

    .rpt-photo-label {
        padding: 6px 10px;
        font-size: 11px; color: var(--text-muted);
        background: #f9f9f9;
        border-top: 1px solid var(--border);
    }

    .rpt-photo-remark {
        padding: 6px 10px;
        font-size: 11px; color: #555;
        background: #f9f9f9;
        border-top: 1px solid var(--border);
    }

    .rpt-photo-empty {
        height: 210px;
        display: flex; align-items: center; justify-content: center;
        font-size: 12px; color: #bbb;
        background: #fafbfc;
        border-radius: 6px;
        border: 1px dashed #ddd;
    }

    .rpt-photo-placeholder {
        background: transparent;
        border: none;
    }

    /* ══════════════════════════════════════════
       QTY TABLE — theo mẫu PDF
    ══════════════════════════════════════════ */
    .rpt-qty-table {
        width: 100%; border-collapse: collapse;
        font-size: 11px; margin-bottom: 14px;
        border: 1px solid #b8c8de;
    }
    .rpt-qty-table th, .rpt-qty-table td {
        border: 1px solid #b8c8de;
        padding: 6px 7px; text-align: center;
        color: #1a1a2e;
    }
    .rpt-qty-table thead th {
        background: white;
        color: #1a1a2e !important;
        font-weight: 700; font-size: 10px;
        border-bottom: 1px solid #b8c8de;
    }
    .rpt-qty-table tbody td {
        color: #1a1a2e;
        background: white;
        height: 32px;
    }
    .rpt-qty-data-row td { height: 36px; }
    .rpt-total-row td {
        font-weight: 700; background: white;
        color: #1a1a2e;
        border-top: 1px solid #b8c8de;
    }
    .rpt-total-label { text-align: right; font-weight: 700; }

    /* ── Qty photo grid: 2 cột × 2 hàng ── */
    .rpt-qty-photo-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0;
        border: 1px solid #b8c8de;
        margin-bottom: 12px;
    }
    .rpt-qty-photo-cell {
        border: 1px solid #b8c8de;
        height: 330px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: white;
        overflow: hidden;
        margin: -1px 0 0 -1px; /* collapse borders */
    }
    .rpt-qty-photo-img {
        width: 100%;
        height: 330px;
        object-fit: contain;
        display: block;
        vertical-align: top;
    }

    /* ══════════════════════════════════════════
       PACKAGING TABLE
    ══════════════════════════════════════════ */
    .rpt-pkg-table { margin-bottom: 16px; }

    /* ══════════════════════════════════════════
       PRODUCT SPEC TABLE
    ══════════════════════════════════════════ */
    .rpt-spec-table {
        width: 100%; border-collapse: collapse;
        font-size: 12px; margin-bottom: 10px;
    }
    .rpt-spec-table th, .rpt-spec-table td {
        border: 1px solid var(--border);
        padding: 7px 10px; text-align: center;
    }
    .rpt-spec-table thead th { background: #f4f7fc; font-weight: 700; color: #1a1a2e; }
    .rpt-spec-table td { color: #1a1a2e; background: white; }

    /* ══════════════════════════════════════════
       SWATCH TABLE
    ══════════════════════════════════════════ */
    .rpt-swatch-table {
        width: 100%; border-collapse: collapse;
        font-size: 12px; margin-bottom: 10px;
    }
    .rpt-swatch-table th, .rpt-swatch-table td {
        border: 1px solid var(--border); padding: 7px 10px;
    }
    .rpt-swatch-table thead th { background: #f4f7fc; font-weight: 700; color: #1a1a2e; }
    .rpt-swatch-table td { color: #1a1a2e; background: white; }

    /* ══════════════════════════════════════════
       PERFORMANCE TEST TABLE
    ══════════════════════════════════════════ */
    .rpt-perf-table {
        width: 100%; border-collapse: collapse;
        font-size: 12px; margin-bottom: 14px;
    }
    .rpt-perf-table td {
        border: 1px solid var(--border); padding: 7px 10px;
        color: #1a1a2e; background: white;
    }

    /* ══════════════════════════════════════════
       AQL SECTION
    ══════════════════════════════════════════ */
    .rpt-aql-label {
        font-size: 12px; font-weight: 700;
        color: var(--text); margin-bottom: 8px;
    }
    .rpt-aql-row {
        display: flex; gap: 24px;
        margin-bottom: 12px;
    }
    .rpt-aql-item {
        display: flex; align-items: center; gap: 8px;
        font-size: 12px;
    }
    .rpt-aql-key { font-weight: 600; color: var(--text-muted); }
    .rpt-aql-val { font-weight: 700; color: var(--text); }

