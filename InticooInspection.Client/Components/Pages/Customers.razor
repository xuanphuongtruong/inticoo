@page "/customers"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using Microsoft.AspNetCore.Components.Forms
@inject HttpClient Http
@inject Blazored.SessionStorage.ISessionStorageService SessionStorage
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider
@using InticooInspection.Client.Services
@inject WaitingService Waiting

<PageTitle>Customers - Inticoo</PageTitle>

<div class="top-bar">
    <div class="title-block">
        <h1 class="page-title">Customer Profile</h1>
        <span class="page-sub">Manage customer accounts and contacts</span>
    </div>
    <div class="tb-divider"></div>
    <div class="search-wrap">
        <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="9" cy="9" r="5.5"/><path d="M15 15l-2.5-2.5" stroke-linecap="round"/>
        </svg>
        <input class="search-input" type="text" placeholder="Search by company, contact, phone, email..."
               @bind="_search" @bind:event="oninput" @onkeyup="OnSearchKey" />
    </div>
    <span class="total-count">@_total customers</span>
    <AuthorizeView Roles="Admin">
        <button class="btn-new" @onclick="OpenCreate">
            <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M10 4v12M4 10h12"/></svg>
            New Customer
        </button>
    </AuthorizeView>
</div>

@if (_loading)
{
    <div class="loading-wrap"><div class="spinner"></div><span>Loading...</span></div>
}
else if (_customers.Count == 0)
{
    <div class="empty-state">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1.5">
            <circle cx="10" cy="7" r="4"/><path d="M3 21v-2a7 7 0 0 1 7-7h1"/>
            <path d="M16 19l2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <p>No customers found.</p>
    </div>
}
else
{
    <div class="table-wrap">
        <table class="ptable">
            <thead>
                <tr class="thead-group">
                    <th rowspan="2" class="tc th-no">No</th>
                    <th rowspan="2">Customer Name</th>
                    <th rowspan="2" class="tc">Customer ID</th>
                    <th rowspan="2">Category</th>
                    <th colspan="3" class="th-grp">Customer Address</th>
                    <th colspan="3" class="th-grp">Contact Information</th>
                    <th rowspan="2" class="tc">Files</th>
                    <th rowspan="2" class="tc">Status</th>
                    <th rowspan="2" class="tc">Full Detail</th>
                    <th rowspan="2" class="tc">Action</th>
                </tr>
                <tr class="thead-sub">
                    <th>City</th>
                    <th>States / Province</th>
                    <th>Country</th>
                    <th>Contact Name</th>
                    <th>Position</th>
                    <th>Mobile</th>
                </tr>
            </thead>
            <tbody>
                @{ int _rowIdx = 0; }
                @foreach (var c in _customers)
                {
                    _rowIdx++;
                    var item = c;
                    <tr class="table-row @(_rowIdx % 2 == 0 ? "tr-alt" : "")">
                        <td class="td-center muted">@((_page - 1) * _pageSize + _customers.IndexOf(item) + 1)</td>
                        <td>
                            <div class="company-cell">
                                <div class="company-avatar">@GetInitials(item.CompanyName)</div>
                                <div>
                                    <div class="company-name">@item.CompanyName</div>
                                    @if (!string.IsNullOrEmpty(item.ShortName))
                                    {
                                        <div style="font-size:11px;color:#9baac8;">@item.ShortName</div>
                                    }
                                </div>
                            </div>
                        </td>
                        <td class="td-center mono">@(string.IsNullOrEmpty(item.CustomerId) ? "-" : item.CustomerId)</td>
                        <td class="muted">
                            @if (!string.IsNullOrEmpty(item.Category))
                            {
                                <span class="cat-badge">@item.Category</span>
                            }
                            else { <span class="muted">-</span> }
                        </td>
                        <td class="muted">@(string.IsNullOrEmpty(item.City)    ? "-" : item.City)</td>
                        <td class="muted">@(string.IsNullOrEmpty(item.State)   ? "-" : item.State)</td>
                        <td class="muted">@(string.IsNullOrEmpty(item.Country) ? "-" : item.Country)</td>
                        <td class="muted">@(string.IsNullOrEmpty(item.ContactPerson) ? "-" : item.ContactPerson)</td>
                        <td class="muted">@(string.IsNullOrEmpty(item.Position)      ? "-" : item.Position)</td>
                        <td class="mono">@(string.IsNullOrEmpty(item.Mobile)         ? "-" : item.Mobile)</td>
                        <td class="tc">
                            @if (item.FileCount > 0)
                            {
                                <button class="file-count-btn" @onclick="() => OpenFilesPopup(item)">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                                    @item.FileCount
                                </button>
                            }
                            else { <span class="muted">—</span> }
                        </td>
                        <td class="tc">
                            <span class="status-badge @(item.IsActive ? "active" : "inactive")">
                                @(item.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td class="tc">
                            <button class="action-btn view" @onclick="() => OpenDetail(item)" title="View Detail">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                View
                            </button>
                        </td>
                        <td class="tc">
                            <AuthorizeView Roles="Admin">
                                <div class="action-btns">
                                    <button class="bico bedit" @onclick="() => OpenEdit(item)" title="Edit">
                                        <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14 2l4 4-10 10H4v-4L14 2z" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                    </button>
                                    <button class="bico bdel" @onclick="() => ConfirmDelete(item)" title="Delete">
                                        <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 6h14M8 6V4h4v2M5 6l1 11h8l1-11" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                    </button>
                                </div>
                            </AuthorizeView>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (_total > _pageSize)
    {
        <div class="pagination">
            <button class="page-btn" disabled="@(_page == 1)" @onclick="PrevPage">&#8592; Prev</button>
            <span class="page-info">Page @_page of @TotalPages()</span>
            <button class="page-btn" disabled="@(_page >= TotalPages())" @onclick="NextPage">Next &#8594;</button>
        </div>
    }
}

<!-- Modal Create/Edit -->
@if (_showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-card modal-wide" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2>@(_editId == null ? "New Customer" : "Edit Customer")</h2>
                <button class="modal-close" @onclick="CloseModal">&#x2715;</button>
            </div>

            @if (!string.IsNullOrEmpty(_formError))
            {
                <div class="error-alert">@_formError</div>
            }

            @if (_editId != null)
            {
                <div class="form-grid" style="margin-bottom:8px;">
                    <div class="form-group">
                        <label>Customer ID</label>
                        <input class="form-input form-input-disabled" type="text" value="@_formCustomerId" disabled />
                    </div>
                    <div class="form-group">
                        <label>Status</label>
                        <label class="check-label" style="margin-top:10px;">
                            <input type="checkbox" @bind="_formIsActive" />
                            <span>@(_formIsActive ? "Active" : "Inactive")</span>
                        </label>
                    </div>
                </div>
            }

            <!-- Section: Customer Profile -->
            <div class="form-section-title">Customer Profile</div>
            <div class="form-grid">
                <div class="form-group">
                    <label>Customer Name <span class="required">*</span></label>
                    <input class="form-input" type="text" placeholder="Enter company name"
                           @bind="_formCompanyName" @bind:event="oninput" />
                </div>
                <div class="form-group">
                    <label>Short Name</label>
                    <input class="form-input" type="text" placeholder="Enter short name"
                           @bind="_formShortName" @bind:event="oninput" />
                </div>
                <div class="form-group full-width">
                    <label>Business Type</label>
                    <div class="btype-group">
                        @foreach (var bt in new[] { "Importer", "Wholesalers", "Retailers", "Trading Company", "Other" })
                        {
                            var btVal = bt;
                            <label class="btype-label @(_formBusinessType == btVal ? "btype-active" : "")"
                                   @onclick="() => _formBusinessType = btVal">
                                @btVal
                            </label>
                        }
                    </div>
                </div>
                <div class="form-group full-width">
                    <label>Product Category <span style="font-size:11px;color:#9baac8;font-weight:400;">(chọn nhiều)</span></label>
                    <div class="cat-check-list">
                        @foreach (var _catOpt in new[] {
                            "Furniture","Outdoor Furniture","Indoor Furniture","Office Furniture",
                            "Lighting","Home Decor","Electronics","Toys & Games",
                            "Clothing & Apparel","Footwear","Bags & Luggage","Kitchenware",
                            "Sportswear","Hardware & Tools","Other"
                        })
                        {
                            var catVal = _catOpt;
                            var isChecked = _formCategories.Contains(catVal);
                            <label class="cat-check-item @(isChecked ? "cat-check-active" : "")">
                                <input type="checkbox" checked="@isChecked"
                                       @onchange="() => ToggleCategory(catVal)" />
                                @catVal
                            </label>
                        }
                    </div>
                    @if (_formCategories.Count > 0)
                    {
                        <div style="margin-top:8px; display:flex; flex-wrap:wrap; gap:4px;">
                            @foreach (var cat in _formCategories.ToList())
                            {
                                var c = cat;
                                <span class="cat-badge" style="cursor:pointer;" @onclick="() => { _formCategories.Remove(c); StateHasChanged(); }">@c ✕</span>
                            }
                        </div>
                    }
                </div>
                <div class="form-group">
                    <label>Tax Code</label>
                    <input class="form-input" type="text" placeholder="Enter tax code"
                           @bind="_formTaxCode" @bind:event="oninput" />
                </div>
                <div class="form-group">
                    <label>Business Ref. No</label>
                    <input class="form-input" type="text" placeholder="Enter business reference number"
                           @bind="_formBusinessRefNo" @bind:event="oninput" />
                </div>
                <div class="form-group">
                    <label>Phone</label>
                    <input class="form-input" type="text" placeholder="Enter phone number"
                           @bind="_formPhone" @bind:event="oninput" />
                </div>
                <div class="form-group">
                    <label>Website</label>
                    <input class="form-input" type="text" placeholder="https://..."
                           @bind="_formWebsite" @bind:event="oninput" />
                </div>
            </div>

            <!-- Section: Customer Address -->
            <div class="form-section-title">Customer Address</div>
            <div class="form-grid">
                <div class="form-group full-width">
                    <label>Address 1</label>
                    <input class="form-input" type="text" placeholder="Street address line 1"
                           @bind="_formAddress1" @bind:event="oninput" />
                </div>
                <div class="form-group full-width">
                    <label>Address 2</label>
                    <input class="form-input" type="text" placeholder="Street address line 2 (optional)"
                           @bind="_formAddress2" @bind:event="oninput" />
                </div>
                <div class="form-group">
                    <label>City</label>
                    @if (_loadingCities)
                    {
                        <div class="form-input" style="color:#9baac8;font-style:italic;">Loading cities...</div>
                    }
                    else
                    {
                        <select class="form-input" @bind="_formCity" disabled="@(string.IsNullOrEmpty(_formCountry))">
                            <option value="">-- Select City --</option>
                            @foreach (var ct in _cities)
                            {
                                <option value="@ct.Name">@ct.Name</option>
                            }
                        </select>
                    }
                </div>
                <div class="form-group">
                    <label>State / Province</label>
                    <input class="form-input" type="text" placeholder="Enter state or province"
                           @bind="_formState" @bind:event="oninput" />
                </div>
                <div class="form-group">
                    <label>Country</label>
                    @if (_loadingCountries)
                    {
                        <div class="form-input" style="color:#9baac8;font-style:italic;">Loading...</div>
                    }
                    else
                    {
                        <select class="form-input" value="@_formCountry" @onchange="OnCountryChanged">
                            <option value="">-- Select Country --</option>
                            @foreach (var co in _countries)
                            {
                                <option value="@co.Name">@co.Name</option>
                            }
                        </select>
                    }
                </div>
                <div class="form-group">
                    <label>Postal / ZIP</label>
                    <input class="form-input" type="text" placeholder="Enter postal code"
                           @bind="_formPostalCode" @bind:event="oninput" />
                </div>
            </div>

            <!-- Section: Contact Information -->
            <div class="form-section-title">Contact Information</div>
            <div class="form-grid">
                <div class="form-group">
                    <label>Contact Name</label>
                    <input class="form-input" type="text" placeholder="Enter contact name"
                           @bind="_formContactPerson" @bind:event="oninput" />
                </div>
                <div class="form-group">
                    <label>Title / Position</label>
                    <input class="form-input" type="text" placeholder="Enter title or position"
                           @bind="_formPosition" @bind:event="oninput" />
                </div>
                <div class="form-group">
                    <label>Mobile</label>
                    <input class="form-input" type="text" placeholder="Enter mobile number"
                           @bind="_formMobile" @bind:event="oninput" />
                </div>
                <div class="form-group">
                    <label>Email</label>
                    <input class="form-input" type="email" placeholder="Enter email address"
                           @bind="_formEmail" @bind:event="oninput" />
                </div>
            </div>

            <!-- Section: Remark -->
            <div class="form-section-title">Remark</div>
            <div class="form-grid">
                <div class="form-group full-width">
                    <textarea class="form-input form-textarea" placeholder="Enter remarks..."
                              @bind="_formNotes" @bind:event="oninput"></textarea>
                </div>
            </div>

            <!-- Section: Reference (Attachments) -->
            <div class="form-section-title">Reference</div>
            <div class="upload-zone" @ondragover:preventDefault @ondrop:preventDefault @ondrop="HandleDrop">
                <InputFile id="fileInput" OnChange="HandleFileSelected" multiple accept=".pdf,.png,.jpg,.jpeg,.gif,.webp" style="display:none" />
                <label for="fileInput" class="upload-label">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.25)" stroke-width="1.5">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                        <polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>
                    </svg>
                    <span>Click or drag files here</span>
                    <span class="upload-hint">PDF, PNG, JPG, WEBP · Max 20 MB each</span>
                </label>
            </div>
            @if (_selectedFiles.Count > 0)
            {
                <div class="file-list">
                    @foreach (var f in _selectedFiles)
                    {
                        var file = f;
                        <div class="file-item">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                            <div class="file-info">
                                <span class="file-name">@file.Name</span>
                                <span class="file-size">@FormatSize(file.Size)</span>
                            </div>
                            <button class="file-remove" @onclick="() => RemoveFile(file)" title="Remove">&#x2715;</button>
                        </div>
                    }
                </div>
            }
            @if (_existingFiles.Count > 0)
            {
                <div class="file-list">
                    @foreach (var eFile in _existingFiles)
                    {
                        var ef = eFile;
                        <div class="file-item">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                            <div class="file-info">
                                <a class="file-name file-link" href="@ef.Url" target="_blank">@ef.FileName</a>
                                <span class="file-size">@FormatSize(ef.FileSize)</span>
                            </div>
                            <button class="file-remove" @onclick="() => RemoveExistingFile(ef)" title="Remove">&#x2715;</button>
                        </div>
                    }
                </div>
            }

            @if (_editId == null)
            {
                <div class="form-group" style="margin-top:16px;">
                    <label class="check-label">
                        <input type="checkbox" @bind="_formIsActive" />
                        <span>Active</span>
                    </label>
                </div>
            }

            <div class="modal-footer">
                <button class="btn-cancel" @onclick="CloseModal">Cancel</button>
                <button class="btn-submit" @onclick="SaveCustomer" disabled="@_saving">
                    @if (_saving) { <span class="spinner"></span> }
                    else { <span>@(_editId == null ? "Create Customer" : "Save Changes")</span> }
                </button>
            </div>
        </div>
    </div>
}

<!-- Modal View Detail (readonly) -->
@if (_showDetail && _detailItem != null)
{
    var d = _detailItem;
    <div class="modal-overlay" @onclick="() => _showDetail = false">
        <div class="modal-card modal-wide" @onclick:stopPropagation="true">
            <div class="modal-header">
                <div>
                    <h2>@d.CompanyName</h2>
                    <p style="font-size:12px;color:rgba(255,255,255,.4);margin-top:3px;">@d.CustomerId</p>
                </div>
                <button class="modal-close" @onclick="() => _showDetail = false">&#x2715;</button>
            </div>

            <!-- ID + Status -->
            <div class="form-grid" style="margin-bottom:8px;">
                <div class="form-group">
                    <label>Customer ID</label>
                    <div class="form-input form-input-disabled">@(string.IsNullOrEmpty(d.CustomerId) ? "—" : d.CustomerId)</div>
                </div>
                <div class="form-group">
                    <label>Status</label>
                    <div style="padding-top:10px;">
                        <span class="status-badge @(d.IsActive ? "active" : "inactive")">
                            @(d.IsActive ? "Active" : "Inactive")
                        </span>
                    </div>
                </div>
            </div>

            <!-- Customer Profile -->
            <div class="form-section-title">Customer Profile</div>
            <div class="form-grid">
                <div class="form-group">
                    <label>Customer Name</label>
                    <div class="form-input form-input-disabled">@(string.IsNullOrEmpty(d.CompanyName) ? "—" : d.CompanyName)</div>
                </div>
                <div class="form-group">
                    <label>Short Name</label>
                    <div class="form-input form-input-disabled">@(string.IsNullOrEmpty(d.ShortName) ? "—" : d.ShortName)</div>
                </div>
                <div class="form-group full-width">
                    <label>Business Type</label>
                    <div class="btype-group">
                        @foreach (var bt in new[] { "Importer", "Wholesalers", "Retailers", "Trading Company", "Other" })
                        {
                            <label class="btype-label @(d.BusinessType == bt ? "btype-active" : "")" style="cursor:default;">@bt</label>
                        }
                    </div>
                </div>
                <div class="form-group">
                    <label>Product Category</label>
                    <div class="form-input form-input-disabled">@(string.IsNullOrEmpty(d.Category) ? "—" : d.Category)</div>
                </div>
                <div class="form-group">
                    <label>Tax Code</label>
                    <div class="form-input form-input-disabled">@(string.IsNullOrEmpty(d.TaxCode) ? "—" : d.TaxCode)</div>
                </div>
                <div class="form-group">
                    <label>Business Ref. No</label>
                    <div class="form-input form-input-disabled">@(string.IsNullOrEmpty(d.BusinessRefNo) ? "—" : d.BusinessRefNo)</div>
                </div>
                <div class="form-group">
                    <label>Phone</label>
                    <div class="form-input form-input-disabled">@(string.IsNullOrEmpty(d.Phone) ? "—" : d.Phone)</div>
                </div>
                <div class="form-group">
                    <label>Website</label>
                    @if (!string.IsNullOrEmpty(d.Website))
                    {
                        <a class="form-input form-input-disabled" href="@d.Website" target="_blank"
                           style="display:block;color:#1e90d6;text-decoration:none;">@d.Website</a>
                    }
                    else
                    {
                        <div class="form-input form-input-disabled">—</div>
                    }
                </div>
            </div>

            <!-- Customer Address -->
            <div class="form-section-title">Customer Address</div>
            <div class="form-grid">
                <div class="form-group full-width">
                    <label>Address 1</label>
                    <div class="form-input form-input-disabled">@(string.IsNullOrEmpty(d.Address1) ? "—" : d.Address1)</div>
                </div>
                <div class="form-group full-width">
                    <label>Address 2</label>
                    <div class="form-input form-input-disabled">@(string.IsNullOrEmpty(d.Address2) ? "—" : d.Address2)</div>
                </div>
                <div class="form-group">
                    <label>City</label>
                    <div class="form-input form-input-disabled">@(string.IsNullOrEmpty(d.City) ? "—" : d.City)</div>
                </div>
                <div class="form-group">
                    <label>State / Province</label>
                    <div class="form-input form-input-disabled">@(string.IsNullOrEmpty(d.State) ? "—" : d.State)</div>
                </div>
                <div class="form-group">
                    <label>Country</label>
                    <div class="form-input form-input-disabled">@(string.IsNullOrEmpty(d.Country) ? "—" : d.Country)</div>
                </div>
                <div class="form-group">
                    <label>Postal / ZIP</label>
                    <div class="form-input form-input-disabled">@(string.IsNullOrEmpty(d.PostalCode) ? "—" : d.PostalCode)</div>
                </div>
            </div>

            <!-- Contact Information -->
            <div class="form-section-title">Contact Information</div>
            <div class="form-grid">
                <div class="form-group">
                    <label>Contact Name</label>
                    <div class="form-input form-input-disabled">@(string.IsNullOrEmpty(d.ContactPerson) ? "—" : d.ContactPerson)</div>
                </div>
                <div class="form-group">
                    <label>Title / Position</label>
                    <div class="form-input form-input-disabled">@(string.IsNullOrEmpty(d.Position) ? "—" : d.Position)</div>
                </div>
                <div class="form-group">
                    <label>Mobile</label>
                    <div class="form-input form-input-disabled">@(string.IsNullOrEmpty(d.Mobile) ? "—" : d.Mobile)</div>
                </div>
                <div class="form-group">
                    <label>Email</label>
                    @if (!string.IsNullOrEmpty(d.Email))
                    {
                        <a class="form-input form-input-disabled" href="mailto:@d.Email"
                           style="display:block;color:#1e90d6;text-decoration:none;">@d.Email</a>
                    }
                    else
                    {
                        <div class="form-input form-input-disabled">—</div>
                    }
                </div>
            </div>

            <!-- Remark -->
            @if (!string.IsNullOrEmpty(d.Notes))
            {
                <div class="form-section-title">Remark</div>
                <div class="form-input form-input-disabled" style="min-height:60px;white-space:pre-wrap;">@d.Notes</div>
            }

            <!-- Reference files -->
            @if (d.FileCount > 0)
            {
                <div class="form-section-title">Reference (@d.FileCount file(s))</div>
                <button class="btn-view-files" @onclick="async () => { _showDetail = false; await OpenFilesPopup(d); }">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    View @d.FileCount attached file(s)
                </button>
            }

            <div class="modal-footer">
                <button class="btn-cancel" @onclick="() => _showDetail = false">Close</button>
                <AuthorizeView Roles="Admin">
                    <button class="btn-submit" @onclick="async () => { _showDetail = false; await OpenEdit(d); }">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                        Edit
                    </button>
                </AuthorizeView>
            </div>
        </div>
    </div>
}

<!-- Files Popup -->
@if (_showFilesPopup)
{
    <div class="modal-overlay" @onclick="() => _showFilesPopup = false">
        <div class="modal-card modal-files" @onclick:stopPropagation="true">
            <div class="modal-header">
                <div>
                    <h2>📎 Files — @_filesPopupCustomerName</h2>
                    <p style="font-size:12px;color:rgba(255,255,255,0.35);margin-top:3px;">@_filesPopupList.Count file(s)</p>
                </div>
                <button class="modal-close" @onclick="() => _showFilesPopup = false">&#x2715;</button>
            </div>

            @if (_filesPopupLoading)
            {
                <div class="loading-state" style="padding:30px"><div class="spinner-lg"></div></div>
            }
            else if (_filesPopupList.Count == 0)
            {
                <div class="empty-state" style="padding:30px">
                    <p>No files found.</p>
                </div>
            }
            else
            {
                <div class="popup-file-list">
                    @foreach (var f in _filesPopupList)
                    {
                        var pf = f;
                        bool isPdf = pf.FileName.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase);
                        <div class="popup-file-item">
                            <div class="file-icon @(isPdf ? "pdf" : "img")">
                                @if (isPdf)
                                {
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/></svg>
                                }
                                else
                                {
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                                }
                            </div>
                            <div class="file-info">
                                <span class="file-name" title="@pf.FileName">@pf.FileName</span>
                                <span class="file-size">@FormatSize(pf.FileSize)</span>
                            </div>
                            <div class="popup-file-actions">
                                <a class="popup-btn view-btn" href="@pf.Url" target="_blank" title="View">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                    View
                                </a>
                                <a class="popup-btn download-btn" href="@pf.Url" download="@pf.FileName" title="Download">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                                    Download
                                </a>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

<!-- Confirm Delete -->
@if (_deleteItem != null)
{
    <div class="modal-overlay" @onclick="() => _deleteItem = null">
        <div class="modal-card confirm-card" @onclick:stopPropagation="true">
            <div class="confirm-icon">&#9888;</div>
            <h2>Delete Customer</h2>
            <p>Are you sure you want to delete <strong>@_deleteItem.CompanyName</strong>?<br/>This action cannot be undone.</p>
            <div class="modal-footer">
                <button class="btn-cancel" @onclick="() => _deleteItem = null">Cancel</button>
                <button class="btn-delete" @onclick="DeleteCustomer" disabled="@_saving">
                    @if (_saving) { <span class="spinner"></span> } else { <span>Delete</span> }
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<CustomerDto> _customers = new();
    private bool _loading = true;
    private string _search = "";
    private int _page = 1, _pageSize = 20, _total = 0;

    private bool _showModal = false;
    private int? _editId = null;

    // Form fields
    private string _formCustomerId = "", _formCompanyName = "", _formShortName = "";
    private string _formBusinessType = "", _formTaxCode = "";
    private List<string> _formCategories = new();
    private string _formBusinessRefNo = "", _formPhone = "", _formWebsite = "";
    private string _formAddress1 = "", _formAddress2 = "", _formCity = "", _formState = "";
    private string _formCountry = "", _formPostalCode = "";
    private string _formContactPerson = "", _formPosition = "", _formMobile = "";
    private string _formEmail = "", _formOfficePhone = "", _formNotes = "";
    private bool   _formIsActive = true;
    private string _formError = "";
    private bool   _saving = false;

    // Country/City dropdowns
    private List<CountryItem> _countries       = new();
    private List<CityItem>    _cities          = new();
    private bool              _loadingCountries = true;
    private bool              _loadingCities    = false;

    // File upload
    private List<IBrowserFile>   _selectedFiles  = new();
    private List<CustomerFileDto> _existingFiles  = new();
    private List<int>            _filesToDelete  = new();

    // Files popup
    private bool   _showFilesPopup        = false;
    private bool   _filesPopupLoading     = false;
    private string _filesPopupCustomerName = "";
    private List<CustomerFileDto> _filesPopupList = new();

    private CustomerDto? _deleteItem = null;

    // Detail view
    private bool        _showDetail     = false;
    private CustomerDto? _detailItem    = null;

    private void OpenDetail(CustomerDto c) { _detailItem = c; _showDetail = true; }

    private async Task OpenFilesPopup(CustomerDto c)
    {
        _filesPopupCustomerName = c.CompanyName;
        _filesPopupList = new();
        _filesPopupLoading = true;
        _showFilesPopup = true;
        try
        {
            var files = await Http.GetFromJsonAsync<List<CustomerFileDto>>($"api/customers/{c.Id}/files");
            _filesPopupList = files ?? new();
        }
        catch { }
        finally { _filesPopupLoading = false; }
    }

    private void CloseFilesPopup() => _showFilesPopup = false;

    protected override async Task OnInitializedAsync()
    {
        await SetAuthHeader();
        await Task.WhenAll(LoadPage(1), LoadCountries());
    }

    private async Task SetAuthHeader()
    {
        try
        {
            var token = await SessionStorage.GetItemAsync<string>("auth_token");
            if (!string.IsNullOrEmpty(token))
                Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
        }
        catch { }
    }

    private async Task LoadPage(int page)
    {
        _loading = true; _page = page;
        try
        {
            var url = $"api/customers?page={page}&pageSize={_pageSize}&search={Uri.EscapeDataString(_search)}";
            var result = await Http.GetFromJsonAsync<CustomerPageResult>(url);
            if (result != null) { _customers = result.Items; _total = result.Total; }
        }
        catch { }
        finally { _loading = false; }
    }

    private async Task OnSearchKey(KeyboardEventArgs e) { if (e.Key == "Enter") await LoadPage(1); }
    private async Task PrevPage() => await LoadPage(_page - 1);
    private async Task NextPage() => await LoadPage(_page + 1);
    private int TotalPages() => (_total + _pageSize - 1) / _pageSize;

    private void OpenCreate()
    {
        _editId = null;
        _formCustomerId = ""; _formCompanyName = ""; _formShortName = "";
        _formBusinessType = ""; _formCategories = new(); _formTaxCode = ""; _formBusinessRefNo = "";
        _formPhone = ""; _formWebsite = "";
        _formAddress1 = ""; _formAddress2 = ""; _formCity = ""; _formState = "";
        _formCountry = ""; _formPostalCode = "";
        _formContactPerson = ""; _formPosition = ""; _formMobile = "";
        _formEmail = ""; _formOfficePhone = ""; _formNotes = "";
        _formIsActive = true; _formError = "";
        _selectedFiles = new(); _existingFiles = new(); _filesToDelete = new();
        _showModal = true;
    }

    private async Task OpenEdit(CustomerDto c)
    {
        _editId = c.Id;
        _formCustomerId    = c.CustomerId;
        _formCompanyName   = c.CompanyName;
        _formShortName     = c.ShortName     ?? "";
        _formBusinessType  = c.BusinessType  ?? "";
        _formCategories    = string.IsNullOrEmpty(c.Category)
                                ? new()
                                : c.Category.Split(',', StringSplitOptions.RemoveEmptyEntries)
                                            .Select(x => x.Trim()).ToList();
        _formTaxCode       = c.TaxCode       ?? "";
        _formBusinessRefNo = c.BusinessRefNo ?? "";
        _formPhone         = c.Phone         ?? "";
        _formWebsite       = c.Website       ?? "";
        _formAddress1      = c.Address1      ?? "";
        _formAddress2      = c.Address2      ?? "";
        _formCity          = "";
        _formState         = c.State         ?? "";
        _formCountry       = c.Country       ?? "";
        _formPostalCode    = c.PostalCode    ?? "";
        _formContactPerson = c.ContactPerson ?? "";
        _formPosition      = c.Position      ?? "";
        _formMobile        = c.Mobile        ?? "";
        _formEmail         = c.Email         ?? "";
        _formOfficePhone   = c.OfficePhone   ?? "";
        _formNotes         = c.Notes         ?? "";
        _formIsActive      = c.IsActive;
        _formError = "";
        _selectedFiles = new(); _filesToDelete = new();
        try
        {
            var files = await Http.GetFromJsonAsync<List<CustomerFileDto>>($"api/customers/{c.Id}/files");
            _existingFiles = files ?? new();
        }
        catch { _existingFiles = new(); }
        _showModal = true;
        await LoadCitiesForCountry(c.Country ?? "", c.City ?? "");
    }

    private void CloseModal() => _showModal = false;

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        var allowed = new[] { ".pdf", ".png", ".jpg", ".jpeg", ".gif", ".webp" };
        foreach (var f in e.GetMultipleFiles(50))
        {
            var ext = System.IO.Path.GetExtension(f.Name).ToLowerInvariant();
            if (allowed.Contains(ext) && !_selectedFiles.Any(x => x.Name == f.Name))
                _selectedFiles.Add(f);
        }
    }

    private void HandleDrop(DragEventArgs e) { /* drag-drop handled via InputFile fallback */ }

    private void RemoveFile(IBrowserFile f) => _selectedFiles.Remove(f);

    private void RemoveExistingFile(CustomerFileDto f)
    {
        _filesToDelete.Add(f.Id);
        _existingFiles.Remove(f);
    }

    private string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024):F1} MB";
    }

    private async Task SaveCustomer()
    {
        _formError = "";
        if (string.IsNullOrWhiteSpace(_formCompanyName)) { _formError = "Company name is required."; return; }

        _saving = true;
        Waiting.Show(_editId == null ? "Creating customer..." : "Saving customer...");
        try
        {
            var payload = new
            {
                customerId    = _formCustomerId,
                companyName   = _formCompanyName,
                shortName     = _formShortName,
                businessType  = _formBusinessType,
                category      = string.Join(", ", _formCategories),
                taxCode       = _formTaxCode,
                businessRefNo = _formBusinessRefNo,
                phone         = _formPhone,
                website       = _formWebsite,
                address1      = _formAddress1,
                address2      = _formAddress2,
                city          = _formCity,
                state         = _formState,
                country       = _formCountry,
                postalCode    = _formPostalCode,
                contactPerson = _formContactPerson,
                position      = _formPosition,
                mobile        = _formMobile,
                email         = _formEmail,
                officePhone   = _formOfficePhone,
                notes         = _formNotes,
                isActive      = _formIsActive
            };

            HttpResponseMessage response;
            int customerId;

            if (_editId == null)
            {
                response = await Http.PostAsJsonAsync("api/customers", payload);
                if (!response.IsSuccessStatusCode)
                {
                    var err = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                    _formError = err?.Message ?? "An error occurred."; return;
                }
                var created = await response.Content.ReadFromJsonAsync<CreateResult>();
                customerId = created?.Id ?? 0;
            }
            else
            {
                response = await Http.PutAsJsonAsync($"api/customers/{_editId}", payload);
                if (!response.IsSuccessStatusCode)
                {
                    var err = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                    _formError = err?.Message ?? "An error occurred."; return;
                }
                customerId = _editId.Value;

                // Delete removed files
                foreach (var fid in _filesToDelete)
                    await Http.DeleteAsync($"api/customers/{customerId}/files/{fid}");
            }

            // Upload new files
            if (_selectedFiles.Count > 0 && customerId > 0)
            {
                using var form = new MultipartFormDataContent();
                foreach (var f in _selectedFiles)
                {
                    var stream = f.OpenReadStream(maxAllowedSize: 20 * 1024 * 1024);
                    var content = new StreamContent(stream);
                    content.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(f.ContentType);
                    form.Add(content, "files", f.Name);
                }
                await Http.PostAsync($"api/customers/{customerId}/files", form);
            }

            _showModal = false;
            await LoadPage(_page);
        }
        catch { _formError = "Connection error."; }
        finally { _saving = false; Waiting.Hide(); }
    }

    private void ConfirmDelete(CustomerDto c) => _deleteItem = c;

    private async Task DeleteCustomer()
    {
        if (_deleteItem == null) return;
        _saving = true;
        Waiting.Show("Deleting customer...");
        var response = await Http.DeleteAsync($"api/customers/{_deleteItem.Id}");
        _saving = false;
        Waiting.Hide();
        if (response.IsSuccessStatusCode) { _deleteItem = null; await LoadPage(_page); }
    }

    private string GetInitials(string name)
        => string.Concat(name.Split(" ").Take(2).Select(w => w.Length > 0 ? w[0].ToString().ToUpper() : ""));

    private class CustomerPageResult { public int Total { get; set; } public List<CustomerDto> Items { get; set; } = new(); }
    private class ErrorResponse { public string? Message { get; set; } }
    private class CreateResult   { public int Id { get; set; } }

    private class CustomerDto
    {
        public int     Id            { get; set; }
        public string  CustomerId    { get; set; } = "";
        public string  CompanyName   { get; set; } = "";
        public string? ShortName     { get; set; }
        public string? BusinessType  { get; set; }
        public string? Category      { get; set; }
        public string? TaxCode       { get; set; }
        public string? BusinessRefNo { get; set; }
        public string? Phone         { get; set; }
        public string? Website       { get; set; }
        public string? Address1      { get; set; }
        public string? Address2      { get; set; }
        public string? City          { get; set; }
        public string? State         { get; set; }
        public string? Country       { get; set; }
        public string? PostalCode    { get; set; }
        public string? ContactPerson { get; set; }
        public string? Position      { get; set; }
        public string? Mobile        { get; set; }
        public string? Email         { get; set; }
        public string? OfficePhone   { get; set; }
        public string? Notes         { get; set; }
        public bool    IsActive      { get; set; }
        public int     FileCount     { get; set; }
        public DateTime CreatedAt   { get; set; }
    }

    private class CustomerFileDto
    {
        public int    Id       { get; set; }
        public string FileName { get; set; } = "";
        public string Url      { get; set; } = "";
        public long   FileSize { get; set; }
    }
    private void ToggleCategory(string cat)
    {
        if (_formCategories.Contains(cat))
            _formCategories.Remove(cat);
        else
            _formCategories.Add(cat);
    }

    private async Task LoadCountries()
    {
        try
        {
            var opts = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var json = await Http.GetStringAsync("api/geo/countries");
            _countries = System.Text.Json.JsonSerializer.Deserialize<List<CountryItem>>(json, opts) ?? new();
        }
        catch { }
        finally { _loadingCountries = false; }
    }

    private async Task OnCountryChanged(ChangeEventArgs e)
    {
        _formCountry = e.Value?.ToString() ?? "";
        _formCity    = "";
        _cities      = new();
        if (string.IsNullOrEmpty(_formCountry)) return;

        _loadingCities = true;
        try
        {
            var country = _countries.FirstOrDefault(c => c.Name == _formCountry);
            if (country == null) return;
            var opts = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var json = await Http.GetStringAsync($"api/geo/cities?countryId={country.Id}");
            _cities = System.Text.Json.JsonSerializer.Deserialize<List<CityItem>>(json, opts) ?? new();
        }
        catch { }
        finally { _loadingCities = false; }
    }

    private async Task LoadCitiesForCountry(string countryName, string cityName)
    {
        if (string.IsNullOrEmpty(countryName)) return;
        var country = _countries.FirstOrDefault(c => c.Name == countryName);
        if (country == null) return;
        _loadingCities = true;
        try
        {
            var opts = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var json = await Http.GetStringAsync($"api/geo/cities?countryId={country.Id}");
            _cities = System.Text.Json.JsonSerializer.Deserialize<List<CityItem>>(json, opts) ?? new();
            _formCity = cityName;
        }
        catch { }
        finally { _loadingCities = false; }
    }

    private class CountryItem
    {
        public int    Id     { get; set; }
        public string Name   { get; set; } = "";
        public string Code   { get; set; } = "";
        public string Region { get; set; } = "";
    }

    private class CityItem
    {
        public int    Id        { get; set; }
        public string Name      { get; set; } = "";
        public bool   IsCapital { get; set; }
    }

}

<style>
    @@import url("https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Sora:wght@600;700&display=swap");

    .page-container { font-family: "DM Sans", sans-serif; color: #fff; }

    /* ── Top bar ── */
    .top-bar { display:flex; align-items:center; gap:10px; margin-bottom:14px; flex-wrap:wrap; }
    .title-block { display:flex; align-items:baseline; gap:10px; flex-shrink:0; margin-right:4px; }
    .page-title  { font-family:"Sora",sans-serif; font-size:18px; font-weight:700; color:#fff; margin:0; white-space:nowrap; }
    .page-sub    { font-size:12px; color:rgba(255,255,255,.45); white-space:nowrap; }
    .tb-divider  { width:1px; height:20px; background:rgba(255,255,255,.15); flex-shrink:0; }
    .search-wrap { flex:1; min-width:200px; display:flex; align-items:center; gap:8px; background:rgba(255,255,255,.1); border:1px solid rgba(255,255,255,.15); border-radius:8px; padding:8px 12px; }
    .search-wrap svg { color:rgba(255,255,255,.4); flex-shrink:0; }
    .search-input { flex:1; background:none; border:none; outline:none; color:#fff; font-size:13px; font-family:"DM Sans",sans-serif; }
    .search-input::placeholder { color:rgba(255,255,255,.35); }
    .filter-select { background:rgba(255,255,255,.1); border:1px solid rgba(255,255,255,.15); border-radius:8px; padding:8px 12px; color:#fff; font-size:13px; outline:none; cursor:pointer; flex-shrink:0; font-family:"DM Sans",sans-serif; }
    .filter-select option { background:#1565c0; }
    .total-count { font-size:12px; color:rgba(255,255,255,.4); white-space:nowrap; flex-shrink:0; }
    .btn-new { display:flex; align-items:center; gap:6px; padding:8px 16px; background:#1e90d6; color:#fff; border:none; border-radius:8px; font-size:13px; font-weight:600; cursor:pointer; white-space:nowrap; flex-shrink:0; font-family:"DM Sans",sans-serif; transition:background .2s,transform .1s; }
    .btn-new:hover { background:#1565c0; transform:translateY(-1px); }

    /* ── Alerts ── */
    .alert-box { display:flex; align-items:center; justify-content:space-between; padding:10px 14px; border-radius:8px; font-size:13px; margin-bottom:14px; }
    .alert-err  { background:rgba(220,38,38,.12); border:1px solid rgba(220,38,38,.3); color:#fca5a5; }
    .alert-ok   { background:rgba(34,197,94,.12); border:1px solid rgba(34,197,94,.3); color:#86efac; }
    .alert-x    { background:none; border:none; cursor:pointer; color:inherit; font-size:14px; padding:0 4px; }

    /* ── Table ── */
    .table-wrap { overflow-x:auto; border-radius:10px; box-shadow:0 4px 20px rgba(0,0,0,.25); }
    .ptable { width:100%; border-collapse:collapse; background:#fff; font-size:12.5px; }
    .ptable th { padding:8px 10px; border:1px solid #b8c4d8; text-align:center; font-weight:600; font-size:11px; color:#1a2d5a; white-space:nowrap; text-transform:uppercase; letter-spacing:.04em; }
    .th-y   { background:#fffde7; }
    .th-grp { background:#e3f2fd; color:#1565c0 !important; }
    .th-no  { background:#f5f5f5; width:38px; }
    .th-act { background:#f5f5f5; width:72px; }
    .ptable td { padding:8px 10px; border:1px solid #dde4ef; color:#1a2d5a; vertical-align:middle; font-size:13px; }
    .tc   { text-align:center; }
    .fw   { font-weight:500; }
    .mono { font-family:monospace; font-size:12px; color:#3d5080; }
    .muted { color:#9baac8; }
    .remark-td { max-width:140px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .td-empty { text-align:center; padding:40px; color:#9baac8; font-style:italic; }
    .tr-alt td { background:#eef5fd; }
    .ptable tbody tr:hover td { background:#ddeeff; }
    .dash { color:#c0c9d8; }

    /* action icon buttons */
    .bico { display:inline-flex; align-items:center; justify-content:center; width:28px; height:28px; border:none; border-radius:6px; cursor:pointer; transition:all .15s; margin:0 6px; }
    .bedit { background:#e8f0fe; color:#1565c0; } .bedit:hover { background:#1565c0; color:#fff; }
    .bdel  { background:#fef2f2; color:#dc2626; } .bdel:hover  { background:#dc2626; color:#fff; }

    /* status badges */
    .s-active   { display:inline-block; padding:3px 9px; border-radius:20px; font-size:11px; font-weight:600; text-transform:uppercase; background:#eaf3de; color:#3b6d11; border:1px solid #c0dd97; }
    .s-inactive { display:inline-block; padding:3px 9px; border-radius:20px; font-size:11px; font-weight:600; text-transform:uppercase; background:#fef2f2; color:#dc2626; border:1px solid #fecaca; }
    .s-suspended{ display:inline-block; padding:3px 9px; border-radius:20px; font-size:11px; font-weight:600; text-transform:uppercase; background:#fff8e1; color:#b45309; border:1px solid #fcd34d; }

    .tfoot { margin-top:8px; text-align:right; font-size:12px; color:rgba(255,255,255,.4); }
    .loading-wrap { display:flex; align-items:center; justify-content:center; gap:12px; padding:60px; color:rgba(255,255,255,.6); }
    .spinner    { width:20px; height:20px; border:2.5px solid rgba(30,144,214,.3); border-top-color:#1e90d6; border-radius:50%; animation:spin .7s linear infinite; display:inline-block; }
    .spinner-sm { width:14px; height:14px; border:2px solid rgba(30,144,214,.3); border-top-color:#1e90d6; border-radius:50%; animation:spin .7s linear infinite; display:inline-block; vertical-align:middle; margin-right:5px; }
    .spinner-lg { width:36px; height:36px; border:3px solid #c9d8ee; border-top-color:#1e90d6; border-radius:50%; animation:spin .7s linear infinite; }
    .loading-state,.empty-state { display:flex; flex-direction:column; align-items:center; gap:16px; padding:60px; color:#9baac8; }
    @@keyframes spin { to { transform:rotate(360deg); } }

    /* ── Modal ── */
    .modal-overlay { position:fixed; inset:0; background:rgba(0,0,0,0.55); backdrop-filter:blur(4px); display:flex; align-items:center; justify-content:center; z-index:1000; padding:20px; }
    .modal-card { background:#fff; border:1px solid #dde4ef; border-radius:16px; padding:28px 32px; width:75vw; max-width:1000px; max-height:90vh; overflow-y:auto; box-shadow:0 24px 60px rgba(0,0,0,0.18); }
    .modal-lg   { max-width:1000px; }
    .modal-wide { max-width:900px; }
    .modal-sm   { max-width:480px; }
    .modal-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; }
    .modal-header h2 { font-family:"Sora",sans-serif; font-size:20px; font-weight:700; color:#1a2d5a; }
    .modal-close { background:none; border:none; cursor:pointer; color:#9baac8; font-size:18px; padding:4px 8px; border-radius:6px; line-height:1; flex-shrink:0; }
    .modal-close:hover { background:#f0f4fb; color:#1a2d5a; }
    .error-alert { background:#fff1f1; border:1px solid #fecaca; border-radius:10px; padding:12px 14px; font-size:13px; color:#b42318; margin-bottom:16px; }

    /* form */
    .form-section-title { font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:.08em; color:#1e90d6; margin:20px 0 12px; padding-bottom:7px; border-bottom:1.5px solid #c7e3f8; display:flex; align-items:center; gap:8px; flex-wrap:wrap; }
    .form-grid  { display:grid; grid-template-columns:1fr 1fr; gap:16px 28px; }
    .form-group { margin-bottom:2px; }
    .form-group.full-width { grid-column:1 / -1; }
    .form-group label { display:block; font-size:11px; font-weight:600; color:#7a8fad; margin-bottom:6px; text-transform:uppercase; letter-spacing:.06em; }
    .label-hint { font-size:11px; font-weight:400; text-transform:none; color:#9baac8; letter-spacing:0; margin-left:4px; }
    .fg-row { display:flex; flex-wrap:wrap; gap:12px; margin-bottom:2px; }
    .fg     { display:flex; flex-direction:column; min-width:0; }
    .fg-1   { flex:1 1 140px; }
    .fg-2   { flex:2 1 240px; }
    .fg-3   { flex:10 1 100%; }
    .fg label { display:block; font-size:11px; font-weight:600; color:#7a8fad; margin-bottom:5px; text-transform:uppercase; letter-spacing:.06em; white-space:nowrap; }
    .required,.req { color:#e53935; }
    .form-input { width:100%; padding:10px 13px; background:#f7fafd; border:1.5px solid #c9d8ee; border-radius:9px; color:#1a2d5a; font-size:14px; outline:none; font-family:inherit; box-sizing:border-box; transition:border-color .15s,box-shadow .15s; }
    .form-input:focus { border-color:#1e90d6; background:#fff; box-shadow:0 0 0 3px rgba(30,144,214,0.1); }
    .form-input::placeholder { color:#b0bdd4; }
    .form-input-disabled,.form-input[disabled],.form-input[readonly] { background:#f0f4f8; color:#9baac8; cursor:not-allowed; }
    .form-textarea { min-height:80px; resize:vertical; }

    /* upload */
    .upload-zone { border:2px dashed #c9d8ee; border-radius:12px; padding:4px; transition:border-color .2s,background .2s; margin-bottom:12px; cursor:pointer; }
    .upload-zone:hover,.upload-zone.drag-over { border-color:#1e90d6; background:#f0f7ff; }
    .upload-label { display:flex; flex-direction:column; align-items:center; gap:6px; padding:24px 20px; cursor:pointer; }
    .upload-text  { font-size:14px; color:#4a6080; }
    .upload-hint  { font-size:12px; color:#9baac8; }
    .upload-zone-inner { display:flex; flex-direction:column; align-items:center; gap:8px; color:#9baac8; font-size:13px; text-align:center; }
    .upload-icon-wrap  { width:44px; height:44px; border-radius:12px; background:#e6f1fb; display:flex; align-items:center; justify-content:center; margin-bottom:2px; }
    .browse-link  { color:#1e90d6; cursor:pointer; text-decoration:underline; }
    .upload-inline-btn { display:inline-flex; align-items:center; gap:4px; padding:4px 9px; border-radius:6px; font-size:11px; font-weight:600; color:#9baac8; border:1px dashed #c9d8ee; cursor:pointer; transition:all .15s; white-space:nowrap; }
    .upload-inline-btn:hover { border-color:#1e90d6; color:#1e90d6; background:#e6f1fb; }

    /* file list */
    .file-list { display:flex; flex-direction:column; gap:6px; margin-bottom:8px; }
    .existing-files { margin-top:4px; }
    .existing-label { font-size:11px; text-transform:uppercase; color:#9baac8; letter-spacing:.05em; margin-bottom:6px; }
    .file-item { display:flex; align-items:center; gap:10px; background:#f7fafd; border:1px solid #dde4ef; border-radius:8px; padding:8px 12px; }
    .att-list  { display:flex; flex-direction:column; gap:5px; margin-bottom:10px; }
    .att-item  { display:flex; align-items:center; gap:10px; padding:8px 12px; background:#f7fafd; border:1px solid #dde4ef; border-radius:10px; transition:background .15s; }
    .att-item:hover { background:#eef4fb; }
    .att-pending { border-color:rgba(255,152,0,.35); background:rgba(255,152,0,.04); }
    .att-icon  { flex-shrink:0; display:flex; align-items:center; }
    .att-info  { flex:1; min-width:0; }
    .att-name  { font-size:13px; color:#1e90d6; text-decoration:none; display:block; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .att-name:hover { text-decoration:underline; }
    .att-meta  { font-size:11px; color:#9baac8; display:block; margin-top:2px; }
    .pending-badge { color:#e65100; font-weight:600; }
    .att-count-label { font-size:10px; background:#e6f1fb; color:#1e90d6; padding:2px 7px; border-radius:10px; }
    .att-hint-label  { font-size:10px; color:#9baac8; font-style:italic; text-transform:none; letter-spacing:0; }
    .att-action-btn  { background:none; border:none; cursor:pointer; padding:5px 7px; border-radius:6px; display:flex; align-items:center; transition:all .15s; flex-shrink:0; text-decoration:none; }
    .att-download    { color:#9baac8; }
    .att-download:hover { background:#e6f1fb; color:#1e90d6; }
    .att-delete      { color:#c9d8ee; }
    .att-delete:hover{ background:#fef2f2; color:#dc2626; }
    .att-action-btn:disabled { opacity:.4; cursor:not-allowed; }
    .file-icon { width:30px; height:30px; border-radius:6px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .file-icon.pdf { background:rgba(239,83,80,.1); color:#ef5350; }
    .file-icon.img { background:rgba(30,144,214,.1); color:#1e90d6; }
    .file-info { flex:1; min-width:0; }
    .file-name { display:block; font-size:13px; color:#1a2d5a; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .file-link { color:#1e90d6; text-decoration:none; }
    .file-link:hover { text-decoration:underline; }
    .file-size { font-size:11px; color:#9baac8; }
    .file-remove { background:none; border:none; cursor:pointer; color:#9baac8; font-size:14px; padding:4px; border-radius:4px; flex-shrink:0; line-height:1; }
    .file-remove:hover { color:#dc2626; background:#fef2f2; }

    /* cv upload */
    .cv-upload-box  { position:relative; border:1.5px dashed #c9d8ee; border-radius:12px; min-height:72px; transition:border-color .2s,background .2s; overflow:hidden; background:#f7fafd; }
    .cv-upload-box.drag-over { border-color:#1e90d6; background:#f0f7ff; }
    .cv-placeholder { display:flex; flex-direction:column; align-items:center; justify-content:center; gap:4px; padding:18px; pointer-events:none; }
    .cv-upload-icon { font-size:22px; color:#b0bdd4; }
    .cv-upload-text { font-size:13px; color:#4a6080; }
    .cv-browse-link { color:#1e90d6; cursor:pointer; pointer-events:all; text-decoration:underline; }
    .cv-upload-hint { font-size:11px; color:#9baac8; }
    .cv-selected,.cv-existing { display:flex; align-items:center; gap:12px; padding:14px 16px; }
    .cv-file-icon  { font-size:24px; flex-shrink:0; }
    .cv-file-info  { flex:1; min-width:0; }
    .cv-file-name  { display:block; font-size:13px; font-weight:500; color:#1a2d5a; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .cv-file-size  { font-size:11px; color:#9baac8; }
    .cv-view-link  { display:inline-block; font-size:11px; color:#1e90d6; text-decoration:none; margin-top:2px; }
    .cv-remove-btn { background:none; border:none; cursor:pointer; color:#9baac8; font-size:16px; padding:4px; border-radius:4px; pointer-events:all; position:relative; z-index:2; }
    .cv-remove-btn:hover { color:#dc2626; }
    .cv-replace-btn { font-size:12px; color:#1e90d6; cursor:pointer; border:1px solid #b5d4f4; border-radius:6px; padding:4px 10px; pointer-events:all; position:relative; z-index:2; white-space:nowrap; background:#e6f1fb; }
    .cv-error { margin-top:6px; font-size:12px; color:#b42318; }

    /* roles */
    .roles-picker { display:flex; gap:8px; flex-wrap:wrap; margin-top:4px; }
    .role-check   { display:flex; align-items:center; gap:6px; cursor:pointer; padding:6px 12px; border-radius:8px; border:1.5px solid #c9d8ee; background:#f7fafd; transition:all .2s; }
    .role-check input { display:none; }
    .role-check.checked { border-color:#1e90d6; background:#e6f1fb; }
    .role-badge   { padding:3px 8px; border-radius:20px; font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:.04em; }
    .role-admin      { background:rgba(156,39,176,.12); color:#7b1fa2; }
    .role-user       { background:rgba(33,150,243,.12);  color:#1565c0; }
    .role-inspector  { background:rgba(255,152,0,.12);   color:#e65100; }

    /* type & code badges */
    .code-badge         { font-family:monospace; font-size:12px; font-weight:600; background:#e6f1fb; color:#1565c0; padding:3px 8px; border-radius:6px; border:1px solid #b5d4f4; }
    .type-badge         { padding:3px 8px; border-radius:6px; font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:.04em; }
    .type-material      { background:#eaf3de; color:#3b6d11; border:1px solid #c0dd97; }
    .type-accessory     { background:#e6f1fb; color:#1565c0; border:1px solid #b5d4f4; }
    .type-service       { background:#f3e8fc; color:#7b1fa2; border:1px solid #d1b3f0; }
    .type-logistics     { background:#fff3e0; color:#e65100; border:1px solid #ffcc80; }
    .type-manufacturing { background:#fef2f2; color:#dc2626; border:1px solid #fecaca; }

    /* file count badge / file popup */
    .file-count-btn { display:inline-flex; align-items:center; gap:5px; padding:3px 10px; background:#e6f1fb; border:1px solid #b5d4f4; border-radius:20px; color:#1e90d6; font-size:12px; font-weight:600; cursor:pointer; transition:all .2s; }
    .file-count-btn:hover { background:#cce4f8; border-color:#85b7eb; transform:translateY(-1px); }
    .file-count-badge { display:inline-flex; align-items:center; gap:4px; padding:3px 8px; border-radius:20px; font-size:12px; font-weight:600; background:#e6f1fb; color:#1e90d6; border:1px solid #b5d4f4; }
    .fp-backdrop { position:fixed; inset:0; z-index:1100; }
    .fp-popup    { position:fixed; z-index:1101; width:380px; background:#fff; border:1px solid #c9d8ee; border-radius:14px; box-shadow:0 20px 60px rgba(0,0,0,.18); overflow:hidden; animation:fp-in .15s ease; }
    @@keyframes fp-in { from { opacity:0; transform:translateY(-6px) scale(.97); } to { opacity:1; transform:none; } }
    .fp-header  { display:flex; align-items:center; justify-content:space-between; padding:12px 14px 10px; border-bottom:1px solid #e8eef7; }
    .fp-title   { font-size:12px; font-weight:600; color:#4a6080; display:flex; align-items:center; gap:6px; }
    .fp-close   { background:none; border:none; cursor:pointer; color:#9baac8; font-size:14px; padding:2px 6px; border-radius:5px; line-height:1; }
    .fp-close:hover { background:#f0f4fb; color:#1a2d5a; }
    .fp-list    { max-height:320px; overflow-y:auto; padding:6px 0; }
    .fp-item    { display:flex; align-items:center; gap:10px; padding:9px 14px; transition:background .12s; }
    .fp-item:hover { background:#f7fafd; }
    .fp-icon    { flex-shrink:0; display:flex; align-items:center; }
    .fp-info    { flex:1; min-width:0; }
    .fp-name    { display:block; font-size:13px; color:#1a2d5a; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; font-weight:500; }
    .fp-meta    { display:block; font-size:11px; color:#9baac8; margin-top:2px; }
    .fp-actions { display:flex; gap:4px; flex-shrink:0; }

    /* inline file popup used in Customers */
    .files-popup-sub { font-size:13px; color:#9baac8; margin-top:2px; }
    .popup-file-list  { display:flex; flex-direction:column; gap:8px; max-height:420px; overflow-y:auto; padding-right:4px; }
    .popup-file-item  { display:flex; align-items:center; gap:12px; background:#f7fafd; border:1px solid #dde4ef; border-radius:10px; padding:10px 14px; transition:background .15s; }
    .popup-file-item:hover { background:#eef4fb; }
    .popup-file-actions { display:flex; gap:6px; flex-shrink:0; }
    .popup-btn  { display:inline-flex; align-items:center; gap:5px; padding:5px 12px; border-radius:7px; font-size:12px; font-weight:600; text-decoration:none; transition:all .2s; cursor:pointer; border:none; }
    .view-btn   { background:#e6f1fb; color:#1e90d6; border:1px solid #b5d4f4; }
    .view-btn:hover { background:#cce4f8; }
    .download-btn { background:#eaf3de; color:#3b6d11; border:1px solid #c0dd97; }
    .download-btn:hover { background:#d4ebb8; }

    /* business type pills */
    .btype-group { display:flex; gap:8px; flex-wrap:wrap; padding:4px 0; }
    .btype-label { padding:5px 14px; border-radius:20px; font-size:12px; font-weight:600; cursor:pointer; border:1px solid #c9d8ee; background:#f0f4fb; color:#4a6080; transition:all .15s; user-select:none; }
    .btype-label:hover { background:#e0eaf7; border-color:#1e90d6; color:#1e90d6; }
    .btype-active { background:#1e90d6 !important; border-color:#1e90d6 !important; color:#fff !important; }
    .btn-view-files { display:inline-flex; align-items:center; gap:7px; padding:9px 18px; background:#e6f1fb; border:1px solid #b5d4f4; border-radius:9px; color:#1e90d6; font-size:13px; font-weight:600; cursor:pointer; transition:background .15s; margin-top:4px; }
    .btn-view-files:hover { background:#cce4f8; }

    /* vendor/user cell */
    .vendor-cell   { display:flex; align-items:center; gap:10px; }
    .vendor-avatar { width:36px; height:36px; border-radius:10px; background:#1e90d6; display:flex; align-items:center; justify-content:center; font-size:13px; font-weight:700; flex-shrink:0; color:#fff; }
    .vendor-name   { font-weight:600; font-size:14px; color:#1a2d5a; }
    .vendor-short  { font-size:12px; color:#9baac8; margin-top:2px; }
    .contact-name  { font-size:13px; color:#4a6080; }
    .contact-phone { font-size:12px; color:#9baac8; font-family:monospace; margin-top:2px; }
    .company-cell  { display:flex; align-items:center; gap:10px; }
    .company-avatar{ width:32px; height:32px; border-radius:8px; background:#1e90d6; display:flex; align-items:center; justify-content:center; font-size:12px; font-weight:700; flex-shrink:0; color:#fff; }
    .company-name  { font-weight:600; font-size:13px; color:#1a2d5a; }
    .user-cell     { display:flex; align-items:center; gap:8px; }
    .user-avatar   { width:30px; height:30px; border-radius:50%; background:#1e90d6; display:flex; align-items:center; justify-content:center; font-size:11px; font-weight:700; flex-shrink:0; color:#fff; }
    .user-fullname { font-weight:500; font-size:13px; white-space:nowrap; color:#1a2d5a; }
    .mono-sm  { font-family:monospace; font-size:12px; color:#3d5080; }
    .dim      { color:#9baac8; }
    .sm       { font-size:12px; }
    .small-td { font-size:12px; max-width:130px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .cat-badge{ padding:3px 9px; border-radius:20px; font-size:11px; font-weight:600; background:#e6f1fb; color:#1565c0; white-space:nowrap; border:1px solid #b5d4f4; }

    /* status toggle (Users) */
    .status-toggle           { padding:3px 10px; border-radius:20px; border:none; cursor:pointer; font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:.04em; transition:all .2s; white-space:nowrap; }
    .status-toggle.s-active  { background:#eaf3de; color:#3b6d11; border:1px solid #c0dd97; }
    .status-toggle.s-inactive{ background:#fef2f2; color:#dc2626; border:1px solid #fecaca; }
    .status-toggle:hover     { filter:brightness(.95); }

    /* cv link */
    .cv-link { display:inline-flex; align-items:center; gap:3px; font-size:12px; color:#1e90d6; text-decoration:none; padding:3px 8px; border-radius:6px; border:1px solid #b5d4f4; background:#e6f1fb; transition:background .2s; white-space:nowrap; }
    .cv-link:hover { background:#cce4f8; }

    /* detail view (Vendors) */
    .detail-grid          { display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:8px; }
    .detail-section       { background:#f7fafd; border:1px solid #dde4ef; border-radius:12px; padding:16px; }
    .detail-section.col-2 { grid-column:span 2; }
    .detail-section-title { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.08em; color:#7a8fad; margin-bottom:12px; }
    .detail-row           { display:flex; justify-content:space-between; align-items:center; padding:6px 0; border-bottom:1px solid #eef4fb; font-size:13px; gap:8px; }
    .detail-row:last-child { border-bottom:none; }
    .detail-row span:first-child { color:#9baac8; flex-shrink:0; }
    .detail-row span:last-child  { color:#1a2d5a; text-align:right; }
    .detail-link  { color:#1e90d6; font-size:13px; text-decoration:none; }
    .detail-link:hover { text-decoration:underline; }
    .detail-notes { font-size:13px; color:#4a6080; line-height:1.7; }

    /* misc */
    .check-label  { display:flex; align-items:center; gap:8px; cursor:pointer; font-size:14px; color:#4a6080; }
    .check-label input { width:16px; height:16px; accent-color:#1e90d6; }
    .btn-file-hint { font-size:11px; background:#e6f1fb; color:#1e90d6; padding:2px 7px; border-radius:8px; }
    .action-btns { display:flex; gap:4px; }
    .action-btn  { background:none; border:none; cursor:pointer; padding:5px 9px; border-radius:6px; font-size:13px; font-weight:500; transition:all .2s; color:#9baac8; display:flex; align-items:center; gap:4px; }
    .action-btn.view:hover   { background:#f0f4fb; color:#4a6080; }
    .action-btn.edit:hover   { background:#e8f0fe; color:#1565c0; }
    .action-btn.delete:hover { background:#fef2f2; color:#dc2626; }

    /* modal footer & buttons */
    .modal-footer { display:flex; justify-content:flex-end; align-items:center; gap:10px; padding-top:20px; border-top:1px solid #e8eef7; margin-top:16px; }
    .btn-cancel   { padding:10px 20px; background:#f0f4fb; border:1px solid #c9d8ee; border-radius:9px; color:#4a6080; font-size:14px; cursor:pointer; transition:background .15s; }
    .btn-cancel:hover { background:#e0eaf7; }
    .btn-submit   { display:flex; align-items:center; gap:8px; padding:10px 24px; background:#1e90d6; border:none; border-radius:9px; color:#fff; font-size:14px; font-weight:600; cursor:pointer; min-width:140px; justify-content:center; transition:background .15s; }
    .btn-submit:hover:not(:disabled) { background:#1565c0; }
    .btn-submit:disabled { opacity:.65; cursor:not-allowed; }
    .btn-delete   { padding:10px 22px; background:#fff1f1; border:1px solid #fecaca; border-radius:9px; color:#dc2626; font-size:14px; font-weight:600; cursor:pointer; }
    .btn-delete:hover { background:#fee2e2; }
    .confirm-card { text-align:center; max-width:440px; }
    .confirm-icon { font-size:40px; margin-bottom:12px; }
