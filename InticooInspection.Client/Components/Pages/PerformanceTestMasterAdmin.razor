        z-index: 50;
    }
    .ptm-cmb-item {
        padding: 8px 12px; font-size: 13px; color: #1a1a2e; cursor: pointer;
    }
    .ptm-cmb-item:hover, .ptm-cmb-highlight { background: #eef4ff; }
    .ptm-cmb-selected { background: #e3f2fd; font-weight: 600; }
