        font-size: 11px; font-weight: 700; white-space: nowrap;
    }
    .cat-packagingtest        { background: #fff3e0; color: #e65100; }
    .cat-producttest          { background: #e3f2fd; color: #1565c0; }
    .cat-moisturecontenttest  { background: #e8f5e9; color: #2e7d32; }
    .cat-adhesivetest         { background: #fce4ec; color: #c2185b; }

    /* Reference link in table */
    .ptm-ref-link {
        display: inline-flex; align-items: center; gap: 5px;
        font-size: 12px; color: #1565c0; text-decoration: none;
        background: #e3f2fd; padding: 4px 8px; border-radius: 6px;
        max-width: 100%; word-break: break-all;
    }
    .ptm-ref-link:hover { background: #bbdefb; text-decoration: underline; }
    .ptm-ref-more {
        margin-left: 6px; padding: 3px 8px; border-radius: 12px;
        background: #eef4ff; color: #1565c0; border: 1px solid #c7dcf2;
        font-size: 11px; font-weight: 700; cursor: pointer;
    }
    .ptm-ref-more:hover { background: #d6e7fb; }

    .ptm-toggle {
        display: inline-block; font-size: 11px; font-weight: 700;
