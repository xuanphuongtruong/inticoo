@page "/admin/performance-test-master"
@using System.Net.Http.Json
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Forms
@inject HttpClient Http
@inject IJSRuntime JS
@inject Blazored.SessionStorage.ISessionStorageService SessionStorage

<div class="ptm-page">

    <!-- ═══════ HEADER ═══════ -->
    <div class="ptm-header">
        <div class="ptm-header-left">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#2D7DD2" stroke-width="2" stroke-linecap="round">
                <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/>
                <rect x="9" y="3" width="6" height="4" rx="1"/>
                <path d="M9 12h6M9 16h4"/>
            </svg>
            <div>
                <div class="ptm-title">Performance Test Master</div>
                <div class="ptm-subtitle">Manage test standard list · @_items.Count records</div>
            </div>
        </div>
        <button class="ptm-add-btn" @onclick="OpenCreate">
            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M10 4v12M4 10h12"/></svg>
            + Add New
        </button>
    </div>

    <!-- ═══════ FILTERS ═══════ -->
    <div class="ptm-filters">
        <div class="ptm-filter-group">
            <label class="ptm-filter-label">Category</label>
            <div class="ptm-cmb-root ptm-combo-filter @(_filterCmbOpen ? "ptm-cmb-root-open" : "")" tabindex="-1"
                 @onfocusout="@(async () => { await Task.Delay(150); if (_filterCmbOpen) { _filterCmbOpen = false; StateHasChanged(); } })">
                <div class="ptm-cmb-control @(_filterCmbOpen ? "ptm-cmb-open" : "")" @onclick="@(() => _filterCmbOpen = !_filterCmbOpen)">
                    <input class="ptm-cmb-input" type="text" placeholder="All categories"
                           value="@_filterCmbQuery"
                           @oninput="OnFilterCmbInput"
                           @onfocus="@(() => _filterCmbOpen = true)"
                           @onkeydown="OnFilterCmbKeyDown" />
                    @if (!string.IsNullOrEmpty(_filterCategory))
                    {
                        <button type="button" class="ptm-cmb-clear"
                                @onclick="@(() => SelectFilterCategory(""))"
                                @onclick:stopPropagation="true" tabindex="-1" title="Clear">✕</button>
                    }
                    <span class="ptm-cmb-arrow">
                        <svg width="10" height="6" viewBox="0 0 10 6" xmlns="http://www.w3.org/2000/svg">
                            <path d="M1 1l4 4 4-4" stroke="#7a8fad" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </span>
                </div>
                @if (_filterCmbOpen)
                {
                    <div class="ptm-cmb-menu">
                        @if (string.IsNullOrEmpty(_filterCmbQuery))
                        {
                            <div class="ptm-cmb-item ptm-cmb-item-empty @(string.IsNullOrEmpty(_filterCategory) ? "ptm-cmb-selected" : "")"
                                 @onclick="@(() => SelectFilterCategory(""))"
                                 @onclick:stopPropagation="true">
                                All
                            </div>
                        }
                        @{ var filterList = FilterCmbItems().ToList(); }
                        @if (!filterList.Any())
                        {
                            <div class="ptm-cmb-empty">No matches</div>
                        }
                        else
                        {
                            @for (int i = 0; i < filterList.Count; i++)
                            {
                                var idx = i;
                                var opt = filterList[idx];
                                <div class="ptm-cmb-item @(idx == _filterCmbHighlight ? "ptm-cmb-highlight" : "") @(opt == _filterCategory ? "ptm-cmb-selected" : "")"
                                     @onclick="@(() => SelectFilterCategory(opt))"
                                     @onclick:stopPropagation="true"
                                     @onmouseenter="@(() => _filterCmbHighlight = idx)">
                                    @opt
                                </div>
                            }
                        }
                    </div>
                }
            </div>
        </div>
        <div class="ptm-filter-group">
            <label class="ptm-filter-label">Status</label>
            <select class="ptm-select" @bind="_filterActive">
                <option value="all">All</option>
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
            </select>
        </div>
        <div class="ptm-filter-group ptm-search-group">
            <label class="ptm-filter-label">Search</label>
            <input class="ptm-search" placeholder="Protocol / Standard / Test..." @bind="_searchText" @bind:event="oninput" />
        </div>
    </div>

    <!-- ═══════ TABLE ═══════ -->
    @if (_loading)
    {
        <div class="ptm-loading"><div class="ptm-spinner"></div><span>Loading...</span></div>
    }
    else if (!FilteredItems().Any())
    {
        <div class="ptm-empty">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none" stroke="#ccc" stroke-width="1.5">
                <rect x="8" y="10" width="32" height="32" rx="4"/><path d="M16 10V6M32 10V6M8 22h32" stroke-linecap="round"/><circle cx="24" cy="32" r="4"/>
            </svg>
            <p>No data found</p>
        </div>
    }
    else
    {
        <div class="ptm-table-wrap">
            <table class="ptm-table">
                <thead>
                    <tr>
                        <th class="th-no">#</th>
                        <th class="th-category">Category</th>
                        <th class="th-protocol">Protocol Name</th>
                        <th class="th-testprot">Test Protocol</th>
                        <th class="th-req">Requirements</th>
                        <th class="th-ref">References</th>
                        <th class="th-status">Status</th>
                        <th class="th-action">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @{ var filtered = FilteredItems(); var rowNo = 0; }
                    @foreach (var item in filtered)
                    {
                        rowNo++;
                        var displayNo = rowNo;
                        <tr class="@(item.IsActive ? "" : "row-inactive")">
                            <td class="td-no">@displayNo</td>
                            <td class="td-category">
                                <span class="ptm-cat-badge cat-@Slug(item.Category)">@item.Category</span>
                            </td>
                            <td class="td-protocol">@item.ProtocolName</td>
                            <td class="td-testprot">
                                @if (!string.IsNullOrEmpty(item.TestProtocol))
                                { <span class="ptm-tp-text">@item.TestProtocol</span> }
                                else { <span class="ptm-na">—</span> }
                            </td>
                            <td class="td-req">
                                @if (!string.IsNullOrEmpty(item.Requirements))
                                { <span class="ptm-req-text">@item.Requirements</span> }
                                else { <span class="ptm-na">—</span> }
                            </td>
                            <td class="td-ref">
                                @if (item.References != null && item.References.Count > 0)
                                {
                                    <!-- File đầu tiên hiển thị link tải -->
                                    var first = item.References[0];
                                    <a class="ptm-ref-link" href="@($"api/performance-test-master/references/{first.Id}")"
                                       target="_blank" title="@first.FileName">
                                        <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                                            <path d="M14 2H6a2 2 0 00-2 2v12a2 2 0 002 2h8a2 2 0 002-2V6l-2-4z"/>
                                            <path d="M14 2v4h4"/>
                                        </svg>
                                        <span>@Truncate(first.FileName, 16)</span>
                                    </a>
                                    @if (item.References.Count > 1)
                                    {
                                        <button class="ptm-ref-more" @onclick="() => OpenDetail(item)" title="View all files">
                                            +@(item.References.Count - 1)
                                        </button>
                                    }
                                }
                                else
                                {
                                    <span class="ptm-na">—</span>
                                }
                            </td>
                            <td class="td-status">
                                <button class="ptm-toggle @(item.IsActive ? "tog-on" : "tog-off")"
                                        @onclick="() => ToggleActive(item)">
                                    @(item.IsActive ? "Active" : "Inactive")
                                </button>
                            </td>
                            <td class="td-action">
                                <button class="ptm-btn-view" @onclick="() => OpenDetail(item)" title="Full Detail">
                                    <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                                        <path d="M1 10s3-7 9-7 9 7 9 7-3 7-9 7-9-7-9-7z"/>
                                        <circle cx="10" cy="10" r="3"/>
                                    </svg>
                                </button>
                                <button class="ptm-btn-edit" @onclick="() => OpenEdit(item)" title="Edit">
                                    <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M11 4l5 5-9 9H2v-5L11 4z"/></svg>
                                </button>
                                <button class="ptm-btn-del" @onclick="() => ConfirmDelete(item)" title="Delete">
                                    <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 6h14M8 6V4h4v2M6 6l1 12h6l1-12"/></svg>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="ptm-count">Showing @filtered.Count / @_items.Count records</div>
    }
</div>

<!-- ═══════ MODAL THÊM/SỬA ═══════ -->
@if (_showModal)
{
    <div class="ptm-overlay" @onclick="CloseModal">
        <div class="ptm-modal" @onclick:stopPropagation="true">
            <div class="ptm-modal-header">
                <span class="ptm-modal-title">@(_editId == null ? "+ Add New" : "Edit") Test Protocol</span>
                <button class="ptm-modal-close" @onclick="CloseModal">
                    <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 5l10 10M15 5L5 15"/></svg>
                </button>
            </div>

            <div class="ptm-modal-body">
                @if (!string.IsNullOrEmpty(_modalError))
                { <div class="ptm-modal-error">@_modalError</div> }

                <!-- Category -->
                <div class="ptm-form-group">
                    <label class="ptm-label">Category <span class="req">*</span></label>
                    <div class="ptm-cmb-root ptm-combo-form @(_formCmbOpen ? "ptm-cmb-root-open" : "")" tabindex="-1"
                         @onfocusout="@(async () => { await Task.Delay(150); if (_formCmbOpen) { if (!string.IsNullOrWhiteSpace(_formCmbQuery) && _formCmbQuery != _form.Category) { _form.Category = _formCmbQuery.Trim(); } _formCmbOpen = false; StateHasChanged(); } })">
                        <div class="ptm-cmb-control @(_formCmbOpen ? "ptm-cmb-open" : "")" @onclick="@(() => _formCmbOpen = !_formCmbOpen)">
                            <input class="ptm-cmb-input" type="text" placeholder="Select or type a category"
                                   value="@_formCmbQuery"
                                   @oninput="OnFormCmbInput"
                                   @onfocus="@(() => _formCmbOpen = true)"
                                   @onkeydown="OnFormCmbKeyDown" />
                            @if (!string.IsNullOrEmpty(_form.Category))
                            {
                                <button type="button" class="ptm-cmb-clear"
                                        @onclick="@(() => SelectFormCategory(""))"
                                        @onclick:stopPropagation="true" tabindex="-1" title="Clear">✕</button>
                            }
                            <span class="ptm-cmb-arrow">
                                <svg width="10" height="6" viewBox="0 0 10 6" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M1 1l4 4 4-4" stroke="#7a8fad" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </span>
                        </div>
                        @if (_formCmbOpen)
                        {
                            <div class="ptm-cmb-menu">
                                @{ var formList = FormCmbItems().ToList(); }
                                @if (!formList.Any())
                                {
                                    @if (!string.IsNullOrWhiteSpace(_formCmbQuery))
                                    {
                                        <div class="ptm-cmb-item ptm-cmb-item-create"
                                             @onclick="@(() => SelectFormCategory(_formCmbQuery.Trim()))"
                                             @onclick:stopPropagation="true">
                                            <span class="ptm-cmb-create-tag">Add</span> "@_formCmbQuery"
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="ptm-cmb-empty">No categories</div>
                                    }
                                }
                                else
                                {
                                    @for (int i = 0; i < formList.Count; i++)
                                    {
                                        var idx = i;
                                        var opt = formList[idx];
                                        <div class="ptm-cmb-item @(idx == _formCmbHighlight ? "ptm-cmb-highlight" : "") @(opt == _form.Category ? "ptm-cmb-selected" : "")"
                                             @onclick="@(() => SelectFormCategory(opt))"
                                             @onclick:stopPropagation="true"
                                             @onmouseenter="@(() => _formCmbHighlight = idx)">
                                            @opt
                                        </div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(_formCmbQuery)
                                         && !_categories.Any(x => string.Equals(x, _formCmbQuery.Trim(), StringComparison.OrdinalIgnoreCase)))
                                    {
                                        <div class="ptm-cmb-item ptm-cmb-item-create"
                                             @onclick="@(() => SelectFormCategory(_formCmbQuery.Trim()))"
                                             @onclick:stopPropagation="true">
                                            <span class="ptm-cmb-create-tag">Add</span> "@_formCmbQuery"
                                        </div>
                                    }
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- Protocol Name -->
                <div class="ptm-form-group">
                    <label class="ptm-label">Protocol Name <span class="req">*</span></label>
                    <input class="ptm-input" placeholder="Full name: EN581-1 & EN581-2:2015 (Outdoor Seating for Europe market)" @bind="_form.ProtocolName" />
                </div>

                <!-- Sort Order (ẩn) -->
                <div class="ptm-form-group" style="max-width:160px;display: none;">
                    <label class="ptm-label">Sort Order</label>
                    <input class="ptm-input" type="number" min="0" @bind="_form.SortOrder" />
                </div>

                <!-- Test Protocol -->
                <div class="ptm-form-group">
                    <label class="ptm-label">Test Protocol (Step name)</label>
                    <textarea class="ptm-textarea ptm-textarea-3"
                              rows="3"
                              placeholder="E.g.: 1. General Safety Requirements. / 2. Seat and back static load test..."
                              @bind="_form.TestProtocol"></textarea>
                </div>

                <!-- Procedure -->
                <div class="ptm-form-group">
                    <label class="ptm-label">Test Procedure</label>
                    <textarea class="ptm-textarea" rows="5" placeholder="Describe step-by-step procedure..." @bind="_form.Procedure"></textarea>
                </div>

                <!-- Requirements -->
                <div class="ptm-form-group">
                    <label class="ptm-label">Requirements</label>
                    <textarea class="ptm-textarea" rows="2" placeholder="E.g.: No product damage is allowed. / Must meet all." @bind="_form.Requirements"></textarea>
                </div>

                <!-- ═══════ Reference (multi-file) ═══════ -->
                <div class="ptm-form-group">
                    <label class="ptm-label">Reference (Attached files)</label>

                    <!-- Danh sách file đã upload (có Id thật, lưu sẵn ở DB) -->
                    @if (_existingRefs != null && _existingRefs.Count > 0)
                    {
                        <div class="ptm-ref-list">
                            @foreach (var r in _existingRefs)
                            {
                                <div class="ptm-ref-existing">
                                    <div class="ptm-ref-existing-info">
                                        <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="#2D7DD2" stroke-width="2" stroke-linecap="round">
                                            <path d="M14 2H6a2 2 0 00-2 2v12a2 2 0 002 2h8a2 2 0 002-2V6l-2-4z"/>
                                            <path d="M14 2v4h4"/>
                                        </svg>
                                        <a href="@($"api/performance-test-master/references/{r.Id}")" target="_blank">
                                            @r.FileName
                                        </a>
                                        <span class="ptm-ref-size">(@FormatSize(r.FileSize))</span>
                                    </div>
                                    <button type="button" class="ptm-ref-remove"
                                            @onclick="@(() => RemoveExistingReference(r.Id))"
                                            title="Remove this file">✕</button>
                                </div>
                            }
                        </div>
                    }

                    <!-- File mới được chọn (queue, chưa upload) -->
                    @if (_pickedRefs != null && _pickedRefs.Count > 0)
                    {
                        <div class="ptm-ref-list">
                            @foreach (var pf in _pickedRefs)
                            {
                                <div class="ptm-ref-picked-row">
                                    <div class="ptm-ref-existing-info">
                                        <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="#2e7d32" stroke-width="2" stroke-linecap="round">
                                            <path d="M14 2H6a2 2 0 00-2 2v12a2 2 0 002 2h8a2 2 0 002-2V6l-2-4z"/>
                                            <path d="M14 2v4h4"/>
                                        </svg>
                                        <strong>@pf.File.Name</strong>
                                        <span class="ptm-ref-size">(@FormatSize(pf.File.Size))</span>
                                        <span class="ptm-ref-newtag">NEW</span>
                                    </div>
                                    <button type="button" class="ptm-ref-remove ptm-ref-remove-inline"
                                            @onclick="@(() => RemovePickedFile(pf.Key))"
                                            title="Cancel this file">✕</button>
                                </div>
                            }
                        </div>
                    }

                    <!-- Nút chọn file (multiple) -->
                    <div class="ptm-file-row">
                        <InputFile OnChange="OnPickReferenceFiles"
                                   class="ptm-file-input"
                                   id="ptm-ref-file"
                                   multiple
                                   accept=".pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg,.zip,.rar" />
                        <label for="ptm-ref-file" class="ptm-file-btn">
                            <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                                <path d="M10 4v12M4 10h12"/>
                            </svg>
                            + Add files
                        </label>
                        @{
                            var existCount  = _existingRefs?.Count ?? 0;
                            var pickedCount = _pickedRefs?.Count   ?? 0;
                            var totalCount  = existCount + pickedCount;
                        }
                        @if (totalCount > 0)
                        {
                            <span class="ptm-ref-counter">@totalCount file(s) attached</span>
                        }
                    </div>
                    <div class="ptm-ref-hint">PDF, Word, Excel, image or archive — up to 50 MB per file. You can attach multiple files.</div>
                </div>

                <!-- Active -->
                <div class="ptm-form-group ptm-form-check">
                    <input type="checkbox" id="chk-active" @bind="_form.IsActive" />
                    <label for="chk-active">Active</label>
                </div>
            </div>

            <div class="ptm-modal-footer">
                <button class="ptm-btn-cancel" @onclick="CloseModal" disabled="@_saving">Cancel</button>
                <button class="ptm-btn-save" @onclick="SaveAsync" disabled="@_saving">
                    @if (_saving)
                    { <div class="ptm-spinner-sm"></div><span>Saving...</span> }
                    else
                    {
                        <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M4 10l5 5 7-8"/></svg>
                        <span>@(_editId == null ? "+ Add New" : "Save")</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

<!-- ═══════ MODAL FULL DETAIL ═══════ -->
@if (_detailItem != null)
{
    <div class="ptm-overlay" @onclick="@(() => _detailItem = null)">
        <div class="ptm-modal ptm-modal-detail" @onclick:stopPropagation="true">
            <div class="ptm-modal-header">
                <span class="ptm-modal-title">Full Detail</span>
                <button class="ptm-modal-close" @onclick="@(() => _detailItem = null)">
                    <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 5l10 10M15 5L5 15"/></svg>
                </button>
            </div>
            <div class="ptm-modal-body">
                <div class="ptm-detail-row">
                    <div class="ptm-detail-label">Category</div>
                    <div class="ptm-detail-value">
                        <span class="ptm-cat-badge cat-@Slug(_detailItem.Category)">@_detailItem.Category</span>
                    </div>
                </div>
                <div class="ptm-detail-row">
                    <div class="ptm-detail-label">Protocol Name</div>
                    <div class="ptm-detail-value ptm-detail-strong">@_detailItem.ProtocolName</div>
                </div>
                <div class="ptm-detail-row">
                    <div class="ptm-detail-label">Test Protocol</div>
                    <div class="ptm-detail-value">
                        @if (string.IsNullOrEmpty(_detailItem.TestProtocol))
                        { <span class="ptm-na">—</span> }
                        else
                        { <pre class="ptm-detail-pre">@_detailItem.TestProtocol</pre> }
                    </div>
                </div>
                <div class="ptm-detail-row">
                    <div class="ptm-detail-label">Procedure</div>
                    <div class="ptm-detail-value">
                        @if (string.IsNullOrEmpty(_detailItem.Procedure))
                        { <span class="ptm-na">—</span> }
                        else
                        { <pre class="ptm-detail-pre">@_detailItem.Procedure</pre> }
                    </div>
                </div>
                <div class="ptm-detail-row">
                    <div class="ptm-detail-label">Requirements</div>
                    <div class="ptm-detail-value">
                        @if (string.IsNullOrEmpty(_detailItem.Requirements))
                        { <span class="ptm-na">—</span> }
                        else
                        { <pre class="ptm-detail-pre">@_detailItem.Requirements</pre> }
                    </div>
                </div>
                <div class="ptm-detail-row">
                    <div class="ptm-detail-label">References</div>
                    <div class="ptm-detail-value">
                        @if (_detailItem.References != null && _detailItem.References.Count > 0)
                        {
                            <div class="ptm-ref-list">
                                @foreach (var r in _detailItem.References)
                                {
                                    <a class="ptm-ref-link" href="@($"api/performance-test-master/references/{r.Id}")" target="_blank">
                                        <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                                            <path d="M14 2H6a2 2 0 00-2 2v12a2 2 0 002 2h8a2 2 0 002-2V6l-2-4z"/>
                                            <path d="M14 2v4h4"/>
                                        </svg>
                                        <span>@r.FileName</span>
                                        <span class="ptm-ref-size">(@FormatSize(r.FileSize))</span>
                                    </a>
                                }
                            </div>
                        }
                        else
                        {
                            <span class="ptm-na">No file attached</span>
                        }
                    </div>
                </div>
                <div class="ptm-detail-row">
                    <div class="ptm-detail-label">Status</div>
                    <div class="ptm-detail-value">
                        <span class="ptm-toggle @(_detailItem.IsActive ? "tog-on" : "tog-off")" style="cursor:default;">
                            @(_detailItem.IsActive ? "Active" : "Inactive")
                        </span>
                    </div>
                </div>
            </div>
            <div class="ptm-modal-footer">
                <button class="ptm-btn-cancel" @onclick="@(() => _detailItem = null)">Close</button>
                <button class="ptm-btn-save" @onclick="@(() => { var x = _detailItem; _detailItem = null; OpenEdit(x!); })">
                    <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M11 4l5 5-9 9H2v-5L11 4z"/></svg>
                    <span>Edit</span>
                </button>
            </div>
        </div>
    </div>
}

<!-- ═══════ CONFIRM XÓA ═══════ -->
@if (_deleteTarget != null)
{
    <div class="ptm-overlay" @onclick="() => _deleteTarget = null">
        <div class="ptm-confirm-modal" @onclick:stopPropagation="true">
            <div class="ptm-confirm-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#e53935" stroke-width="2" stroke-linecap="round">
                    <circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/>
                </svg>
            </div>
            <div class="ptm-confirm-title">Confirm Delete</div>
            <div class="ptm-confirm-msg">
                Delete record:<br />
                <strong>"@Truncate(_deleteTarget.TestProtocol ?? _deleteTarget.ProtocolName, 60)"</strong><br />
                <span style="color:#e53935;font-size:12px;">This action cannot be undone.</span>
            </div>
            <div class="ptm-confirm-btns">
                <button class="ptm-btn-cancel" @onclick="() => _deleteTarget = null">Cancel</button>
                <button class="ptm-btn-delete" @onclick="DeleteAsync" disabled="@_saving">
                    @if (_saving) { <span>Deleting...</span> } else { <span>Delete</span> }
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool   _loading = true;
    private bool   _saving  = false;
    private string _modalError = "";
    private List<TestMasterItem> _items = new();

    private string _filterCategory = "";
    private string _filterActive    = "all";
    private string _searchText        = "";

    private readonly List<string> _categories = new()
    {
        "Packaging Test",
        "Product Test",
        "Moisture Content Test",
        "Adhesive Test"
    };

    private bool  _showModal  = false;
    private int?  _editId     = null;
    private FormModel _form   = new();
    private TestMasterItem? _deleteTarget = null;
    private TestMasterItem? _detailItem = null;

    // ─── Reference state (multi-file) ───
    /// <summary>File đã có trên DB của bản ghi đang edit (snapshot khi mở modal)</summary>
    private List<ReferenceFileItem> _existingRefs = new();
    /// <summary>Id các file user bấm xoá khi đang edit (sẽ gọi DELETE khi Save)</summary>
    private HashSet<int> _pendingDeleteRefIds = new();
    /// <summary>File user mới chọn, chờ upload khi Save</summary>
    private List<PickedFile> _pickedRefs = new();
    /// <summary>Khoá tăng dần để key duy nhất cho file mới chọn (dùng cho @key)</summary>
    private int _pickedKeySeq = 0;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) { await LoadAsync(); StateHasChanged(); }
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var opts = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var result = await Http.GetFromJsonAsync<List<TestMasterItem>>(
                "api/performance-test-master?activeOnly=false", opts);
            _items = result ?? new();
        }
        catch (Exception ex) { Console.WriteLine($"[PTM] Load: {ex.Message}"); }
        finally { _loading = false; }
    }

    private List<TestMasterItem> FilteredItems()
    {
        var q = _items.AsEnumerable();
        if (!string.IsNullOrEmpty(_filterCategory)) q = q.Where(x => x.Category == _filterCategory);
        if (_filterActive == "active")   q = q.Where(x => x.IsActive);
        if (_filterActive == "inactive") q = q.Where(x => !x.IsActive);
        if (!string.IsNullOrEmpty(_searchText))
        {
            var s = _searchText.ToLower();
            q = q.Where(x =>
                x.ProtocolName.ToLower().Contains(s) ||
                (x.TestProtocol?.ToLower().Contains(s) ?? false));
        }
        return q.OrderBy(x => x.SortOrder).ThenBy(x => x.Id).ToList();
    }

    private void OpenCreate()
    {
        _editId = null;
        _form   = new FormModel { IsActive = true };
        _formCmbQuery = "";
        _formCmbOpen = false;
        _modalError = "";
        _existingRefs = new();
        _pendingDeleteRefIds = new();
        _pickedRefs = new();
        _showModal  = true;
    }

    private void OpenDetail(TestMasterItem item) => _detailItem = item;

    // ─── ComboBox state (filter) ───
    private bool   _filterCmbOpen      = false;
    private string _filterCmbQuery     = "";
    private int    _filterCmbHighlight = -1;

    // ─── ComboBox state (form) ───
    private bool   _formCmbOpen        = false;
    private string _formCmbQuery       = "";
    private int    _formCmbHighlight   = -1;

    private IEnumerable<string> FilterCmbItems()
    {
        if (string.IsNullOrWhiteSpace(_filterCmbQuery)) return _categories;
        var q = _filterCmbQuery.Trim();
        return _categories.Where(c => c.Contains(q, StringComparison.OrdinalIgnoreCase));
    }

    private IEnumerable<string> FormCmbItems()
    {
        if (string.IsNullOrWhiteSpace(_formCmbQuery)) return _categories;
        var q = _formCmbQuery.Trim();
        return _categories.Where(c => c.Contains(q, StringComparison.OrdinalIgnoreCase));
    }

    private void OnFilterCmbInput(ChangeEventArgs e)
    {
        _filterCmbQuery = e.Value?.ToString() ?? "";
        _filterCmbOpen = true;
        _filterCmbHighlight = 0;
    }

    private void OnFormCmbInput(ChangeEventArgs e)
    {
        _formCmbQuery = e.Value?.ToString() ?? "";
        _formCmbOpen = true;
        _formCmbHighlight = 0;
    }

    private void SelectFilterCategory(string value)
    {
        _filterCategory     = value ?? "";
        _filterCmbQuery     = value ?? "";
        _filterCmbOpen      = false;
        _filterCmbHighlight = -1;
    }

    private void SelectFormCategory(string value)
    {
        _form.Category    = value ?? "";
        _formCmbQuery     = value ?? "";
        _formCmbOpen      = false;
        _formCmbHighlight = -1;
    }

    private void OnFilterCmbKeyDown(KeyboardEventArgs e)
    {
        var list = FilterCmbItems().ToList();
        switch (e.Key)
        {
            case "ArrowDown":
                _filterCmbOpen = true;
                if (list.Count > 0) _filterCmbHighlight = Math.Min(_filterCmbHighlight + 1, list.Count - 1);
                break;
            case "ArrowUp":
                if (list.Count > 0) _filterCmbHighlight = Math.Max(_filterCmbHighlight - 1, 0);
                break;
            case "Enter":
                if (_filterCmbOpen && _filterCmbHighlight >= 0 && _filterCmbHighlight < list.Count)
                    SelectFilterCategory(list[_filterCmbHighlight]);
                else _filterCmbOpen = false;
                break;
            case "Escape":
                _filterCmbOpen = false;
                _filterCmbQuery = _filterCategory;
                break;
        }
    }

    private void OnFormCmbKeyDown(KeyboardEventArgs e)
    {
        var list = FormCmbItems().ToList();
        switch (e.Key)
        {
            case "ArrowDown":
                _formCmbOpen = true;
                if (list.Count > 0) _formCmbHighlight = Math.Min(_formCmbHighlight + 1, list.Count - 1);
                break;
            case "ArrowUp":
                if (list.Count > 0) _formCmbHighlight = Math.Max(_formCmbHighlight - 1, 0);
                break;
            case "Enter":
                if (_formCmbOpen)
                {
                    if (_formCmbHighlight >= 0 && _formCmbHighlight < list.Count)
                        SelectFormCategory(list[_formCmbHighlight]);
                    else if (!string.IsNullOrWhiteSpace(_formCmbQuery))
                        SelectFormCategory(_formCmbQuery.Trim());
                }
                break;
            case "Escape":
                _formCmbOpen = false;
                _formCmbQuery = _form.Category;
                break;
        }
    }

    private void OpenEdit(TestMasterItem item)
    {
        _editId = item.Id;
        _form = new FormModel
        {
            Category     = item.Category,
            ProtocolName = item.ProtocolName,
            TestProtocol = item.TestProtocol,
            Procedure    = item.Procedure,
            Requirements = item.Requirements,
            SortOrder    = item.SortOrder,
            IsActive     = item.IsActive,
        };
        _formCmbQuery = item.Category ?? "";
        _formCmbOpen = false;
        _modalError = "";

        _existingRefs = item.References != null
            ? item.References.Select(r => new ReferenceFileItem
            {
                Id = r.Id, FileName = r.FileName,
                ContentType = r.ContentType, FileSize = r.FileSize
            }).ToList()
            : new();
        _pendingDeleteRefIds = new();
        _pickedRefs = new();
        _showModal  = true;
    }

    private void CloseModal() { _showModal = false; _modalError = ""; }

    // ── Reference file handlers ──────────────────────────────────────────
    /// <summary>User chọn nhiều file qua InputFile (multiple).</summary>
    private void OnPickReferenceFiles(InputFileChangeEventArgs e)
    {
        // GetMultipleFiles cho phép giới hạn số file; lấy max 20 file/lần để an toàn.
        var files = e.GetMultipleFiles(maximumFileCount: 20);
        foreach (var f in files)
        {
            _pickedKeySeq++;
            _pickedRefs.Add(new PickedFile { Key = _pickedKeySeq, File = f });
        }
    }

    /// <summary>Bỏ 1 file mới chọn ra khỏi queue (chưa upload).</summary>
    private void RemovePickedFile(int key)
    {
        var idx = _pickedRefs.FindIndex(p => p.Key == key);
        if (idx >= 0) _pickedRefs.RemoveAt(idx);
    }

    /// <summary>Đánh dấu xoá 1 file đã có trên DB. Sẽ thực thi DELETE khi Save.</summary>
    private void RemoveExistingReference(int refId)
    {
        _pendingDeleteRefIds.Add(refId);
        _existingRefs.RemoveAll(r => r.Id == refId);
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_form.Category) || string.IsNullOrWhiteSpace(_form.ProtocolName))
        { _modalError = "Please enter Category and Protocol Name."; return; }

        _saving = true; _modalError = "";
        try
        {
            var token = await SessionStorage.GetItemAsync<string>("auth_token") ?? "";
            if (string.IsNullOrEmpty(token))
            { _modalError = "Not authenticated. Please log in again."; _saving = false; return; }

            // 1) Upsert dữ liệu chính
            var reqPayload = new UpsertPayload
            {
                Category     = _form.Category,
                ProtocolName = _form.ProtocolName,
                TestProtocol = _form.TestProtocol,
                Procedure    = _form.Procedure,
                Requirements = _form.Requirements,
                SortOrder    = _form.SortOrder,
                IsActive     = _form.IsActive
            };

            var json    = JsonSerializer.Serialize(reqPayload,
                          new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase });
            var content = new StringContent(json, System.Text.Encoding.UTF8, "application/json");
            var url     = _editId == null ? "api/performance-test-master" : $"api/performance-test-master/{_editId}";
            var method  = _editId == null ? HttpMethod.Post : HttpMethod.Put;
            var msg     = new HttpRequestMessage(method, url) { Content = content };
            msg.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            var resp = await Http.SendAsync(msg);
            if (!resp.IsSuccessStatusCode)
            {
                var body = await resp.Content.ReadAsStringAsync();
                _modalError = $"Error {(int)resp.StatusCode}: {body}";
                _saving = false; return;
            }

            var saved   = await resp.Content.ReadFromJsonAsync<TestMasterItem>();
            var savedId = saved?.Id ?? _editId ?? 0;
            if (savedId <= 0)
            {
                _modalError = "Could not determine saved record id.";
                _saving = false; return;
            }

            // 2) Xoá những file user đã bấm ✕ (nếu là edit)
            if (_editId != null && _pendingDeleteRefIds.Count > 0)
            {
                foreach (var refId in _pendingDeleteRefIds)
                {
                    var delMsg = new HttpRequestMessage(
                        HttpMethod.Delete,
                        $"api/performance-test-master/references/{refId}");
                    delMsg.Headers.Authorization =
                        new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
                    await Http.SendAsync(delMsg);
                }
            }

            // 3) Upload toàn bộ file mới chọn (gộp 1 request multipart)
            if (_pickedRefs.Count > 0)
            {
                using var multipart = new MultipartFormDataContent();
                foreach (var pf in _pickedRefs)
                {
                    using var ms = new MemoryStream();
                    // 50 MB / file
                    await pf.File.OpenReadStream(50 * 1024 * 1024).CopyToAsync(ms);
                    var bytes = ms.ToArray();

                    var fileContent = new ByteArrayContent(bytes);
                    fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(
                        string.IsNullOrWhiteSpace(pf.File.ContentType)
                            ? "application/octet-stream"
                            : pf.File.ContentType);
                    multipart.Add(fileContent, "files", pf.File.Name);
                }

                var upMsg = new HttpRequestMessage(
                    HttpMethod.Post,
                    $"api/performance-test-master/{savedId}/references")
                { Content = multipart };
                upMsg.Headers.Authorization =
                    new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

                var upResp = await Http.SendAsync(upMsg);
                if (!upResp.IsSuccessStatusCode)
                {
                    var body = await upResp.Content.ReadAsStringAsync();
                    _modalError = $"Saved record but file upload failed: {(int)upResp.StatusCode} {body}";
                    await LoadAsync();
                    _saving = false; return;
                }
            }

            _showModal = false;
            await LoadAsync();
        }
        catch (Exception ex) { _modalError = ex.Message; }
        finally { _saving = false; }
    }

    private void ConfirmDelete(TestMasterItem item) => _deleteTarget = item;

    private async Task DeleteAsync()
    {
        if (_deleteTarget == null) return;
        _saving = true;
        try
        {
            var token = await SessionStorage.GetItemAsync<string>("auth_token") ?? "";
            var msg   = new HttpRequestMessage(HttpMethod.Delete, $"api/performance-test-master/{_deleteTarget.Id}");
            msg.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            var resp = await Http.SendAsync(msg);
            if (resp.IsSuccessStatusCode) { _deleteTarget = null; await LoadAsync(); }
        }
        catch (Exception ex) { Console.WriteLine($"[PTM] Delete: {ex.Message}"); }
        finally { _saving = false; }
    }

    private async Task ToggleActive(TestMasterItem item)
    {
        try
        {
            var token = await SessionStorage.GetItemAsync<string>("auth_token") ?? "";
            var msg   = new HttpRequestMessage(HttpMethod.Patch, $"api/performance-test-master/{item.Id}/toggle-active");
            msg.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            var resp = await Http.SendAsync(msg);
            if (resp.IsSuccessStatusCode) { item.IsActive = !item.IsActive; StateHasChanged(); }
        }
        catch { }
    }

    private static string Truncate(string? s, int max) =>
        string.IsNullOrEmpty(s) ? "" : s.Length <= max ? s : s[..max] + "…";
    private static string Slug(string s) => s.ToLower().Replace(" ", "").Replace("/","");

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024)            return $"{bytes} B";
        if (bytes < 1024 * 1024)     return $"{bytes / 1024.0:0.#} KB";
        if (bytes < 1024L * 1024 * 1024) return $"{bytes / (1024.0 * 1024):0.#} MB";
        return $"{bytes / (1024.0 * 1024 * 1024):0.#} GB";
    }

    // ─── Models ──────────────────────────────────────────────────────────
    private class TestMasterItem
    {
        public int     Id           { get; set; }
        public string  Category     { get; set; } = "";
        public string  ProtocolName { get; set; } = "";
        public string? TestProtocol { get; set; }
        public string? Procedure    { get; set; }
        public string? Requirements { get; set; }
        public int     SortOrder    { get; set; }
        public bool    IsActive     { get; set; }
        public List<ReferenceFileItem> References { get; set; } = new();
    }

    private class ReferenceFileItem
    {
        public int      Id          { get; set; }
        public string   FileName    { get; set; } = "";
        public string   ContentType { get; set; } = "";
        public long     FileSize    { get; set; }
        public int      SortOrder   { get; set; }
        public DateTime UploadedAt  { get; set; }
    }

    private class PickedFile
    {
        public int           Key  { get; set; }
        public IBrowserFile  File { get; set; } = default!;
    }

    private class UpsertPayload
    {
        public string  Category     { get; set; } = "";
        public string  ProtocolName { get; set; } = "";
        public string? TestProtocol { get; set; }
        public string? Procedure    { get; set; }
        public string? Requirements { get; set; }
        public int     SortOrder    { get; set; }
        public bool    IsActive     { get; set; }
    }

    private class FormModel
    {
        public string  Category     { get; set; } = "";
        public string  ProtocolName { get; set; } = "";
        public string? TestProtocol { get; set; }
        public string? Procedure    { get; set; }
        public string? Requirements { get; set; }
        public int     SortOrder    { get; set; } = 0;
        public bool    IsActive     { get; set; } = true;
    }
}

<style>
    .ptm-page {
        font-family: 'SF Pro Display', -apple-system, 'Segoe UI', sans-serif;
        background: #f0f3f8; min-height: 100vh; padding: 24px 20px 48px;
    }
    .ptm-header {
        display: flex; align-items: center; justify-content: space-between;
        background: white; border-radius: 14px; padding: 18px 24px;
        box-shadow: 0 2px 10px rgba(0,0,0,.07); margin-bottom: 16px;
    }
    .ptm-header-left { display: flex; align-items: center; gap: 14px; }
    .ptm-title { font-size: 18px; font-weight: 800; color: #1a1a2e; }
    .ptm-subtitle { font-size: 12px; color: #aaa; margin-top: 2px; }
    .ptm-add-btn {
        display: inline-flex; align-items: center; gap: 7px;
        background: linear-gradient(135deg,#2D7DD2,#1a5fa8); color: white;
        border: none; border-radius: 10px; padding: 10px 20px;
        font-size: 14px; font-weight: 700; cursor: pointer; transition: all .2s;
        box-shadow: 0 3px 10px rgba(45,125,210,.35);
    }
    .ptm-add-btn:hover { box-shadow: 0 5px 16px rgba(45,125,210,.45); transform: translateY(-1px); }

    .ptm-filters {
        display: grid; grid-template-columns: 240px 160px 1fr; gap: 14px;
        background: white; border-radius: 14px; padding: 14px 18px;
        box-shadow: 0 2px 10px rgba(0,0,0,.07); margin-bottom: 14px;
    }
    .ptm-filter-group { display: flex; flex-direction: column; gap: 4px; }
    .ptm-filter-label { font-size: 11px; font-weight: 700; color: #7a8fad; text-transform: uppercase; letter-spacing: .04em; }
    .ptm-select, .ptm-search {
        border: 1.5px solid #e4eaf4; border-radius: 9px; padding: 8px 11px;
        font-size: 13px; background: #fafbfe; outline: none;
    }
    .ptm-select:focus, .ptm-search:focus { border-color: #2D7DD2; }
    .ptm-search-group { min-width: 0; }

    /* ─── ComboBox ─── */
    .ptm-cmb-root { position: relative; }
    .ptm-cmb-control {
        display: flex; align-items: center; gap: 6px;
        border: 1.5px solid #e4eaf4; border-radius: 9px; background: #fafbfe;
        padding: 0 10px 0 11px; height: 36px; cursor: text; transition: border .2s;
    }
    .ptm-cmb-control.ptm-cmb-open, .ptm-cmb-control:focus-within { border-color: #2D7DD2; }
    .ptm-cmb-input {
        flex: 1; border: none; outline: none; background: transparent;
        font-size: 13px; color: #1a1a2e; min-width: 0;
    }
    .ptm-cmb-clear {
        background: transparent; border: none; cursor: pointer;
        color: #aaa; font-size: 12px; padding: 2px 6px; border-radius: 4px;
    }
    .ptm-cmb-clear:hover { background: #f0f3f8; color: #555; }
    .ptm-cmb-arrow { display: inline-flex; pointer-events: none; }
