    /* ─── Table ─── */
    .ptm-table-wrap { background: white; border-radius: 14px; overflow: auto; box-shadow: 0 2px 10px rgba(0,0,0,.07); }
    .ptm-table { width: 100%; border-collapse: collapse; font-size: 13px; }
