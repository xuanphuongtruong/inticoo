        font-family: 'SF Pro Display', -apple-system, 'Segoe UI', sans-serif;
        background: #f0f3f8;
        min-height: 100vh;
        padding-bottom: 48px;
    }

    /* ══════════ REFERENCE TABLE ══════════ */
    .iss-ref-table { margin-top: 8px; border: 1px solid #e4eaf4; border-radius: 10px; overflow: hidden; background: #fff; }
    .iss-ref-header { display: flex; align-items: center; background: #f5f8fc; padding: 8px 12px; border-bottom: 1px solid #e4eaf4; font-size: 11px; font-weight: 700; color: #7a8fad; text-transform: uppercase; letter-spacing: .05em; }
    .iss-ref-row { display: flex; align-items: center; padding: 10px 12px; border-bottom: 1px solid #f0f3f8; font-size: 13px; }
    .iss-ref-row:last-child { border-bottom: none; }
    .iss-ref-row:hover { background: #f7fafd; }
    .iss-ref-no   { width: 36px; flex-shrink: 0; color: #b0bdd4; font-size: 12px; text-align: center; }
    .iss-ref-name { flex: 1; color: #1a2d5a; font-weight: 500; padding-right: 12px; }
    .iss-ref-file { display: flex; gap: 6px; flex-shrink: 0; }
    .iss-ref-view-btn { display: inline-flex; align-items: center; gap: 4px; padding: 4px 10px; border-radius: 6px; background: #e6f1fb; color: #1e90d6; border: 1px solid #b5d4f4; font-size: 12px; font-weight: 500; text-decoration: none; transition: background .15s; }
    .iss-ref-view-btn:hover { background: #cce4f8; }
    .iss-ref-dl-btn { display: inline-flex; align-items: center; gap: 4px; padding: 4px 10px; border-radius: 6px; background: #eaf3de; color: #3b6d11; border: 1px solid #c0dd97; font-size: 12px; font-weight: 500; text-decoration: none; transition: background .15s; }
    .iss-ref-dl-btn:hover { background: #d4ebb8; }

    /* ══════════ LOADING ══════════ */
    .iss-loading {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 14px;
        min-height: 40vh;
        color: #888;
        font-size: 14px;
    }
    .iss-spinner {
        width: 38px; height: 38px;
        border: 3px solid #dde6f4;
        border-top-color: #2D7DD2;
        border-radius: 50%;
        animation: iss-spin .75s linear infinite;
    }
    @@keyframes iss-spin { to { transform: rotate(360deg); } }

    /* ══════════ HEADER CARD ══════════ */
    .iss-header-card {
        background: white;
        padding: 18px 16px 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,.07);
        border-bottom: 1px solid #e4eaf4;
    }
    .iss-header-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 14px;
    }
    .iss-logo { display: flex; align-items: center; gap: 8px; }
    .iss-logo-text {
        font-size: 20px; font-weight: 700;
        color: #1a1a2e; letter-spacing: -.5px;
    }
    .iss-year-badge {
        background: #e8f0fe; color: #1565c0;
        font-size: 12px; font-weight: 700;
        padding: 3px 10px; border-radius: 20px;
    }

    /* Monthly grid */
    .iss-month-header {
        display: flex; justify-content: flex-start; align-items: baseline; gap: 8px;
        margin-bottom: 8px;
    }
    .iss-month-title { font-size: 11px; font-weight: 700; color: #666; text-transform: uppercase; letter-spacing: .06em; }
    .iss-month-total { font-size: 12px; color: #2D7DD2; font-weight: 600; }

    .iss-month-grid {
        display: grid;
        grid-template-columns: repeat(6, 1fr);   /* 2 rows × 6 */
        gap: 3px;
        margin-bottom: 12px;
    }
    @@media (min-width: 600px) {
        .iss-month-grid { grid-template-columns: repeat(12, 1fr); }  /* 1 row × 12 */
    }

    .iss-month-cell {
        background: #f6f8fc;
        border: 1px solid #e4eaf4;
        border-radius: 6px;
        padding: 5px 3px 4px;
        text-align: center;
        min-height: 36px;
        transition: background .2s;
    }
    .iss-month-cell.has-jobs { background: #ddeeff; border-color: #a8cef8; }
    .iss-m-name { font-size: 10px; font-weight: 600; color: #999; display: block; }
    .iss-month-cell.has-jobs .iss-m-name { color: #1565c0; }
    .iss-m-count { display: block; font-size: 13px; font-weight: 700; color: #2D7DD2; margin-top: 1px; }

    /* User strip */
    .iss-user-strip { display: flex; gap: 20px; padding-top: 10px; border-top: 1px solid #f0f3f8; flex-wrap: wrap; }
    .iss-user-info  { display: flex; gap: 5px; align-items: baseline; }
    .iss-u-label { font-size: 11px; color: #aaa; }
    .iss-u-val   { font-size: 12px; font-weight: 700; color: #333; }
    .iss-u-todo  { color: #f08c5a; }
    .iss-u-done  { color: #27ae60; }

    @@media (min-width: 640px)  { .iss-header-card { padding: 20px 32px 14px; } }
    @@media (min-width: 1024px) { .iss-header-card { padding: 22px 40px 14px; } }

    /* ══════════ STATUS BAR ══════════ */
    .iss-status-bar {
        display: flex;
        gap: 8px;
        background: white;
        padding: 10px 16px 0;
        border-bottom: 1px solid #eee;
    }
    .iss-status-btn {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        padding: 9px 10px;
        border: none; border-radius: 24px;
        font-size: 13px; font-weight: 600;
        cursor: pointer;
        transition: all .2s;
    }
    .iss-cnt-badge {
        background: rgba(255,255,255,.3);
        border-radius: 10px;
        padding: 1px 6px;
        font-size: 11px; font-weight: 700;
    }
    .s-idle  { background: #f0f2f5; color: #aaa; }
    .s-active.s-todo { background: linear-gradient(135deg, #f4a77a, #f08c5a); color: white; box-shadow: 0 4px 12px rgba(240,140,90,.4); transform: translateY(-1px); }
    .s-active.s-done { background: linear-gradient(135deg, #43c776, #27ae60); color: white; box-shadow: 0 4px 12px rgba(39,174,96,.35); transform: translateY(-1px); }

    @@media (min-width: 640px)  { .iss-status-bar { padding: 10px 32px 0; gap: 12px; } .iss-status-btn { flex: none; min-width: 160px; } }
    @@media (min-width: 1024px) { .iss-status-bar { padding: 10px 40px 0; } }

    /* ══════════ TIME BAR ══════════ */
    .iss-time-bar {
        display: flex;
        gap: 8px;
        padding: 10px 16px 10px;
        background: white;
        border-bottom: 2px solid #f0f3f8;
    }
    .iss-time-btn {
        flex: 1;
        padding: 8px 0;
        border: none; border-radius: 20px;
        font-size: 13px; font-weight: 600;
        cursor: pointer;
        background: #e2f0fd; color: #2D7DD2;
        transition: all .2s;
    }
    .iss-time-btn.t-active {
        background: linear-gradient(135deg, #2acfcf, #17a8a8);
        color: white;
        box-shadow: 0 4px 10px rgba(42,207,207,.3);
        transform: translateY(-1px);
    }
    @@media (min-width: 640px)  { .iss-time-bar { padding: 10px 32px; gap: 12px; } .iss-time-btn { flex: none; padding: 8px 28px; } }
    @@media (min-width: 1024px) { .iss-time-bar { padding: 10px 40px; } }

    /* ══════════ CONTENT WRAPPER ══════════ */
    .iss-content {
        max-width: 1200px;
        margin: 0 auto;
        padding: 16px;
    }
    @@media (min-width: 640px)  { .iss-content { padding: 20px 32px; } }
    @@media (min-width: 1024px) { .iss-content { padding: 24px 40px; } }

    .iss-section-title {
        font-size: 15px; font-weight: 700; color: #1a1a2e;
        margin-bottom: 14px;
        padding-bottom: 8px;
        border-bottom: 2px solid #e4eaf4;
    }

    /* Empty */
    .iss-empty { display: flex; flex-direction: column; align-items: center; gap: 10px; padding: 60px 0; color: #ccc; font-size: 14px; }

    /* ══════════ TODAY — CARD GRID ══════════ */
    .iss-card-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px;
    }
    @@media (min-width: 600px)  { .iss-card-grid { grid-template-columns: repeat(2, 1fr); } }
    @@media (min-width: 1024px) { .iss-card-grid { grid-template-columns: repeat(3, 1fr); } }

    .iss-job-card {
        background: white;
        border-radius: 12px;
        padding: 14px 16px;
        box-shadow: 0 2px 8px rgba(0,0,0,.07);
        cursor: pointer;
        transition: transform .15s, box-shadow .15s;
        border: 1px solid transparent;
        display: flex; flex-direction: column; gap: 0;
    }
    .iss-job-card:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(0,0,0,.11); border-color: #bbd9f8; }

    /* ── Overdue (inspection date trước hôm nay) ────────────────────── */
    .iss-job-card-overdue {
        background: linear-gradient(180deg, #fff7ed 0%, #ffedd5 100%);
        border: 1px solid #fdba74;
        box-shadow: 0 2px 10px rgba(234,88,12,.15);
    }
    .iss-job-card-overdue:hover {
        border-color: #f97316;
        box-shadow: 0 6px 22px rgba(234,88,12,.22);
    }
    .iss-job-card-overdue .iss-jc-top { border-bottom-color: rgba(249,115,22,.25); }
    .iss-job-card-overdue .iss-job-no { color: #c2410c; }

    .iss-jc-top-right {
        display: flex; align-items: center; gap: 6px;
    }
    .iss-overdue-badge {
        display: inline-flex; align-items: center; gap: 4px;
        font-size: 10px; font-weight: 700;
        padding: 2.5px 8px; border-radius: 10px;
        background: #ea580c; color: #fff;
        text-transform: uppercase; white-space: nowrap;
        letter-spacing: .03em;
    }
    .iss-overdue-badge svg { flex-shrink: 0; }
    .iss-jv-overdue { color: #c2410c; font-weight: 700; }

    .iss-overdue-count {
        display: inline-block;
        margin-left: 10px;
        font-size: 11px; font-weight: 700;
        padding: 3px 9px; border-radius: 10px;
        background: #ea580c; color: #fff;
        text-transform: uppercase; letter-spacing: .04em;
        vertical-align: middle;
    }

    .iss-jc-top {
        display: flex; align-items: center; justify-content: space-between;
        margin-bottom: 10px; padding-bottom: 8px; border-bottom: 1px solid #f0f3f8;
    }
    .iss-job-no { font-size: 12px; font-weight: 700; color: #1565c0; }

    .iss-it-badge {
        font-size: 10px; font-weight: 700;
        padding: 2px 8px; border-radius: 10px;
        text-transform: uppercase; white-space: nowrap;
    }
    .it-dpi { background: #e8f0fe; color: #1565c0; }
    .it-ppt { background: #fff3e0; color: #e65100; }
    .it-pst { background: #f3e5f5; color: #7b1fa2; }

    .iss-jc-body { flex: 1; }
    .iss-jf { display: flex; gap: 6px; margin-bottom: 5px; align-items: baseline; }
    .iss-jl { font-size: 11px; color: #2D7DD2; font-weight: 600; min-width: 100px; flex-shrink: 0; }
    .iss-jf-section { margin-top:6px; padding-top:6px; border-top:1px dashed #e0e8f5; }
    .iss-jl-section  { color:#555; font-weight:700; font-size:11px; }
    .iss-jf-sub .iss-jl { color:#888; font-weight:500; padding-left:4px; }
    .iss-li-sub .iss-ll { color:#888; font-weight:500; padding-left:4px; }
    .iss-jv { font-size: 12px; color: #333; word-break: break-word; }

    .iss-jc-foot {
        display: flex; align-items: center; justify-content: space-between;
        margin-top: 10px; padding-top: 8px; border-top: 1px solid #f0f3f8;
    }
    .iss-st-pill { font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 10px; }
    .st-new     { background: #e8f0fe; color: #1565c0; }
    .st-going   { background: #e3f2fd; color: #0277bd; }
    .st-done    { background: #e8f5e9; color: #2e7d32; }
    .st-pending { background: #fff8e1; color: #f57f17; }
    .st-cancel  { background: #fce4ec; color: #c62828; }

    .iss-start-sm {
        background: #27ae60; color: white;
        border: none; border-radius: 8px;
        padding: 6px 18px;
        font-size: 12px; font-weight: 700;
        cursor: pointer; transition: background .2s;
    }
    .iss-start-sm:hover { background: #219a52; }

    /* ══════════ 7-DAY LIST ══════════ */
    .iss-day-group {
        background: white;
        border-radius: 10px;
        margin-bottom: 12px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,.06);
    }
    .iss-day-hdr {
        display: flex; align-items: center; justify-content: space-between;
        padding: 9px 14px;
        background: #f6f8fc;
        border-bottom: 1px solid #eef1f7;
    }
    .iss-day-date { font-size: 13px; font-weight: 700; color: #1a1a2e; }
    .iss-day-cnt  { font-size: 11px; font-weight: 600; color: #2D7DD2; background: #e8f0fe; padding: 2px 8px; border-radius: 10px; }

    .iss-list-item {
        display: flex; align-items: center;
        padding: 12px 14px;
        cursor: pointer;
        border-bottom: 1px solid #f5f7fa;
        transition: background .15s;
    }
    .iss-list-item:last-child { border-bottom: none; }
    .iss-list-item:hover { background: #f0f8ff; }
    .iss-li-body { flex: 1; }
    .iss-li-row { display: flex; gap: 6px; margin-bottom: 4px; align-items: baseline; }
    .iss-ll { font-size: 11px; color: #2D7DD2; font-weight: 600; min-width: 108px; flex-shrink: 0; }
    .iss-lv { font-size: 12px; color: #333; }
    .iss-chevron { flex-shrink: 0; margin-left: 6px; }

    @@media (min-width: 768px) {
        .iss-ll { font-size: 12px; min-width: 120px; }
        .iss-lv { font-size: 13px; }
    }

    /* ══════════ 14-DAY TABLE (≥ 600px) ══════════ */
    .iss-cal-table-wrap { display: none; }
    @@media (min-width: 600px) {
        .iss-cal-table-wrap { display: block; }
        .iss-cal-mobile     { display: none; }
    }

    .iss-cal-table {
        width: 100%;
        border-collapse: collapse;
        background: white;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,.06);
    }
    .iss-cal-cell {
        width: 50%; vertical-align: top;
        border: 1px solid #e4eaf4;
        padding: 10px 12px;
    }
    .iss-cal-cell.cell-has { background: #fafcff; }
    .iss-cal-date {
        font-size: 12px; font-weight: 700; color: #1a1a2e;
        margin-bottom: 6px; padding-bottom: 4px;
        border-bottom: 1px solid #f0f3f8;
    }
    .iss-cal-job {
        padding: 5px 0; cursor: pointer;
        border-top: 1px dashed #eee; margin-top: 4px;
        transition: color .15s;
    }
    .iss-cal-job:first-of-type { border-top: none; margin-top: 0; }
    .iss-cal-job:hover .iss-cj-cat { color: #1565c0; }
    .iss-cj-cat { font-size: 11px; color: #333; display: block; margin-top: 2px; }
    .iss-cj-vendor { font-size: 10px; color: #999; }

    /* ══════════ 14-DAY MOBILE CARDS ══════════ */
    .iss-cal-mobile { display: block; }
    @@media (min-width: 600px) { .iss-cal-mobile { display: none; } }

    .iss-cal-day {
        background: white;
        border-radius: 10px;
        margin-bottom: 8px;
        overflow: hidden;
        border: 1px solid #e4eaf4;
        box-shadow: 0 1px 4px rgba(0,0,0,.05);
    }
    .iss-cal-day.cday-empty { opacity: .75; }
    .iss-cal-day-hdr {
        display: flex; align-items: center; justify-content: space-between;
        padding: 9px 14px;
        background: #f6f8fc;
        border-bottom: 1px solid #eef1f7;
    }
    .iss-cal-day-name { font-size: 13px; font-weight: 700; color: #1a1a2e; }
    .iss-cal-day-cnt  { font-size: 11px; font-weight: 700; color: #1565c0; background: #e8f0fe; padding: 2px 8px; border-radius: 10px; }
    .iss-cal-day-empty { font-size: 12px; color: #ccc; padding: 10px 14px; }

    .iss-cal-row {
        display: flex; align-items: center; gap: 8px;
        padding: 9px 14px;
        cursor: pointer;
        border-bottom: 1px solid #f5f7fa;
        transition: background .15s;
    }
    .iss-cal-row:last-child { border-bottom: none; }
    .iss-cal-row:hover { background: #f0f8ff; }
    .iss-cal-info { flex: 1; font-size: 12px; color: #444; }

    /* ══════════ DETAIL PAGE ══════════ */
    .iss-detail-wrap {
        max-width: 680px; margin: 0 auto;
        padding: 20px 16px;
    }
    @@media (min-width: 640px)  { .iss-detail-wrap { padding: 28px 32px; } }
    @@media (min-width: 1024px) { .iss-detail-wrap { padding: 32px 40px; } }

    .iss-back-btn {
        display: flex; align-items: center; gap: 4px;
        background: none; border: none;
        font-size: 14px; color: #2D7DD2; font-weight: 600;
        cursor: pointer; padding: 0 0 18px 0;
        transition: color .2s;
    }
    .iss-back-btn:hover { color: #1565c0; }

    .iss-detail-card {
        background: white; border-radius: 14px;
        padding: 20px 20px 16px;
        box-shadow: 0 3px 14px rgba(0,0,0,.09);
    }
    .iss-detail-badge {
        display: inline-block;
        font-size: 11px; font-weight: 700;
        padding: 4px 12px; border-radius: 12px;
        margin-bottom: 14px;
    }

    .iss-field-group { margin-bottom: 12px; }
    .iss-field {
        display: flex; gap: 10px;
        padding: 8px 0;
        border-bottom: 1px solid #f5f7fa;
        align-items: baseline;
    }
    .iss-field:last-child { border-bottom: none; }
    .iss-fl { font-size: 13px; font-weight: 600; color: #2D7DD2; min-width: 130px; flex-shrink: 0; }
    .iss-fv { font-size: 13px; color: #1a1a2e; word-break: break-word; }

    .iss-vendor-section { background: #f7f9fc; border-radius: 8px; padding: 12px 14px; margin-top: 4px; }
    .iss-vendor-title { font-size: 11px; font-weight: 700; color: #2D7DD2; margin-bottom: 8px; text-transform: uppercase; letter-spacing: .04em; }
    .iss-vi-row { display: flex; align-items: baseline; gap: 6px; margin-bottom: 5px; }
    .iss-vi-dot { color: #bbb; }
    .iss-vi-label { font-size: 12px; color: #888; min-width: 70px; flex-shrink: 0; }
    .iss-vi-val { font-size: 13px; color: #333; }

    .iss-start-btn {
        display: flex; align-items: center; justify-content: center; gap: 8px;
        background: linear-gradient(135deg, #27ae60, #1e8449);
        color: white; border: none; border-radius: 12px;
        padding: 14px 0; font-size: 15px; font-weight: 700;
        cursor: pointer; width: 100%; margin-top: 20px;
        transition: all .2s;
        box-shadow: 0 4px 14px rgba(39,174,96,.35);
    }
    .iss-start-btn:hover { box-shadow: 0 6px 20px rgba(39,174,96,.45); transform: translateY(-1px); }

    /* ══════════ COMPLETED — CARD GRID ══════════ */
    .iss-section-title {
        display: flex; align-items: center; gap: 10px;
    }
    .iss-section-count {
        font-size: 12px; font-weight: 600;
        color: #2D7DD2; background: #e8f0fe;
        padding: 2px 9px; border-radius: 10px;
        margin-left: auto;
    }

    .iss-comp-card {
        background: white;
        border-radius: 14px;
        margin-bottom: 12px;
        box-shadow: 0 2px 10px rgba(0,0,0,.07);
        border: 1px solid #e8edf6;
        overflow: hidden;
        transition: box-shadow .2s, transform .15s;
    }
    .iss-comp-card:hover {
        box-shadow: 0 6px 20px rgba(0,0,0,.11);
        transform: translateY(-2px);
    }

    /* Card header */
    .iss-comp-card-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 12px 16px 10px;
        border-bottom: 1px solid #f0f3f8;
        background: #fafbfe;
    }
    .iss-comp-card-left  { display: flex; align-items: center; gap: 8px; }
    .iss-comp-card-right { display: flex; align-items: center; }
    .iss-comp-jobno {
        font-size: 13px; font-weight: 800;
        color: #1565c0; letter-spacing: -.2px;
    }

    /* Card body */
    .iss-comp-card-body {
        padding: 10px 16px 6px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2px 16px;
    }
    @@media (max-width: 480px) {
        .iss-comp-card-body { grid-template-columns: 1fr; }
    }

    .iss-comp-field {
        display: flex; flex-direction: column;
        padding: 6px 0;
        border-bottom: 1px solid #f5f7fa;
    }
    .iss-comp-field:nth-last-child(-n+2) { border-bottom: none; }
    @@media (max-width: 480px) {
        .iss-comp-field:last-child { border-bottom: none; }
        .iss-comp-field:nth-last-child(2) { border-bottom: 1px solid #f5f7fa; }
    }

    .iss-comp-label {
        font-size: 10px; font-weight: 600;
        color: #aab; text-transform: uppercase;
        letter-spacing: .06em;
        display: flex; align-items: center; gap: 4px;
        margin-bottom: 2px;
    }
    .iss-comp-val {
        font-size: 13px; color: #1a1a2e;
        font-weight: 500;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }

    /* Card footer */
    .iss-comp-card-footer {
        padding: 10px 16px 12px;
        border-top: 1px solid #f0f3f8;
        display: flex; justify-content: flex-end;
        background: #fafbfe;
    }

    .iss-report-btn {
        display: inline-flex; align-items: center; gap: 6px;
        background: linear-gradient(135deg, #2D7DD2, #1a5fa8);
        color: white; border: none; border-radius: 9px;
        padding: 8px 18px;
        font-size: 13px; font-weight: 700;
        cursor: pointer;
