@page "/inspection-schedule"
@using System.Globalization
@using System.Net.Http.Json
@using System.Text.Json
@using System.Net.Http.Headers
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient Http
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject Blazored.SessionStorage.ISessionStorageService SessionStorage

<div class="iss-page">

    <!-- ═══════════════════════ LOADING ═══════════════════════ -->
    @if (_loading)
    {
        <div class="iss-loading">
            <div class="iss-spinner"></div>
            <span>Loading schedule…</span>
        </div>
    }
    else if (_view == View.JobDetail && _selectedJob != null)
    {
        <!-- ═══════════════════════ JOB DETAIL ═══════════════════════ -->
        <div class="iss-detail-wrap">
            <button class="iss-back-btn" @onclick="GoBack">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor"
                     stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 15l-5-5 5-5"/>
                </svg>
                Back
            </button>

            @if (_detailLoading)
            {
                <div style="display:flex;align-items:center;justify-content:center;padding:32px;gap:12px;color:#888;font-size:14px;">
                    <div class="iss-spinner"></div>
                    <span>Loading details…</span>
                </div>
            }

            <div class="iss-detail-card">
                <div class="iss-detail-badge @GetStatusClass(_selectedJob.Status)">@_selectedJob.Status</div>

                <div class="iss-field-group">
                    <div class="iss-field"><span class="iss-fl">Job No</span><span class="iss-fv">@(_selectedJob.JobNumber ?? "—")</span></div>
                    <div class="iss-field"><span class="iss-fl">Customer Name</span><span class="iss-fv">@_selectedJob.CustomerName</span></div>
                    <div class="iss-field"><span class="iss-fl">Category</span><span class="iss-fv">@(_selectedJob.ProductCategory ?? "—")</span></div>
                    @* <div class="iss-field"><span class="iss-fl">Product Type</span><span class="iss-fv">@(_selectedJob.ProductType ?? "—")</span></div> *@
                    <div class="iss-field"><span class="iss-fl">Inspection Type</span><span class="iss-fv">@_selectedJob.InspectionType</span></div>
                    <div class="iss-field"><span class="iss-fl">PO Number</span><span class="iss-fv">@(string.IsNullOrEmpty(_selectedJob.PoNumber) ? "—" : _selectedJob.PoNumber)</span></div>
                    <div class="iss-field"><span class="iss-fl">Vendor Name</span><span class="iss-fv">@_selectedJob.VendorName</span></div>
                    <div class="iss-field"><span class="iss-fl">Vendor Address</span><span class="iss-fv">@(string.IsNullOrEmpty(_selectedJob.VendorAddress) ? "—" : _selectedJob.VendorAddress)</span></div>
                    @if (!string.IsNullOrEmpty(_selectedJob.VendorCountry))
                    {
                        <div class="iss-field"><span class="iss-fl">Country</span><span class="iss-fv">@_selectedJob.VendorCountry</span></div>
                    }
                    <div class="iss-field"><span class="iss-fl">Contact Name</span><span class="iss-fv">@(string.IsNullOrEmpty(_selectedJob.VendorContactName) ? "—" : _selectedJob.VendorContactName)</span></div>
                    <div class="iss-field"><span class="iss-fl">Position</span><span class="iss-fv">@(string.IsNullOrEmpty(_selectedJob.VendorContactPosition) ? "—" : _selectedJob.VendorContactPosition)</span></div>
                    <div class="iss-field"><span class="iss-fl">Mobile</span><span class="iss-fv">@(string.IsNullOrEmpty(_selectedJob.VendorContactMobile) ? "—" : _selectedJob.VendorContactMobile)</span></div>
                </div>

                @* Vendor Contact Information — Address 1/2, City, State, Country *@
                @{
                    bool hasVendorAddr = !string.IsNullOrEmpty(_selectedJob.VendorAddress1)
                                      || !string.IsNullOrEmpty(_selectedJob.VendorAddress2)
                                      || !string.IsNullOrEmpty(_selectedJob.VendorCity)
                                      || !string.IsNullOrEmpty(_selectedJob.VendorState)
                                      || !string.IsNullOrEmpty(_selectedJob.VendorCountry);
                }
                @if (hasVendorAddr)
                {
                    <div class="iss-vendor-section">
                        <div class="iss-vendor-title">Vendor Contact Information</div>
                        @if (!string.IsNullOrEmpty(_selectedJob.VendorAddress1))
                        {
                            <div class="iss-vi-row">
                                <span class="iss-vi-dot">•</span>
                                <span class="iss-vi-label">Address 1</span>
                                <span class="iss-vi-val">@_selectedJob.VendorAddress1</span>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(_selectedJob.VendorAddress2))
                        {
                            <div class="iss-vi-row">
                                <span class="iss-vi-dot">•</span>
                                <span class="iss-vi-label">Address 2</span>
                                <span class="iss-vi-val">@_selectedJob.VendorAddress2</span>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(_selectedJob.VendorCity))
                        {
                            <div class="iss-vi-row">
                                <span class="iss-vi-dot">•</span>
                                <span class="iss-vi-label">City</span>
                                <span class="iss-vi-val">@_selectedJob.VendorCity</span>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(_selectedJob.VendorState))
                        {
                            <div class="iss-vi-row">
                                <span class="iss-vi-dot">•</span>
                                <span class="iss-vi-label">State/Province</span>
                                <span class="iss-vi-val">@_selectedJob.VendorState</span>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(_selectedJob.VendorCountry))
                        {
                            <div class="iss-vi-row">
                                <span class="iss-vi-dot">•</span>
                                <span class="iss-vi-label">Country</span>
                                <span class="iss-vi-val">@_selectedJob.VendorCountry</span>
                            </div>
                        }
                    </div>
                }

                @* Reference List *@
                @if (_selectedJobRefs.Count > 0)
                {
                    <div class="iss-vendor-section">
                        <div class="iss-vendor-title">Product References</div>
                        <div class="iss-ref-table">
                            <div class="iss-ref-header">
                                <span class="iss-ref-no">No</span>
                                <span class="iss-ref-name">Reference</span>
                                <span class="iss-ref-file">File</span>
                            </div>
                            @foreach (var ref_ in _selectedJobRefs)
                            {
                                <div class="iss-ref-row">
                                    <span class="iss-ref-no">@ref_.No</span>
                                    <span class="iss-ref-name">@ref_.ReferenceName</span>
                                    <span class="iss-ref-file">
                                        @if (!string.IsNullOrEmpty(ref_.FileUrl))
                                        {
                                            <a href="@ref_.FileUrl" target="_blank" class="iss-ref-view-btn" title="View">
                                                <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                                                    <path d="M1 10s3.5-7 9-7 9 7 9 7-3.5 7-9 7-9-7-9-7z"/><circle cx="10" cy="10" r="3"/>
                                                </svg>
                                                View
                                            </a>
                                            <a href="@ref_.FileUrl" download="@ref_.FileName" class="iss-ref-dl-btn" title="Download">
                                                <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                                                    <path d="M10 3v10M6 9l4 4 4-4" stroke-linecap="round" stroke-linejoin="round"/>
                                                    <path d="M3 17h14" stroke-linecap="round"/>
                                                </svg>
                                                Download
                                            </a>
                                        }
                                        else
                                        {
                                            <span style="color:#bbb;font-size:12px;">No file</span>
                                        }
                                    </span>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <button class="iss-start-btn" @onclick="() => StartInspection(_selectedJob)">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="currentColor"><path d="M6 4l12 6-12 6V4z"/></svg>
                Start Inspection
            </button>
        </div>
    }
    else
    {
        <!-- ═══════════════════════ SUMMARY ═══════════════════════ -->

        <!-- HEADER -->
        <div class="iss-header-card">
            <div class="iss-header-top">
                <div class="iss-year-badge">@DateTime.Now.Year</div>
            </div>

            <div class="iss-month-header">
                <span class="iss-month-title">Total Job</span>
                <span class="iss-month-total">@_completedCount completed</span>
            </div>
            <div class="iss-month-grid">
                @foreach (var m in _monthSummary)
                {
                    <div class="iss-month-cell @(m.Count > 0 ? "has-jobs" : "")">
                        <span class="iss-m-name">@m.ShortName</span>
                        @if (m.Count > 0)
                        {
                            <span class="iss-m-count">@m.Count</span>
                        }
                    </div>
                }
            </div>

            <div class="iss-user-strip">
                <div class="iss-user-info">
                    <span class="iss-u-label">Completed</span>
                    <span class="iss-u-val iss-u-done">@_completedCount</span>
                </div>
                <div class="iss-user-info">
                    <span class="iss-u-label">To Do</span>
                    <span class="iss-u-val iss-u-todo">@_todoCount</span>
                </div>
            </div>
        </div>

        <!-- STATUS TABS -->
        <div class="iss-status-bar">
            <button class="iss-status-btn @(_statusFilter == "todo" ? "s-active s-todo" : "s-idle")"
                    @onclick='() => _statusFilter = "todo"'>
                <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor"
                     stroke-width="2" stroke-linecap="round"><circle cx="10" cy="10" r="8"/><path d="M10 6v4l3 3"/></svg>
                To Do
                @if (_todoCount > 0) { <span class="iss-cnt-badge">@_todoCount</span> }
            </button>
            <button class="iss-status-btn @(_statusFilter == "completed" ? "s-active s-done" : "s-idle")"
                    @onclick='() => _statusFilter = "completed"'>
                <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor"
                     stroke-width="2" stroke-linecap="round"><path d="M4 10l5 5 7-8"/></svg>
                Completed
                @if (_completedCount > 0) { <span class="iss-cnt-badge">@_completedCount</span> }
            </button>
        </div>

        <!-- TIME TABS — chỉ hiện khi To Do -->
        @if (_statusFilter == "todo")
        {
        <div class="iss-time-bar">
            <button class="iss-time-btn @(_timeFilter == "today" ? "t-active" : "")"
                    @onclick='() => SetTimeFilter("today")'>Today</button>
            <button class="iss-time-btn @(_timeFilter == "7days" ? "t-active" : "")"
                    @onclick='() => SetTimeFilter("7days")'>7 days</button>
            <button class="iss-time-btn @(_timeFilter == "14days" ? "t-active" : "")"
                    @onclick='() => SetTimeFilter("14days")'>14 days</button>
        </div>
        }

        <!-- CONTENT -->
        <div class="iss-content">
            @{var filtered = FilteredJobs();}

            @if (_statusFilter == "completed")
            {
                <div class="iss-section-title">
                    Completed
                    <span class="iss-section-count">@filtered.Count job@(filtered.Count != 1 ? "s" : "")</span>
                </div>
                @if (!filtered.Any())
                {
                    <div class="iss-empty">
                        <svg width="48" height="48" viewBox="0 0 48 48" fill="none" stroke="#ccc" stroke-width="1.5">
                            <rect x="8" y="10" width="32" height="32" rx="4"/>
                            <path d="M16 10V6M32 10V6M8 20h32" stroke-linecap="round"/>
                            <circle cx="24" cy="32" r="4"/>
                        </svg>
                        <p>No completed inspections this year</p>
                    </div>
                }
                @foreach (var job in filtered.OrderByDescending(j => j.CompletedAt ?? j.InspectionDate))
                {
                    <div class="iss-comp-card">
                        <!-- Card header: Job No + Type badge + Result -->
                        <div class="iss-comp-card-header">
                            <div class="iss-comp-card-left">
                                <span class="iss-comp-jobno">@(job.JobNumber ?? $"#{job.Id}")</span>
                                <span class="iss-it-badge it-@job.InspectionType.ToLower()">@job.InspectionType</span>
                            </div>
                            <div class="iss-comp-card-right">
                                @{
                                    var rawResult  = !string.IsNullOrEmpty(job.OverallResult)
                                                     ? job.OverallResult
                                                     : job.FinalResult ?? "";
                                    var resultKey  = rawResult.ToLower();
                                    var isPassed   = resultKey == "pass"   || resultKey == "passed";
                                    var isFailed   = resultKey == "fail"   || resultKey == "failed";
                                    var resultClass = isPassed ? "res-passed"
                                                   : isFailed ? "res-failed"
                                                   : "res-na";
                                }
                                @if (!string.IsNullOrEmpty(rawResult))
                                {
                                    <span class="iss-result-badge @resultClass">
                                        @if (isPassed)
                                        {
                                            <svg width="11" height="11" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M4 10l5 5 7-8"/></svg>
                                        }
                                        else if (isFailed)
                                        {
                                            <svg width="11" height="11" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M6 6l8 8M14 6l-8 8"/></svg>
                                        }
                                        @rawResult.ToUpper()
                                    </span>
                                }
                            </div>
                        </div>

                        <!-- Card body: fields -->
                        <div class="iss-comp-card-body">
                            <div class="iss-comp-field">
                                <span class="iss-comp-label">
                                    <svg width="11" height="11" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="14" height="14" rx="2"/><path d="M3 9h14M7 4V2M13 4V2"/></svg>
                                    Completed Date
                                </span>
                                <span class="iss-comp-val">
                                    @(job.CompletedAt.HasValue
                                        ? job.CompletedAt.Value.ToString("d MMM yyyy")
                                        : job.InspectionDate != DateTime.MinValue
                                            ? job.InspectionDate.ToString("d MMM yyyy")
                                            : "—")
                                </span>
                            </div>
                            <div class="iss-comp-field">
                                <span class="iss-comp-label">
                                    <svg width="11" height="11" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="10" cy="7" r="4"/><path d="M3 17c0-3.3 3.1-6 7-6s7 2.7 7 6"/></svg>
                                    Customer
                                </span>
                                <span class="iss-comp-val">@job.CustomerName</span>
                            </div>
                            <div class="iss-comp-field">
                                <span class="iss-comp-label">
                                    <svg width="11" height="11" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="2" y="7" width="16" height="11" rx="2"/><path d="M6 7V5a4 4 0 018 0v2"/></svg>
                                    Vendor
                                </span>
                                <span class="iss-comp-val">@job.VendorName</span>
                            </div>
                            <div class="iss-comp-field">
                                <span class="iss-comp-label">
                                    <svg width="11" height="11" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 3h14v14H3z"/><path d="M3 8h14M8 3v14"/></svg>
                                    Category
                                </span>
                                <span class="iss-comp-val">@(job.ProductCategory ?? "—")</span>
                            </div>
                            <div class="iss-comp-field">
                                <span class="iss-comp-label">
                                    <svg width="11" height="11" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 4h12v12H4z"/><circle cx="10" cy="10" r="3"/></svg>
                                    PO Number
                                </span>
                                <span class="iss-comp-val">@(job.PoNumber ?? "—")</span>
                            </div>
                        </div>

                        <!-- Card footer: View Report button -->
                        <div class="iss-comp-card-footer">
                            <button class="iss-report-btn" @onclick="() => ViewReport(job)">
                                <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor"
                                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M14 2H6a2 2 0 00-2 2v12a2 2 0 002 2h8a2 2 0 002-2V8z"/>
                                    <polyline points="14 2 14 8 20 8"/>
                                    <line x1="8" y1="13" x2="12" y2="13"/>
                                    <line x1="8" y1="10" x2="12" y2="10"/>
                                </svg>
                                View Report
                            </button>
                        </div>
                    </div>
                }
            }
            else if (!filtered.Any())
            {
                <div class="iss-empty">
                    <svg width="48" height="48" viewBox="0 0 48 48" fill="none" stroke="#ccc" stroke-width="1.5">
                        <rect x="8" y="10" width="32" height="32" rx="4"/>
                        <path d="M16 10V6M32 10V6M8 20h32" stroke-linecap="round"/>
                        <circle cx="24" cy="32" r="4"/>
                    </svg>
                    <p>No inspections for this period</p>
                </div>
            }
            else if (_timeFilter == "today")
            {
                var today = DateTime.Today;
                // Overdue (InspectionDate < today) hiển thị trước, sau đó đến hôm nay
                var sortedJobs = filtered
                    .OrderBy(j => j.InspectionDate.Date >= today)   // false (overdue) trước, true (today) sau
                    .ThenBy(j => j.InspectionDate.Date)              // overdue cũ nhất lên đầu
                    .ToList();

                var overdueCount = sortedJobs.Count(j => j.InspectionDate.Date < today);

                <div class="iss-section-title">
                    Today — @today.ToString("dddd, d MMMM yyyy")
                    @if (overdueCount > 0)
                    {
                        <span class="iss-overdue-count">@overdueCount overdue</span>
                    }
                </div>
                <div class="iss-card-grid">
                    @foreach (var job in sortedJobs)
                    {
                        var isOverdue = job.InspectionDate.Date < today;
                        var daysLate  = isOverdue ? (today - job.InspectionDate.Date).Days : 0;
                        <div class="iss-job-card @(isOverdue ? "iss-job-card-overdue" : "")"
                             @onclick="async () => await OpenJobDetail(job)">
                            <div class="iss-jc-top">
                                <span class="iss-job-no">@(job.JobNumber ?? $"#{job.Id}")</span>
                                <div class="iss-jc-top-right">
                                    @if (isOverdue)
                                    {
                                        <span class="iss-overdue-badge" title="Scheduled on @job.InspectionDate.ToString("d MMM yyyy")">
                                            <svg width="11" height="11" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.2">
                                                <circle cx="10" cy="10" r="8"/>
                                                <path d="M10 6v5M10 14h.01" stroke-linecap="round"/>
                                            </svg>
                                            @(daysLate == 1 ? "1 day late" : $"{daysLate} days late")
                                        </span>
                                    }
                                    <span class="iss-it-badge it-@job.InspectionType.ToLower()">@job.InspectionType</span>
                                </div>
                            </div>
                            <div class="iss-jc-body">
                                @if (isOverdue)
                                {
                                    <div class="iss-jf"><span class="iss-jl">Scheduled Date</span><span class="iss-jv iss-jv-overdue">@job.InspectionDate.ToString("d MMM yyyy")</span></div>
                                }
                                <div class="iss-jf"><span class="iss-jl">Customer Name</span><span class="iss-jv">@job.CustomerName</span></div>
                                <div class="iss-jf"><span class="iss-jl">Category</span><span class="iss-jv">@(job.ProductCategory ?? "—")</span></div>
                                @* <div class="iss-jf"><span class="iss-jl">Product Type</span><span class="iss-jv">@(job.ProductType ?? "—")</span></div> *@
                                <div class="iss-jf"><span class="iss-jl">Inspection Type</span><span class="iss-jv">@job.InspectionType</span></div>
                                <div class="iss-jf"><span class="iss-jl">Vendor Name</span><span class="iss-jv">@job.VendorName</span></div>
                                <div class="iss-jf"><span class="iss-jl">Vendor Address</span><span class="iss-jv">@(string.IsNullOrEmpty(job.VendorAddress) ? "—" : job.VendorAddress)</span></div>
                                @if (!string.IsNullOrEmpty(job.VendorContactName) || !string.IsNullOrEmpty(job.VendorContactMobile))
                                {
                                    <div class="iss-jf iss-jf-section"><span class="iss-jl iss-jl-section">Vendor Information</span></div>
                                    @if (!string.IsNullOrEmpty(job.VendorContactName))
                                    { <div class="iss-jf iss-jf-sub"><span class="iss-jl">• Name</span><span class="iss-jv">@job.VendorContactName</span></div> }
                                    @if (!string.IsNullOrEmpty(job.VendorContactPosition))
                                    { <div class="iss-jf iss-jf-sub"><span class="iss-jl">• Position</span><span class="iss-jv">@job.VendorContactPosition</span></div> }
                                    @if (!string.IsNullOrEmpty(job.VendorContactMobile))
                                    { <div class="iss-jf iss-jf-sub"><span class="iss-jl">• Mobile</span><span class="iss-jv">@job.VendorContactMobile</span></div> }
                                    @if (!string.IsNullOrEmpty(job.VendorContactOffice))
                                    { <div class="iss-jf iss-jf-sub"><span class="iss-jl">• Office</span><span class="iss-jv">@job.VendorContactOffice</span></div> }
                                    @if (!string.IsNullOrEmpty(job.VendorContactEmail))
                                    { <div class="iss-jf iss-jf-sub"><span class="iss-jl">• Email</span><span class="iss-jv">@job.VendorContactEmail</span></div> }
                                }
                            </div>
                            <div class="iss-jc-foot">
                                <span class="iss-st-pill @GetStatusClass(job.Status)">@job.Status</span>
                                <button class="iss-start-sm" @onclick:stopPropagation="true"
                                        @onclick="() => StartInspection(job)">Start</button>
                            </div>
                        </div>
                    }
                </div>
            }
            else if (_timeFilter == "7days")
            {
                var byDay = filtered
                    .GroupBy(j => j.InspectionDate.Date)
                    .OrderBy(g => g.Key).ToList();
                <div class="iss-section-title">Next 7 days</div>
                foreach (var grp in byDay)
                {
                    <div class="iss-day-group">
                        <div class="iss-day-hdr">
                            <span class="iss-day-date">@grp.Key.ToString("ddd, d MMM yyyy")</span>
                            <span class="iss-day-cnt">@grp.Count() job@(grp.Count() > 1 ? "s" : "")</span>
                        </div>
                        @foreach (var job in grp)
                        {
                            <div class="iss-list-item" @onclick="async () => await OpenJobDetail(job)">
                                <div class="iss-li-body">
                                    <div class="iss-li-row"><span class="iss-ll">Date</span><span class="iss-lv">@job.InspectionDate.ToString("d MMM yyyy")</span></div>
                                    <div class="iss-li-row"><span class="iss-ll">Category</span><span class="iss-lv">@(job.ProductCategory ?? "—")</span></div>
                                    @* <div class="iss-li-row"><span class="iss-ll">Product Type</span><span class="iss-lv">@(job.ProductType ?? "—")</span></div> *@
                                    <div class="iss-li-row"><span class="iss-ll">Inspection Type</span><span class="iss-lv">@job.InspectionType</span></div>
                                    <div class="iss-li-row"><span class="iss-ll">Vendor Name</span><span class="iss-lv">@job.VendorName</span></div>
                                    <div class="iss-li-row"><span class="iss-ll">Vendor Address</span><span class="iss-lv">@(string.IsNullOrEmpty(job.VendorCity) ? "—" : job.VendorCity)</span></div>
                                    @if (!string.IsNullOrEmpty(job.VendorContactName) || !string.IsNullOrEmpty(job.VendorContactMobile))
                                    {
                                        <div class="iss-li-row"><span class="iss-ll iss-jl-section">Vendor Information</span></div>
                                        @if (!string.IsNullOrEmpty(job.VendorContactName))
                                        { <div class="iss-li-row iss-li-sub"><span class="iss-ll">• Name</span><span class="iss-lv">@job.VendorContactName</span></div> }
                                        @if (!string.IsNullOrEmpty(job.VendorContactPosition))
                                        { <div class="iss-li-row iss-li-sub"><span class="iss-ll">• Position</span><span class="iss-lv">@job.VendorContactPosition</span></div> }
                                        @if (!string.IsNullOrEmpty(job.VendorContactMobile))
                                        { <div class="iss-li-row iss-li-sub"><span class="iss-ll">• Mobile</span><span class="iss-lv">@job.VendorContactMobile</span></div> }
                                        @if (!string.IsNullOrEmpty(job.VendorContactOffice))
                                        { <div class="iss-li-row iss-li-sub"><span class="iss-ll">• Office</span><span class="iss-lv">@job.VendorContactOffice</span></div> }
                                        @if (!string.IsNullOrEmpty(job.VendorContactEmail))
                                        { <div class="iss-li-row iss-li-sub"><span class="iss-ll">• Email</span><span class="iss-lv">@job.VendorContactEmail</span></div> }
                                    }
                                </div>
                                <svg class="iss-chevron" width="16" height="16" viewBox="0 0 20 20"
                                     fill="none" stroke="#ccc" stroke-width="2" stroke-linecap="round">
                                    <path d="M7 5l5 5-5 5"/>
                                </svg>
                            </div>
                        }
                    </div>
                }
            }
            else if (_timeFilter == "14days")
            {
                var days14 = Enumerable.Range(0, 14).Select(i => DateTime.Today.AddDays(i)).ToList();
                <div class="iss-section-title">Next 14 days</div>

                <div class="iss-cal-table-wrap">
                    <table class="iss-cal-table">
                        <tbody>
                        @for (int idx = 0; idx < days14.Count; idx += 2)
                        {
                            var d1 = days14[idx];
                            var d2 = idx + 1 < days14.Count ? days14[idx + 1] : (DateTime?)null;
                            var j1 = filtered.Where(j => j.InspectionDate.Date == d1.Date).ToList();
                            var j2 = d2.HasValue
                                ? filtered.Where(j => j.InspectionDate.Date == d2.Value.Date).ToList()
                                : new List<JobItem>();
                            <tr>
                                <td class="iss-cal-cell @(j1.Any() ? "cell-has" : "")">
                                    <div class="iss-cal-date">@d1.ToString("d MMM yyyy")</div>
                                    @foreach (var j in j1)
                                    {
                                        <div class="iss-cal-job" @onclick="async () => await OpenJobDetail(j)">
                                            <span class="iss-it-badge it-@j.InspectionType.ToLower()">@j.InspectionType</span>
                                            <div class="iss-cj-cat">@(j.ProductCategory ?? "—")</div>
                                            <div class="iss-cj-vendor">@j.VendorName</div>
                                        </div>
                                    }
                                </td>
                                @if (d2.HasValue)
                                {
                                    <td class="iss-cal-cell @(j2.Any() ? "cell-has" : "")">
                                        <div class="iss-cal-date">@d2.Value.ToString("d MMM yyyy")</div>
                                        @foreach (var j in j2)
                                        {
                                            <div class="iss-cal-job" @onclick="async () => await OpenJobDetail(j)">
                                                <span class="iss-it-badge it-@j.InspectionType.ToLower()">@j.InspectionType</span>
                                                <div class="iss-cj-cat">@(j.ProductCategory ?? "—")</div>
                                                <div class="iss-cj-vendor">@j.VendorName</div>
                                            </div>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>

                <div class="iss-cal-mobile">
                    @foreach (var day in days14)
                    {
                        var dj = filtered.Where(j => j.InspectionDate.Date == day.Date).ToList();
                        <div class="iss-cal-day @(dj.Any() ? "cday-has" : "cday-empty")">
                            <div class="iss-cal-day-hdr">
                                <span class="iss-cal-day-name">@day.ToString("ddd, d MMM")</span>
                                @if (dj.Any())
                                {
                                    <span class="iss-cal-day-cnt">@dj.Count</span>
                                }
                            </div>
                            @if (dj.Any())
                            {
                                @foreach (var j in dj)
                                {
                                    <div class="iss-cal-row" @onclick="async () => await OpenJobDetail(j)">
                                        <span class="iss-it-badge it-@j.InspectionType.ToLower()">@j.InspectionType</span>
                                        <span class="iss-cal-info">@(j.ProductCategory ?? "—") · @j.VendorName</span>
                                        <svg width="14" height="14" viewBox="0 0 20 20" fill="none"
                                             stroke="#ccc" stroke-width="2" stroke-linecap="round">
                                            <path d="M7 5l5 5-5 5"/>
                                        </svg>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="iss-cal-day-empty">No jobs</div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    // ────────────────────────────────────────────
    //  STATE
    // ────────────────────────────────────────────
    private enum View { Summary, JobDetail }
    private View    _view           = View.Summary;
    private string  _timeFilter     = "today";
    private string  _statusFilter   = "todo";
    private string  _prevTimeFilter = "today";
    private bool    _loading        = true;
    private JobItem? _selectedJob;
    private List<JobItem>    _allJobs      = new();
    private List<MonthStat>  _monthSummary = new();

    // Role-based filter
    private string _filterInspectorId = "";
    private string _filterCustomerId  = "";

    // Job detail state
    private bool               _detailLoading = false;
    private List<JobReference> _selectedJobRefs = new();

    // ────────────────────────────────────────────
    //  VIEW MODELS
    // ────────────────────────────────────────────
    public class JobItem
    {
        public int      Id              { get; set; }
        public string?  JobNumber       { get; set; }
        public string   Title           { get; set; } = "";
        public string   CustomerName    { get; set; } = "";
        public string?  CustomerId      { get; set; }
        public string?  ProductCategory { get; set; }
        public string?  ProductType     { get; set; }
        public string   InspectionType  { get; set; } = "DPI";
        public string   VendorName      { get; set; } = "";
        public string?  VendorAddress   { get; set; }
        public string?  VendorAddress1  { get; set; }
        public string?  VendorAddress2  { get; set; }
        public string?  VendorCity      { get; set; }
        public string?  VendorState     { get; set; }
        public string?  VendorCountry   { get; set; }
        // Vendor Information (contact)
        public string?  VendorContactName     { get; set; }
        public string?  VendorContactPosition { get; set; }
        public string?  VendorContactMobile   { get; set; }
        public string?  VendorContactOffice   { get; set; }
        public string?  VendorContactEmail    { get; set; }
        public string?  PoNumber         { get; set; }
        public string?  InspectorName   { get; set; }
        public string?  InspectorId     { get; set; }
        public string   Status          { get; set; } = "New";
        public DateTime InspectionDate  { get; set; }
        public DateTime CreatedAt       { get; set; }
        public DateTime? CompletedAt    { get; set; }
        public string?   OverallResult  { get; set; }
        public string?   FinalResult    { get; set; }
        public string?   ReportUrl      { get; set; }
    }

    public class JobReference
    {
        public int     No            { get; set; }
        public string  ReferenceName { get; set; } = "";
        public string? FileName      { get; set; }
        public string? FileUrl       { get; set; }
    }

    public record MonthStat(string ShortName, int Count);

    // ────────────────────────────────────────────
    //  STATUS HELPERS
    //  API trả: "New" | "OnGoing" | "Completed" | "Cancel"
    //  To Do  = New hoặc OnGoing  (chưa hoàn thành)
    //  Done   = Completed
    // ────────────────────────────────────────────
    private static bool IsCompleted(JobItem j) =>
        string.Equals(j.Status, "Completed", StringComparison.OrdinalIgnoreCase);

    private static bool IsTodo(JobItem j) =>
        string.Equals(j.Status, "New",      StringComparison.OrdinalIgnoreCase) ||
        string.Equals(j.Status, "OnGoing",  StringComparison.OrdinalIgnoreCase);

    // ────────────────────────────────────────────
    //  COMPUTED
    //  _todoCount / _completedCount: chỉ tính job trong năm hiện tại
    // ────────────────────────────────────────────
    private int _currentYear => DateTime.Now.Year;

    private int _todoCount =>
        _allJobs.Count(j => IsTodo(j) && j.InspectionDate.Year == _currentYear);

    private int _completedCount =>
        _allJobs.Count(j => IsCompleted(j) && j.InspectionDate.Year == _currentYear);

    // ────────────────────────────────────────────
    //  FILTER JOBS
    //  - Tab "To Do"       → New | OnGoing, lọc theo ngày
    //  - Tab "Completed"   → Completed, lọc theo ngày
    //  - Chỉ job trong năm hiện tại
    // ────────────────────────────────────────────
    private List<JobItem> FilteredJobs()
    {
        var today = DateTime.Today;

        // Tab Completed: trả về toàn bộ job Completed trong năm, không lọc theo ngày
        if (_statusFilter == "completed")
        {
            return _allJobs
                .Where(j => IsCompleted(j) &&
                            j.InspectionDate != DateTime.MinValue &&
                            j.InspectionDate.Year == _currentYear)
                .OrderByDescending(j => j.CompletedAt ?? j.InspectionDate)
                .ToList();
        }

        // Tab To Do: lọc New | OnGoing, năm hiện tại, theo khoảng thời gian
        IEnumerable<JobItem> q = _allJobs
            .Where(j => IsTodo(j) &&
                        j.InspectionDate != DateTime.MinValue &&
                        j.InspectionDate.Year == _currentYear);

        return _timeFilter switch
        {
            // "today" now includes all overdue inspections (date <= today) so users can see
            // jobs that are past due and need attention. Overdue items are highlighted in UI.
            "today"  => q.Where(j => j.InspectionDate.Date <= today).ToList(),
            "7days"  => q.Where(j => j.InspectionDate.Date >= today &&
                                     j.InspectionDate.Date <  today.AddDays(7)).ToList(),
            "14days" => q.Where(j => j.InspectionDate.Date >= today &&
                                     j.InspectionDate.Date <  today.AddDays(14)).ToList(),
            _ => new()
        };
    }

    // ────────────────────────────────────────────
    //  LIFECYCLE
    // ────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user      = authState.User;

        if (user.IsInRole("Inspector") || user.IsInRole("Customer"))
        {
            var username = user.Identity?.Name
                        ?? user.FindFirst("name")?.Value
                        ?? user.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value
                        ?? "";

            Console.WriteLine($"[Schedule] Role filter — username={username}, isInspector={user.IsInRole("Inspector")}, isCustomer={user.IsInRole("Customer")}");

            if (!string.IsNullOrEmpty(username))
            {
                try
                {
                    var token = await SessionStorage.GetItemAsync<string>("auth_token");
                    if (!string.IsNullOrEmpty(token))
                        Http.DefaultRequestHeaders.Authorization =
                            new AuthenticationHeaderValue("Bearer", token);

                    var opts = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                    var json = await Http.GetStringAsync(
                        $"api/users?search={Uri.EscapeDataString(username)}&pageSize=5");

                    Console.WriteLine($"[Schedule] api/users response: {json}");

                    var result = JsonSerializer.Deserialize<UserPageResult>(json, opts);
                    var me = result?.Items?.FirstOrDefault(u =>
                        string.Equals(u.Username, username, StringComparison.OrdinalIgnoreCase));

                    Console.WriteLine($"[Schedule] me={me?.Username}, InspectorId={me?.InspectorId}, CustomerId={me?.CustomerId}");

                    if (me != null)
                    {
                        if (user.IsInRole("Inspector"))
                            _filterInspectorId = me.InspectorId ?? "";
                        else if (user.IsInRole("Customer"))
                            _filterCustomerId = me.CustomerId ?? "";
                    }

                    Console.WriteLine($"[Schedule] _filterInspectorId={_filterInspectorId}, _filterCustomerId={_filterCustomerId}");
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"[InspectionSchedule] Error resolving user filter: {ex.Message}");
                }
            }
        }
        // Admin: không filter, load hết

        await LoadAllJobs();

        // Fallback: nếu backend không filter được, filter client-side theo customerId/inspectorId
        if (!string.IsNullOrEmpty(_filterCustomerId))
        {
            _allJobs = _allJobs.Where(j =>
                !string.IsNullOrEmpty(j.CustomerId) &&
                j.CustomerId.Equals(_filterCustomerId, StringComparison.OrdinalIgnoreCase)
            ).ToList();
            Console.WriteLine($"[Schedule] After client filter by customerId={_filterCustomerId}: {_allJobs.Count} jobs");
        }
        else if (!string.IsNullOrEmpty(_filterInspectorId))
        {
            _allJobs = _allJobs.Where(j =>
                !string.IsNullOrEmpty(j.InspectorId) &&
                j.InspectorId.Equals(_filterInspectorId, StringComparison.OrdinalIgnoreCase)
            ).ToList();
            Console.WriteLine($"[Schedule] After client filter by inspectorId={_filterInspectorId}: {_allJobs.Count} jobs");
        }

        BuildMonthSummary();
        _loading = false;
    }

    private async Task LoadAllJobs()
    {
        try
        {
            // Build filter suffix theo role
            var filterSuffix = "";
            if (!string.IsNullOrEmpty(_filterInspectorId))
                filterSuffix = $"&inspectorId={Uri.EscapeDataString(_filterInspectorId)}";
            else if (!string.IsNullOrEmpty(_filterCustomerId))
                filterSuffix = $"&customerId={Uri.EscapeDataString(_filterCustomerId)}";

            var opts = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };

            var r1 = await Http.GetFromJsonAsync<ApiPageResponse>(
                $"api/inspections?page=1&pageSize=200{filterSuffix}", opts);

            if (r1?.Items == null) return;
            _allJobs = r1.Items.Select(MapToJobItem).ToList();

            int totalPages = (int)Math.Ceiling((double)r1.Total / 200);
            for (int p = 2; p <= totalPages; p++)
            {
                var rp = await Http.GetFromJsonAsync<ApiPageResponse>(
                    $"api/inspections?page={p}&pageSize=200{filterSuffix}", opts);
                if (rp?.Items != null)
                    _allJobs.AddRange(rp.Items.Select(MapToJobItem));
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[InspectionScheduleSummary] Error: {ex.Message}");
        }
    }

    private static JobItem MapToJobItem(ApiItem i) => new()
    {
        Id              = i.Id,
        JobNumber       = i.JobNumber ?? i.Title,
        Title           = i.Title      ?? "",
        CustomerName    = i.CustomerName ?? "",
        CustomerId      = i.CustomerId,
        ProductCategory = string.IsNullOrEmpty(i.ProductCategory) ? null : i.ProductCategory,
        ProductType     = string.IsNullOrEmpty(i.ProductType)     ? null : i.ProductType,
        InspectionType  = i.InspectionType ?? "DPI",
        VendorName      = i.VendorName  ?? "",
        VendorAddress   = string.IsNullOrEmpty(i.VendorAddress)   ? null : i.VendorAddress,
        VendorAddress1  = string.IsNullOrEmpty(i.VendorAddress1)  ? null : i.VendorAddress1,
        VendorAddress2  = string.IsNullOrEmpty(i.VendorAddress2)  ? null : i.VendorAddress2,
        VendorCity      = string.IsNullOrEmpty(i.VendorCity)      ? null : i.VendorCity,
        VendorState     = string.IsNullOrEmpty(i.VendorState)     ? null : i.VendorState,
        VendorCountry   = string.IsNullOrEmpty(i.VendorCountry)   ? null : i.VendorCountry,
        VendorContactName     = i.VendorContactName,
        VendorContactPosition = i.VendorContactPosition,
        VendorContactMobile   = i.VendorContactMobile,
        VendorContactOffice   = i.VendorContactOffice,
        VendorContactEmail    = i.VendorContactEmail,
        InspectorName   = i.InspectorName,
        InspectorId     = i.InspectorId,
        Status          = i.Status      ?? "New",
        InspectionDate  = i.InspectionDate ?? DateTime.MinValue,
        CreatedAt       = i.CreatedAt,
        CompletedAt     = i.CompletedAt,
        OverallResult   = null,
        FinalResult     = i.FinalResult,
        ReportUrl       = null,
        PoNumber        = i.PoNumber,
    };

    private void BuildMonthSummary()
    {
        // Monthly grid: đếm job Completed theo từng tháng trong năm hiện tại
        var year = _currentYear;
        _monthSummary = Enumerable.Range(1, 12).Select(m =>
        {
            var abbr = CultureInfo.InvariantCulture.DateTimeFormat.AbbreviatedMonthNames[m - 1];
            var cnt  = _allJobs.Count(j =>
                IsCompleted(j) &&
                j.InspectionDate != DateTime.MinValue &&
                j.InspectionDate.Year  == year &&
                j.InspectionDate.Month == m);
            return new MonthStat(abbr, cnt);
        }).ToList();
    }

    // ────────────────────────────────────────────
    //  ACTIONS
    // ────────────────────────────────────────────
    private void SetTimeFilter(string f) { _timeFilter = f; _view = View.Summary; }

    private async Task OpenJobDetail(JobItem job)
    {
        _selectedJob     = job;
        _prevTimeFilter  = _timeFilter;
        _selectedJobRefs = new();
        _view            = View.JobDetail;
        _detailLoading   = true;
        StateHasChanged();

        try
        {
            var token = await SessionStorage.GetItemAsync<string>("auth_token");
            if (!string.IsNullOrEmpty(token))
                Http.DefaultRequestHeaders.Authorization =
                    new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            var opts = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var json = await Http.GetStringAsync($"api/inspections/{job.Id}");
            using var doc = JsonDocument.Parse(json);
            var root = doc.RootElement;

            // Vendor Address & Country
            if (root.TryGetProperty("vendorAddress", out var va) && va.ValueKind != JsonValueKind.Null)
                _selectedJob.VendorAddress = va.GetString();
            if (root.TryGetProperty("vendorAddress1", out var va1) && va1.ValueKind != JsonValueKind.Null)
                _selectedJob.VendorAddress1 = va1.GetString();
            if (root.TryGetProperty("vendorAddress2", out var va2) && va2.ValueKind != JsonValueKind.Null)
                _selectedJob.VendorAddress2 = va2.GetString();
            if (root.TryGetProperty("vendorCity", out var vci) && vci.ValueKind != JsonValueKind.Null)
                _selectedJob.VendorCity = vci.GetString();
            if (root.TryGetProperty("vendorState", out var vst) && vst.ValueKind != JsonValueKind.Null)
                _selectedJob.VendorState = vst.GetString();
            if (root.TryGetProperty("vendorCountry", out var vc) && vc.ValueKind != JsonValueKind.Null)
                _selectedJob.VendorCountry = vc.GetString();

            // Vendor Information (contact)
            // Thử lấy từ vendor object hoặc flat fields
            if (root.TryGetProperty("contactName",     out var cn) && cn.ValueKind != JsonValueKind.Null)
                _selectedJob.VendorContactName     = cn.GetString();
            if (root.TryGetProperty("contactTitle",    out var ct) && ct.ValueKind != JsonValueKind.Null)
                _selectedJob.VendorContactPosition = ct.GetString();
            if (root.TryGetProperty("contactPhone",    out var cp) && cp.ValueKind != JsonValueKind.Null)
                _selectedJob.VendorContactMobile   = cp.GetString();
            if (root.TryGetProperty("contactOffice",   out var co) && co.ValueKind != JsonValueKind.Null)
                _selectedJob.VendorContactOffice   = co.GetString();
            if (root.TryGetProperty("contactEmail",    out var ce) && ce.ValueKind != JsonValueKind.Null)
                _selectedJob.VendorContactEmail    = ce.GetString();

            // References
            if (root.TryGetProperty("references", out var refs) &&
                refs.ValueKind == JsonValueKind.Array)
            {
                int no = 1;
                foreach (var r in refs.EnumerateArray())
                {
                    var rawUrl  = r.TryGetProperty("fileUrl",       out var fu) ? fu.GetString() ?? "" : "";
                    var baseUrl = Http.BaseAddress?.ToString().TrimEnd('/') ?? "";
                    var fullUrl = (!string.IsNullOrEmpty(rawUrl) && !rawUrl.StartsWith("http"))
                                  ? $"{baseUrl}{(rawUrl.StartsWith('/') ? rawUrl : "/" + rawUrl)}"
                                  : rawUrl;
                    _selectedJobRefs.Add(new JobReference
                    {
                        No            = no++,
                        ReferenceName = r.TryGetProperty("referenceName", out var rn) ? rn.GetString() ?? "" : "",
                        FileName      = r.TryGetProperty("fileName",      out var fn) ? fn.GetString() : null,
                        FileUrl       = string.IsNullOrEmpty(fullUrl) ? null : fullUrl,
                    });
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[InspectionSchedule] Detail load error: {ex.Message}");
        }
        finally
        {
            _detailLoading = false;
            StateHasChanged();
        }
    }

    private void GoBack() { _view = View.Summary; _timeFilter = _prevTimeFilter; }

    private void StartInspection(JobItem? job)
    {
        if (job == null) return;
        Navigation.NavigateTo($"/inspection-qc/{job.Id}");
    }

    private void ViewReport(JobItem? job)
    {
        if (job == null) return;
        Navigation.NavigateTo($"/inspection-report/{job.Id}");
    }

    private static string GetStatusClass(string status) => status switch
    {
        "Completed" or "completed"   => "st-done",
        "OnGoing"   or "ongoing"     => "st-going",
        "Pending"   or "pending"     => "st-pending",
        "Cancel"    or "cancelled"   => "st-cancel",
        _                            => "st-new"
    };

    // ────────────────────────────────────────────
    //  API DTOs  (mirrors GetAll response shape)
    // ────────────────────────────────────────────
    private class ApiPageResponse
    {
        public int            Total    { get; set; }
        public int            Page     { get; set; }
        public int            PageSize { get; set; }
        public List<ApiItem>? Items    { get; set; }
    }

    private class UserPageResult
    {
        public int Total { get; set; }
        public List<CurrentUserDto> Items { get; set; } = new();
    }
    private class CurrentUserDto
    {
        public string  Username    { get; set; } = "";
        public string? InspectorId { get; set; }
        public string? CustomerId  { get; set; }
    }

    private class ApiItem
    {
        public int       Id              { get; set; }
        public string?   Title           { get; set; }
        public string?   Status          { get; set; }
        public string?   JobNumber       { get; set; }
        public string?   CustomerName    { get; set; }
        public string?   CustomerId      { get; set; }
        public string?   VendorName      { get; set; }
        public string?   VendorId        { get; set; }
        public string?   VendorAddress   { get; set; }
        public string?   VendorAddress1  { get; set; }
        public string?   VendorAddress2  { get; set; }
        public string?   VendorCity      { get; set; }
        public string?   VendorState     { get; set; }
        public string?   VendorCountry   { get; set; }
        public string?   VendorContactName     { get; set; }
        public string?   VendorContactPosition { get; set; }
        public string?   VendorContactMobile   { get; set; }
        public string?   VendorContactOffice   { get; set; }
        public string?   VendorContactEmail    { get; set; }
        public string?   ProductCategory { get; set; }
        public string?   ProductType     { get; set; }
        public string?   InspectionType  { get; set; }
        public string?   InspectorName   { get; set; }
        public string?   InspectorId     { get; set; }
        public string?   PoNumber        { get; set; }
        public string?   FinalResult     { get; set; }
        public DateTime? InspectionDate  { get; set; }
        public DateTime  CreatedAt       { get; set; }
        public DateTime? CompletedAt     { get; set; }
    }
}

<style>
    /* ══════════ BASE ══════════ */
