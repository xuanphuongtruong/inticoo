    // ── Save to API ──
    async Task SaveAndDone()
    {
        _saving = true;
        _saveMsg = "";
        try
        {
            var payload = BuildSavePayload();
            var resp = await Http.PutAsJsonAsync($"api/inspections/{InspectionId}/qc-result", payload);
            if (resp.IsSuccessStatusCode)
            {
                _saveMsg = "Saved successfully!";
                _saveError = false;
                await Task.Delay(1500);
                Navigation.NavigateTo("/inspection-schedule");
            }
            else
            {
                _saveMsg = $"Error: {(int)resp.StatusCode}";
                _saveError = true;
            }
        }
        catch (Exception ex)
        {
            _saveMsg = ex.Message;
            _saveError = true;
        }
        _saving = false;
        StateHasChanged();
    }

    object BuildSavePayload()
    {
        return new
        {
            // ── Fields lưu thẳng vào DB column (không vào QcResultJson) ──
            inspectionLocation  = _data.InspectionLocation,
            inspectionReference = _data.InspectionReference,
            inspectorComments   = _data.InspectorComments,
            finalResult         = _data.FinalResult,         // → Inspection.FinalResult
            signatureUrl        = _data.SignatureUrl,        // → Inspection.SignatureUrl
            inspectionDate      = DateTime.Now,              // → Inspection.InspectionDate
            photo1Url           = _data.Photo1Url,
            photo2Url           = _data.Photo2Url,
            // ── QC data (serialize vào QcResultJson) ──
            overallConclusions  = _data.OverallConclusions.Select(oc => new
            {
                letter     = oc.Letter,
                label      = oc.Label,
                compliance = oc.Compliance,
                remark     = oc.Remark
            }).ToArray(),
            quantityConformity = new
            {
                itemPerCarton      = _data.QuantityConformity.ItemPerCarton,
                presentedPacked    = _data.QuantityConformity.PresentedPacked,
                presentedNotPacked = _data.QuantityConformity.PresentedNotPacked,
                cartonsPacked      = _data.QuantityConformity.CartonsPacked,
                cartonsNotPacked   = _data.QuantityConformity.CartonsNotPacked,
                qtyNotFinished     = _data.QuantityConformity.QtyNotFinished,
                photos             = _data.QuantityConformity.Photos
            },
            packaging = new
            {
                cartonNumber        = _data.Packaging.CartonNumber,
                packagingType       = _data.Packaging.PackagingType,
                cartonColor         = _data.Packaging.CartonColor,
                cardboardType       = _data.Packaging.CardboardType,
                shippingMark        = _data.Packaging.ShippingMark,
                hasBarcode          = _data.Packaging.HasBarcode,
                innerPackingQty     = _data.Packaging.InnerPackingQty,
                innerPackingRemark  = _data.Packaging.InnerPackingRemark,
                outerL              = _data.Packaging.OuterL,
                outerW              = _data.Packaging.OuterW,
                outerH              = _data.Packaging.OuterH,
                outerWeight         = _data.Packaging.OuterWeight,
                cartonSizeResult    = _data.Packaging.CartonSizeResult,
                shippingMarkResult  = _data.Packaging.ShippingMarkResult,
                cartonWeightResult  = _data.Packaging.CartonWeightResult,
                pkgLabelResult      = _data.Packaging.PkgLabelResult,
                assemblyResult      = _data.Packaging.AssemblyResult,
                hardwareResult      = _data.Packaging.HardwareResult,
                cartonSizes         = _data.Packaging.CartonSizes,
                cartonWeights       = _data.Packaging.CartonWeights,
            },
            productSpec = new
            {
                specL             = _data.ProductSpec.SpecL,
                specW             = _data.ProductSpec.SpecW,
                specH             = _data.ProductSpec.SpecH,
                additionalText    = _data.ProductSpec.AdditionalText,
                sizeResult        = _data.ProductSpec.SizeResult,
                goldenResult      = _data.ProductSpec.GoldenResult,
                sizeRows          = _data.ProductSpec.SizeRows,
                colourSwatches    = _data.ProductSpec.ColourSwatches,
            },
            aql = new
            {
                quantity         = _data.Aql.Quantity,
                inspectionLevel  = _data.Aql.InspectionLevel,
                criticalAql      = _data.Aql.CriticalAql,
                majorAql         = _data.Aql.MajorAql,
                minorAql         = _data.Aql.MinorAql,
                criticalFound    = _data.Aql.CriticalFound,
                majorFound       = _data.Aql.MajorFound,
                minorFound       = _data.Aql.MinorFound,
                criticalSampleSize = _data.Aql.CriticalSampleSize,
                majorSampleSize    = _data.Aql.MajorSampleSize,
                minorSampleSize    = _data.Aql.MinorSampleSize,
                criticalAccept   = _data.Aql.CriticalAccept,
