@page "/inspection-qc/{InspectionId:int}"
@using System.Net.Http.Json
@using System.Text.Json
@using System.Text.Json.Serialization
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

@* ═══════════════════════════════════════════════════════════════
   QC Inspection Wizard — theo giao diện chính PDF
   Route: /inspection-qc/{InspectionId}
   ═══════════════════════════════════════════════════════════════ *@

@if (_loading)
{
    <div class="qc-loading">
        <div class="qc-spinner"></div>
        <span>Loading inspection…</span>
    </div>
}
else if (_inspection == null)
{
    <div class="qc-error">
        <p>Inspection not found.</p>
        <button @onclick="GoBack">← Back</button>
    </div>
}
else
{
    <!-- PROGRESS BAR -->
    <div class="qc-progress-wrap">
        <div class="qc-progress-bar" style="width:@ProgressPct%"></div>
    </div>

    <!-- HEADER -->
    <div class="qc-header">
        <button class="qc-back-btn" @onclick="HandleBack">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor"
                 stroke-width="2.2" stroke-linecap="round"><path d="M12 15l-5-5 5-5"/></svg>
        </button>
        <div class="qc-header-center">
            <div class="qc-step-label">@CurrentStep.StepLabel</div>
            <div class="qc-step-title">@CurrentStep.Title</div>
        </div>
        <div class="qc-step-counter">@(_currentStepIdx + 1)/@_steps.Count</div>
    </div>

    <!-- STEP DOTS -->
    <div class="qc-dots">
        @for (int i = 0; i < _steps.Count; i++)
        {
            var idx = i;
            <div class="qc-dot @(idx == _currentStepIdx ? "dot-active" : idx < _currentStepIdx ? "dot-done" : "")"></div>
        }
    </div>

    <!-- ═══════════ STEP CONTENT ═══════════ -->
    <div class="qc-body">

        @* ── STEP 0: Product Overview & General Info ── *@
        @if (_currentStepIdx == 0)
        {
            <div class="qc-card">
                <div class="qc-section-title">Product Overview</div>
                <div class="qc-photo-row">
                    @if (!string.IsNullOrEmpty(_data.Photo1Url))
                    {
                        <div class="qc-photo-box qc-photo-readonly">
                            <img src="@GetImageUrl(_data.Photo1Url)" class="qc-photo-img"/>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(_data.Photo2Url))
                    {
                        <div class="qc-photo-box qc-photo-readonly">
                            <img src="@GetImageUrl(_data.Photo2Url)" class="qc-photo-img"/>
                        </div>
                    }
                    @if (string.IsNullOrEmpty(_data.Photo1Url) && string.IsNullOrEmpty(_data.Photo2Url))
                    {
                        <div class="qc-photo-box qc-photo-readonly">
                            <svg width="36" height="36" viewBox="0 0 24 24" fill="none"
                                 stroke="#ccc" stroke-width="1.5" style="margin-bottom:6px">
                                <rect x="3" y="3" width="18" height="18" rx="2"/>
                                <circle cx="8.5" cy="8.5" r="1.5"/>
                                <polyline points="21 15 16 10 5 21"/>
                            </svg>
                            <span style="font-size:12px;color:#bbb">Chưa có ảnh sản phẩm</span>
                        </div>
                    }
                </div>

                <div class="qc-section-title" style="margin-top:18px">General Information</div>
                <div class="qc-info-table">
                    <div class="qc-info-row"><span class="qc-info-lbl">Customer Name</span><span class="qc-info-val">@_inspection.CustomerName</span></div>
                    <div class="qc-info-row"><span class="qc-info-lbl">Customer ID</span><span class="qc-info-val">@(_inspection.CustomerId ?? "—")</span></div>
                    <div class="qc-info-row"><span class="qc-info-lbl">Vendor Name</span><span class="qc-info-val">@_inspection.VendorName</span></div>
                    <div class="qc-info-row"><span class="qc-info-lbl">Vendor ID</span><span class="qc-info-val">@(_inspection.VendorId ?? "—")</span></div>
                    <div class="qc-info-row"><span class="qc-info-lbl">Inspection Location</span>
                        <span class="qc-info-val">@(!string.IsNullOrEmpty(_data.InspectionLocation) ? _data.InspectionLocation : "—")</span></div>
                    <div class="qc-info-row"><span class="qc-info-lbl">Inspection Date &amp; Time</span>
                        <span class="qc-info-val qc-auto">@DateTime.Now.ToString("dd MMM yyyy HH:mm")</span></div>
                    <div class="qc-info-row"><span class="qc-info-lbl">Inspection Type</span><span class="qc-info-val">@_inspection.InspectionType</span></div>
                    <div class="qc-info-row"><span class="qc-info-lbl">Inspection Reference</span>
                        <input class="qc-info-input" @bind="_data.InspectionReference" placeholder="Reference no."/></div>
                    <div class="qc-info-row"><span class="qc-info-lbl">Product Category</span><span class="qc-info-val">@(_inspection.ProductCategory ?? "—")</span></div>
                    <div class="qc-info-row"><span class="qc-info-lbl">P.O. Number</span><span class="qc-info-val">@(_inspection.PoNumber ?? "—")</span></div>
                    <div class="qc-info-row"><span class="qc-info-lbl">Item Number</span><span class="qc-info-val">@(_inspection.ItemNumber ?? "—")</span></div>
                    <div class="qc-info-row"><span class="qc-info-lbl">Product Name</span><span class="qc-info-val">@(_inspection.ProductName ?? "—")</span></div>
                    <div class="qc-info-row"><span class="qc-info-lbl">Total Shipment Qty</span><span class="qc-info-val">@_inspection.TotalShipmentQty</span></div>
                    <div class="qc-info-row"><span class="qc-info-lbl">Total Carton Boxes</span><span class="qc-info-val">@_inspection.TotalCartonBoxes</span></div>
                    @if (!string.IsNullOrWhiteSpace(_inspection.GeneralRemark))
                    {
                        <div class="qc-info-row" style="border:1.5px solid #e53935;border-radius:8px;padding:8px 12px;margin-top:4px;background:#fff5f5;">
                            <span class="qc-info-lbl" style="color:#e53935;font-weight:700;">Remark</span>
                            <span class="qc-info-val" style="color:#e53935;font-weight:500;">@_inspection.GeneralRemark</span>
                        </div>
                    }
                </div>
            </div>
        }

        @* ── STEP 1: Overall Conclusion ── *@
        else if (_currentStepIdx == 1)
        {
            <div class="qc-card">
                <div class="qc-section-title">Overall Conclusion</div>
                <table class="qc-table">
                    <thead><tr><th>No</th><th>Overall Conclusion</th><th>Compliance</th></tr></thead>
                    <tbody>
                        @foreach (var oc in _data.OverallConclusions)
                        {
                            <tr>
                                <td class="td-center fw-bold">@oc.Letter</td>
                                <td>
                                    <div class="td-label">@oc.Label</div>
                                    <div style="font-size:11px;color:#aaa;font-weight:600;margin-top:4px">Remark:</div>
                                    <div style="font-size:12px;color:#555;margin-top:2px;min-height:16px">
                                        @(string.IsNullOrEmpty(oc.Remark) ? "—" : oc.Remark)
                                    </div>
                                </td>
                                <td class="td-center">
                                    @{
                                        var (bgColor, label) = oc.Compliance switch {
                                            "Pass" => ("#27ae60", "Yes"),
                                            "Fail" => ("#e74c3c", "No"),
                                            "N/A" => ("#888888", "N/A"),
                                            _      => ("", "")
                                        };
                                    }
                                    @if (!string.IsNullOrEmpty(bgColor))
                                    {
                                        <span style="background:@bgColor;color:#fff;padding:3px 12px;border-radius:12px;font-size:11px;font-weight:700;white-space:nowrap">
                                            @label
                                        </span>
                                    }
                                    else
                                    {
                                        <span style="color:#bbb;font-size:13px">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @* ── STEP 2: A. Quantity Conformity ── *@
        else if (_currentStepIdx == 2)
        {
            <div class="qc-card">
                <div class="qc-section-title">A. Quantity Conformity</div>
                <div class="qc-info-table">
                    <div class="qc-info-row"><span class="qc-info-lbl">P.O. No</span><span class="qc-info-val">@(_inspection.PoNumber ?? "—")</span></div>
                    <div class="qc-info-row"><span class="qc-info-lbl">Item Number</span><span class="qc-info-val">@(_inspection.ItemNumber ?? "—")</span></div>
                    <div class="qc-info-row"><span class="qc-info-lbl">Item per Carton</span>
                        <input class="qc-info-input" type="number" @bind="_data.QuantityConformity.ItemPerCarton" placeholder="0"/></div>
                    <div class="qc-info-row"><span class="qc-info-lbl">Shipment Qty</span><span class="qc-info-val">@_inspection.TotalShipmentQty</span></div>
                    <div class="qc-info-row" style="flex-direction:column;align-items:flex-start;gap:6px">
                        <span class="qc-info-lbl" style="padding-top:0">Presented Qty for Inspection <span style="color:#e74c3c">*</span></span>
                        <div class="qc-split-val">
                            <div class="qc-split-item">
                                <span class="qc-sub-lbl">Packed <span style="color:#e74c3c">*</span></span>
                                <input class="qc-info-input sm @(_qtyValidated && (_data.QuantityConformity.PresentedPacked + _data.QuantityConformity.PresentedNotPacked) <= 0 ? "input-error" : "")"
                                       type="number" @bind="_data.QuantityConformity.PresentedPacked" placeholder="0"/>
                            </div>
                            <div class="qc-split-item">
                                <span class="qc-sub-lbl">Not Packed <span style="color:#e74c3c">*</span></span>
                                <input class="qc-info-input sm @(_qtyValidated && (_data.QuantityConformity.PresentedPacked + _data.QuantityConformity.PresentedNotPacked) <= 0 ? "input-error" : "")"
                                       type="number" @bind="_data.QuantityConformity.PresentedNotPacked" placeholder="0"/>
                            </div>
                        </div>
                    </div>
                    <div class="qc-info-row" style="flex-direction:column;align-items:flex-start;gap:6px">
                        <span class="qc-info-lbl" style="padding-top:0">Number of Cartons <span style="color:#e74c3c">*</span></span>
                        <div class="qc-split-val">
                            <div class="qc-split-item">
                                <span class="qc-sub-lbl">Packed <span style="color:#e74c3c">*</span></span>
                                <input class="qc-info-input sm @(_qtyValidated && (_data.QuantityConformity.CartonsPacked + _data.QuantityConformity.CartonsNotPacked) <= 0 ? "input-error" : "")"
                                       type="number" @bind="_data.QuantityConformity.CartonsPacked" placeholder="0"/>
                            </div>
                            <div class="qc-split-item">
                                <span class="qc-sub-lbl">Not Packed <span style="color:#e74c3c">*</span></span>
                                <input class="qc-info-input sm @(_qtyValidated && (_data.QuantityConformity.CartonsPacked + _data.QuantityConformity.CartonsNotPacked) <= 0 ? "input-error" : "")"
                                       type="number" @bind="_data.QuantityConformity.CartonsNotPacked" placeholder="0"/>
                            </div>
                        </div>
                    </div>
                    <div class="qc-info-row"><span class="qc-info-lbl">Qty Not Finished <span style="color:#e74c3c">*</span></span>
                        <input class="qc-info-input @(_qtyValidated && _data.QuantityConformity.QtyNotFinished < 0 ? "input-error" : "")"
                               type="number" @bind="_data.QuantityConformity.QtyNotFinished" placeholder="0"/></div>
                </div>
                <!-- Photo slots - at least 1 photo required -->
                <div style="display:flex;align-items:center;justify-content:space-between;margin:10px 0 4px">
                    <span style="font-size:12px;font-weight:600;color:#555">Photos <span style="color:#e74c3c">*</span> <span style="color:#aaa;font-weight:400">(min. 1 photo)</span></span>
                    @if (_qtyValidated && !_data.QuantityConformity.Photos.Any(p => !string.IsNullOrEmpty(p)))
                    {
                        <span style="color:#e74c3c;font-size:11px;font-weight:600">⚠ At least 1 photo required</span>
                    }
                </div>
                <div class="qc-photo3-row">
                    @for (int i = 0; i < _data.QuantityConformity.Photos.Count; i++)
                    {
                        var idx = i;
                        var isFirst = idx == 0;
                        var hasPhoto = !string.IsNullOrEmpty(_data.QuantityConformity.Photos[idx]);
                        var uKey = $"A:{idx}";
                        var isUp = _uploadingKey == uKey;
                        <label class="qc-photo-box3 @(_qtyValidated && isFirst && !hasPhoto ? "photo-required" : "")">
                            @if (isUp)
                            {
                                <div class="qc-photo-spinner"><div class="qc-spinner-ring"></div><span style="font-size:11px;color:#2D7DD2">Uploading…</span></div>
                            }
                            else if (hasPhoto)
                            {
                                <img src="@GetImageUrl(_data.QuantityConformity.Photos[idx])" class="qc-photo-img"/>
                                <button class="qc-photo-del" @onclick:stopPropagation="true"
                                        @onclick="() => { var i2=idx; SetPhotoInList(_data.QuantityConformity.Photos,i2,string.Empty); }">✕</button>
                            }
                            else
                            {
                                <span class="qc-photo-add">@(isFirst ? "📷 *" : "📷")</span>
                            }
                            <InputFile OnChange="@(async e => { var url = await UploadPhotoWithSpinner(e, uKey); if(!string.IsNullOrEmpty(url)) SetPhotoInList(_data.QuantityConformity.Photos, idx, url); StateHasChanged(); })"
                                       accept="image/*" capture="environment" style="display:none"/>
                        </label>
                    }
                    @{ var aNewIdx = _data.QuantityConformity.Photos.Count; var aNewKey = $"A:{aNewIdx}"; }
                    <label class="qc-photo-box3" style="border:2px dashed #2D7DD2;background:#eef4ff;cursor:pointer;display:flex;align-items:center;justify-content:center">
                        @if (_uploadingKey == aNewKey)
                        { <div class="qc-photo-spinner"><div class="qc-spinner-ring"></div><span style="font-size:11px;color:#2D7DD2">Uploading…</span></div> }
                        else { <span style="font-size:26px;color:#2D7DD2;font-weight:300;line-height:1">+</span> }
                        <InputFile OnChange="@(async e => { _data.QuantityConformity.Photos.Add(string.Empty); var url = await UploadPhotoWithSpinner(e, aNewKey); if(!string.IsNullOrEmpty(url)) _data.QuantityConformity.Photos[aNewIdx] = url; StateHasChanged(); })"
                                   accept="image/*" capture="environment" style="display:none"/>
                    </label>
                </div>
            </div>
        }

        @* ── STEP 3: B. Packaging & Identification — READONLY từ DB ── *@
        else if (_currentStepIdx == 3)
        {
            <div class="qc-card">
                <div class="qc-section-title">B. Packaging &amp; Identification</div>
                <div class="qc-info-table">
                    <div class="qc-info-row"><span class="qc-info-lbl">Item Number</span>
                        <span class="qc-info-val">@(string.IsNullOrEmpty(_data.Packaging.ItemNumber) ? (_inspection.ItemNumber ?? "—") : _data.Packaging.ItemNumber)</span></div>
                    <div class="qc-info-row"><span class="qc-info-lbl">Carton Number</span>
                        <span class="qc-info-val">@(string.IsNullOrEmpty(_data.Packaging.CartonNumber) ? "—" : _data.Packaging.CartonNumber)</span></div>
                    <div class="qc-info-row"><span class="qc-info-lbl">Type of Packaging</span>
                        <span class="qc-info-val">@(string.IsNullOrEmpty(_data.Packaging.PackagingType) ? "—" : _data.Packaging.PackagingType)</span></div>
                    <div class="qc-info-row"><span class="qc-info-lbl">Color of Carton</span>
                        <span class="qc-info-val">@(string.IsNullOrEmpty(_data.Packaging.CartonColor) ? "—" : _data.Packaging.CartonColor)</span></div>
                    <div class="qc-info-row"><span class="qc-info-lbl">Type of Cardboard</span>
                        <span class="qc-info-val">@(string.IsNullOrEmpty(_data.Packaging.CardboardType) ? "—" : _data.Packaging.CardboardType)</span></div>
                    <div class="qc-info-row"><span class="qc-info-lbl">Shipping Mark</span>
                        <span class="qc-info-val">@(string.IsNullOrEmpty(_data.Packaging.ShippingMark) ? "—" : _data.Packaging.ShippingMark)</span></div>
                    <div class="qc-info-row"><span class="qc-info-lbl">Barcode / QR Code</span>
                        <span class="qc-info-val">@(_data.Packaging.HasBarcode ? "Yes" : "No")</span></div>
                    <div class="qc-info-row"><span class="qc-info-lbl">Inner Packing Qty</span>
                        <span class="qc-info-val">@_data.Packaging.InnerPackingQty</span></div>
                    <div class="qc-info-row"><span class="qc-info-lbl">Inner Packing Remark</span>
                        <span class="qc-info-val">@(string.IsNullOrEmpty(_data.Packaging.InnerPackingRemark) ? "—" : _data.Packaging.InnerPackingRemark)</span></div>
                    <div class="qc-info-row"><span class="qc-info-lbl">Outer Packing (mm)</span>
                        <span class="qc-info-val">L: @_data.Packaging.OuterL <br/>W: @_data.Packaging.OuterW <br/> H: @_data.Packaging.OuterH</span></div>
                    <div class="qc-info-row"><span class="qc-info-lbl">Weight (Kgs)</span>
                        <span class="qc-info-val">@_data.Packaging.OuterWeight</span></div>
                </div>
            </div>
        }

        @* ── STEPS B-i to B-vi: dynamic per carton ── *@
        else if (GetCurrentCartonStep() is var (cartonIdx, bSub) && cartonIdx >= 0
                 && cartonIdx < _data.Packaging.CartonDataList.Count)
        {
            var cd = _data.Packaging.CartonDataList[cartonIdx];
            var cartonLabel = _cartonCount > 1 ? $" — Carton {cd.CartonIndex}" : "";

            @* B-i: Carton Size — 1 dòng cố định *@
            @if (bSub == 0)
            {
                <div class="qc-card">
                    <div class="qc-section-title">B-i. Carton Size@(cartonLabel)</div>

                    @* ── Outer Packing spec (readonly từ DB) ── *@
                    <div class="qc-outer-packing-block">
                        <div class="qc-outer-packing-title">OUTER PACKING</div>
                        <div class="qc-outer-packing-row">
                            <div class="qc-outer-packing-item">
                                <span class="qc-outer-packing-lbl">L (MM)</span>
                                <div class="qc-outer-packing-val">@(_data.Packaging.OuterL > 0 ? _data.Packaging.OuterL.ToString() : "—")</div>
                            </div>
                            <div class="qc-outer-packing-item">
                                <span class="qc-outer-packing-lbl">W (MM)</span>
                                <div class="qc-outer-packing-val">@(_data.Packaging.OuterW > 0 ? _data.Packaging.OuterW.ToString() : "—")</div>
                            </div>
                            <div class="qc-outer-packing-item">
                                <span class="qc-outer-packing-lbl">H (MM)</span>
                                <div class="qc-outer-packing-val">@(_data.Packaging.OuterH > 0 ? _data.Packaging.OuterH.ToString() : "—")</div>
                            </div>
                        </div>
                    </div>

                    @* ── Inspector nhập kích thước thực tế ── *@
                    <table class="qc-table">
                        <thead><tr><th>Carton No</th><th>L (mm)</th><th>W (mm)</th><th>H (mm)</th></tr></thead>
                        <tbody>
                            <tr>
                                <td><span class="qc-info-val">@cd.CartonIndex</span></td>
                                <td><input class="qc-cell-input num" type="number" @bind="cd.SizeL" placeholder="0"/></td>
                                <td><input class="qc-cell-input num" type="number" @bind="cd.SizeW" placeholder="0"/></td>
                                <td><input class="qc-cell-input num" type="number" @bind="cd.SizeH" placeholder="0"/></td>
                            </tr>
                        </tbody>
                    </table>
                    <div class="qc-photo3-row">
                        @for (int i = 0; i < cd.SizePhotos.Count; i++)
                        {
                            var idx = i; var cdRef = cd;
                            var uKey = $"Bsize:{cartonIdx}:{idx}"; var isUp = _uploadingKey == uKey;
                            <label class="qc-photo-box3">
                                @if (isUp) { <div class="qc-photo-spinner"><div class="qc-spinner-ring"></div><span style="font-size:11px;color:#2D7DD2">Uploading…</span></div> }
                                else if (cdRef.SizePhotos.Count > idx && !string.IsNullOrEmpty(cdRef.SizePhotos[idx]))
                                { <img src="@GetImageUrl(cdRef.SizePhotos[idx])" class="qc-photo-img"/>
                                  <button class="qc-photo-del" @onclick:stopPropagation="true" @onclick="() => SetPhotoInList(cdRef.SizePhotos, idx, string.Empty)">✕</button> }
                                else { <span class="qc-photo-add">📷</span> }
                                <InputFile OnChange="@(async e => { var url = await UploadPhotoWithSpinner(e, uKey); if(!string.IsNullOrEmpty(url)) SetPhotoInList(cdRef.SizePhotos, idx, url); StateHasChanged(); })"
                                           accept="image/*" capture="environment" style="display:none"/>
                            </label>
                        }
                        @{ var bsNI = cd.SizePhotos.Count; var bsNK = $"Bsize:{cartonIdx}:{bsNI}"; var bsCD = cd; }
                        <label class="qc-photo-box3" style="border:2px dashed #2D7DD2;background:#eef4ff;cursor:pointer;display:flex;align-items:center;justify-content:center">
                            @if (_uploadingKey == bsNK) { <div class="qc-photo-spinner"><div class="qc-spinner-ring"></div><span style="font-size:11px;color:#2D7DD2">Uploading…</span></div> }
                            else { <span style="font-size:26px;color:#2D7DD2;font-weight:300;line-height:1">+</span> }
                            <InputFile OnChange="@(async e => { bsCD.SizePhotos.Add(string.Empty); var url = await UploadPhotoWithSpinner(e, bsNK); if(!string.IsNullOrEmpty(url)) bsCD.SizePhotos[bsNI] = url; StateHasChanged(); })"
                                       accept="image/*" capture="environment" style="display:none"/>
                        </label>
                    </div>
                </div>
            }

            @* B-ii: Shipping Mark *@
            else if (bSub == 1)
            {
                <div class="qc-card">
                    <div class="qc-section-title">B-ii. Shipping Mark / Labeling / Barcode@(cartonLabel)</div>
                    <div class="qc-photo3-row">
                        @for (int i = 0; i < cd.ShippingMarkPhotos.Count; i++)
                        {
                            var idx = i; var cdRef = cd;
                            var uKey = $"Bsm:{cartonIdx}:{idx}"; var isUp = _uploadingKey == uKey;
                            <label class="qc-photo-box3 tall">
                                @if (isUp) { <div class="qc-photo-spinner"><div class="qc-spinner-ring"></div><span style="font-size:11px;color:#2D7DD2">Uploading…</span></div> }
                                else if (cdRef.ShippingMarkPhotos.Count > idx && !string.IsNullOrEmpty(cdRef.ShippingMarkPhotos[idx]))
                                { <img src="@GetImageUrl(cdRef.ShippingMarkPhotos[idx])" class="qc-photo-img"/>
                                  <button class="qc-photo-del" @onclick:stopPropagation="true" @onclick="() => SetPhotoInList(cdRef.ShippingMarkPhotos, idx, string.Empty)">✕</button> }
                                else { <span class="qc-photo-add">📷</span> }
                                <InputFile OnChange="@(async e => { var url = await UploadPhotoWithSpinner(e, uKey); if(!string.IsNullOrEmpty(url)) SetPhotoInList(cdRef.ShippingMarkPhotos, idx, url); StateHasChanged(); })"
                                           accept="image/*" capture="environment" style="display:none"/>
                            </label>
                        }
                        @{ var bsmNI = cd.ShippingMarkPhotos.Count; var bsmNK = $"Bsm:{cartonIdx}:{bsmNI}"; var bsmCD = cd; }
                        <label class="qc-photo-box3 tall" style="border:2px dashed #2D7DD2;background:#eef4ff;cursor:pointer;display:flex;align-items:center;justify-content:center">
                            @if (_uploadingKey == bsmNK) { <div class="qc-photo-spinner"><div class="qc-spinner-ring"></div><span style="font-size:11px;color:#2D7DD2">Uploading…</span></div> }
                            else { <span style="font-size:26px;color:#2D7DD2;font-weight:300;line-height:1">+</span> }
                            <InputFile OnChange="@(async e => { bsmCD.ShippingMarkPhotos.Add(string.Empty); var url = await UploadPhotoWithSpinner(e, bsmNK); if(!string.IsNullOrEmpty(url)) bsmCD.ShippingMarkPhotos[bsmNI] = url; StateHasChanged(); })"
                                       accept="image/*" capture="environment" style="display:none"/>
                        </label>
                    </div>
                </div>
            }

            @* B-iii: Carton Weight *@
            else if (bSub == 2)
            {
                <div class="qc-card">
                    <div class="qc-section-title">B-iii. Carton Weight@(cartonLabel)</div>
                    <div class="qc-info-table" style="margin-bottom:12px">
                        <div class="qc-info-row"><span class="qc-info-lbl">Spec Weight (Kgs)</span>
                            <span class="qc-info-val">@_data.Packaging.OuterWeight</span></div>
                    </div>
                    <div class="qc-info-table">
                        <div class="qc-info-row">
                            <span class="qc-info-lbl">Actual Weight (Kgs)</span>
                            <input class="qc-info-input" type="number" @bind="cd.Weight" placeholder="0.0"/>
                        </div>
                    </div>
                    <div class="qc-photo3-row">
                        @for (int i = 0; i < cd.WeightPhotos.Count; i++)
                        {
                            var idx = i; var cdRef = cd;
                            var uKey = $"Bwt:{cartonIdx}:{idx}"; var isUp = _uploadingKey == uKey;
                            <label class="qc-photo-box3">
                                @if (isUp) { <div class="qc-photo-spinner"><div class="qc-spinner-ring"></div><span style="font-size:11px;color:#2D7DD2">Uploading…</span></div> }
                                else if (cdRef.WeightPhotos.Count > idx && !string.IsNullOrEmpty(cdRef.WeightPhotos[idx]))
                                { <img src="@GetImageUrl(cdRef.WeightPhotos[idx])" class="qc-photo-img"/>
                                  <button class="qc-photo-del" @onclick:stopPropagation="true" @onclick="() => SetPhotoInList(cdRef.WeightPhotos, idx, string.Empty)">✕</button> }
                                else { <span class="qc-photo-add">📷</span> }
                                <InputFile OnChange="@(async e => { var url = await UploadPhotoWithSpinner(e, uKey); if(!string.IsNullOrEmpty(url)) SetPhotoInList(cdRef.WeightPhotos, idx, url); StateHasChanged(); })"
                                           accept="image/*" capture="environment" style="display:none"/>
                            </label>
                        }
                        @{ var bwtNI = cd.WeightPhotos.Count; var bwtNK = $"Bwt:{cartonIdx}:{bwtNI}"; var bwtCD = cd; }
                        <label class="qc-photo-box3" style="border:2px dashed #2D7DD2;background:#eef4ff;cursor:pointer;display:flex;align-items:center;justify-content:center">
                            @if (_uploadingKey == bwtNK) { <div class="qc-photo-spinner"><div class="qc-spinner-ring"></div><span style="font-size:11px;color:#2D7DD2">Uploading…</span></div> }
                            else { <span style="font-size:26px;color:#2D7DD2;font-weight:300;line-height:1">+</span> }
                            <InputFile OnChange="@(async e => { bwtCD.WeightPhotos.Add(string.Empty); var url = await UploadPhotoWithSpinner(e, bwtNK); if(!string.IsNullOrEmpty(url)) bwtCD.WeightPhotos[bwtNI] = url; StateHasChanged(); })"
                                       accept="image/*" capture="environment" style="display:none"/>
                        </label>
                    </div>
                </div>
            }

            @* B-iv: Packaging & Labeling *@
            else if (bSub == 3)
            {
                <div class="qc-card">
                    <div class="qc-section-title">B-iv. Packaging &amp; Labeling Specifications@(cartonLabel)</div>
                    <div class="qc-photo3-row">
                        @for (int i = 0; i < cd.PkgLabelPhotos.Count; i++)
                        {
                            var idx = i; var cdRef = cd;
                            var uKey = $"Bpkg:{cartonIdx}:{idx}"; var isUp = _uploadingKey == uKey;
                            <label class="qc-photo-box3 tall">
                                @if (isUp) { <div class="qc-photo-spinner"><div class="qc-spinner-ring"></div><span style="font-size:11px;color:#2D7DD2">Uploading…</span></div> }
                                else if (cdRef.PkgLabelPhotos.Count > idx && !string.IsNullOrEmpty(cdRef.PkgLabelPhotos[idx]))
                                { <img src="@GetImageUrl(cdRef.PkgLabelPhotos[idx])" class="qc-photo-img"/>
                                  <button class="qc-photo-del" @onclick:stopPropagation="true" @onclick="() => SetPhotoInList(cdRef.PkgLabelPhotos, idx, string.Empty)">✕</button> }
                                else { <span class="qc-photo-add">📷</span> }
                                <InputFile OnChange="@(async e => { var url = await UploadPhotoWithSpinner(e, uKey); if(!string.IsNullOrEmpty(url)) SetPhotoInList(cdRef.PkgLabelPhotos, idx, url); StateHasChanged(); })"
                                           accept="image/*" capture="environment" style="display:none"/>
                            </label>
                        }
                        @{ var bpkNI = cd.PkgLabelPhotos.Count; var bpkNK = $"Bpkg:{cartonIdx}:{bpkNI}"; var bpkCD = cd; }
                        <label class="qc-photo-box3 tall" style="border:2px dashed #2D7DD2;background:#eef4ff;cursor:pointer;display:flex;align-items:center;justify-content:center">
                            @if (_uploadingKey == bpkNK) { <div class="qc-photo-spinner"><div class="qc-spinner-ring"></div><span style="font-size:11px;color:#2D7DD2">Uploading…</span></div> }
                            else { <span style="font-size:26px;color:#2D7DD2;font-weight:300;line-height:1">+</span> }
                            <InputFile OnChange="@(async e => { bpkCD.PkgLabelPhotos.Add(string.Empty); var url = await UploadPhotoWithSpinner(e, bpkNK); if(!string.IsNullOrEmpty(url)) bpkCD.PkgLabelPhotos[bpkNI] = url; StateHasChanged(); })"
                                       accept="image/*" capture="environment" style="display:none"/>
                        </label>
                    </div>
                </div>
            }

            @* B-v: Assembly Instruction *@
            else if (bSub == 4)
            {
                <div class="qc-card">
                    <div class="qc-section-title">B-v. Assembly Instruction Specifications@(cartonLabel)</div>
                    <div class="qc-photo3-row">
                        @for (int i = 0; i < cd.AssemblyPhotos.Count; i++)
                        {
                            var idx = i; var cdRef = cd;
                            var uKey = $"Basm:{cartonIdx}:{idx}"; var isUp = _uploadingKey == uKey;
                            <label class="qc-photo-box3 tall">
                                @if (isUp) { <div class="qc-photo-spinner"><div class="qc-spinner-ring"></div><span style="font-size:11px;color:#2D7DD2">Uploading…</span></div> }
                                else if (cdRef.AssemblyPhotos.Count > idx && !string.IsNullOrEmpty(cdRef.AssemblyPhotos[idx]))
                                { <img src="@GetImageUrl(cdRef.AssemblyPhotos[idx])" class="qc-photo-img"/>
                                  <button class="qc-photo-del" @onclick:stopPropagation="true" @onclick="() => SetPhotoInList(cdRef.AssemblyPhotos, idx, string.Empty)">✕</button> }
                                else { <span class="qc-photo-add">📷</span> }
                                <InputFile OnChange="@(async e => { var url = await UploadPhotoWithSpinner(e, uKey); if(!string.IsNullOrEmpty(url)) SetPhotoInList(cdRef.AssemblyPhotos, idx, url); StateHasChanged(); })"
                                           accept="image/*" capture="environment" style="display:none"/>
                            </label>
                        }
                        @{ var basmNI = cd.AssemblyPhotos.Count; var basmNK = $"Basm:{cartonIdx}:{basmNI}"; var basmCD = cd; }
                        <label class="qc-photo-box3 tall" style="border:2px dashed #2D7DD2;background:#eef4ff;cursor:pointer;display:flex;align-items:center;justify-content:center">
                            @if (_uploadingKey == basmNK) { <div class="qc-photo-spinner"><div class="qc-spinner-ring"></div><span style="font-size:11px;color:#2D7DD2">Uploading…</span></div> }
                            else { <span style="font-size:26px;color:#2D7DD2;font-weight:300;line-height:1">+</span> }
                            <InputFile OnChange="@(async e => { basmCD.AssemblyPhotos.Add(string.Empty); var url = await UploadPhotoWithSpinner(e, basmNK); if(!string.IsNullOrEmpty(url)) basmCD.AssemblyPhotos[basmNI] = url; StateHasChanged(); })"
                                       accept="image/*" capture="environment" style="display:none"/>
                        </label>
                    </div>
                </div>
            }

            @* B-vi: Hardware Specifications *@
            else if (bSub == 5)
            {
                <div class="qc-card">
                    <div class="qc-section-title">B-vi. Hardware Specifications@(cartonLabel)</div>
                    <div class="qc-photo3-row">
                        @for (int i = 0; i < cd.HardwarePhotos.Count; i++)
                        {
                            var idx = i; var cdRef = cd;
                            var uKey = $"Bhw:{cartonIdx}:{idx}"; var isUp = _uploadingKey == uKey;
                            <label class="qc-photo-box3 tall">
                                @if (isUp) { <div class="qc-photo-spinner"><div class="qc-spinner-ring"></div><span style="font-size:11px;color:#2D7DD2">Uploading…</span></div> }
                                else if (cdRef.HardwarePhotos.Count > idx && !string.IsNullOrEmpty(cdRef.HardwarePhotos[idx]))
                                { <img src="@GetImageUrl(cdRef.HardwarePhotos[idx])" class="qc-photo-img"/>
                                  <button class="qc-photo-del" @onclick:stopPropagation="true" @onclick="() => SetPhotoInList(cdRef.HardwarePhotos, idx, string.Empty)">✕</button> }
                                else { <span class="qc-photo-add">📷</span> }
                                <InputFile OnChange="@(async e => { var url = await UploadPhotoWithSpinner(e, uKey); if(!string.IsNullOrEmpty(url)) SetPhotoInList(cdRef.HardwarePhotos, idx, url); StateHasChanged(); })"
                                           accept="image/*" capture="environment" style="display:none"/>
                            </label>
                        }
                        @{ var bhwNI = cd.HardwarePhotos.Count; var bhwNK = $"Bhw:{cartonIdx}:{bhwNI}"; var bhwCD = cd; }
                        <label class="qc-photo-box3 tall" style="border:2px dashed #2D7DD2;background:#eef4ff;cursor:pointer;display:flex;align-items:center;justify-content:center">
                            @if (_uploadingKey == bhwNK) { <div class="qc-photo-spinner"><div class="qc-spinner-ring"></div><span style="font-size:11px;color:#2D7DD2">Uploading…</span></div> }
                            else { <span style="font-size:26px;color:#2D7DD2;font-weight:300;line-height:1">+</span> }
                            <InputFile OnChange="@(async e => { bhwCD.HardwarePhotos.Add(string.Empty); var url = await UploadPhotoWithSpinner(e, bhwNK); if(!string.IsNullOrEmpty(url)) bhwCD.HardwarePhotos[bhwNI] = url; StateHasChanged(); })"
                                       accept="image/*" capture="environment" style="display:none"/>
                        </label>
                    </div>
                </div>
            }
        }

        @* ── C-i Product Size: step index = 4 + cartonCount*6 ── *@
        else if (_currentStepIdx == 4 + _cartonCount * B_STEPS_PER_CARTON)
        {
            <div class="qc-card">
                <div class="qc-section-title">C-i. Product Size</div>

                @* ── Product Size spec (readonly từ DB) ── *@
                @if (_inspection?.ProductSpec != null &&
                     (_inspection.ProductSpec.SizeL > 0 || _inspection.ProductSpec.SizeW > 0 || _inspection.ProductSpec.SizeH > 0))
                {
                    <div class="qc-outer-packing-block">
                        <div class="qc-outer-packing-title">I. PRODUCT SIZE</div>
                        <div class="qc-outer-packing-row">
                            <div class="qc-outer-packing-item">
                                <span class="qc-outer-packing-lbl">L (MM)</span>
                                <div class="qc-outer-packing-val">@(_inspection.ProductSpec.SizeL > 0 ? _inspection.ProductSpec.SizeL.ToString() : "—")</div>
                            </div>
                            <div class="qc-outer-packing-item">
                                <span class="qc-outer-packing-lbl">W (MM)</span>
                                <div class="qc-outer-packing-val">@(_inspection.ProductSpec.SizeW > 0 ? _inspection.ProductSpec.SizeW.ToString() : "—")</div>
                            </div>
                            <div class="qc-outer-packing-item">
                                <span class="qc-outer-packing-lbl">H (MM)</span>
                                <div class="qc-outer-packing-val">@(_inspection.ProductSpec.SizeH > 0 ? _inspection.ProductSpec.SizeH.ToString() : "—")</div>
                            </div>
                        </div>
                    </div>
                }

                <!-- Nhập kích thước thực tế -->
                <div class="qc-info-table" style="margin-bottom:12px">
                    <div class="qc-info-row qc-sub-row" style="flex-direction:column;align-items:flex-start;gap:6px">
                        <span class="qc-info-lbl" style="padding-top:0">Product Size (mm)</span>
                        <div class="qc-split-val qc-lwh">
                            <div class="qc-split-item">
                                <span class="qc-sub-lbl">L</span>
                                <input class="qc-info-input sm" type="number" @bind="_data.ProductSpec.SpecL" placeholder="0"/>
                            </div>
                            <div class="qc-split-item">
                                <span class="qc-sub-lbl">W</span>
                                <input class="qc-info-input sm" type="number" @bind="_data.ProductSpec.SpecW" placeholder="0"/>
                            </div>
                            <div class="qc-split-item">
                                <span class="qc-sub-lbl">H</span>
                                <input class="qc-info-input sm" type="number" @bind="_data.ProductSpec.SpecH" placeholder="0"/>
                            </div>
                        </div>
                    </div>
                    <div class="qc-info-row">
                        <span class="qc-info-lbl">Additional</span>
                        <input class="qc-info-input" @bind="_data.ProductSpec.AdditionalText" placeholder="Enter additional info…"/>
                    </div>
                </div>
                <!-- 4 ô ảnh — bắt buộc tối thiểu 2 hình -->
                @{
                    int sizePhotoCount = _data.ProductSpec.SizePhotos.Count(p => !string.IsNullOrEmpty(p));
                    bool sizePhotoOk   = sizePhotoCount >= 2;
                }
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px">
                    <span style="font-size:12px;font-weight:600;color:#555">
                        Photos <span style="color:#e74c3c">*</span>
                        <span style="color:#aaa;font-weight:400">(min. 2 photos)</span>
                        <span style="color:@(sizePhotoOk ? "#27ae60" : "#aaa");font-weight:700"> @sizePhotoCount/2</span>
                    </span>
                    @if (_sizeValidated && !sizePhotoOk)
                    {
                        <span style="color:#e74c3c;font-size:11px;font-weight:600">⚠ At least 2 photos required</span>
                    }
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px">
                    @for (int i = 0; i < _data.ProductSpec.SizePhotos.Count; i++)
                    {
                        var idx = i;
                        var hasP = !string.IsNullOrEmpty(_data.ProductSpec.SizePhotos[idx]);
                        var isRequired = _sizeValidated && !sizePhotoOk && idx < 2;
                        var uKey = $"Csize:{idx}"; var isUp = _uploadingKey == uKey;
                        <label class="qc-photo-box @(isRequired ? "photo-required" : "")" style="aspect-ratio:4/3;min-height:100px">
                            @if (isUp) { <div class="qc-photo-spinner"><div class="qc-spinner-ring"></div><span style="font-size:11px;color:#2D7DD2">Uploading…</span></div> }
                            else if (hasP)
                            {
                                <img src="@GetImageUrl(_data.ProductSpec.SizePhotos[idx])" class="qc-photo-img"/>
                                <button class="qc-photo-del" @onclick:stopPropagation="true"
                                        @onclick="() => SetPhotoInList(_data.ProductSpec.SizePhotos, idx, string.Empty)">✕</button>
                            }
                            else { <span class="qc-photo-add">@(idx < 2 ? "📷 *" : "📷")</span> }
                            <InputFile OnChange="@(async e => { var url = await UploadPhotoWithSpinner(e, uKey); if(!string.IsNullOrEmpty(url)) SetPhotoInList(_data.ProductSpec.SizePhotos, idx, url); StateHasChanged(); })"
                                       accept="image/*" capture="environment" style="display:none"/>
                        </label>
                    }
                    @{ var csNI = _data.ProductSpec.SizePhotos.Count; var csNK = $"Csize:{csNI}"; }
                    <label class="qc-photo-box" style="aspect-ratio:4/3;min-height:100px;border:2px dashed #2D7DD2;background:#eef4ff;cursor:pointer;display:flex;align-items:center;justify-content:center">
                        @if (_uploadingKey == csNK) { <div class="qc-photo-spinner"><div class="qc-spinner-ring"></div><span style="font-size:11px;color:#2D7DD2">Uploading…</span></div> }
                        else { <span style="font-size:26px;color:#2D7DD2;font-weight:300;line-height:1">+</span> }
                        <InputFile OnChange="@(async e => { _data.ProductSpec.SizePhotos.Add(string.Empty); var url = await UploadPhotoWithSpinner(e, csNK); if(!string.IsNullOrEmpty(url)) _data.ProductSpec.SizePhotos[csNI] = url; StateHasChanged(); })"
                                   accept="image/*" capture="environment" style="display:none"/>
                    </label>
                </div>

            </div>
        }

        else if (_currentStepIdx == 5 + _cartonCount * B_STEPS_PER_CARTON)
        {
            <div class="qc-card">
                <div class="qc-section-title">C-ii. Golden Sample/Compare</div>
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px">
                    <span style="font-size:12px;font-weight:600;color:#555">
                        Photos <span style="color:#e74c3c">*</span>
                        <span style="color:#aaa;font-weight:400">(min. 2 photos)</span>
                        <span style="color:@(_data.ProductSpec.GoldenPhotos.Count(p=>!string.IsNullOrEmpty(p))>=2?"#27ae60":"#aaa");font-weight:700">
                            @(_data.ProductSpec.GoldenPhotos.Count(p=>!string.IsNullOrEmpty(p)))/2
                        </span>
                    </span>
                    @if (_goldenValidated && _data.ProductSpec.GoldenPhotos.Count(p=>!string.IsNullOrEmpty(p)) < 2)
                    {
                        <span style="color:#e74c3c;font-size:11px;font-weight:600">⚠ At least 2 photos required</span>
                    }
                </div>
                <div class="qc-photo3-row">
                    @for (int i = 0; i < _data.ProductSpec.GoldenPhotos.Count; i++)
                    {
                        var idx = i;
                        var hasG = !string.IsNullOrEmpty(_data.ProductSpec.GoldenPhotos[idx]);
                        var reqG = _goldenValidated && _data.ProductSpec.GoldenPhotos.Count(p=>!string.IsNullOrEmpty(p)) < 2 && idx < 2;
                        var uKey = $"Gold:{idx}"; var isUp = _uploadingKey == uKey;
                        <label class="qc-photo-box3 tall @(reqG ? "photo-required" : "")">
                            @if (isUp) { <div class="qc-photo-spinner"><div class="qc-spinner-ring"></div><span style="font-size:11px;color:#2D7DD2">Uploading…</span></div> }
                            else if (hasG)
                            { <img src="@GetImageUrl(_data.ProductSpec.GoldenPhotos[idx])" class="qc-photo-img"/>
                              <button class="qc-photo-del" @onclick:stopPropagation="true" @onclick="() => SetPhotoInList(_data.ProductSpec.GoldenPhotos, idx, string.Empty)">✕</button> }
                            else { <span class="qc-photo-add">@(idx < 2 ? "📷 *" : "📷")</span> }
                            <InputFile OnChange="@(async e => { var url = await UploadPhotoWithSpinner(e, uKey); if(!string.IsNullOrEmpty(url)) SetPhotoInList(_data.ProductSpec.GoldenPhotos, idx, url); StateHasChanged(); })"
                                       accept="image/*" capture="environment" style="display:none"/>
                        </label>
                    }
                    @{ var gNI = _data.ProductSpec.GoldenPhotos.Count; var gNK = $"Gold:{gNI}"; }
                    <label class="qc-photo-box3 tall" style="border:2px dashed #2D7DD2;background:#eef4ff;cursor:pointer;display:flex;align-items:center;justify-content:center">
                        @if (_uploadingKey == gNK) { <div class="qc-photo-spinner"><div class="qc-spinner-ring"></div><span style="font-size:11px;color:#2D7DD2">Uploading…</span></div> }
                        else { <span style="font-size:26px;color:#2D7DD2;font-weight:300;line-height:1">+</span> }
                        <InputFile OnChange="@(async e => { _data.ProductSpec.GoldenPhotos.Add(string.Empty); var url = await UploadPhotoWithSpinner(e, gNK); if(!string.IsNullOrEmpty(url)) _data.ProductSpec.GoldenPhotos[gNI] = url; StateHasChanged(); })"
                                   accept="image/*" capture="environment" style="display:none"/>
                    </label>
                </div>
            </div>
        }

        else if (_currentStepIdx == 6 + _cartonCount * B_STEPS_PER_CARTON)
        {
            <div class="qc-card">
                <div class="qc-section-title">C-iii. Colour Swatch Comparison</div>
                <!-- Material readonly từ DB InspectionColourSwatches -->
                <table class="qc-table">
                    <thead><tr><th>No</th><th>Material</th><th>Result</th></tr></thead>
                    <tbody>
                        @foreach (var cs in _data.ProductSpec.ColourSwatches)
                        {
                            <tr>
                                <td class="td-center fw-bold">@cs.No</td>
                                <td>
                                    <span class="qc-info-val" style="font-size:13px">
                                        @(string.IsNullOrEmpty(cs.Material) ? "—" : cs.Material)
                                    </span>
                                </td>
                                <td>
                                    <select class="qc-select-sm" @bind="cs.Result">
                                        <option value="">—</option>
                                        <option value="Passed">Passed</option>
                                        <option value="Failed">Failed</option>
                                        <option value="N/A">N/A</option>
                                    </select>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                <!-- Photos — bắt buộc tối thiểu 2 hình -->
                <div style="display:flex;align-items:center;justify-content:space-between;margin:10px 0 6px">
                    <span style="font-size:12px;font-weight:600;color:#555">
                        Photos <span style="color:#e74c3c">*</span>
                        <span style="color:#aaa;font-weight:400">(min. 2 photos)</span>
                        <span style="color:@(_data.ProductSpec.SwatchPhotos.Count(p=>!string.IsNullOrEmpty(p))>=2?"#27ae60":"#aaa");font-weight:700">
                            @(_data.ProductSpec.SwatchPhotos.Count(p=>!string.IsNullOrEmpty(p)))/2
                        </span>
                    </span>
                    @if (_swatchValidated && _data.ProductSpec.SwatchPhotos.Count(p=>!string.IsNullOrEmpty(p)) < 2)
                    {
                        <span style="color:#e74c3c;font-size:11px;font-weight:600">⚠ At least 2 photos required</span>
                    }
                </div>
                <div class="qc-photo3-row">
                    @for (int i = 0; i < _data.ProductSpec.SwatchPhotos.Count; i++)
                    {
                        var idx = i;
                        var hasS = !string.IsNullOrEmpty(_data.ProductSpec.SwatchPhotos[idx]);
                        var reqS = _swatchValidated && _data.ProductSpec.SwatchPhotos.Count(p=>!string.IsNullOrEmpty(p)) < 2 && idx < 2;
                        var uKey = $"Swt:{idx}"; var isUp = _uploadingKey == uKey;
                        <label class="qc-photo-box3 @(reqS ? "photo-required" : "")">
                            @if (isUp) { <div class="qc-photo-spinner"><div class="qc-spinner-ring"></div><span style="font-size:11px;color:#2D7DD2">Uploading…</span></div> }
                            else if (hasS)
                            { <img src="@GetImageUrl(_data.ProductSpec.SwatchPhotos[idx])" class="qc-photo-img"/>
                              <button class="qc-photo-del" @onclick:stopPropagation="true" @onclick="() => SetPhotoInList(_data.ProductSpec.SwatchPhotos, idx, string.Empty)">✕</button> }
                            else { <span class="qc-photo-add">@(idx < 2 ? "📷 *" : "📷")</span> }
                            <InputFile OnChange="@(async e => { var url = await UploadPhotoWithSpinner(e, uKey); if(!string.IsNullOrEmpty(url)) SetPhotoInList(_data.ProductSpec.SwatchPhotos, idx, url); StateHasChanged(); })"
                                       accept="image/*" capture="environment" style="display:none"/>
                        </label>
                    }
                    @{ var swNI = _data.ProductSpec.SwatchPhotos.Count; var swNK = $"Swt:{swNI}"; }
                    <label class="qc-photo-box3" style="border:2px dashed #2D7DD2;background:#eef4ff;cursor:pointer;display:flex;align-items:center;justify-content:center">
                        @if (_uploadingKey == swNK) { <div class="qc-photo-spinner"><div class="qc-spinner-ring"></div><span style="font-size:11px;color:#2D7DD2">Uploading…</span></div> }
                        else { <span style="font-size:26px;color:#2D7DD2;font-weight:300;line-height:1">+</span> }
                        <InputFile OnChange="@(async e => { _data.ProductSpec.SwatchPhotos.Add(string.Empty); var url = await UploadPhotoWithSpinner(e, swNK); if(!string.IsNullOrEmpty(url)) _data.ProductSpec.SwatchPhotos[swNI] = url; StateHasChanged(); })"
                                   accept="image/*" capture="environment" style="display:none"/>
                    </label>
                </div>
            </div>
        }

        @* ── D. Performance Testing — mỗi test = 1 step ── *@
        else if (_currentStepIdx >= 7 + _cartonCount * B_STEPS_PER_CARTON &&
                 _currentStepIdx <  7 + _cartonCount * B_STEPS_PER_CARTON + Math.Max(1, _data.PerformanceTests.Count))
        {
            var dIdx = _currentStepIdx - (7 + _cartonCount * B_STEPS_PER_CARTON);
            @if (_data.PerformanceTests.Any() && dIdx < _data.PerformanceTests.Count)
            {
                var pt = _data.PerformanceTests[dIdx];
                int perfPhotoCount = pt.Photos.Count(p => !string.IsNullOrEmpty(p));
                <div class="qc-card">
                    <div class="qc-section-title">D. Performance Testing</div>
                    <div class="qc-perf-block">
                        <!-- Bảng theo mẫu PDF -->
                        <table class="qc-table" style="margin-bottom:12px">
                            <thead>
                                <tr>
                                    <th style="width:35%">Test Item</th>
                                    <th style="font-weight:700;color:#1a1a2e">@pt.TestItem</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="qc-info-lbl" style="vertical-align:middle;padding:8px 6px">Test Protocol</td>
                                    <td style="padding:6px 6px">
                                        <div style="display:flex;align-items:center;gap:10px">
                                            <span style="font-size:13px;color:#333;line-height:1.4;flex:1">
                                                @if (string.IsNullOrEmpty(pt.TestProtocol))
                                                {
                                                    <span style="color:#bbb">—</span>
                                                }
                                                else
                                                {
                                                    @(pt.TestProtocol.Length > 60 ? pt.TestProtocol[..60] + "…" : pt.TestProtocol)
                                                }
                                            </span>
                                            @if (!string.IsNullOrEmpty(pt.TestProtocol))
                                            {
                                                <button class="proto-view-btn" @onclick="() => ShowProtocolPopup(pt.TestProtocol)">
                                                    <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                                                        <path d="M1 10s3.5-7 9-7 9 7 9 7-3.5 7-9 7-9-7-9-7z"/><circle cx="10" cy="10" r="3"/>
                                                    </svg>
                                                    View
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="qc-info-lbl" style="vertical-align:top;padding:8px 6px">Test Requirement</td>
                                    <td style="font-size:13px;color:#333;padding:8px 6px;line-height:1.5">@pt.TestRequirement</td>
                                </tr>
                                <tr>
                                    <td class="qc-info-lbl" style="padding:8px 6px">Test Quantity</td>
                                    <td style="padding:4px 6px">
                                        <input class="qc-info-input" type="number" @bind="pt.TestQuantity" placeholder="0" style="max-width:100px"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="qc-info-lbl" style="padding:8px 6px">Remark</td>
                                    <td style="padding:4px 6px">
                                        <input class="qc-info-input" @bind="pt.Remark" placeholder="Remark…"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                        <!-- 4 ảnh — bắt buộc tối thiểu 2 hình -->
                        <div style="display:flex;align-items:center;justify-content:space-between;margin:10px 0 6px">
                            <span style="font-size:12px;font-weight:600;color:#555">
                                Photos <span style="color:#e74c3c">*</span>
                                <span style="color:#aaa;font-weight:400">(min. 2 photos)</span>
                                <span style="color:@(perfPhotoCount>=2?"#27ae60":"#aaa");font-weight:700"> @perfPhotoCount/2</span>
                            </span>
                            @if ((dIdx < _perfValidated.Length && _perfValidated[dIdx]) && perfPhotoCount < 2)
                            {
                                <span style="color:#e74c3c;font-size:11px;font-weight:600">⚠ At least 2 photos required</span>
                            }
                        </div>
                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px">
                            @for (int i = 0; i < pt.Photos.Count; i++)
                            {
                                var idx = i; var ptRef = pt; var dIdxRef = dIdx;
                                var hasP = !string.IsNullOrEmpty(ptRef.Photos[idx]);
                                var reqP = (dIdxRef < _perfValidated.Length && _perfValidated[dIdxRef]) && ptRef.Photos.Count(p=>!string.IsNullOrEmpty(p)) < 2 && idx < 2;
                                var uKey = $"Perf:{dIdx}:{idx}"; var isUp = _uploadingKey == uKey;
                                <label class="qc-photo-box @(reqP ? "photo-required" : "")" style="aspect-ratio:4/3;min-height:90px">
                                    @if (isUp) { <div class="qc-photo-spinner"><div class="qc-spinner-ring"></div><span style="font-size:11px;color:#2D7DD2">Uploading…</span></div> }
                                    else if (hasP)
                                    {
                                        <img src="@GetImageUrl(ptRef.Photos[idx])" class="qc-photo-img"/>
                                        <button class="qc-photo-del" @onclick:stopPropagation="true"
                                                @onclick="() => SetPhotoInList(ptRef.Photos, idx, string.Empty)">✕</button>
                                    }
                                    else { <span class="qc-photo-add">@(idx < 2 ? "📷 *" : "📷")</span> }
                                    <InputFile OnChange="@(async e => { var url = await UploadPhotoWithSpinner(e, uKey); if(!string.IsNullOrEmpty(url)) SetPhotoInList(ptRef.Photos, idx, url); StateHasChanged(); })"
                                               accept="image/*" capture="environment" style="display:none"/>
                                </label>
                            }
                            @{ var pNI = pt.Photos.Count; var pNK = $"Perf:{dIdx}:{pNI}"; var ptAdd = pt; }
                            <label class="qc-photo-box" style="aspect-ratio:4/3;min-height:90px;border:2px dashed #2D7DD2;background:#eef4ff;cursor:pointer;display:flex;align-items:center;justify-content:center">
                                @if (_uploadingKey == pNK) { <div class="qc-photo-spinner"><div class="qc-spinner-ring"></div><span style="font-size:11px;color:#2D7DD2">Uploading…</span></div> }
                                else { <span style="font-size:26px;color:#2D7DD2;font-weight:300;line-height:1">+</span> }
                                <InputFile OnChange="@(async e => { ptAdd.Photos.Add(string.Empty); var url = await UploadPhotoWithSpinner(e, pNK); if(!string.IsNullOrEmpty(url)) ptAdd.Photos[pNI] = url; StateHasChanged(); })"
                                           accept="image/*" capture="environment" style="display:none"/>
                            </label>
                        </div>

                    </div>
                </div>
            }
            else
            {
                <div class="qc-card">
                    <div class="qc-section-title">D. Performance Testing</div>
                    <div class="qc-empty-msg">No performance tests configured.</div>
                </div>
            }
        }

        @* ── E. Appearance & Craftsmanship (AQL) ── *@
        else if (_currentStepIdx == 7 + _cartonCount * B_STEPS_PER_CARTON + Math.Max(1, _data.PerformanceTests.Count))
        {
            <div class="qc-card">
                <div class="qc-section-title">E. Appearance &amp; Craftsmanship</div>
                <div class="qc-aql-header">AQL Sampling Simulator</div>
                <div class="qc-aql-row">
                    <div class="qc-aql-item">
                        <label class="qc-aql-lbl">Quantity</label>
                        <input class="qc-aql-input" type="number" @bind="_data.Aql.Quantity"
                               @bind:event="oninput" @bind:after="() => { RecalcAql(); return Task.CompletedTask; }"/>
                    </div>
                    <div class="qc-aql-item">
                        <label class="qc-aql-lbl">Inspection Level</label>
                        <select class="qc-aql-input" @bind="_data.Aql.InspectionLevel"
                                @bind:after="() => { RecalcAql(); return Task.CompletedTask; }">
                            <option value="I">I</option>
                            <option value="II">II</option>
                            <option value="III">III</option>
                            <option value="S1">S1</option>
                            <option value="S2">S2</option>
                            <option value="S3">S3</option>
                            <option value="S4">S4</option>
                        </select>
                    </div>
                </div>
                <div class="qc-aql-cols">
                    @foreach (var dc in new[]{ ("Critical", "aql-critical"), ("Major", "aql-major"), ("Minor", "aql-minor") })
                    {
                        var (label, cls) = dc;
                        var aqlSel = label == "Critical" ? _data.Aql.CriticalAql : label == "Major" ? _data.Aql.MajorAql : _data.Aql.MinorAql;
                        var sample = label == "Critical" ? _data.Aql.CriticalSampleSize : label == "Major" ? _data.Aql.MajorSampleSize : _data.Aql.MinorSampleSize;
                        var accept = label == "Critical" ? _data.Aql.CriticalAccept : label == "Major" ? _data.Aql.MajorAccept : _data.Aql.MinorAccept;
                        var reject = label == "Critical" ? _data.Aql.CriticalReject : label == "Major" ? _data.Aql.MajorReject : _data.Aql.MinorReject;
                        <div class="qc-aql-col @cls">
                            <div class="qc-aql-col-title">@label Defects</div>
                            <div class="qc-aql-field">
                                <label>Select AQL</label>
                                <select class="qc-aql-sm" value="@aqlSel" @onchange="e => SetAql(label, e.Value?.ToString() ?? string.Empty)">
                                    <option value="Not Allowed">Not Allowed</option>
                                    <option value="0.065">0.065</option>
                                    <option value="0.1">0.1</option>
                                    <option value="0.15">0.15</option>
                                    <option value="0.25">0.25</option>
                                    <option value="0.40">0.40</option>
                                    <option value="0.65">0.65</option>
                                    <option value="1.0">1.0</option>
                                    <option value="1.5">1.5</option>
                                    <option value="2.5">2.5</option>
                                    <option value="4.0">4.0</option>
                                    <option value="6.5">6.5</option>
                                </select>
                            </div>
                            <div class="qc-aql-stat"><span>Sample Size:</span><span>@sample</span></div>
                            <div class="qc-aql-stat"><span>Accept Point:</span><span>@accept</span></div>
                            <div class="qc-aql-stat red-stat"><span>Reject Point:</span><span>@reject</span></div>
                        </div>
                    }
                </div>
                <div class="qc-section-title" style="margin-top:18px">RESULT</div>
                <table class="qc-table">
                    <thead><tr><th>Details of Defect Found</th><th>Critical</th><th>Major</th><th>Minor</th></tr></thead>
                    <tbody>
                        <tr>
                            <td>Total Found</td>
                            <td><input class="qc-cell-input num" type="number" @bind="_data.Aql.CriticalFound"
                                       @bind:event="oninput" @bind:after="StateHasChanged"/></td>
                            <td><input class="qc-cell-input num" type="number" @bind="_data.Aql.MajorFound"
                                       @bind:event="oninput" @bind:after="StateHasChanged"/></td>
                            <td><input class="qc-cell-input num" type="number" @bind="_data.Aql.MinorFound"
                                       @bind:event="oninput" @bind:after="StateHasChanged"/></td>
                        </tr>
                        <tr>
                            <td>Status</td>
                            <td class="@(_data.Aql.CriticalFound > _data.Aql.CriticalAccept ? "cell-fail" : "cell-pass")">
                                @(_data.Aql.CriticalFound > _data.Aql.CriticalAccept ? "FAIL" : "PASS")</td>
                            <td class="@(_data.Aql.MajorFound > _data.Aql.MajorAccept ? "cell-fail" : "cell-pass")">
                                @(_data.Aql.MajorFound > _data.Aql.MajorAccept ? "FAIL" : "PASS")</td>
                            <td class="@(_data.Aql.MinorFound > _data.Aql.MinorAccept ? "cell-fail" : "cell-pass")">
                                @(_data.Aql.MinorFound > _data.Aql.MinorAccept ? "FAIL" : "PASS")</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        }

        @* ── F. Details of Defect Found ── *@
        else if (_currentStepIdx == 8 + _cartonCount * B_STEPS_PER_CARTON + Math.Max(1, _data.PerformanceTests.Count) ||
                 _currentStepIdx == 9 + _cartonCount * B_STEPS_PER_CARTON + Math.Max(1, _data.PerformanceTests.Count) ||
                 _currentStepIdx == 10 + _cartonCount * B_STEPS_PER_CARTON + Math.Max(1, _data.PerformanceTests.Count))
        {
            int fBase    = 8 + _cartonCount * B_STEPS_PER_CARTON + Math.Max(1, _data.PerformanceTests.Count);
            var defType  = _currentStepIdx == fBase ? "Critical" : _currentStepIdx == fBase+1 ? "Major" : "Minor";
            var defColor = defType == "Critical" ? "#e74c3c" : defType == "Major" ? "#e67e22" : "#3498db";

            var defItems = _data.Defects.Where(d => d.Type == defType).ToList();

            <div class="qc-card">
                <div class="qc-section-title">F. Details of Defect Found</div>
                <div style="font-size:15px;font-weight:800;color:@defColor;margin-bottom:12px">@defType</div>

                @foreach (var d in defItems)
                {
                    var dRef = d;
                    <div style="border:1px solid #e8eef8;border-radius:10px;padding:10px;margin-bottom:10px;background:#fafcff">
                        <!-- Grid ảnh 2 cột — mỗi ô có ảnh + remark riêng -->
                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:8px">
                            @for (int pi = 0; pi < dRef.Photos.Count; pi++)
                            {
                                var pIdx = pi; var dRef2 = dRef;
                                var hasPhoto = !string.IsNullOrEmpty(dRef2.Photos[pIdx]);
                                // Ensure Remarks slot
                                while (dRef2.Remarks.Count <= pIdx) dRef2.Remarks.Add(string.Empty);
                                <div style="display:flex;flex-direction:column;gap:0">
                                    <!-- Ô ảnh -->
                                    <label style="aspect-ratio:1;background:#f0f5ff;border:2px dashed #b0c8f0;
                                                  border-bottom:none;border-radius:8px 8px 0 0;
                                                  display:flex;align-items:center;justify-content:center;cursor:pointer;
                                                  overflow:hidden;position:relative;min-height:120px;width:100px">
                                        @{ var defUKey = $"Def:{_data.Defects.IndexOf(dRef2)}:{pIdx}"; }
                                        @if (_uploadingKey == defUKey)
                                        { <div class="qc-photo-spinner"><div class="qc-spinner-ring"></div><span style="font-size:11px;color:#2D7DD2">Uploading…</span></div> }
                                        else if (hasPhoto)
                                        {
                                            <img src="@GetImageUrl(dRef2.Photos[pIdx])" style="width:100%;height:100%;object-fit:cover"/>
                                            <button style="position:absolute;top:4px;right:4px;background:rgba(0,0,0,.55);color:#fff;
                                                           border:none;border-radius:50%;width:22px;height:22px;font-size:11px;cursor:pointer;line-height:1"
                                                    @onclick:stopPropagation="true"
                                                    @onclick="() => { var dr2=dRef2; int pi2=pIdx; if(pi2<dr2.Photos.Count) dr2.Photos[pi2]=string.Empty; var i2=_data.Defects.IndexOf(dr2); if(i2>=0) _data.Defects[i2]=dr2; StateHasChanged(); }">✕</button>
                                        }
                                        else { <span style="font-size:28px;color:#c0cce0">📷</span> }
                                        <InputFile OnChange="@(async e => await UploadDefectPhotoWithSpinner(e, dRef2, pIdx))"
                                                   accept="image/*" capture="environment" style="display:none;position:absolute;inset:0"/>
                                    </label>
                                    <!-- Remark của ảnh này -->
                                    <input type="text"
                                           style="width:100px;border:1px solid #dce6f8;border-top:1px solid #eef1f8;
                                                  border-radius:0 0 8px 8px;padding:6px 8px;font-size:11px;
                                                  background:#f8faff;outline:none;box-sizing:border-box;color:#555"
                                           placeholder="Remark…"
                                           value="@dRef2.Remarks[pIdx]"
                                           @onchange="e => { dRef2.Remarks[pIdx] = e.Value?.ToString() ?? string.Empty; var i2=_data.Defects.IndexOf(dRef2); if(i2>=0) _data.Defects[i2]=dRef2; }" />
                                </div>
                            }
                            <!-- Nút + thêm ô ảnh -->
                            <button style="aspect-ratio:1;min-height:120px;background:#eef4ff;border:2px dashed #2D7DD2;border-radius:8px;
                                           display:flex;flex-direction:column;align-items:center;justify-content:center;
                                           cursor:pointer;color:#2D7DD2;font-size:30px;gap:4px;font-weight:300"
                                    @onclick="() => { var dr = dRef; dr.Photos.Add(string.Empty); dr.Remarks.Add(string.Empty); var i2=_data.Defects.IndexOf(dr); if(i2>=0) _data.Defects[i2]=dr; StateHasChanged(); }">
                                <span>+</span>
                            </button>
                        </div>
                        @if (defItems.Count > 1)
                        {
                            <div style="display:flex;justify-content:flex-end;margin-top:6px">
                                <button class="qc-del-btn-sm" @onclick="() => { _data.Defects.Remove(dRef); StateHasChanged(); }">✕ Remove</button>
                            </div>
                        }
                    </div>
                }

                <!-- Add thêm defect cùng loại -->
                <button class="qc-add-row-btn" @onclick='() => { _data.Defects.Add(new QcDefect { Type = defType, Photos = new List<string>{"",""}, Remarks = new List<string>{"",""} }); StateHasChanged(); }'>
                    + Add @defType Defect
                </button>
            </div>
        }

        @* ── Step: Inspector Comments & Final Result ── *@
        else if (_currentStepIdx == 11 + _cartonCount * B_STEPS_PER_CARTON + Math.Max(1, _data.PerformanceTests.Count))
        {
            <div class="qc-card">
                <!-- Logo inticoo -->
                <!-- <div class="qc-logo-row" style="margin-bottom:16px">
                    <svg width="28" height="28" viewBox="0 0 32 32" fill="none">
                        <polygon points="16,2 28,9 28,23 16,30 4,23 4,9" fill="#2D7DD2" opacity="0.85"/>
                        <polygon points="16,6 25,11 25,21 16,26 7,21 7,11" fill="#1a5fa8"/>
                        <rect x="13" y="10" width="6" height="12" rx="1" fill="white" opacity="0.9"/>
                        <rect x="10" y="13" width="12" height="6" rx="1" fill="white" opacity="0.6"/>
                    </svg>
                    <span class="qc-logo-text">inticoo</span>
                </div> -->

                <!-- Bảng Inspector Comments theo mẫu PDF -->
                <table class="qc-table" style="margin-bottom:16px;border:1px solid #ddd">
                    <tbody>
                        <tr>
                            <td style="width:35%;font-weight:700;color:#1a1a2e;padding:14px 10px;vertical-align:middle;
                                       border-right:1px solid #ddd;background:#f8faff;line-height:1.4">
                                Inspector<br/>Comments
                            </td>
                            <td style="padding:8px 10px">
                                <textarea class="qc-info-textarea" @bind="_data.InspectorComments" rows="4"
                                          placeholder="Enter comments…" style="width:100%;box-sizing:border-box;border:none;background:transparent;outline:none;resize:none"></textarea>
                            </td>
                        </tr>
                    </tbody>
                </table>

                <!-- Final Result theo mẫu PDF: FINAL RESULT | PASSED / FAILED / NA -->
                <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;margin-bottom:6px">
                    <span style="font-size:13px;font-weight:700;color:#1a1a2e;white-space:nowrap">FINAL RESULT</span>
                    @if (_finalValidated && string.IsNullOrEmpty(_data.FinalResult))
                    {
                        <span style="color:#e74c3c;font-size:11px">⚠ Please select a result</span>
                    }
                </div>
                <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:6px">
                    @foreach (var r in new[]{"PASSED","FAILED","N/A"})
                    {
                        var bg  = _data.FinalResult == r ? (r=="PASSED"?"#27ae60":r=="FAILED"?"#e74c3c":"#888") : "#f0f5ff";
                        var txt = _data.FinalResult == r ? "#fff" : "#555";
                        var bdr = _data.FinalResult == r ? bg : "#dce6f8";
                        <button style="padding:12px 28px;border-radius:10px;font-size:15px;font-weight:700;
                                       border:2px solid @bdr;background:@bg;color:@txt;cursor:pointer;transition:all .2s"
                                @onclick='() => _data.FinalResult = r'>@r</button>
                    }
                </div>
            </div>
        }

        @* ── Step: Compliance & Signature ── *@
        else if (_currentStepIdx == 12 + _cartonCount * B_STEPS_PER_CARTON + Math.Max(1, _data.PerformanceTests.Count))
        {
            <div class="qc-card">
                <!-- Logo -->
                <!-- <div class="qc-logo-row" style="margin-bottom:14px">
                    <svg width="28" height="28" viewBox="0 0 32 32" fill="none">
                        <polygon points="16,2 28,9 28,23 16,30 4,23 4,9" fill="#2D7DD2" opacity="0.85"/>
                        <polygon points="16,6 25,11 25,21 16,26 7,21 7,11" fill="#1a5fa8"/>
                        <rect x="13" y="10" width="6" height="12" rx="1" fill="white" opacity="0.9"/>
                        <rect x="10" y="13" width="12" height="6" rx="1" fill="white" opacity="0.6"/>
                    </svg>
                    <span class="qc-logo-text">inticoo</span>
                </div> -->

                <!-- Compliance clause -->
                <div style="margin-bottom:14px;padding:12px;background:#fffbf0;border-left:3px solid #e67e22;border-radius:0 8px 8px 0">
                    <div style="font-size:13px;font-weight:700;color:#e67e22;margin-bottom:6px">Compliance &amp; Integrity Clause</div>
                    <p style="font-size:12px;color:#555;line-height:1.6;margin:0;font-style:italic">
                        All inspections follow the customer protocol, and any attempt to bribe, pressure, or threaten the inspector will render the inspection invalid and may lead to termination of the agreement and legal consequences.
                    </p>
                </div>

                <!-- Bảng Inspection by / Confirmed by theo mẫu PDF -->
                <table class="qc-table">
                    <tbody>
                        <tr>
                            <td style="width:35%;font-weight:700;color:#1a1a2e;padding:12px 8px;vertical-align:top">Inspection by</td>
                            <td style="padding:10px 8px">
                                <div style="color:#e74c3c;font-size:12px;font-weight:600;margin-bottom:4px">Auto</div>
                                <div style="font-size:13px;font-weight:600;color:#1a1a2e">@_inspection.InspectorName</div>
                                @if (!string.IsNullOrEmpty(_inspection.InspectorId))
                                {
                                    <div style="font-size:12px;color:#888;margin-top:2px">ID: @_inspection.InspectorId</div>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td colspan="2" style="padding:10px 8px">
                                <div style="font-weight:700;color:#1a1a2e;margin-bottom:10px">Confirmed by</div>
                                @if (!string.IsNullOrEmpty(_data.SignatureUrl))
                                {
                                    <img src="@GetImageUrl(_data.SignatureUrl)" style="max-height:120px;object-fit:contain;display:block;width:100%;border:1px dashed #b0c8f0;border-radius:8px;background:#f8faff"/>
                                    <button style="margin-top:8px;background:#fee;color:#e74c3c;border:none;border-radius:5px;padding:6px 14px;font-size:12px;cursor:pointer"
                                            @onclick="() => _data.SignatureUrl = string.Empty">↺ Ký lại</button>
                                }
                                else
                                {
                                    @if (_sigValidated)
                                    {
                                        <div style="color:#e74c3c;font-size:11px;font-weight:600;margin-bottom:6px">⚠ Signature is required</div>
                                    }
                                    <div style="color:#e74c3c;font-size:12px;font-weight:600;margin-bottom:8px">Add Signature</div>
                                    <!-- Canvas ký tay full width -->
                                    <canvas id="sig-canvas"
                                            style="border:1.5px dashed #b0c8f0;border-radius:10px;background:#f8faff;
                                                   touch-action:none;display:block;width:100%;height:180px;">
                                    </canvas>
                                    <div style="display:flex;gap:8px;margin-top:10px">
                                        <button style="flex:1;background:#2D7DD2;color:#fff;border:none;border-radius:8px;padding:10px 0;font-size:13px;font-weight:600;cursor:pointer"
                                                @onclick="SaveSignature">✔ Save Signature</button>
                                        <button style="background:#f0f3f8;color:#555;border:none;border-radius:8px;padding:10px 18px;font-size:13px;cursor:pointer"
                                                @onclick="ClearCanvas">↺ Clear</button>
                                    </div>
                                }
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        }

    </div><!-- end qc-body -->

    <!-- BOTTOM NAV BUTTONS -->
    <div class="qc-nav-bar">
        <button class="qc-nav-btn btn-back" @onclick="HandleBack">Back</button>
        @{
            int _fBase2 = 8 + _cartonCount * B_STEPS_PER_CARTON + Math.Max(1, _data.PerformanceTests.Count);
            bool _isFStep = _currentStepIdx == _fBase2 || _currentStepIdx == _fBase2+1 || _currentStepIdx == _fBase2+2;
        }
        @if (_isFStep)
        {
            var _fDefType = _currentStepIdx == _fBase2 ? "Critical" : _currentStepIdx == _fBase2+1 ? "Major" : "Minor";
            <button class="qc-nav-btn btn-skip" style="background:#eef4ff;color:#2D7DD2;flex:0 0 auto;padding:13px 16px"
                    @onclick='() => { _data.Defects.Add(new QcDefect { Type = _fDefType, Photos = new List<string>{"",""}, Remarks = new List<string>{"",""} }); StateHasChanged(); }'>
                Add
            </button>
        }
        else if (CurrentStep.CanSkip)
        {
            <button class="qc-nav-btn btn-skip" @onclick="SkipStep">Skip</button>
        }
        @if (_currentStepIdx == _steps.Count - 1)
        {
            <button class="qc-nav-btn btn-done @(_saving ? "saving" : "")" @onclick="SaveAndDone" disabled="@_saving">
                @(_saving ? "Saving…" : "Done")
            </button>
        }
        else
        {
            <button class="qc-nav-btn btn-next" @onclick="HandleNext">Next</button>
        }
    </div>

    <!-- SAVE STATUS TOAST -->
    @if (!string.IsNullOrEmpty(_saveMsg))
    {
        <div class="qc-toast @(_saveError ? "toast-err" : "toast-ok")">@_saveMsg</div>
    }

    <!-- TEST PROTOCOL POPUP -->
    @if (_showProtocolPopup)
    {
        <div class="proto-backdrop" @onclick="CloseProtocolPopup">
            <div class="proto-modal" @onclick:stopPropagation="true">
                <div class="proto-modal-header">
                    <span class="proto-modal-title">Test Protocol</span>
                    <button class="proto-close-btn" @onclick="CloseProtocolPopup">✕</button>
                </div>
                <div class="proto-modal-body">
                    @_protocolPopupText
                </div>
                <div class="proto-modal-footer">
                    <button class="proto-ok-btn" @onclick="CloseProtocolPopup">Close</button>
                </div>
            </div>
        </div>
    }
}

<!-- ═══════════════════════ CODE-BEHIND ═══════════════════════ -->
@code {
    [Parameter] public int InspectionId { get; set; }

    bool _loading = true;
    bool _saving;
    bool _saveError;
    string _saveMsg = "";
    // Key dạng "section:slot" để hiển thị spinner đúng ô đang upload
    string _uploadingKey = "";
    InspectionDetailDto? _inspection;
    QcFormData _data = new();
    int _currentStepIdx = 0;
    int _cartonCount = 1;       // số carton từ DB (CartonNumber)

    // ── Popup TestProtocol ──
    bool   _showProtocolPopup  = false;
    string _protocolPopupText  = "";
    void ShowProtocolPopup(string text) { _protocolPopupText = text; _showProtocolPopup = true; }
    void CloseProtocolPopup()           { _showProtocolPopup = false; }

    // ── Step definitions ──
    record StepDef(string StepLabel, string Title, bool CanSkip = false);
    List<StepDef> _steps = new();

    StepDef CurrentStep => _steps[_currentStepIdx];
    double ProgressPct => (_currentStepIdx + 1.0) / _steps.Count * 100;

    // ── Helper: build đúng URL ảnh từ API server ──────────────────
    // - Nếu đã là full URL (http/https) hoặc base64 data: → giữ nguyên
    // - Nếu là relative path (uploads/photos/xxx.png) → gắn BaseAddress của API
    string GetImageUrl(string? url)
    {
        if (string.IsNullOrEmpty(url)) return "";
        if (url.StartsWith("data:") || url.StartsWith("http://") || url.StartsWith("https://"))
            return url;
        var baseUrl = Http.BaseAddress?.ToString().TrimEnd('/') ?? "";
        return $"{baseUrl}/{url.TrimStart('/')}";
    }

    bool _jsReady = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try
        {
            // Sync canvas width với CSS, fill nền trắng, sau đó init signature
            await JS.InvokeVoidAsync("eval", @"
                (function(){
                    var c = document.getElementById('sig-canvas');
                    if(c){
                        c.width  = c.offsetWidth  || 400;
                        c.height = c.offsetHeight || 180;
                        var ctx = c.getContext('2d');
                        ctx.fillStyle = '#ffffff';
                        ctx.fillRect(0, 0, c.width, c.height);
                    }
                })();
            ");
            await JS.InvokeVoidAsync("initSignatureCanvas", "sig-canvas");
        }
        catch { /* canvas chưa có trong DOM — bỏ qua */ }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadInspection();
    }

    async Task LoadInspection()
    {
        try
        {
            _inspection = await Http.GetFromJsonAsync<InspectionDetailDto>($"api/inspections/{InspectionId}");
            if (_inspection != null) InitFormData();
            else { _saveMsg = $"Inspection #{InspectionId} not found."; _saveError = true; }
        }
        catch (Exception ex)
        {
            _saveMsg = $"Load error: {ex.Message}";
            _saveError = true;
        }
        _loading = false;
    }

    void InitFormData()
    {
        if (_inspection == null) return;

        _data.Photo1Url = _inspection.Photo1Url ?? "";
        _data.Photo2Url = _inspection.Photo2Url ?? "";
        _data.InspectionLocation = _inspection.InspectionLocation ?? "";

        _data.OverallConclusions = _inspection.OverallConclusions?.Any() == true
            ? _inspection.OverallConclusions.Select(o => new QcOverallConclusion
            {
                Letter     = o.Letter,
                Label      = o.Label,
                Compliance = (o.Compliance == "None" || o.Compliance == "NA") ? "" : o.Compliance,
                Remark     = o.Remark ?? ""
            }).ToList()
            : new List<QcOverallConclusion>
            {
                new() { Letter = "A", Label = "Quantity Conformity" },
                new() { Letter = "B", Label = "Packaging & Identification" },
                new() { Letter = "C", Label = "Product Specification Compliance" },
                new() { Letter = "D", Label = "Performance Testing" },
                new() { Letter = "E", Label = "Appearance & Craftsmanship" },
                new() { Letter = "F", Label = "Details of Defect Found" },
            };

        // Load Packaging từ DB
        if (_inspection.Packaging != null)
        {
            var p = _inspection.Packaging;
            _data.Packaging.ItemNumber         = p.ItemNumber         ?? "";
            _data.Packaging.CartonNumber       = p.CartonNumber       ?? "";
            _data.Packaging.PackagingType      = p.PackagingType      ?? "";
            _data.Packaging.CartonColor        = p.CartonColor        ?? "";
            _data.Packaging.CardboardType      = p.CardboardType      ?? "";
            _data.Packaging.ShippingMark       = p.ShippingMark       ?? "";
            _data.Packaging.HasBarcode         = p.HasBarcode;
            _data.Packaging.InnerPackingQty    = p.InnerPackingQty    ?? 0;
            _data.Packaging.InnerPackingRemark = p.InnerPackingRemark ?? "";
            _data.Packaging.OuterL             = p.OuterL             ?? 0;
            _data.Packaging.OuterW             = p.OuterW             ?? 0;
            _data.Packaging.OuterH             = p.OuterH             ?? 0;
            _data.Packaging.OuterWeight        = p.OuterWeight        ?? 0;
        }

        // Parse CartonNumber → số carton để lặp B-i đến B-vi
        _cartonCount = 1;
        if (!string.IsNullOrEmpty(_data.Packaging.CartonNumber) &&
            int.TryParse(_data.Packaging.CartonNumber.Trim(), out var parsedCarton) && parsedCarton > 0)
            _cartonCount = parsedCarton;

        // Khởi tạo CartonDataList cho từng carton
        _data.Packaging.CartonDataList = Enumerable.Range(1, _cartonCount)
            .Select(i => new QcCartonData
            {
                CartonIndex  = i,
                SizePhotos         = new List<string> { "", "", "" },
                WeightPhotos       = new List<string> { "", "", "" },
                ShippingMarkPhotos = new List<string> { "", "", "" },
                PkgLabelPhotos     = new List<string> { "", "", "" },
                AssemblyPhotos     = new List<string> { "", "", "" },
                HardwarePhotos     = new List<string> { "", "", "" },
            }).ToList();

        _data.Aql.Quantity        = _inspection.AqlQuantity > 0 ? _inspection.AqlQuantity : _inspection.TotalShipmentQty;
        _data.Aql.InspectionLevel = _inspection.AqlLevel ?? "II";
        _data.Aql.CriticalAql     = NormalizeAql(_inspection.AqlCritical);
        _data.Aql.MajorAql        = NormalizeAql(_inspection.AqlMajor) is "Not Allowed" ? "2.5" : NormalizeAql(_inspection.AqlMajor);
        _data.Aql.MinorAql        = NormalizeAql(_inspection.AqlMinor) is "Not Allowed" ? "4.0" : NormalizeAql(_inspection.AqlMinor);
        RecalcAql();

        if (_inspection.PerformanceTests?.Any() == true)
        {
            _data.PerformanceTests = _inspection.PerformanceTests.Select(pt => new QcPerformanceTest
            {
                TestItem        = pt.TestItem ?? "",
                TestProtocol    = pt.TestProtocol ?? "",
                TestRequirement = pt.TestRequirement ?? "",
                Category        = pt.Category ?? "",
                Photos          = new List<string> { "", "", "", "" }
            }).ToList();
        }
        else
        {
            _data.PerformanceTests = new List<QcPerformanceTest>
            {
                new() { TestItem = "Transportation drop test",
                        TestRequirement = "No critical & major issue found on package/product after 9 times drop. Please refer to ISTA 3A drop test standard.",
                        Photos = new List<string> { "", "", "", "" } }
            };
        }

        // Sinh steps động SAU KHI đã load PerformanceTests (để BuildSteps biết đúng số bước D)
        _perfValidated = new bool[Math.Max(1, _data.PerformanceTests.Count)];
        BuildSteps();

        if (_inspection.ColourSwatches?.Any() == true)
        {
            _data.ProductSpec.ColourSwatches = _inspection.ColourSwatches
                .Select((m, i) => new QcColourSwatch { No = i + 1, Material = m }).ToList();
        }
        else
        {
            _data.ProductSpec.ColourSwatches = new List<QcColourSwatch>
            {
                new() { No = 1 }, new() { No = 2 }
            };
        }

        for (int i = _data.ProductSpec.SizeRows.Count; i < 3; i++)
            _data.ProductSpec.SizeRows.Add(new QcSizeRow());

        EnsureList(_data.Packaging.CartonSizes, 0);
        EnsurePhotoList(_data.Packaging.Photos, 3);
        EnsurePhotoList(_data.Packaging.ShippingMarkPhotos, 3);
        EnsurePhotoList(_data.Packaging.PkgLabelPhotos, 3);
        EnsurePhotoList(_data.Packaging.AssemblyPhotos, 3);
        EnsurePhotoList(_data.Packaging.HardwarePhotos, 3);
        EnsurePhotoList(_data.ProductSpec.GoldenPhotos, 3);
        EnsurePhotoList(_data.ProductSpec.SwatchPhotos, 3);
        EnsurePhotoList(_data.ProductSpec.SizePhotos, 4);
        EnsurePhotoList(_data.QuantityConformity.Photos, 3);
    }

    void EnsureList<T>(List<T> list, int minCount) where T : new()
    { while (list.Count < minCount) list.Add(new T()); }
    void EnsurePhotoList(List<string> list, int count)
    { while (list.Count < count) list.Add(""); }

    // ── Build steps động theo carton count ──
    // Step layout: [Overview][OverallConclusion][QuantityConformity][PackagingID]
    //              [B-i..B-vi × cartonCount]
    //              [C-i][C-ii][C-iii][D][E][F-Crit][F-Maj][F-Min][Final]
    const int STEP_OVERVIEW    = 0;
    const int STEP_CONCLUSION  = 1;
    const int STEP_QTY         = 2;
    const int STEP_PKG_ID      = 3;
    // B-i=4, B-ii=5, B-iii=6, B-iv=7, B-v=8, B-vi=9  (repeated × cartonCount)
    const int B_STEPS_PER_CARTON = 6; // B-i đến B-vi

    void BuildSteps()
    {
        var list = new List<StepDef>
        {
            new("", "Product Overview",       false),
            new("", "Overall Conclusion",     false),
            new("", "A. Quantity Conformity", false),
            new("", "B. Packaging & ID",      false),
        };

        for (int c = 1; c <= _cartonCount; c++)
        {
            string suffix = _cartonCount > 1 ? $" (Carton {c})" : "";
            list.Add(new("", $"B-i. Carton Size{suffix}",          true));
            list.Add(new("", $"B-ii. Shipping Mark{suffix}",       true));
            list.Add(new("", $"B-iii. Carton Weight{suffix}",      true));
            list.Add(new("", $"B-iv. Pkg & Label{suffix}",         true));
            list.Add(new("", $"B-v. Assembly{suffix}",             true));
            list.Add(new("", $"B-vi. Hardware{suffix}",            true));
        }

        list.Add(new("", "C-i. Product Size",         false));
        list.Add(new("", "C-ii. Golden Sample",       true));
        list.Add(new("", "C-iii. Colour Swatch",      true));
        // D: mỗi performance test = 1 step riêng
        for (int d = 0; d < _data.PerformanceTests.Count; d++)
        {
            var testName = _data.PerformanceTests[d].TestItem;
            var suffix = _data.PerformanceTests.Count > 1 ? $" ({d+1}/{_data.PerformanceTests.Count})" : "";
            list.Add(new("", $"D. {(string.IsNullOrEmpty(testName) ? "Performance Test" : testName)}{suffix}", true));
        }
        if (!_data.PerformanceTests.Any())
            list.Add(new("", "D. Performance Testing", true));
        list.Add(new("", "E. Appearance & AQL",       false));
        list.Add(new("", "F. Critical Defects",       true));
        list.Add(new("", "F. Major Defects",          true));
        list.Add(new("", "F. Minor Defects",          true));
        list.Add(new("", "Inspector Comments",          false));
        list.Add(new("", "Compliance & Signature",        false));

        _steps = list;
        for (int i = 0; i < _steps.Count; i++)
            _steps[i] = _steps[i] with { StepLabel = $"Step {i+1} of {_steps.Count}" };

        // Đảm bảo _perfValidated đủ kích thước
        int perfCount2 = Math.Max(1, _data.PerformanceTests.Count);
        if (_perfValidated.Length != perfCount2)
            _perfValidated = new bool[perfCount2];
    }

    // Lấy carton index hiện tại và sub-step trong B (0=B-i .. 5=B-vi)
    // Trả về (-1, -1) nếu không phải bước B
    (int cartonIdx, int bSubStep) GetCurrentCartonStep()
    {
        int idx = _currentStepIdx - (STEP_PKG_ID + 1); // offset sau B. Packaging & ID
        if (idx < 0) return (-1, -1);
        int totalBSteps = _cartonCount * B_STEPS_PER_CARTON;
        if (idx >= totalBSteps) return (-1, -1);
        return (idx / B_STEPS_PER_CARTON, idx % B_STEPS_PER_CARTON);
    }

    // ── Navigation ──
    void HandleBack()
    {
        if (_currentStepIdx > 0)
        {
            _currentStepIdx--;
            // Skip ngược lại nếu bước đó bị tắt (Compliance không phải Pass)
            while (_currentStepIdx > 1 && IsStepSkippedByCompliance(_currentStepIdx))
                _currentStepIdx--;
        }
        else GoBack();
    }
    bool _qtyValidated    = false;
    bool _sizeValidated   = false;
    bool _goldenValidated = false;
    bool _swatchValidated = false;
    bool[] _perfValidated = Array.Empty<bool>();

    void HandleNext()
    {
        // Validate Step 2 — A. Quantity Conformity
        if (_currentStepIdx == 2)
        {
            _qtyValidated = true;
            var qc = _data.QuantityConformity;
            bool hasPhoto = qc.Photos.Any(p => !string.IsNullOrEmpty(p));
            // Chỉ cần 1 trong 2 (Packed hoặc Not Packed) > 0
            bool presentedOk = (qc.PresentedPacked + qc.PresentedNotPacked) > 0;
            bool cartonsOk   = (qc.CartonsPacked   + qc.CartonsNotPacked)   > 0;
            bool fieldsOk    = presentedOk && cartonsOk;
            if (!fieldsOk || !hasPhoto)
            {
                if (!fieldsOk)
                    _saveMsg = "Please enter at least one value for Presented Qty and Number of Cartons.";
                else
                    _saveMsg = "Please take at least 1 photo.";
                _saveError = true;
                StateHasChanged();
                return;
            }
            _saveMsg = "";
            _saveError = false;
        }
        // Validate D — Performance Testing: bắt buộc tối thiểu 2 hình
        int dBase = 7 + _cartonCount * B_STEPS_PER_CARTON;
        if (_currentStepIdx >= dBase && _currentStepIdx < dBase + Math.Max(1, _data.PerformanceTests.Count))
        {
            int dIdx = _currentStepIdx - dBase;
            if (dIdx < _data.PerformanceTests.Count)
            {
                if (_perfValidated.Length > dIdx) _perfValidated[dIdx] = true;
                int perfCount = _data.PerformanceTests[dIdx].Photos.Count(p => !string.IsNullOrEmpty(p));
                if (perfCount < 2)
                {
                    _saveMsg = $"Please take at least 2 photos for: {_data.PerformanceTests[dIdx].TestItem}";
                    _saveError = true;
                    StateHasChanged();
                    return;
                }
                _saveMsg = ""; _saveError = false;
            }
        }
        // Validate C-ii — Golden Sample: bắt buộc tối thiểu 2 hình
        if (_currentStepIdx == 5 + _cartonCount * B_STEPS_PER_CARTON)
        {
            _goldenValidated = true;
            int goldenCount = _data.ProductSpec.GoldenPhotos.Count(p => !string.IsNullOrEmpty(p));
            if (goldenCount < 2)
            {
                _saveMsg = "Please take at least 2 photos for Golden Sample.";
                _saveError = true;
                StateHasChanged();
                return;
            }
            _saveMsg = ""; _saveError = false;
        }
        // Validate C-iii — Colour Swatch: bắt buộc tối thiểu 2 hình
        if (_currentStepIdx == 6 + _cartonCount * B_STEPS_PER_CARTON)
        {
            _swatchValidated = true;
            int swatchCount = _data.ProductSpec.SwatchPhotos.Count(p => !string.IsNullOrEmpty(p));
            if (swatchCount < 2)
            {
                _saveMsg = "Please take at least 2 photos for Colour Swatch.";
                _saveError = true;
                StateHasChanged();
                return;
            }
            _saveMsg = ""; _saveError = false;
        }
        // Validate C-i — Product Size: bắt buộc tối thiểu 2 hình
        if (_currentStepIdx == 4 + _cartonCount * B_STEPS_PER_CARTON)
        {
            _sizeValidated = true;
            int sizeCount = _data.ProductSpec.SizePhotos.Count(p => !string.IsNullOrEmpty(p));
            if (sizeCount < 2)
            {
                _saveMsg = "Please take at least 2 photos for Product Size.";
                _saveError = true;
                StateHasChanged();
                return;
            }
            _saveMsg = ""; _saveError = false;
        }

        // Validate Final Result — step 11 + carton*B + max(1,perf)
        int finalResultStep = 11 + _cartonCount * B_STEPS_PER_CARTON + Math.Max(1, _data.PerformanceTests.Count);
        if (_currentStepIdx == finalResultStep)
        {
            _finalValidated = true;
            if (string.IsNullOrEmpty(_data.FinalResult))
            {
                _saveMsg  = "Please select a Final Result (PASSED / FAILED / N/A).";
                _saveError = true;
                StateHasChanged();
                return;
            }
            _saveMsg = ""; _saveError = false;
        }

        // Validate Signature — step 12 + carton*B + max(1,perf)
        int sigStep = 12 + _cartonCount * B_STEPS_PER_CARTON + Math.Max(1, _data.PerformanceTests.Count);
        if (_currentStepIdx == sigStep)
        {
            _sigValidated = true;
            if (string.IsNullOrEmpty(_data.SignatureUrl))
            {
                _saveMsg  = "Please add a signature before proceeding.";
                _saveError = true;
                StateHasChanged();
                return;
            }
            _saveMsg = ""; _saveError = false;
        }

        if (_currentStepIdx < _steps.Count - 1) _currentStepIdx++;
        // Auto-skip step nếu Compliance không phải Pass
        while (_currentStepIdx < _steps.Count - 1 && IsStepSkippedByCompliance(_currentStepIdx))
            _currentStepIdx++;
        // Khi vào F step, đảm bảo có default defect cho mỗi loại
        EnsureDefaultDefects();
    }

    // Trả về true nếu step này cần bỏ qua vì Overall Conclusion của section đó không phải "Pass"
    bool IsStepSkippedByCompliance(int stepIdx)
    {
        int bEnd  = STEP_PKG_ID + _cartonCount * B_STEPS_PER_CARTON;      // last B sub-step index
        int cBase = bEnd + 1;                                               // C-i
        int dBase = cBase + 3;                                              // D start (C-i, C-ii, C-iii = 3 steps)
        int dEnd  = dBase + Math.Max(1, _data.PerformanceTests.Count) - 1; // D last step
        int eStep = dEnd + 1;                                               // E
        int fBase = eStep + 1;                                              // F (Critical/Major/Minor)

        // Lấy compliance theo Letter
        string GetCompliance(string letter) =>
            _data.OverallConclusions.FirstOrDefault(o => o.Letter == letter)?.Compliance ?? "";

        bool isPass(string letter) => GetCompliance(letter) == "Pass";

        // A — Quantity Conformity (step 2)
        if (stepIdx == STEP_QTY && !isPass("A")) return true;

        // B — Packaging steps (STEP_PKG_ID và các B sub-steps)
        if ((stepIdx == STEP_PKG_ID || (stepIdx > STEP_PKG_ID && stepIdx <= bEnd)) && !isPass("B")) return true;

        // C — Product Specification (C-i, C-ii, C-iii)
        if (stepIdx >= cBase && stepIdx <= cBase + 2 && !isPass("C")) return true;

        // D — Performance Testing
        if (stepIdx >= dBase && stepIdx <= dEnd && !isPass("D")) return true;

        // E — Appearance & Craftsmanship
        if (stepIdx == eStep && !isPass("E")) return true;

        // F — Details of Defect Found (F Critical/Major/Minor = 3 steps)
        if (stepIdx >= fBase && stepIdx <= fBase + 2 && !isPass("F")) return true;

        return false;
    }

    void EnsureDefaultDefects()
    {
        int fBase2 = 8 + _cartonCount * B_STEPS_PER_CARTON + Math.Max(1, _data.PerformanceTests.Count);
        bool isFStep = _currentStepIdx < _steps.Count - 2 &&
                      (_currentStepIdx == fBase2 || _currentStepIdx == fBase2+1 || _currentStepIdx == fBase2+2);
        if (!isFStep) return;
        foreach (var t in new[] { "Critical", "Major", "Minor" })
        {
            if (!_data.Defects.Any(d => d.Type == t))
                _data.Defects.Add(new QcDefect
                {
                    Type    = t,
                    Photos  = new List<string> { "", "" },
                    Remarks = new List<string> { "", "" }
