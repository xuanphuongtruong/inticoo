                sizePhotos     = _data.ProductSpec.SizePhotos.Where(p => !string.IsNullOrEmpty(p)).ToList(),
                goldenResult   = _data.ProductSpec.GoldenResult,
                goldenPhotos   = _data.ProductSpec.GoldenPhotos.Where(p => !string.IsNullOrEmpty(p)).ToList(),
                swatchPhotos   = _data.ProductSpec.SwatchPhotos.Where(p => !string.IsNullOrEmpty(p)).ToList(),
                sizeRows       = _data.ProductSpec.SizeRows.Select(r => new
                {
                    photoUrl = r.PhotoUrl,
                    l = r.L, w = r.W, h = r.H, note = r.Note
                }).ToList(),
                colourSwatches = _data.ProductSpec.ColourSwatches,
            },
            aql = new
            {
                quantity           = _data.Aql.Quantity,
                inspectionLevel    = _data.Aql.InspectionLevel,
                criticalAql        = _data.Aql.CriticalAql,
                majorAql           = _data.Aql.MajorAql,
                minorAql           = _data.Aql.MinorAql,
                criticalFound      = _data.Aql.CriticalFound,
                majorFound         = _data.Aql.MajorFound,
                minorFound         = _data.Aql.MinorFound,
                criticalSampleSize = _data.Aql.CriticalSampleSize,
                majorSampleSize    = _data.Aql.MajorSampleSize,
                minorSampleSize    = _data.Aql.MinorSampleSize,
                criticalAccept     = _data.Aql.CriticalAccept,
                majorAccept        = _data.Aql.MajorAccept,
                minorAccept        = _data.Aql.MinorAccept,
            },
            performanceTests = _data.PerformanceTests.Select(pt => new
            {
                testItem        = pt.TestItem,
                testRequirement = pt.TestRequirement,
                category        = pt.Category,
                testQuantity    = pt.TestQuantity,
                remark          = pt.Remark,
                result          = pt.Result,
                photos          = pt.Photos
            }).ToArray(),
            defects = _data.Defects
                .Select(d => new
                {
                    type    = d.Type,
                    photos  = d.Photos.Where(p => !string.IsNullOrEmpty(p)).ToList(),
                    remarks = d.Remarks.Take(d.Photos.Count).ToList()
                })
                .ToArray()
        };
    }

