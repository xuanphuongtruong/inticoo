            var url = await UploadPhoto(e);
            if (string.IsNullOrEmpty(url)) return;
            switch (section)
            {
                case 'A': SetPhotoInList(_data.QuantityConformity.Photos, slot, url);       break;
                case 'B': SetPhotoInList(_data.Packaging.Photos, slot, url);                break;
                case 'S': SetPhotoInList(_data.Packaging.ShippingMarkPhotos, slot, url);    break;
                case 'P': SetPhotoInList(_data.Packaging.PkgLabelPhotos, slot, url);        break;
                case 'I': SetPhotoInList(_data.Packaging.AssemblyPhotos, slot, url);        break;
                case 'H': SetPhotoInList(_data.Packaging.HardwarePhotos, slot, url);        break;
                case 'G': SetPhotoInList(_data.ProductSpec.GoldenPhotos, slot, url);        break;
                case 'C': SetPhotoInList(_data.ProductSpec.SwatchPhotos, slot, url);        break;
            }
            StateHasChanged();
        }
        catch (Exception ex) { _saveMsg = $"Lỗi ảnh: {ex.Message}"; _saveError = true; }
    }

