    async Task SaveSignature()
    {
        // Composite nền trắng lên canvas trước khi export → tránh nền đen trong PNG
        var dataUrl = await JS.InvokeAsync<string>("eval", @"
            (function(){
                var c = document.getElementById('sig-canvas');
                if(!c) return '';
                // Tạo canvas tạm với nền trắng + vẽ chữ ký lên trên
                var tmp = document.createElement('canvas');
                tmp.width  = c.width;
                tmp.height = c.height;
                var ctx = tmp.getContext('2d');
                ctx.fillStyle = '#ffffff';
                ctx.fillRect(0, 0, tmp.width, tmp.height);
                ctx.drawImage(c, 0, 0);
                return tmp.toDataURL('image/png');
            })()
        ");
        if (string.IsNullOrEmpty(dataUrl) || dataUrl == "data:," || dataUrl == "") return;

        try
        {
            // Convert base64 dataUrl → byte[] → upload lên server
            var base64 = dataUrl.Substring(dataUrl.IndexOf(',') + 1);
            var bytes   = Convert.FromBase64String(base64);
            using var ms      = new System.IO.MemoryStream(bytes);
            using var content = new MultipartFormDataContent();
            var sc = new StreamContent(ms);
            sc.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue("image/png");
            content.Add(sc, "file", $"signature_{InspectionId}.png");
            var resp = await Http.PostAsync("api/upload/photo", content);
            if (resp.IsSuccessStatusCode)
            {
                var result = await resp.Content.ReadFromJsonAsync<UploadResult>();
                _data.SignatureUrl = result?.Url ?? dataUrl;
            }
            else
            {
                _data.SignatureUrl = dataUrl;
            }
        }
        catch
        {
            _data.SignatureUrl = dataUrl;
        }
        StateHasChanged();
    }

    async Task ClearCanvas()
    {
        await JS.InvokeVoidAsync("clearCanvas", "sig-canvas");
    }

    // ── Save to API ──
    async Task SaveAndDone()
    {
        // Bắt buộc chọn Final Result
        _finalValidated = true;
        if (string.IsNullOrEmpty(_data.FinalResult))
        {
            _saveMsg = "Please select a Final Result (PASSED / FAILED / NA).";
            _saveError = true;
            StateHasChanged();
            return;
        }
        // Bắt buộc có chữ ký
        _sigValidated = true;
        if (string.IsNullOrEmpty(_data.SignatureUrl))
        {
            _saveMsg = "Please add a signature before completing.";
            _saveError = true;
            StateHasChanged();
            return;
        }
        _saving = true;
        _saveMsg = "";
        try
        {
            var payload = BuildSavePayload();
            var resp = await Http.PutAsJsonAsync($"api/inspections/{InspectionId}/qc-result", payload);
            if (resp.IsSuccessStatusCode)
            {
                // Parse response để lấy trạng thái email
                var json = await resp.Content.ReadAsStringAsync();
                var result = System.Text.Json.JsonSerializer.Deserialize<SaveQcResponse>(json,
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });

                if (result?.EmailSent == true)
                    _saveMsg = $"✅ Saved! Notification email sent to {result.EmailTo}";
                else if (!string.IsNullOrEmpty(result?.EmailError))
                    _saveMsg = $"✅ Saved! (Email not sent: {result.EmailError})";
                else
                    _saveMsg = "✅ Saved successfully!";

                _saveError = false;
                StateHasChanged();
                await Task.Delay(3000);
                Navigation.NavigateTo("/inspection-schedule");
            }
            else
            {
                _saveMsg = $"Save failed ({(int)resp.StatusCode}): {await resp.Content.ReadAsStringAsync()}";
                _saveError = true;
            }
        }
        catch (Exception ex)
        {
            _saveMsg = ex.Message;
            _saveError = true;
        }
        _saving = false;
        StateHasChanged();
    }

