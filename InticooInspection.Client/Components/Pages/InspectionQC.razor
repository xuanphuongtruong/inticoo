    // Upload ảnh cho defect slot cụ thể — đảm bảo cập nhật đúng object
    async Task UploadDefectPhoto(InputFileChangeEventArgs e, QcDefect defect, int slotIdx)
    {
        try
        {
            var url = await UploadPhoto(e);
            if (string.IsNullOrEmpty(url)) return;
            // Ensure Photo slot exists
            while (defect.Photos.Count <= slotIdx)
                defect.Photos.Add(string.Empty);
            defect.Photos[slotIdx] = url;
            // Ensure Remarks slot exists (sync with Photos)
            while (defect.Remarks.Count <= slotIdx)
                defect.Remarks.Add(string.Empty);
            // Force update reference in _data.Defects list
            var idx = _data.Defects.IndexOf(defect);
            if (idx >= 0) _data.Defects[idx] = defect;
            StateHasChanged();
        }
        catch (Exception ex) { _saveMsg = $"Photo error: {ex.Message}"; _saveError = true; }
    }

    async Task UploadDefectPhotoWithSpinner(InputFileChangeEventArgs e, QcDefect defect, int slotIdx)
    {
        var key = $"Def:{_data.Defects.IndexOf(defect)}:{slotIdx}";
        _uploadingKey = key; StateHasChanged();
        try { await UploadDefectPhoto(e, defect, slotIdx); }
        finally { _uploadingKey = ""; StateHasChanged(); }
    }

    static void SetPhotoInList(List<string> list, int slot, string url)
    {
        while (list.Count <= slot) list.Add(string.Empty);
        list[slot] = url;
    }

