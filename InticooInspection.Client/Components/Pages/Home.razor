@page "/"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using InticooInspection.Client.Services
@inject NavigationManager Navigation

<PageTitle>Dashboard - Inticoo Inspection</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Dashboard</h1>
        <p class="page-sub">Overview of your inspection activities</p>
    </div>
    <button class="btn-new" @onclick="GoToNew">
        + New Inspection
    </button>
</div>

<div class="empty-state">
    <span>🔍</span>
    <p>Welcome to Inticoo Inspection!</p>
</div>

@code {
    private void GoToNew() => Navigation.NavigateTo("/inspections/new");
}

<style>
    .page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 32px; }
    .page-title { font-family: "Sora", sans-serif; font-size: 24px; font-weight: 700; margin-bottom: 4px; }
    .page-sub { font-size: 14px; color: rgba(255,255,255,0.4); }
    .btn-new { padding: 10px 18px; background: linear-gradient(135deg, #1e90d6, #3ab4f2); border: none; border-radius: 10px; color: #fff; font-size: 14px; font-weight: 600; cursor: pointer; }
    .empty-state { display: flex; flex-direction: column; align-items: center; padding: 60px; color: rgba(255,255,255,0.4); }
    .empty-state span { font-size: 40px; margin-bottom: 16px; }
</style>