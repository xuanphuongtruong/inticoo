@page "/products"
@using System.Net.Http.Json
@using System.Net.Http.Headers
@inject HttpClient Http
@inject IJSRuntime JS
@using InticooInspection.Client.Services
@inject WaitingService Waiting

<PageTitle>Product Information - Inticoo</PageTitle>

<div class="page-container">

    <!-- ── Top bar: title + search + filter + add (single row) ── -->
    <div class="top-bar">
        <div class="title-block">
            <h1 class="page-title">Product Information</h1>
            <span class="page-sub">Manage product master data</span>
        </div>
        <div class="search-wrap">
            <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="9" cy="9" r="6"/><path d="M15 15l3 3" stroke-linecap="round"/>
            </svg>
            <input class="search-input" type="text" placeholder="Search name, code, customer, category..."
                   @bind="_search" @bind:event="oninput" @bind:after="ApplyFilter" />
        </div>
        <select class="filter-select" @bind="_filterCat" @bind:after="ApplyFilter">
            <option value="">All Categories</option>
            @foreach (var c in _categories)
            { <option value="@c.Name">@c.Name</option> }
        </select>
        <button class="btn-add" @onclick="async () => await OpenAddModal()">
            <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                <path d="M10 4v12M4 10h12"/>
            </svg>
            Add Product
        </button>
    </div>

    <!-- ── Alerts ── -->
    @if (!string.IsNullOrEmpty(_pageError))
    {
        <div class="alert-box alert-err">@_pageError <button class="alert-x" @onclick="ClearError">✕</button></div>
    }
    @if (!string.IsNullOrEmpty(_pageOk))
    {
        <div class="alert-box alert-ok">@_pageOk <button class="alert-x" @onclick="ClearOk">✕</button></div>
    }

    <!-- ── Table ── -->
    @if (_loading)
    {
        <div class="loading-wrap"><div class="spinner"></div><span>Loading...</span></div>
    }
    else
    {
        <div class="table-wrap">
            <table class="ptable">
                <thead>
                    <tr class="thead-group">
                        <th class="th-no tc">No</th>
                        <th>Product ID</th>
                        <th>Vendor Name</th>
                        <th>Vendor ID</th>
                        <th>Category</th>
                        <th>Product Name</th>
                        <th>Product Code</th>
                        <th>Establish Date</th>
                        <th class="tc">Status</th>
                        <th class="tc">Full Detail</th>
                        <th class="tc">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!_filtered.Any())
                    {
                        <tr><td colspan="11" class="td-empty">No products found.</td></tr>
                    }
                    else
                    {
                        @for (int i = 0; i < _filtered.Count; i++)
                        {
                            var item = _filtered[i];
                            <tr class="@(i % 2 == 1 ? "tr-alt" : "")">
                                <td class="tc muted">@(i + 1)</td>
                                <td class="mono">@(string.IsNullOrEmpty(item.ProductCode) ? "—" : item.ProductCode)</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.VendorName))
                                    {
                                        <div class="company-cell">
                                            <span class="company-name">@item.VendorName</span>
                                        </div>
                                    }
                                    else { <span class="muted">—</span> }
                                </td>
                                <td class="mono tc">@(string.IsNullOrEmpty(item.VendorId) ? "—" : item.VendorId)</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.Category))
                                    { <span class="cat-badge">@item.Category</span> }
                                    else { <span class="muted">—</span> }
                                </td>
                                <td class="fw">@item.ProductName</td>
                                <td class="mono">@(string.IsNullOrEmpty(item.ItemNumber) ? "—" : item.ItemNumber)</td>
                                <td class="tc muted">@(item.EstablishDate.HasValue ? item.EstablishDate.Value.ToString("dd MMM yyyy") : "—")</td>
                                <td class="tc">
                                    <span class="status-badge @(item.IsActive ? "active" : "inactive")">
                                        @(item.IsActive ? "Valid" : "Invalid")
                                    </span>
                                </td>
                                <td class="tc">
                                    <button class="action-btn view" @onclick="() => OpenDetail(item)">
                                        <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 10s3.5-6 8-6 8 6 8 6-3.5 6-8 6-8-6-8-6Z"/><circle cx="10" cy="10" r="2.5"/></svg>
                                        View
                                    </button>
                                </td>
                                <td class="tc">
                                    <div class="action-btns">
                                        <button class="bico bedit" @onclick="() => OpenEdit(item)" title="Edit">
                                            <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14 2l4 4-10 10H4v-4L14 2z" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                        </button>
                                        <button class="bico bdel" @onclick="() => AskDelete(item)" title="Delete">
                                            <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 6h14M8 6V4h4v2M5 6l1 11h8l1-11" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        <div class="tfoot">@_filtered.Count / @_all.Count record(s)</div>
    }
</div>

<!-- ═══ ADD / EDIT MODAL ═══ -->
@if (_showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-card" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2>@(_isEdit ? "Edit Product" : "New Product")</h2>
                <button class="modal-close" @onclick="CloseModal">✕</button>
            </div>

            @if (!string.IsNullOrEmpty(_mErr))
            { <div class="error-alert">@_mErr</div> }

            <!-- Product ID + Status -->
            <div class="form-grid">
                <div class="form-group">
                    <label>Product ID</label>
                    @if (_isEdit)
                    {
                        <input class="form-input" @bind="_f.ProductCode" />
                    }
                    else
                    {
                        <div class="form-input form-input-disabled" style="background:#e6f1fb;color:#1e90d6;font-weight:700;font-family:monospace;border-color:#b5d4f4;">@_f.ProductCode</div>
                    }
                </div>
                <div class="form-group">
                    <label>Status</label>
                    <div class="btype-group" style="padding-top:8px;">
                        <label class="btype-label @(_f.IsActive ? "btype-active" : "")" @onclick="() => _f.IsActive = true">Valid</label>
                        <label class="btype-label @(!_f.IsActive ? "btype-active btype-invalid" : "")" @onclick="() => _f.IsActive = false">Invalid</label>
                    </div>
                </div>
            </div>

            <!-- Customer -->
            <div class="form-section-title">Customer</div>
            <div class="form-grid">
                <div class="form-group">
                    <label>Customer ID</label>
                    <select class="form-input" @bind="_f.CustomerId" @bind:after="OnCustChanged">
                        <option value="">— Select Customer —</option>
                        @foreach (var c in _custs)
                        { <option value="@c.CustomerId">@c.CustomerId — @c.CompanyName</option> }
                    </select>
                </div>
                <div class="form-group">
                    <label>Customer Name</label>
                    <input class="form-input form-input-disabled" readonly value="@_f.CustomerName" />
                </div>
            </div>

            <!-- Vendor -->
            <div class="form-section-title">Vendor</div>
            <div class="form-grid">
                <div class="form-group">
                    <label>Vendor ID</label>
                    <select class="form-input" @bind="_f.VendorId" @bind:after="OnVendChanged">
                        <option value="">— Select Vendor —</option>
                        @foreach (var v in _vends)
                        { <option value="@v.Code">@v.Code — @v.Name</option> }
                    </select>
                </div>
                <div class="form-group">
                    <label>Vendor Name</label>
                    <input class="form-input form-input-disabled" readonly value="@_f.VendorName" />
                </div>
            </div>
            <div class="form-section-title">Product Details</div>
            <div class="form-grid">
                <div class="form-group">
                    <label>Product Category <span class="required">*</span></label>
                    <select class="form-input" @bind="_f.Category">
                        <option value="">-- Select Category --</option>
                        @foreach (var c in _categories)
                        { <option value="@c.Name">@c.Name</option> }
                    </select>
                </div>
                <div class="form-group">
                    <label>Product Name <span class="required">*</span></label>
                    <input class="form-input" @bind="_f.ProductName" placeholder="e.g. 55-inch OLED" />
                </div>
                <div class="form-group">
                    <label>Product Code</label>
                    <input class="form-input" @bind="_f.ItemNumber" placeholder="e.g. ITM-001" />
                </div>
                <div class="form-group full-width">
                    <label>Product Size (MM/Inch)</label>
                    <div class="size-grid">
                        <div class="form-group">
                            <label>L</label>
                            <input class="form-input" @bind="_f.SizeL" type="number" min="0" placeholder="0" />
                        </div>
                        <div class="form-group">
                            <label>W</label>
                            <input class="form-input" @bind="_f.SizeW" type="number" min="0" placeholder="0" />
                        </div>
                        <div class="form-group">
                            <label>H</label>
                            <input class="form-input" @bind="_f.SizeH" type="number" min="0" placeholder="0" />
                        </div>
                        <div class="form-group">
                            <label>Net Weight (KGS)</label>
                            <input class="form-input" @bind="_f.Weight" type="number" min="0" step="0.01" placeholder="0" />
                        </div>
                    </div>
                </div>
                <div class="form-group full-width">
                    <label>Remark</label>
                    <textarea class="form-input form-textarea" @bind="_f.Remark" placeholder="Optional notes..."></textarea>
                </div>
            </div>

            <!-- Reference -->
            <div class="form-section-title">Reference</div>
            <div class="ref-table">
                <div class="ref-thead">
                    <span class="ref-col-no">No</span>
                    <span class="ref-col-name">Reference</span>
                    <span class="ref-col-file">Attached File</span>
                </div>
                @for (int ri = 0; ri < _refs.Count; ri++)
                {
                    var idx = ri;
                    <div class="ref-row">
                        <span class="ref-col-no ref-num">@(idx + 1)</span>
                        <input class="form-input ref-col-name ref-input" @bind="_refs[idx].Name" placeholder="Reference name..." />
                        <div class="ref-col-file">
                            @if (_refs[idx].Uploading)
                            { <span class="ref-uploading">⏳ Uploading...</span> }
                            else if (!string.IsNullOrEmpty(_refs[idx].FileUrl))
                            { <a class="ref-fname" href="@_refs[idx].FileUrl" target="_blank" title="@_refs[idx].FileName">📎 @_refs[idx].FileName</a> }
                            else if (!string.IsNullOrEmpty(_refs[idx].FileName))
                            { <span class="ref-fname ref-err">❌ @_refs[idx].FileName</span> }
                            <label class="btn-attach">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
                                @(_refs[idx].Uploading ? "..." : "Attach File")
                                <InputFile OnChange="e => OnRefFile(e, idx)" style="display:none" disabled="@_refs[idx].Uploading" />
                            </label>
                        </div>
                    </div>
                }
                <div class="ref-addrow">
                    <button class="btn-addrow" @onclick="AddRefRow">+ Add Row</button>
                </div>
            </div>

            <!-- Product Photo -->
            <div class="form-section-title">Product Photo</div>
            <div class="photo-area-modal">
                @if (!string.IsNullOrEmpty(_prevUrl))
                {
                    <div class="prev-wrap">
                        <img src="@_prevUrl" class="prev-img" />
                        <button class="rm-photo" @onclick="RemovePhoto">✕</button>
                    </div>
                }
                <label class="upload-zone">
                    <div class="upload-label">
                        @if (_uploading)
                        {
                            <div class="spinner"></div>
                            <span class="upload-text">Uploading...</span>
                        }
                        else
                        {
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="rgba(30,144,214,0.5)" stroke-width="1.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                            <span class="upload-text">Click to upload photo</span>
                            <span class="upload-hint">JPG / PNG / WEBP · max 5 MB</span>
                        }
                    </div>
                    <InputFile OnChange="OnPhoto" accept="image/*" style="display:none" />
                </label>
            </div>

            <div class="modal-footer">
                <button class="btn-cancel" @onclick="CloseModal">Cancel</button>
                <button class="btn-save" @onclick="Save" disabled="@_saving">
                    @if (_saving) { <div class="spinner"></div> }
                    @(_isEdit ? "Update Product" : "Save Product")
                </button>
            </div>
        </div>
    </div>
}

<!-- ═══ DETAIL MODAL ═══ -->
@if (_showDetail && _detailItem != null)
{
    var d = _detailItem;
    <div class="modal-overlay" @onclick="() => _showDetail = false">
        <div class="modal-card" @onclick:stopPropagation="true">
            <div class="modal-header">
                <div>
                    <h2>@d.ProductName</h2>
                    <p style="font-size:12px;color:rgba(255,255,255,.35);margin-top:2px;">@d.ProductCode</p>
                </div>
                <button class="modal-close" @onclick="() => _showDetail = false">✕</button>
            </div>

            <!-- ID + Status -->
            <div class="form-grid" style="margin-bottom:8px;">
                <div class="form-group">
                    <label>Product ID</label>
                    <div class="form-input form-input-disabled">@(string.IsNullOrEmpty(d.ProductCode) ? "—" : d.ProductCode)</div>
                </div>
                <div class="form-group">
                    <label>Status</label>
                    <div style="padding-top:10px;">
                        <span class="status-badge @(d.IsActive ? "active" : "inactive")">
                            @(d.IsActive ? "Valid" : "Invalid")
                        </span>
                    </div>
                </div>
            </div>

            <!-- Vendor -->
            <div class="form-section-title">Vendor</div>
            <div class="form-grid">
                <div class="form-group">
                    <label>Vendor ID</label>
                    <div class="form-input form-input-disabled">@(string.IsNullOrEmpty(d.VendorId) ? "—" : d.VendorId)</div>
                </div>
                <div class="form-group">
                    <label>Vendor Name</label>
                    <div class="form-input form-input-disabled">@(string.IsNullOrEmpty(d.VendorName) ? "—" : d.VendorName)</div>
                </div>
            </div>

            <!-- Product Details -->
            <div class="form-section-title">Product Details</div>
            <div class="form-grid">
                <div class="form-group">
                    <label>Category</label>
                    <div class="form-input form-input-disabled">@(string.IsNullOrEmpty(d.Category) ? "—" : d.Category)</div>
                </div>
                <div class="form-group">
                    <label>Product Name</label>
                    <div class="form-input form-input-disabled">@d.ProductName</div>
                </div>
                <div class="form-group">
                    <label>Product Code</label>
                    <div class="form-input form-input-disabled">@(string.IsNullOrEmpty(d.ItemNumber) ? "—" : d.ItemNumber)</div>
                </div>
                <div class="form-group">
                    <label>Establish Date</label>
                    <div class="form-input form-input-disabled">@(d.EstablishDate.HasValue ? d.EstablishDate.Value.ToString("dd MMM yyyy") : "—")</div>
                </div>
                <div class="form-group full-width">
                    <label>Size (MM/Inch) &amp; Weight</label>
                    <div class="size-grid">
                        <div class="form-group">
                            <label>L</label>
                            <div class="form-input form-input-disabled">@(d.SizeL.HasValue ? d.SizeL.Value.ToString("0.##") : "—")</div>
                        </div>
                        <div class="form-group">
                            <label>W</label>
                            <div class="form-input form-input-disabled">@(d.SizeW.HasValue ? d.SizeW.Value.ToString("0.##") : "—")</div>
                        </div>
                        <div class="form-group">
                            <label>H</label>
                            <div class="form-input form-input-disabled">@(d.SizeH.HasValue ? d.SizeH.Value.ToString("0.##") : "—")</div>
                        </div>
                        <div class="form-group">
                            <label>Weight (KGS)</label>
                            <div class="form-input form-input-disabled">@(d.Weight.HasValue ? d.Weight.Value.ToString("0.###") : "—")</div>
                        </div>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(d.Remark))
                {
                    <div class="form-group full-width">
                        <label>Remark</label>
                        <div class="form-input form-input-disabled" style="min-height:50px;white-space:pre-wrap;">@d.Remark</div>
                    </div>
                }
            </div>

            @if (d.References.Any(r => !string.IsNullOrEmpty(r.Name)))
            {
                <div class="form-section-title">Reference</div>
                <div class="ref-table">
                    @foreach (var r in d.References.Where(r => !string.IsNullOrEmpty(r.Name)))
                    {
                        <div class="ref-row">
                            <span class="ref-col-no ref-num">@r.SortOrder</span>
                            <span class="ref-col-name" style="font-size:13px;color:#1a2d5a;">@r.Name</span>
                            <div class="ref-col-file">
                                @if (!string.IsNullOrEmpty(r.FileUrl))
                                {
                                    var fUrl = r.FileUrl.StartsWith("http") ? r.FileUrl : $"{Http.BaseAddress?.ToString().TrimEnd('/')}{r.FileUrl}";
                                    <a class="ref-fname" href="@fUrl" target="_blank">📎 @r.FileName</a>
                                }
                            </div>
                        </div>
                    }
                </div>
            }

            @if (!string.IsNullOrEmpty(d.PhotoUrl))
            {
                <div class="form-section-title">Product Photo</div>
                var photoUrl = d.PhotoUrl.StartsWith("http") ? d.PhotoUrl : $"{Http.BaseAddress?.ToString().TrimEnd('/')}{d.PhotoUrl}";
                <div style="text-align:center;padding:8px 0;">
                    <img src="@photoUrl" style="max-width:100%;max-height:280px;border-radius:10px;border:1px solid #dde4ef;" />
                </div>
            }

            <div class="modal-footer">
                <button class="btn-cancel" @onclick="() => _showDetail = false">Close</button>
                <button class="btn-save" @onclick="() => { _showDetail = false; OpenEdit(d); }">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    Edit
                </button>
            </div>
        </div>
    </div>
}

<!-- ═══ DELETE CONFIRM ═══ -->
@if (_showDel)
{
    <div class="modal-overlay" @onclick="() => _showDel = false">
        <div class="modal-card confirm-card" @onclick:stopPropagation="true">
            <div class="confirm-icon">🗑️</div>
            <h2>Confirm Delete</h2>
            <p>Delete <strong>@_delItem?.ProductName</strong>?</p>
            <p>This action cannot be undone.</p>
            <div class="modal-footer">
                <button class="btn-cancel" @onclick="() => _showDel = false">Cancel</button>
                <button class="btn-delete" @onclick="DoDelete" disabled="@_saving">
                    @if (_saving) { <div class="spinner"></div> } else { <span>Delete</span> }
                </button>
            </div>
        </div>
    </div>
}

<!-- ═══ PHOTO LIGHTBOX ═══ -->
@if (!string.IsNullOrEmpty(_lightbox))
{
    <div class="modal-overlay" @onclick="CloseLightbox">
        <div class="lb-box" @onclick:stopPropagation="true">
            <button class="lb-close" @onclick="CloseLightbox">✕</button>
            <img src="@_lightbox" />
        </div>
    </div>
}

@code {
    // ── Records ──────────────────────────────────────────────────────
    class CategoryItem
    {
        public int    Id   { get; set; }
        public string Name { get; set; } = "";
    }

    class PDto
    {
        public int    Id           { get; set; }
        public string CustomerId   { get; set; } = "";
        public string CustomerName { get; set; } = "";
        public string VendorId     { get; set; } = "";
        public string VendorName   { get; set; } = "";
        public string Category     { get; set; } = "";
        public string ProductType  { get; set; } = "";
        public string ProductName  { get; set; } = "";
        public string ProductCode  { get; set; } = "";
        public string  ItemNumber   { get; set; } = "";
        public string  ProductColor { get; set; } = "";
        public string  ProductSize  { get; set; } = "";
        public decimal? SizeL       { get; set; }
        public decimal? SizeW       { get; set; }
        public decimal? SizeH       { get; set; }
        public decimal? Weight      { get; set; }
        public string  PhotoUrl     { get; set; } = "";
        public string  Remark       { get; set; } = "";
        public bool    IsActive      { get; set; } = true;
        public DateTime? EstablishDate { get; set; }
        public DateTime CreatedAt   { get; set; }
        public List<PRefDto> References { get; set; } = new();
    }

    class PRefDto
    {
        public int     Id        { get; set; }
        public int     SortOrder { get; set; }
        public string  Name      { get; set; } = "";
        public string? FileUrl   { get; set; }
        public string? FileName  { get; set; }
    }

    class CustItem
    {
        public int    Id           { get; set; }
        public string CustomerId   { get; set; } = "";
        public string CompanyName  { get; set; } = "";
    }
    class VendItem
    {
        public int    Id   { get; set; }
        public string Code { get; set; } = "";
        public string Name { get; set; } = "";
    }
    class Paged<T>
    {
        public int      Total    { get; set; }
        public int      Page     { get; set; }
        public int      PageSize { get; set; }
        public List<T>  Items    { get; set; } = new();
    }
    class PhotoRes { public bool Success { get; set; } public string PhotoUrl { get; set; } = ""; }
    class SaveRes  { public bool Success { get; set; } public int    Id       { get; set; } }

    class PForm
    {
        public string CustomerId   { get; set; } = "";
        public string CustomerName { get; set; } = "";
        public string VendorId     { get; set; } = "";
        public string VendorName   { get; set; } = "";
        public string Category     { get; set; } = "";
        public string ProductType  { get; set; } = "";
        public string ProductName  { get; set; } = "";
        public string ProductCode  { get; set; } = "";
        public string ProductColor { get; set; } = "";
        public string ProductSize  { get; set; } = "";
        public decimal SizeL       { get; set; } = 0;
        public decimal SizeW       { get; set; } = 0;
        public decimal SizeH       { get; set; } = 0;
        public decimal Weight      { get; set; } = 0;
        public string ItemNumber   { get; set; } = "";
        public string PhotoUrl     { get; set; } = "";
        public string Remark       { get; set; } = "";
        public bool   IsActive      { get; set; } = true;
        public DateTime? EstablishDate { get; set; }
    }

    class RefRow
    {
        public string  Name        { get; set; } = "";
        public string  FileName    { get; set; } = "";
        public string  FileUrl     { get; set; } = "";
        public bool    Uploading   { get; set; } = false;
        public IBrowserFile? PendingFile { get; set; }
    }

    // ── State ────────────────────────────────────────────────────────
    List<PDto>     _all = new(); List<PDto> _filtered = new();
    List<CategoryItem> _categories = new();
    List<CustItem> _custs = new();
    List<VendItem> _vends = new();

    bool   _loading = true, _saving = false, _uploading = false;
    string _pageError = "", _pageOk = "", _mErr = "";
    string _search = "", _filterCat = "";
    string _lightbox = "", _prevUrl = "";
    bool   _showModal = false, _isEdit = false;
    int    _editId = 0;
    PForm  _f = new();
    List<RefRow> _refs = new() { new(), new(), new(), new(), new() };
    bool   _showDel = false;
    PDto?  _delItem = null;
    IBrowserFile? _pendingFile = null;

    // Detail view
    bool  _showDetail = false;
    PDto? _detailItem = null;
    void OpenDetail(PDto item) { _detailItem = item; _showDetail = true; }

    string GetInitials(string name)
        => string.Concat((name ?? "").Split(" ").Take(2).Select(w => w.Length > 0 ? w[0].ToString().ToUpper() : ""));

    protected override async Task OnInitializedAsync()
        => await Task.WhenAll(Load(), LoadCusts(), LoadVends(), LoadCategories());

    async Task Load()
    {
        _loading = true;
        try
        {
            var opts = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var json = await Http.GetStringAsync("api/products?pageSize=500");
            var r = System.Text.Json.JsonSerializer.Deserialize<Paged<PDto>>(json, opts);
            _all = r?.Items ?? new();
            // _categories được load riêng từ api/products/productcategories
            ApplyFilter();
        }
        catch (Exception ex) { _pageError = ex.Message; }
        finally { _loading = false; }
    }

    async Task LoadCusts()
    {
        try
        {
            var opts = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var json = await Http.GetStringAsync("api/customers?pageSize=500");
            var r = System.Text.Json.JsonSerializer.Deserialize<Paged<CustItem>>(json, opts);
            _custs = r?.Items.OrderBy(c => c.CustomerId).ToList() ?? new();
        }
        catch { }
    }

    async Task LoadVends()
    {
        try
        {
            var opts = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var json = await Http.GetStringAsync("api/vendors?pageSize=500");
            var r = System.Text.Json.JsonSerializer.Deserialize<Paged<VendItem>>(json, opts);
            _vends = r?.Items.OrderBy(v => v.Code).ToList() ?? new();
        }
        catch { }
    }

    async Task LoadCategories()
    {
        try
        {
            var opts = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var json = await Http.GetStringAsync("api/products/productcategories");
            _categories = System.Text.Json.JsonSerializer.Deserialize<List<CategoryItem>>(json, opts) ?? new();
        }
        catch { }
    }

    void ApplyFilter()
    {
        var q = _search.Trim().ToLower();
        _filtered = _all.Where(p =>
            (string.IsNullOrEmpty(q) ||
             p.ProductName.ToLower().Contains(q)  ||
             p.ProductCode.ToLower().Contains(q)  ||
             p.ItemNumber.ToLower().Contains(q)   ||
             p.CustomerName.ToLower().Contains(q) ||
             p.Category.ToLower().Contains(q)     ||
             p.ProductType.ToLower().Contains(q)) &&
            (string.IsNullOrEmpty(_filterCat) || p.Category == _filterCat)
        ).ToList();
    }

    void OnCustChanged()
    {
        var c = _custs.FirstOrDefault(x => x.CustomerId == _f.CustomerId);
        _f.CustomerName = c?.CompanyName ?? "";
    }

    void OnVendChanged()
    {
        var v = _vends.FirstOrDefault(x => x.Code == _f.VendorId);
        _f.VendorName = v?.Name ?? "";
    }

    async Task OpenAddModal()
    {
        _f = new(); _prevUrl = ""; _pendingFile = null;
        _isEdit = false; _editId = 0; _mErr = "";
        _refs = new() { new(), new(), new(), new(), new() };
        // Tự động lấy code tiếp theo từ API
        try
        {
            var opts = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var json = await Http.GetStringAsync("api/products/nextcode");
            var result = System.Text.Json.JsonSerializer.Deserialize<NextCodeResult>(json, opts);
            _f.ProductCode = result?.Code ?? "";
        }
        catch { }
        _showModal = true;
    }

    class NextCodeResult { public string Code { get; set; } = ""; }

    void OpenEdit(PDto item)
    {
        _f = new PForm
        {
            CustomerId    = item.CustomerId,   CustomerName  = item.CustomerName,
            VendorId      = item.VendorId,     VendorName    = item.VendorName,
            Category      = item.Category,     ProductType   = item.ProductType,
            ProductName   = item.ProductName,  ProductCode   = item.ProductCode,
            ProductColor  = item.ProductColor, ProductSize   = item.ProductSize,
            ItemNumber    = item.ItemNumber,
            SizeL         = (decimal)(item.SizeL   ?? 0),
            SizeW         = (decimal)(item.SizeW   ?? 0),
            SizeH         = (decimal)(item.SizeH   ?? 0),
            Weight        = (decimal)(item.Weight  ?? 0),
            PhotoUrl      = item.PhotoUrl,     Remark        = item.Remark,
            IsActive      = item.IsActive,
            EstablishDate = item.EstablishDate
        };
        // Resolve full URL cho photo preview
        if (!string.IsNullOrEmpty(item.PhotoUrl))
        {
            var baseUrl = Http.BaseAddress?.ToString().TrimEnd('/') ?? "";
            _prevUrl = item.PhotoUrl.StartsWith("http") ? item.PhotoUrl : $"{baseUrl}{item.PhotoUrl}";
        }
        else
        {
            _prevUrl = "";
        }
        _pendingFile = null;
        // Load references từ product
        var baseUrlRef = Http.BaseAddress?.ToString().TrimEnd('/') ?? "";
        _refs = item.References.Select(r => new RefRow
        {
            Name     = r.Name,
            FileName = r.FileName ?? "",
            FileUrl  = !string.IsNullOrEmpty(r.FileUrl)
                       ? (r.FileUrl.StartsWith("http") ? r.FileUrl : $"{baseUrlRef}{r.FileUrl}")
                       : ""
        }).ToList();
        // Luôn có ít nhất 5 rows
        while (_refs.Count < 5) _refs.Add(new RefRow());
        _isEdit = true; _editId = item.Id; _mErr = "";
        _showModal = true;
    }

    void CloseModal() => _showModal = false;

    void AddRefRow() => _refs.Add(new RefRow());

    async Task OnRefFile(InputFileChangeEventArgs e, int idx)
    {
        if (idx >= _refs.Count) return;
        var file = e.File;
        if (file == null) return;
        if (file.Size > 20 * 1024 * 1024) { _mErr = $"Row {idx + 1}: File must be under 20 MB."; return; }

        _refs[idx].FileName  = file.Name;
        _refs[idx].FileUrl   = "";
        _refs[idx].Uploading = true;
        StateHasChanged();

        try
        {
            using var content = new MultipartFormDataContent();
            var stream = file.OpenReadStream(20 * 1024 * 1024);
            var sc = new StreamContent(stream);
            sc.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
            content.Add(sc, "file", file.Name);

            var resp = await Http.PostAsync("api/files/upload", content);
            if (resp.IsSuccessStatusCode)
            {
                var opts = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var json = await resp.Content.ReadAsStringAsync();
                var result = System.Text.Json.JsonSerializer.Deserialize<UploadResult>(json, opts);
                _refs[idx].FileUrl = result?.Url ?? "";
            }
            else
            {
                _mErr = $"Row {idx + 1}: Upload failed.";
                _refs[idx].FileName = "";
            }
        }
        catch (Exception ex) { _mErr = ex.Message; _refs[idx].FileName = ""; }
        finally { _refs[idx].Uploading = false; StateHasChanged(); }
    }

    class UploadResult { public string Url { get; set; } = ""; public string FileName { get; set; } = ""; }

    async Task OnPhoto(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;
        if (file.Size > 5 * 1024 * 1024) { _mErr = "Image must be under 5 MB."; return; }
        var ok = new[] { "image/jpeg","image/png","image/webp","image/gif" };
        if (!ok.Contains(file.ContentType)) { _mErr = "Only JPG / PNG / WEBP allowed."; return; }
        _mErr = "";

        // Local preview
        var buf = new byte[Math.Min(file.Size, 2 * 1024 * 1024)];
        await file.OpenReadStream(5 * 1024 * 1024).ReadAsync(buf);
        _prevUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(buf)}";

        if (_isEdit && _editId > 0)
            await DoUpload(_editId, file);
        else
            _pendingFile = file;
    }

    async Task DoUpload(int id, IBrowserFile file)
    {
        _uploading = true;
        try
        {
            using var mc = new MultipartFormDataContent();
            var sc = new StreamContent(file.OpenReadStream(5 * 1024 * 1024));
            sc.Headers.ContentType = new MediaTypeHeaderValue(file.ContentType);
            mc.Add(sc, "file", file.Name);
            var resp = await Http.PostAsync($"api/products/{id}/photo", mc);
            if (resp.IsSuccessStatusCode)
            {
                var opts = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var json = await resp.Content.ReadAsStringAsync();
                var r = System.Text.Json.JsonSerializer.Deserialize<PhotoRes>(json, opts);
                _f.PhotoUrl = r?.PhotoUrl ?? "";
                _prevUrl    = _f.PhotoUrl;
            }
            else
            {
                var err = await resp.Content.ReadAsStringAsync();
                _mErr = $"Photo upload failed: {err}";
            }
        }
        catch (Exception ex) { _mErr = ex.Message; }
        finally { _uploading = false; }
    }

    void RemovePhoto() { _prevUrl = ""; _f.PhotoUrl = ""; _pendingFile = null; }

    async Task Save()
    {
        _mErr = "";
        if (string.IsNullOrWhiteSpace(_f.CustomerId))  { _mErr = "Please select a Customer."; return; }
        if (string.IsNullOrWhiteSpace(_f.Category))    { _mErr = "Category is required."; return; }
        if (string.IsNullOrWhiteSpace(_f.ProductName)) { _mErr = "Product Name is required."; return; }

        _saving = true;
        Waiting.Show(_isEdit ? "Saving product..." : "Creating product...");
        try
        {
            var refs = _refs
                .Where(r => !string.IsNullOrWhiteSpace(r.Name) || !string.IsNullOrWhiteSpace(r.FileUrl))
                .Select((r, i) => new { SortOrder = i + 1, r.Name, r.FileName, FileUrl = r.FileUrl })
                .ToList();

            var body = new {
                _f.CustomerId, _f.VendorId, _f.Category, _f.ProductType,
                _f.ProductName, _f.ProductCode, _f.ItemNumber,
                _f.ProductColor, _f.ProductSize,
                _f.SizeL, _f.SizeW, _f.SizeH, _f.Weight,
                PhotoUrl = _f.PhotoUrl, _f.Remark,
                isActive      = _f.IsActive,
                establishDate = _f.EstablishDate,
                References = refs
            };

            HttpResponseMessage resp;
            int savedId = _editId;

            if (_isEdit)
                resp = await Http.PutAsJsonAsync($"api/products/{_editId}", body);
            else
            {
                resp = await Http.PostAsJsonAsync("api/products", body);
                if (resp.IsSuccessStatusCode)
                {
                    var cr = await resp.Content.ReadFromJsonAsync<SaveRes>();
                    savedId = cr?.Id ?? 0;
                }
            }

            if (resp.IsSuccessStatusCode)
            {
                if (!_isEdit && savedId > 0 && _pendingFile != null)
                {
                    await DoUpload(savedId, _pendingFile);
                    // Update record with the photo URL returned from server
                    if (!string.IsNullOrEmpty(_f.PhotoUrl))
                    {
                        var updateBody = new {
                            _f.CustomerId, _f.VendorId, _f.Category, _f.ProductType,
                            _f.ProductName, _f.ProductCode, _f.ItemNumber,
                            _f.ProductColor, _f.ProductSize,
                            _f.SizeL, _f.SizeW, _f.SizeH, _f.Weight,
                            PhotoUrl = _f.PhotoUrl, _f.Remark,
                            isActive      = _f.IsActive,
                            establishDate = _f.EstablishDate,
                            References = refs
                        };
                        await Http.PutAsJsonAsync($"api/products/{savedId}", updateBody);
                    }
                }

                _pendingFile = null;
                _showModal   = false;
                _pageOk      = _isEdit ? "Product updated." : "Product added.";
                await Load();
            }
            else
            {
                var e = await resp.Content.ReadAsStringAsync();
                _mErr = $"Error: {e}";
            }
        }
        catch (Exception ex) { _mErr = ex.Message; }
        finally { _saving = false; Waiting.Hide(); }
    }

    void ClearError()    => _pageError = "";
    void ClearOk()       => _pageOk    = "";
    void CloseLightbox() => _lightbox  = "";

    void AskDelete(PDto item) { _delItem = item; _showDel = true; }

    async Task DoDelete()
    {
        if (_delItem == null) return;
        _saving = true;
        Waiting.Show("Deleting product...");
        try
        {
            var resp = await Http.DeleteAsync($"api/products/{_delItem.Id}");
            _showDel = false;
            if (resp.IsSuccessStatusCode) { _pageOk = $"'{_delItem.ProductName}' deleted."; await Load(); }
            else _pageError = "Delete failed.";
        }
        catch (Exception ex) { _pageError = ex.Message; }
        finally { _saving = false; Waiting.Hide(); }
    }
}

