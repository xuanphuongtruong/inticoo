@page "/suppliers"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using System.Net.Http.Json
@using System.Net.Http.Headers
@inject HttpClient Http
@inject Blazored.SessionStorage.ISessionStorageService SessionStorage
@using InticooInspection.Client.Services
@inject WaitingService Waiting

<PageTitle>Vendors - Inticoo</PageTitle>

<div class="top-bar">
    <div class="title-block">
        <h1 class="page-title">Vendors</h1>
        <span class="page-sub">Manage supplier and vendor information</span>
    </div>
    <div class="tb-divider"></div>
    <div class="search-wrap">
        <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="9" cy="9" r="5.5"/><path d="M15 15l-2.5-2.5" stroke-linecap="round"/>
        </svg>
        <input class="search-input" type="text" placeholder="Search by code, name, tax code, contact..."
               @bind="_search" @bind:event="oninput" @onkeyup="OnSearchKey" />
    </div>
    <select class="filter-select" @bind="_filterType" @bind:after="() => LoadPage(1)">
        <option value="">All Types</option>
        <option value="Material">Material</option>
        <option value="Accessory">Accessory</option>
        <option value="Service">Service</option>
        <option value="Logistics">Logistics</option>
        <option value="Manufacturing">Manufacturing</option>
    </select>
    <select class="filter-select" @bind="_filterStatus" @bind:after="() => LoadPage(1)">
        <option value="">All Status</option>
        <option value="Active">Active</option>
        <option value="Inactive">Inactive</option>
        <option value="Suspended">Suspended</option>
    </select>
    <span class="total-count">@_total vendors</span>
    <AuthorizeView Roles="Admin">
        <button class="btn-new" @onclick="async () => await OpenCreate()">
            <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M10 4v12M4 10h12"/></svg>
            New Vendor
        </button>
    </AuthorizeView>
</div>

@if (_loading)
{
    <div class="loading-wrap"><div class="spinner"></div><span>Loading...</span></div>
}
else if (_vendors.Count == 0)
{
    <div class="empty-state">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1.5">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        <p>No vendors found.</p>
    </div>
}
else
{
    <div class="table-wrap">
        <table class="ptable">
            <thead>
                <tr class="thead-group">
                    <th rowspan="2" class="tc th-no">No</th>
                    <th rowspan="2">Vendor Name</th>
                    <th rowspan="2" class="tc">Vendor ID</th>
                    <th rowspan="2">Category</th>
                    <th colspan="3" class="th-grp">Vendor Address</th>
                    <th colspan="3" class="th-grp">Contact Information</th>
                    <th rowspan="2" class="tc">Factory Evaluetion</th>
                    <th rowspan="2" class="tc">Files</th>
                    <th rowspan="2" class="tc">Status</th>
                    <th rowspan="2" class="tc">Full Detail</th>
                    <th rowspan="2" class="tc">Action</th>
                </tr>
                <tr class="thead-sub">
                    <th>City</th>
                    <th>States / Province</th>
                    <th>Country</th>
                    <th>Contact Name</th>
                    <th>Position</th>
                    <th>Mobile</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var v in _vendors)
                {
                    var item = v;
                    var rowNo = (_page - 1) * _pageSize + _vendors.IndexOf(v) + 1;
                    <tr class="@(rowNo % 2 == 0 ? "table-row tr-alt" : "table-row")">
                        <td class="tc muted">@rowNo</td>
                        <td>
                            <div class="vendor-cell">
                                <div class="vendor-avatar">@GetInitials(item.Name)</div>
                                <div>
                                    <div class="vendor-name">@item.Name</div>
                                    @if (!string.IsNullOrEmpty(item.ShortName))
                                    { <div class="vendor-short">@item.ShortName</div> }
                                </div>
                            </div>
                        </td>
                        <td class="tc"><span class="code-badge">@item.Code</span></td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.Category))
                            { <span class="cat-badge">@item.Category</span> }
                            else { <span class="muted">-</span> }
                        </td>
                        <td class="muted small-td">@(string.IsNullOrEmpty(item.City)    ? "-" : item.City)</td>
                        <td class="muted small-td">@(string.IsNullOrEmpty(item.State)   ? "-" : item.State)</td>
                        <td class="muted small-td">@(string.IsNullOrEmpty(item.Country) ? "-" : item.Country)</td>
                        <td class="small-td">@(string.IsNullOrEmpty(item.ContactName)  ? "-" : item.ContactName)</td>
                        <td class="muted small-td">@(string.IsNullOrEmpty(item.ContactTitle) ? "-" : item.ContactTitle)</td>
                        <td class="mono small-td">@(string.IsNullOrEmpty(item.ContactPhone)  ? "-" : item.ContactPhone)</td>
                        <td class="tc">
                            @if (item.FactoryEvalFileCount > 0)
                            {
                                <span class="file-count-badge file-count-btn fe-badge"
                                      @onclick="async (e) => await ToggleFePopup(e, item)"
                                      @onclick:stopPropagation="true">
                                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                                    @item.FactoryEvalFileCount
                                </span>
                            }
                            else { <span class="muted">—</span> }
                        </td>
                        <td class="tc">
                            @if (item.Attachments.Count > 0)
                            {
                                <span class="file-count-badge file-count-btn"
                                      @onclick="(e) => ToggleFilePopup(e, item)"
                                      @onclick:stopPropagation="true">
                                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                                    @item.Attachments.Count
                                </span>
                            }
                            else
                            {
                                <label class="upload-inline-btn" title="Upload file">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                                    Upload
                                    <InputFile OnChange="(e) => HandleInlineUpload(e, item)" style="display:none" accept=".pdf,.jpg,.jpeg,.png" multiple />
                                </label>
                            }
                        </td>
                        <td class="tc">
                            <span class="status-badge status-@GetStatusCss(item.Status)">@GetStatusLabel(item.Status)</span>
                        </td>
                        <td class="tc">
                            <button class="action-btn view" @onclick="() => OpenDetail(item)">
                                <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 10s3.5-6 8-6 8 6 8 6-3.5 6-8 6-8-6-8-6Z"/><circle cx="10" cy="10" r="2.5"/></svg>
                                View
                            </button>
                        </td>
                        <td class="tc">
                            <div class="action-btns">
                                <AuthorizeView Roles="Admin">
                                    <button class="bico bedit" @onclick="async () => await OpenEdit(item)">
                                            <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14 2l4 4-10 10H4v-4L14 2z" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
                                    <button class="bico bdel" @onclick="() => ConfirmDelete(item)"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 6h14M8 6V4h4v2M5 6l1 11h8l1-11" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
                                </AuthorizeView>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (_total > _pageSize)
    {
        <div class="pagination">
            <button class="page-btn" disabled="@(_page == 1)" @onclick="PrevPage">&#8592; Prev</button>
            <span class="page-info">Page @_page of @TotalPages()</span>
            <button class="page-btn" disabled="@(_page >= TotalPages())" @onclick="NextPage">Next &#8594;</button>
        </div>
    }
}

<!-- File popup -->
@if (_filePopupVendor != null)
{
    <div class="fp-backdrop" @onclick="CloseFilePopup"></div>
    <div class="fp-popup" style="top:@(_filePopupY)px;left:@(_filePopupX)px" @onclick:stopPropagation="true">
        <div class="fp-header">
            <span class="fp-title">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                @_filePopupVendor.Attachments.Count file(s) — @_filePopupVendor.Name
            </span>
            <button class="fp-close" @onclick="CloseFilePopup">&#x2715;</button>
        </div>
        <div class="fp-list">
            @foreach (var att in _filePopupVendor.Attachments)
            {
                <div class="fp-item">
                    <div class="fp-icon">@((MarkupString)GetFileIconSvg(att.ContentType))</div>
                    <div class="fp-info">
                        <span class="fp-name">@att.OriginalName</span>
                        <span class="fp-meta">@FormatFileSize(att.FileSize) · @att.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="fp-actions">
                        @if (att.ContentType.StartsWith("image/") || att.ContentType == "application/pdf")
                        {
                            <a href="@att.DownloadUrl" target="_blank" class="fp-btn fp-btn-view" title="View">
                                <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 10s3.5-6 8-6 8 6 8 6-3.5 6-8 6-8-6-8-6Z"/><circle cx="10" cy="10" r="2.5"/></svg>
                                View
                            </a>
                        }
                        <a href="@att.DownloadUrl" download="@att.OriginalName" class="fp-btn fp-btn-dl" title="Download">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                            Download
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
}

<!-- Factory Eval File Popup -->
@if (_fePopupVendor != null)
{
    <div class="fp-backdrop" @onclick="CloseFePopup"></div>
    <div class="fp-popup" style="top:@(_fePopupY)px;left:@(_fePopupX)px;width:420px;" @onclick:stopPropagation="true">
        <div class="fp-header">
            <span class="fp-title">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                Factory Eval — @_fePopupVendor.Name
            </span>
            <button class="fp-close" @onclick="CloseFePopup">&#x2715;</button>
        </div>
        @if (_fePopupLoading)
        {
            <div style="padding:20px;text-align:center;"><div class="spinner"></div></div>
        }
        else
        {
            <div class="fp-list">
                @foreach (var f in _fePopupFiles)
                {
                    <div class="fp-item">
                        <div class="fp-icon">@((MarkupString)GetFileIconSvg(f.ContentType))</div>
                        <div class="fp-info">
                            <span class="fp-name">@f.OriginalName</span>
                            <span class="fp-meta">@FormatFileSize(f.FileSize) · @f.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy")</span>
                        </div>
                        <div class="fp-actions">
                            @if (f.ContentType.StartsWith("image/") || f.ContentType == "application/pdf")
                            {
                                <a href="@f.DownloadUrl" target="_blank" class="fp-btn fp-btn-view">
                                    <svg width="12" height="12" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 10s3.5-6 8-6 8 6 8 6-3.5 6-8 6-8-6-8-6Z"/><circle cx="10" cy="10" r="2.5"/></svg>
                                    View
                                </a>
                            }
                            <a href="@f.DownloadUrl" download="@f.OriginalName" class="fp-btn fp-btn-dl">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                                Download
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}

<!-- ═══════════════════ Modal Create / Edit ═══════════════════ -->
@if (_showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-card modal-lg" @onclick:stopPropagation="true">
            <div class="modal-header">
                <div>
                    <h2>@(_editId == null ? "New Vendor" : "Edit Vendor")</h2>
                    @if (_editId != null)
                    { <span style="font-size:12px;color:rgba(255,255,255,0.3);margin-top:2px;display:block;">@_f.Code</span> }
                </div>
                <button class="modal-close" @onclick="CloseModal">&#x2715;</button>
            </div>

            @if (!string.IsNullOrEmpty(_formError))
            { <div class="error-alert">@_formError</div> }

            <!-- Vendor ID + Status -->
            <div class="fg-row">
                <div class="fg fg-1">
                    <label>Vendor ID</label>
                    <input class="form-input input-readonly" type="text" @bind="_f.Code" readonly="true" />
                </div>
                <div class="fg fg-1">
                    <label>Status</label>
                    <select class="form-input" @bind="_f.Status">
                        <option value="0">Active</option>
                        <option value="1">Inactive</option>
                        <option value="2">Suspended</option>
                    </select>
                </div>
            </div>

            <!-- Vendor Profile -->
            <div class="section-title">Vendor Profile</div>
            <div class="fg-row">
                <div class="fg fg-2">
                    <label>Vendor Name <span class="required">*</span></label>
                    <input class="form-input" type="text" placeholder="Full company name" @bind="_f.Name" @bind:event="oninput" />
                </div>
                <div class="fg fg-1">
                    <label>Short Name</label>
                    <input class="form-input" type="text" placeholder="Abbreviation" @bind="_f.ShortName" @bind:event="oninput" />
                </div>
                <div class="fg fg-3" style="grid-column:span 3;">
                    <label>Product Category <span style="font-size:11px;color:#9baac8;font-weight:400;">(chọn nhiều)</span></label>
                    <div class="cat-check-list">
                        @foreach (var _catOpt in new[] {
                            "Furniture","Outdoor Furniture","Indoor Furniture","Office Furniture",
                            "Lighting","Home Decor","Electronics","Toys & Games",
                            "Clothing & Apparel","Footwear","Bags & Luggage","Kitchenware",
                            "Sportswear","Hardware & Tools","Other"
                        })
                        {
                            var catVal = _catOpt;
                            var isChecked = _formCategories.Contains(catVal);
                            <label class="cat-check-item @(isChecked ? "cat-check-active" : "")">
                                <input type="checkbox" checked="@isChecked" @onchange="() => ToggleVendorCategory(catVal)" />
                                @catVal
                            </label>
                        }
                    </div>
                    @if (_formCategories.Count > 0)
                    {
                        <div style="margin-top:6px;display:flex;flex-wrap:wrap;gap:4px;">
                            @foreach (var _c in _formCategories.ToList())
                            {
                                var _cv = _c;
                                <span class="cat-badge" style="cursor:pointer;" @onclick="() => { _formCategories.Remove(_cv); StateHasChanged(); }">@_cv ✕</span>
                            }
                        </div>
                    }
                </div>
                <div class="fg fg-1">
                    <label>Tax Code</label>
                    <input class="form-input" type="text" placeholder="Tax code" @bind="_f.TaxCode" @bind:event="oninput" />
                </div>
                <div class="fg fg-1">
                    <label>Business Ref. No.</label>
                    <input class="form-input" type="text" placeholder="Business Reg. No." @bind="_f.BusinessRegNo" @bind:event="oninput" />
                </div>
                <div class="fg fg-1">
                    <label>Phone</label>
                    <input class="form-input" type="text" placeholder="Company main phone" @bind="_f.Phone" @bind:event="oninput" />
                </div>
                <div class="fg fg-1">
                    <label>Website</label>
                    <input class="form-input" type="text" placeholder="https://example.com" @bind="_f.Website" @bind:event="oninput" />
                </div>
            </div>

            <!-- Vendor Address -->
            <div class="section-title">Vendor Address</div>
            <div class="fg-row">
                <div class="fg fg-3">
                    <label>Address 1</label>
                    <input class="form-input" type="text" placeholder="Street address line 1" @bind="_f.Address1" @bind:event="oninput" />
                </div>
                <div class="fg fg-3">
                    <label>Address 2</label>
                    <input class="form-input" type="text" placeholder="Street address line 2 (optional)" @bind="_f.Address2" @bind:event="oninput" />
                </div>
                <div class="fg fg-1">
                    <label>City</label>
                    <input class="form-input" type="text" placeholder="Enter city" @bind="_f.City" @bind:event="oninput" />
                </div>
                <div class="fg fg-1">
                    <label>State / Province</label>
                    <input class="form-input" type="text" placeholder="State or province" @bind="_f.State" @bind:event="oninput" />
                </div>
                <div class="fg fg-1">
                    <label>Country</label>
                    @if (_loadingCountries)
                    {
                        <div class="form-input" style="color:#9baac8;font-style:italic;">Loading...</div>
                    }
                    else
                    {
                        <select class="form-input" @bind="_f.Country">
                            <option value="">-- Select Country --</option>
                            @foreach (var c in _countries)
                            {
                                <option value="@c.Name">@c.Name</option>
                            }
                        </select>
                    }
                </div>
                <div class="fg fg-1">
                    <label>Postal / ZIP</label>
                    <input class="form-input" type="text" placeholder="Postal code" @bind="_f.PostalCode" @bind:event="oninput" />
                </div>
            </div>

            <!-- Contact Information -->
            <div class="section-title">Contact Information</div>
            <div class="fg-row">
                <div class="fg fg-2">
                    <label>Contact Name</label>
                    <input class="form-input" type="text" placeholder="Full name" @bind="_f.ContactName" @bind:event="oninput" />
                </div>
                <div class="fg fg-1">
                    <label>Title / Position</label>
                    <input class="form-input" type="text" placeholder="e.g. Sales Manager" @bind="_f.ContactTitle" @bind:event="oninput" />
                </div>
                <div class="fg fg-1">
                    <label>Mobile</label>
                    <input class="form-input" type="text" placeholder="Mobile number" @bind="_f.ContactPhone" @bind:event="oninput" />
                </div>
                <div class="fg fg-2">
                    <label>Email</label>
                    <input class="form-input" type="email" placeholder="Email address" @bind="_f.ContactEmail" @bind:event="oninput" />
                </div>
            </div>

            <!-- Remark -->
            <div class="section-title">Remark</div>
            <div class="fg-row">
                <div class="fg fg-3">
                    <textarea class="form-input" rows="3" placeholder="Additional notes..." @bind="_f.Notes" @bind:event="oninput"></textarea>
                </div>
            </div>

            <!-- Factory Evaluation -->
            <div class="section-title">Factory Evaluation</div>
            <div class="fg-row">
                <div class="fg fg-3">
                    <label>Evaluation Notes</label>
                    <textarea class="form-input" rows="3" placeholder="Factory evaluation summary, audit findings..." @bind="_f.FactoryEvaluationNotes" @bind:event="oninput"></textarea>
                </div>
            </div>
            @{ int totalFe = _factoryEvalFiles.Count + _pendingFactoryFiles.Count; }
            @if (totalFe > 0)
            {
                <div class="section-subtitle">
                    Factory Evaluation Files
                    <span class="att-count-label">@totalFe file(s)</span>
                </div>
            }
            @if (_factoryEvalFiles.Count > 0)
            {
                <div class="att-list">
                    @foreach (var fa in _factoryEvalFiles)
                    {
                        var _fa = fa;
                        <div class="att-item">
                            <div class="att-icon">@((MarkupString)GetFileIconSvg(_fa.ContentType))</div>
                            <div class="att-info">
                                <a href="@_fa.DownloadUrl" target="_blank" class="att-name">@_fa.OriginalName</a>
                                <span class="att-meta">@FormatFileSize(_fa.FileSize) · @_fa.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                            <a href="@_fa.DownloadUrl" target="_blank" class="att-action-btn att-download" title="Download">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                            </a>
                            <button class="att-action-btn att-delete" @onclick="() => DeleteFactoryEvalFile(_fa)" disabled="@_uploadLoading">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                            </button>
                        </div>
                    }
                </div>
            }
            @if (_pendingFactoryFiles.Count > 0)
            {
                <div class="att-list">
                    @foreach (var pf in _pendingFactoryFiles)
                    {
                        var _pf = pf;
                        <div class="att-item att-pending">
                            <div class="att-icon">@((MarkupString)GetFileIconSvgByName(_pf.Name))</div>
                            <div class="att-info">
                                <span class="att-name" style="color:rgba(255,255,255,0.75);cursor:default">@_pf.Name</span>
                                <span class="att-meta">@FormatFileSize(_pf.Size) &nbsp;·&nbsp; <span class="pending-badge">Pending</span></span>
                            </div>
                            <button class="att-action-btn att-delete" @onclick="() => _pendingFactoryFiles.Remove(_pf)">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                            </button>
                        </div>
                    }
                </div>
            }
            <div class="upload-zone @(_isDragOverFe ? "drag-over" : "")"
                 @ondragover:preventDefault="true"
                 @ondragenter="() => _isDragOverFe = true"
                 @ondragleave="() => _isDragOverFe = false"
                 @ondrop="HandleDropFe">
                <div class="upload-zone-inner">
                    <div class="upload-icon-wrap">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                    </div>
                    <div class="upload-text">
                        Drag &amp; drop factory evaluation files, or
                        <label class="browse-link">
                            choose files
                            <InputFile OnChange="HandleFactoryEvalUpload" style="display:none" accept=".pdf,.jpg,.jpeg,.png,.xlsx,.docx" multiple disabled="@_uploadLoading" />
                        </label>
                    </div>
                    <span class="upload-hint">PDF, JPG, PNG, XLSX, DOCX &nbsp;·&nbsp; Max 20 MB / file</span>
                </div>
            </div>

            <!-- Reference (Attachments) -->
            <div class="section-title">
                Reference
                @{ int totalAtt = _attachments.Count + _pendingFiles.Count; }
                @if (totalAtt > 0)
                { <span class="att-count-label">@totalAtt file(s)</span> }
            </div>

            @if (_attachments.Count > 0)
            {
                <div class="att-list">
                    @foreach (var att in _attachments)
                    {
                        var a = att;
                        <div class="att-item">
                            <div class="att-icon">@((MarkupString)GetFileIconSvg(a.ContentType))</div>
                            <div class="att-info">
                                <a href="@a.DownloadUrl" target="_blank" class="att-name">@a.OriginalName</a>
                                <span class="att-meta">@FormatFileSize(a.FileSize) · @a.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                            <a href="@a.DownloadUrl" target="_blank" class="att-action-btn att-download" title="Download">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                            </a>
                            <button class="att-action-btn att-delete" @onclick="() => DeleteAttachment(a)" disabled="@_uploadLoading">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                            </button>
                        </div>
                    }
                </div>
            }
            @if (_pendingFiles.Count > 0)
            {
                <div class="att-list">
                    @foreach (var pf in _pendingFiles)
                    {
                        var p = pf;
                        <div class="att-item att-pending">
                            <div class="att-icon">@((MarkupString)GetFileIconSvgByName(p.Name))</div>
                            <div class="att-info">
                                <span class="att-name" style="color:rgba(255,255,255,0.75);cursor:default">@p.Name</span>
                                <span class="att-meta">@FormatFileSize(p.Size) &nbsp;·&nbsp; <span class="pending-badge">Pending</span></span>
                            </div>
                            <button class="att-action-btn att-delete" @onclick="() => RemovePendingFile(p)">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                            </button>
                        </div>
                    }
                </div>
            }

            <div class="upload-zone @(_isDragOver ? "drag-over" : "")"
                 @ondragover:preventDefault="true"
                 @ondragenter="() => _isDragOver = true"
                 @ondragleave="() => _isDragOver = false"
                 @ondrop="HandleDrop">
                @if (_uploadLoading)
                {
                    <div class="upload-zone-inner">
                        <div class="spinner" style="width:24px;height:24px;border-width:3px;"></div>
                        <span>Uploading @_uploadingCount file(s)...</span>
                    </div>
                }
                else
                {
                    <div class="upload-zone-inner">
                        <div class="upload-icon-wrap">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                        </div>
                        <div class="upload-text">
                            Drag &amp; drop files here, or
                            <label class="browse-link">
                                choose files
                                <InputFile OnChange="HandleFileUpload" style="display:none" accept=".pdf,.jpg,.jpeg,.png" multiple disabled="@_uploadLoading" />
                            </label>
                        </div>
                        <span class="upload-hint">PDF, JPG, PNG &nbsp;·&nbsp; Max 10 MB / file</span>
                    </div>
                }
            </div>

            @if (!string.IsNullOrEmpty(_uploadError))
            { <div class="error-alert" style="margin-top:8px">@_uploadError</div> }

            <div class="modal-footer">
                <button class="btn-cancel" @onclick="CloseModal">Cancel</button>
                <button class="btn-submit" @onclick="SaveVendor" disabled="@_saving">
                    @if (_saving)
                    {
                        <span class="spinner"></span>
                        <span>@(_editId == null && _pendingFiles.Count > 0 ? "Creating & Uploading..." : "Saving...")</span>
                    }
                    else
                    {
                        <span>@(_editId == null ? "Create Vendor" : "Save Changes")</span>
                        @if (_editId == null && _pendingFiles.Count > 0)
                        { <span class="btn-file-hint">+ @_pendingFiles.Count file(s)</span> }
                    }
                </button>
            </div>
        </div>
    </div>
}

<!-- Detail Modal -->
@if (_detailItem != null)
{
    var d = _detailItem;
    <div class="modal-overlay" @onclick="() => _detailItem = null">
        <div class="modal-card modal-lg" @onclick:stopPropagation="true">
            <div class="modal-header">
                <div>
                    <h2>@d.Name</h2>
                    <span class="code-badge" style="margin-top:4px;display:inline-block;">@d.Code</span>
                </div>
                <button class="modal-close" @onclick="() => _detailItem = null">&#x2715;</button>
            </div>
            <div class="detail-grid">
                <!-- Vendor Profile -->
                <div class="detail-section">
                    <div class="detail-section-title">Vendor Profile</div>
                    <div class="detail-row"><span>Short Name</span><span>@(d.ShortName ?? "-")</span></div>
                    <div class="detail-row"><span>Status</span><span class="status-badge status-@GetStatusCss(d.Status)">@GetStatusLabel(d.Status)</span></div>
                    <div class="detail-row"><span>Category</span><span>@(d.Category ?? "-")</span></div>
                    <div class="detail-row"><span>Tax Code</span><span class="mono">@(d.TaxCode ?? "-")</span></div>
                    <div class="detail-row"><span>Business Ref.</span><span class="mono">@(d.BusinessRegNo ?? "-")</span></div>
                    <div class="detail-row"><span>Phone</span><span class="mono">@(d.Phone ?? "-")</span></div>
                    <div class="detail-row"><span>Website</span>
                        @if (!string.IsNullOrEmpty(d.Website))
                        { <a href="@d.Website" target="_blank" class="detail-link">@d.Website</a> }
                        else { <span>-</span> }
                    </div>
                </div>
                <!-- Vendor Address -->
                <div class="detail-section">
                    <div class="detail-section-title">Vendor Address</div>
                    <div class="detail-row"><span>Address 1</span><span>@(d.Address1 ?? "-")</span></div>
                    <div class="detail-row"><span>Address 2</span><span>@(d.Address2 ?? "-")</span></div>
                    <div class="detail-row"><span>City</span><span>@(d.City ?? "-")</span></div>
                    <div class="detail-row"><span>State / Province</span><span>@(d.State ?? "-")</span></div>
                    <div class="detail-row"><span>Country</span><span>@(d.Country ?? "-")</span></div>
                    <div class="detail-row"><span>Postal / ZIP</span><span>@(d.PostalCode ?? "-")</span></div>
                </div>
                <!-- Contact Information -->
                <div class="detail-section">
                    <div class="detail-section-title">Contact Information</div>
                    <div class="detail-row"><span>Contact Name</span><span>@(d.ContactName ?? "-")</span></div>
                    <div class="detail-row"><span>Title / Position</span><span>@(d.ContactTitle ?? "-")</span></div>
                    <div class="detail-row"><span>Mobile</span><span class="mono">@(d.ContactPhone ?? "-")</span></div>
                    <div class="detail-row"><span>Email</span>
                        @if (!string.IsNullOrEmpty(d.ContactEmail))
                        { <a href="mailto:@d.ContactEmail" class="detail-link">@d.ContactEmail</a> }
                        else { <span>-</span> }
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(d.Notes))
                {
                    <div class="detail-section col-2">
                        <div class="detail-section-title">Remark</div>
                        <p class="detail-notes">@d.Notes</p>
                    </div>
                }
                @if (d.Attachments.Count > 0)
                {
                    <div class="detail-section col-2">
                        <div class="detail-section-title">Reference (@d.Attachments.Count file(s))</div>
                        <div class="att-list">
                            @foreach (var att in d.Attachments)
                            {
                                <div class="att-item">
                                    <div class="att-icon">@((MarkupString)GetFileIconSvg(att.ContentType))</div>
                                    <div class="att-info">
                                        <a href="@att.DownloadUrl" target="_blank" class="att-name">@att.OriginalName</a>
                                        <span class="att-meta">@FormatFileSize(att.FileSize) · @att.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                    </div>
                                    <a href="@att.DownloadUrl" target="_blank" class="att-action-btn att-download">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" @onclick="() => _detailItem = null">Close</button>
                <AuthorizeView Roles="Admin">
                    <button class="btn-submit" @onclick="async () => { _detailItem = null; await OpenEdit(d); }">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                        Edit
                    </button>
                </AuthorizeView>
            </div>
        </div>
    </div>
}

<!-- Confirm Delete -->
@if (_deleteItem != null)
{
    <div class="modal-overlay" @onclick="() => _deleteItem = null">
        <div class="modal-card confirm-card" @onclick:stopPropagation="true">
            <div class="confirm-icon">&#9888;</div>
            <h2>Delete Vendor</h2>
            <p>Are you sure you want to delete <strong>@_deleteItem.Name</strong>?<br/>This action cannot be undone.</p>
            <div class="modal-footer">
                <button class="btn-cancel" @onclick="() => _deleteItem = null">Cancel</button>
                <button class="btn-delete" @onclick="DeleteVendor" disabled="@_saving">
                    @if (_saving) { <span class="spinner"></span> } else { <span>Delete</span> }
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<VendorDto> _vendors = new();
    private bool   _loading = true;
    private string _search = "", _filterType = "", _filterStatus = "";
    private int    _page = 1, _pageSize = 20, _total = 0;

    private bool   _showModal = false;
    private int?   _editId   = null;
    private VendorForm _f    = new();
    private string _formError = "";

    // Country/City dropdowns
    private List<CountryItem> _countries      = new();
    private bool              _loadingCountries = true;
    private bool   _saving   = false;

    private List<AttachmentDto> _attachments  = new();  // saved on server
    private List<PendingFile>   _pendingFiles = new();  // in-memory, not yet uploaded

    private List<AttachmentDto> _factoryEvalFiles   = new();
    private List<PendingFile>   _pendingFactoryFiles = new();
    private bool   _isDragOverFe = false;

    // Multi-select categories
    private List<string> _formCategories = new();

    private bool   _uploadLoading  = false;
    private int    _uploadingCount = 0;
    private string _uploadError    = "";
    private bool   _isDragOver     = false;

    private VendorDto? _detailItem  = null;
    private VendorDto? _deleteItem  = null;

    // File popup
    private VendorDto? _filePopupVendor = null;
    private double _filePopupX = 0, _filePopupY = 0;

    // Factory Eval popup
    private VendorDto? _fePopupVendor  = null;
    private double     _fePopupX = 0, _fePopupY = 0;
    private bool       _fePopupLoading = false;
    private List<AttachmentDto> _fePopupFiles = new();

    private void ToggleFilePopup(MouseEventArgs e, VendorDto vendor)
    {
        if (_filePopupVendor?.Id == vendor.Id) { _filePopupVendor = null; return; }
        _filePopupVendor = vendor;
        // Position popup near the click, keep within viewport roughly
        _filePopupX = Math.Max(10, e.ClientX - 280);
        _filePopupY = e.ClientY + 12;
    }

    private void CloseFilePopup() => _filePopupVendor = null;

    private async Task ToggleFePopup(MouseEventArgs e, VendorDto vendor)
    {
        if (_fePopupVendor?.Id == vendor.Id) { _fePopupVendor = null; return; }
        _fePopupVendor  = vendor;
        _fePopupX       = Math.Max(10, e.ClientX - 340);
        _fePopupY       = e.ClientY + 12;
        _fePopupFiles   = new();
        _fePopupLoading = true;
        try
        {
            var list = await Http.GetFromJsonAsync<List<AttachmentDto>>($"api/vendors/{vendor.Id}/factory-eval/files");
            _fePopupFiles = list ?? new();
        }
        catch { }
        finally { _fePopupLoading = false; }
    }

    private void CloseFePopup() => _fePopupVendor = null;

    protected override async Task OnInitializedAsync()
    {
        await SetAuthHeader();
        await Task.WhenAll(LoadPage(1), LoadCountries());
    }

    private async Task LoadCountries()
    {
        try
        {
            var opts = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var json = await Http.GetStringAsync("api/geo/countries");
            _countries = System.Text.Json.JsonSerializer.Deserialize<List<CountryItem>>(json, opts) ?? new();
        }
        catch { }
        finally { _loadingCountries = false; }
    }

    private async Task SetAuthHeader()
    {
        try
        {
            var token = await SessionStorage.GetItemAsync<string>("auth_token");
            if (!string.IsNullOrEmpty(token))
                Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
        }
        catch { }
    }

    private async Task LoadPage(int page)
    {
        _loading = true; _page = page;
        try
        {
            var url = $"api/vendors?page={page}&pageSize={_pageSize}&search={Uri.EscapeDataString(_search)}&type={_filterType}&status={_filterStatus}";
            var result = await Http.GetFromJsonAsync<VendorPageResult>(url);
            if (result != null) { _vendors = result.Items; _total = result.Total; }
        }
        catch { }
        finally { _loading = false; }
    }

    private async Task OnSearchKey(KeyboardEventArgs e) { if (e.Key == "Enter") await LoadPage(1); }
    private async Task PrevPage() => await LoadPage(_page - 1);
    private async Task NextPage() => await LoadPage(_page + 1);
    private int TotalPages() => (_total + _pageSize - 1) / _pageSize;

    private async Task OpenCreate()
    {
        _editId = null; _f = new(); _formError = "";
        _attachments.Clear(); _pendingFiles.Clear(); _uploadError = "";
        _factoryEvalFiles.Clear(); _pendingFactoryFiles.Clear();
        _formCategories = new();
        try
        {
            var result = await Http.GetFromJsonAsync<NextCodeResult>("api/vendors/next-code");
            if (result != null) _f.Code = result.Code;
        }
        catch { }
        _showModal = true;
    }

    private async Task OpenEdit(VendorDto v)
    {
        _editId = v.Id;
        _f = new VendorForm
        {
            Code          = v.Code,
            Name          = v.Name,
            ShortName     = v.ShortName     ?? "",
            Type          = v.Type,
            Status        = v.Status,
            Category      = v.Category      ?? "",
            TaxCode       = v.TaxCode       ?? "",
            BusinessRegNo = v.BusinessRegNo ?? "",
            Phone         = v.Phone         ?? "",
            Website       = v.Website       ?? "",
            Notes         = v.Notes         ?? "",
            Address1      = v.Address1      ?? "",
            Address2      = v.Address2      ?? "",
            City          = "",
            State         = v.State         ?? "",
            Country       = v.Country       ?? "",
            PostalCode    = v.PostalCode    ?? "",
            ContactName   = v.ContactName   ?? "",
            ContactTitle  = v.ContactTitle  ?? "",
            ContactPhone  = v.ContactPhone  ?? "",
            ContactEmail  = v.ContactEmail  ?? "",
        };
        _attachments = v.Attachments.ToList();
        _pendingFiles.Clear();
        _formCategories = string.IsNullOrEmpty(v.Category) ? new() :
            v.Category.Split(',', StringSplitOptions.RemoveEmptyEntries).Select(x => x.Trim()).ToList();
        _uploadError = ""; _formError = "";
        // Load factory eval files
        _factoryEvalFiles.Clear(); _pendingFactoryFiles.Clear();
        try {
            var feFiles = await Http.GetFromJsonAsync<List<AttachmentDto>>($"api/vendors/{v.Id}/factory-eval/files");
            if (feFiles != null) _factoryEvalFiles = feFiles;
        } catch { }
        _showModal = true;
        _f.City = v.City ?? "";
    }

    private void OpenDetail(VendorDto v) { _detailItem = v; }
    private void CloseModal() { _showModal = false; _pendingFiles.Clear(); }

    // ── Save ─────────────────────────────────────────────────────────
    private async Task SaveVendor()
    {
        _formError = "";
        if (string.IsNullOrWhiteSpace(_f.Code)) { _formError = "Vendor code is required."; return; }
        if (string.IsNullOrWhiteSpace(_f.Name)) { _formError = "Vendor name is required."; return; }

        _saving = true;
        Waiting.Show(_editId == 0 ? "Creating vendor..." : "Saving vendor...");
        try
        {
            var payload = new
            {
                code          = _f.Code,
                name          = _f.Name,
                shortName     = _f.ShortName,
                type          = _f.Type,
                status        = _f.Status,
                category      = string.Join(", ", _formCategories),
                factoryEvaluationNotes = _f.FactoryEvaluationNotes,
                taxCode       = _f.TaxCode,
                businessRegNo = _f.BusinessRegNo,
                phone         = _f.Phone,
                website       = _f.Website,
                notes         = _f.Notes,
                address1      = _f.Address1,
                address2      = _f.Address2,
                city          = _f.City,
                state         = _f.State,
                country       = _f.Country,
                postalCode    = _f.PostalCode,
                contactName   = _f.ContactName,
                contactTitle  = _f.ContactTitle,
                contactPhone  = _f.ContactPhone,
                contactEmail  = _f.ContactEmail,
            };

            HttpResponseMessage response;
            int? newId = null;

            if (_editId == null)
            {
                // CREATE
                response = await Http.PostAsJsonAsync("api/vendors", payload);
                if (response.IsSuccessStatusCode)
                {
                    var created = await response.Content.ReadFromJsonAsync<CreateResult>();
                    newId = created?.Id;
                }
            }
            else
            {
                // UPDATE
                response = await Http.PutAsJsonAsync($"api/vendors/{_editId}", payload);
            }

            if (!response.IsSuccessStatusCode)
            {
                var err = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                _formError = err?.Message ?? "An error occurred.";
                return;
            }

            // Upload pending files right after create
            int targetId = newId ?? _editId ?? 0;
            if (_pendingFiles.Count > 0 && targetId > 0)
                await UploadPendingFiles(targetId);
            if (_pendingFactoryFiles.Count > 0 && targetId > 0)
                await UploadPendingFactoryFiles(targetId);

            _showModal = false;
            _pendingFiles.Clear();
            _pendingFactoryFiles.Clear();
            await LoadPage(_page);
        }
        catch { _formError = "Connection error."; }
        finally { _saving = false; Waiting.Hide(); }
    }

    // ── File handlers ─────────────────────────────────────────────────
    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        var files = e.GetMultipleFiles(10);

        if (_editId != null)
        {
            // Edit mode: upload ngay lập tức
            await UploadFilesNow(_editId.Value, files);
        }
        else
        {
            // Create mode: đọc vào bộ nhớ, chờ khi Create
            foreach (var f in files)
            {
                try
                {
                    using var ms = new System.IO.MemoryStream();
                    await f.OpenReadStream(10 * 1024 * 1024).CopyToAsync(ms);
                    _pendingFiles.Add(new PendingFile
                    {
                        Name     = f.Name,
                        Size     = f.Size,
                        Data     = ms.ToArray(),
                        MimeType = string.IsNullOrEmpty(f.ContentType) ? "application/octet-stream" : f.ContentType
                    });
                }
                catch { }
            }
        }
    }

    private void HandleDrop(DragEventArgs e) => _isDragOver = false;

    private void RemovePendingFile(PendingFile pf) => _pendingFiles.Remove(pf);

    /// Upload pending (byte[]) files after vendor is created
    private async Task UploadPendingFiles(int vendorId)
    {
        _uploadLoading  = true;
        _uploadingCount = _pendingFiles.Count;
        Waiting.Show($"Uploading {_pendingFiles.Count} file(s)...");
        try
        {
            using var content = new MultipartFormDataContent();
            foreach (var pf in _pendingFiles)
            {
                var sc = new ByteArrayContent(pf.Data);
                sc.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(pf.MimeType);
                content.Add(sc, "files", pf.Name);
            }
            await Http.PostAsync($"api/vendors/{vendorId}/attachments", content);
        }
        catch { }
        finally { _uploadLoading = false; _uploadingCount = 0; }
    }

    /// Upload stream files immediately (edit mode)
    private async Task UploadFilesNow(int vendorId, IReadOnlyList<IBrowserFile> files)
    {
        if (files.Count == 0) return;
        _uploadLoading  = true;
        _uploadingCount = files.Count;
        _uploadError    = "";
        try
        {
            using var content = new MultipartFormDataContent();
            foreach (var file in files)
                content.Add(new StreamContent(file.OpenReadStream(10 * 1024 * 1024)), "files", file.Name);

            var response = await Http.PostAsync($"api/vendors/{vendorId}/attachments", content);
            if (response.IsSuccessStatusCode)
                await RefreshAttachments(vendorId);
            else
                _uploadError = "Upload failed. Please try again.";
        }
        catch (Exception ex) { _uploadError = $"Error: {ex.Message}"; }
        finally { _uploadLoading = false; _uploadingCount = 0; }
    }

    private async Task RefreshAttachments(int vendorId)
    {
        try
        {
            var list = await Http.GetFromJsonAsync<List<AttachmentDto>>($"api/vendors/{vendorId}/attachments");
            if (list != null) _attachments = list;
        }
        catch { }
    }

    private async Task DeleteAttachment(AttachmentDto att)
    {
        if (_editId == null) return;
        _uploadLoading = true;
        try
        {
            var r = await Http.DeleteAsync($"api/vendors/{_editId}/attachments/{att.Id}");
            if (r.IsSuccessStatusCode) _attachments.Remove(att);
        }
        catch { }
        finally { _uploadLoading = false; }
    }

    private void ConfirmDelete(VendorDto v) => _deleteItem = v;

    private async Task HandleInlineUpload(InputFileChangeEventArgs e, VendorDto vendor)
    {
        var files = e.GetMultipleFiles(10);
        if (files.Count == 0) return;
        await UploadFilesNow(vendor.Id, files);
        // Refresh the vendor list so badge updates
        await LoadPage(_page);
    }

    private async Task DeleteVendor()
    {
        if (_deleteItem == null) return;
        _saving = true;
        Waiting.Show("Deleting vendor...");
        var response = await Http.DeleteAsync($"api/vendors/{_deleteItem.Id}");
        _saving = false;
        Waiting.Hide();
        if (response.IsSuccessStatusCode) { _deleteItem = null; await LoadPage(_page); }
    }

    private void ToggleVendorCategory(string cat)
    {
        if (_formCategories.Contains(cat)) _formCategories.Remove(cat);
        else _formCategories.Add(cat);
    }

    private void HandleDropFe(DragEventArgs e) => _isDragOverFe = false;

    private async Task HandleFactoryEvalUpload(InputFileChangeEventArgs e)
    {
        var files = e.GetMultipleFiles(20);
        if (_editId != null)
        {
            await UploadFactoryFilesNow(_editId.Value, files);
        }
        else
        {
            foreach (var f in files)
            {
                try
                {
                    using var ms = new System.IO.MemoryStream();
                    await f.OpenReadStream(20 * 1024 * 1024).CopyToAsync(ms);
                    _pendingFactoryFiles.Add(new PendingFile { Name = f.Name, Size = f.Size, Data = ms.ToArray(),
                        MimeType = string.IsNullOrEmpty(f.ContentType) ? "application/octet-stream" : f.ContentType });
                }
                catch { }
            }
        }
    }

    private async Task UploadFactoryFilesNow(int vendorId, IReadOnlyList<IBrowserFile> files)
    {
        if (files.Count == 0) return;
        _uploadLoading = true; _uploadError = "";
        try
        {
            using var content = new MultipartFormDataContent();
            foreach (var file in files)
                content.Add(new StreamContent(file.OpenReadStream(20 * 1024 * 1024)), "files", file.Name);
            var response = await Http.PostAsync($"api/vendors/{vendorId}/factory-eval/files", content);
            if (response.IsSuccessStatusCode)
            {
                var feFiles = await Http.GetFromJsonAsync<List<AttachmentDto>>($"api/vendors/{vendorId}/factory-eval/files");
                if (feFiles != null) _factoryEvalFiles = feFiles;
            }
            else _uploadError = "Factory eval upload failed.";
        }
        catch (Exception ex) { _uploadError = $"Error: {ex.Message}"; }
        finally { _uploadLoading = false; }
    }

    private async Task UploadPendingFactoryFiles(int vendorId)
    {
        _uploadLoading = true;
        try
        {
            using var content = new MultipartFormDataContent();
            foreach (var pf in _pendingFactoryFiles)
            {
                var sc = new ByteArrayContent(pf.Data);
                sc.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(pf.MimeType);
                content.Add(sc, "files", pf.Name);
            }
            await Http.PostAsync($"api/vendors/{vendorId}/factory-eval/files", content);
        }
        catch { }
        finally { _uploadLoading = false; }
    }

    private async Task DeleteFactoryEvalFile(AttachmentDto att)
    {
        if (_editId == null) return;
        _uploadLoading = true;
        try
        {
            var r = await Http.DeleteAsync($"api/vendors/{_editId}/factory-eval/files/{att.Id}");
            if (r.IsSuccessStatusCode) _factoryEvalFiles.Remove(att);
        }
        catch { }
        finally { _uploadLoading = false; }
    }

    // ── Helpers ──────────────────────────────────────────────────────
    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024)         return $"{bytes} B";
        if (bytes < 1024 * 1024)  return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024):F1} MB";
    }

    private static string GetFileIconSvg(string contentType) =>
        contentType.StartsWith("image/")
            ? "<svg width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='#81c784' stroke-width='2'><rect x='3' y='3' width='18' height='18' rx='2'/><circle cx='8.5' cy='8.5' r='1.5'/><polyline points='21 15 16 10 5 21'/></svg>"
            : "<svg width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='#ef9a9a' stroke-width='2'><path d='M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z'/><polyline points='14 2 14 8 20 8'/><line x1='9' y1='13' x2='15' y2='13'/><line x1='9' y1='17' x2='13' y2='17'/></svg>";

    private static string GetFileIconSvgByName(string name)
    {
        var ext = System.IO.Path.GetExtension(name).ToLowerInvariant();
        return ext is ".jpg" or ".jpeg" or ".png" or ".gif" or ".webp"
            ? GetFileIconSvg("image/")
            : GetFileIconSvg("application/pdf");
    }

    private string GetInitials(string name)
        => string.Concat(name.Split(" ").Take(2).Select(w => w.Length > 0 ? w[0].ToString().ToUpper() : ""));

    private string GetTypeLabel(int t) => t switch { 0=>"Material",1=>"Accessory",2=>"Service",3=>"Logistics",4=>"Manufacturing",_=>"Unknown" };
    private string GetTypeCss(int t)   => t switch { 0=>"material",1=>"accessory",2=>"service",3=>"logistics",4=>"manufacturing",_=>"material" };
    private string GetStatusLabel(int s) => s switch { 0=>"Active",1=>"Inactive",2=>"Suspended",_=>"Unknown" };
    private string GetStatusCss(int s)   => s switch { 0=>"active",1=>"inactive",2=>"suspended",_=>"active" };

