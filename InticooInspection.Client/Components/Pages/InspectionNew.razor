    // Normalize AQL string → table key
    private static string NormalizeAqlKey(string aql) => aql switch
    {
        "0"     => "0",
        "0.065" => "0.065",
        "0.1"   => "0.10",
        "0.10"  => "0.10",
        "0.15"  => "0.15",
        "0.25"  => "0.25",
        "0.4"   => "0.40",
        "0.40"  => "0.40",
        "0.65"  => "0.65",
        "1.0"   => "1.0",
        "1.5"   => "1.5",
        "2.5"   => "2.5",
        "4.0"   => "4.0",
        "6.5"   => "6.5",
        _       => "2.5"
    };

    // Look up Table B — xử lý đúng cả ↑ và ↓ arrow
    private static (int sampleSize, int ac, int re) LookupTableB(string codeLetter, string aqlKey)
    {
        if (aqlKey == "0") return (_codeSizes.GetValueOrDefault(codeLetter, 0), 0, 0);

        var letters = new[] {"A","B","C","D","E","F","G","H","J","K","L","M","N","P","Q","R"};
        int idx = Array.IndexOf(letters, codeLetter);
        if (idx < 0) return (0, 0, 0);

        if (!_tableB.ContainsKey(codeLetter) || !_tableB[codeLetter].ContainsKey(aqlKey))
            return (_codeSizes.GetValueOrDefault(codeLetter, 0), 0, 1);

        var (ac0, re0) = _tableB[codeLetter][aqlKey];

        if (ac0 == -1) // ↑ arrow: dùng plan trên (letter nhỏ hơn, sample nhỏ hơn)
        {
            for (int i = idx - 1; i >= 0; i--)
            {
                var l = letters[i];
                if (!_tableB.ContainsKey(l) || !_tableB[l].ContainsKey(aqlKey)) continue;
                var (a, r) = _tableB[l][aqlKey];
                if (a >= 0) return (_codeSizes.GetValueOrDefault(l, 0), a, r);
            }
            return (_codeSizes.GetValueOrDefault(codeLetter, 0), 0, 1);
        }

        if (ac0 == -2) // ↓ arrow: dùng plan dưới (letter lớn hơn, sample lớn hơn)
        {
            for (int i = idx + 1; i < letters.Length; i++)
            {
                var l = letters[i];
                if (!_tableB.ContainsKey(l) || !_tableB[l].ContainsKey(aqlKey)) continue;
                var (a, r) = _tableB[l][aqlKey];
                if (a >= 0) return (_codeSizes.GetValueOrDefault(l, 0), a, r);
            }
            return (_codeSizes.GetValueOrDefault(codeLetter, 0), 0, 1);
        }

        return (_codeSizes.GetValueOrDefault(codeLetter, 0), ac0, re0);
    }

    private void RecalcAql()
    {
        if (AqlQuantity <= 0)
        {
            CriticalSampleSize = CriticalAccept = CriticalReject = 0;
            MajorSampleSize    = MajorAccept    = MajorReject    = 0;
            MinorSampleSize    = MinorAccept    = MinorReject    = 0;
            _currentCodeLetter = "";
            return;
        }

        var codeLetter = GetCodeLetter(AqlQuantity, AqlInspectionLevel);
        _currentCodeLetter = codeLetter;

        // Critical
        if (CriticalAql == "0")
        {
            CriticalSampleSize = _codeSizes.GetValueOrDefault(codeLetter, 0);
            CriticalAccept = CriticalReject = 0;
        }
        else
        {
            var (sz, ac, re) = LookupTableB(codeLetter, NormalizeAqlKey(CriticalAql));
            CriticalSampleSize = sz; CriticalAccept = ac; CriticalReject = re;
        }

        // Major
        var (szM, acM, reM) = LookupTableB(codeLetter, NormalizeAqlKey(MajorAql));
        MajorSampleSize = szM; MajorAccept = acM; MajorReject = reM;

        // Minor
        var (szN, acN, reN) = LookupTableB(codeLetter, NormalizeAqlKey(MinorAql));
        MinorSampleSize = szN; MinorAccept = acN; MinorReject = reN;
    }

