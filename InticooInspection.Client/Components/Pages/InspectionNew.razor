            else
            {
                <div class="data-table">
                    <div class="data-table-header">
                        <div class="col-no">No</div>
                        <div class="col-flex">Category</div>
                        <div class="col-flex">Test Item</div>
                        <div class="col-flex">Test Protocol</div>
                        <div class="col-flex2">Test Requirement</div>
                        <div class="col-flex">Remark</div>
                    </div>
                    @for (int i = 0; i < PerformanceTests.Count; i++)
                    {
                        var idx  = i;
                        var test = PerformanceTests[idx];
                        var testItems = GetPerfTestItems(test.Category);
                        <div class="data-table-row">
                            <div class="col-no">@(idx + 1)</div>
                            <div class="col-flex">
                                <select class="table-select"
                                        value="@test.Category"
                                        @onchange="e => OnPerfCategoryChanged(e, idx)">
                                    <option value="">Category...</option>
                                    @foreach (var cat in _perfCategories)
                                    {
                                        <option value="@cat">@cat</option>
                                    }
                                </select>
                            </div>
                            <div class="col-flex">
                                @if (string.IsNullOrEmpty(test.Category))
                                {
                                    <select class="table-select" disabled>
                                        <option value="">Select category first...</option>
                                    </select>
                                }
                                else
                                {
                                    <select class="table-select"
                                            value="@test.TestItem"
                                            @onchange="e => OnPerfTestItemChanged(e, idx)">
                                        <option value="">Test item...</option>
                                        @foreach (var item in testItems)
                                        {
                                            <option value="@item.ProtocolName">@item.ProtocolName</option>
                                        }
                                    </select>
                                }
                            </div>
                            <div class="col-flex">
                                <input @bind="test.TestProtocol"
                                       placeholder="Protocol auto-filled..."
                                       class="table-input" readonly />
                            </div>
                            <div class="col-flex2">
                                <textarea @bind="test.TestRequirement"
                                          placeholder="Requirement auto-filled..."
                                          class="table-textarea"
                                          rows="2"></textarea>
                            </div>
                            <div class="col-flex">
                                <input @bind="test.Remark" placeholder="Remark..." class="table-input" />
                            </div>
