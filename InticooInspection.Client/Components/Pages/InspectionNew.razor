    // ══════════════════════════════════════════════════════════════
    //  AQL ANSI/ASQ Z1.4 – 2008  (Table A + Table B)
    // ══════════════════════════════════════════════════════════════

    // TABLE A — Lot size → Code letter (General Inspection Level I, II, III)
    private static string GetCodeLetter(int qty, string level)
    {
        if (qty <= 1) return "A";

        // Special Inspection Levels S1-S4
        if (level == "S1" || level == "S2" || level == "S3" || level == "S4")
        {
            var special = new (int max, string S1, string S2, string S3, string S4)[]
            {
                (     150, "A","A","A","A"),
                (     500, "A","A","B","B"),
                (   1200, "A","A","B","C"),
                (  10000, "A","B","C","C"),
                (  35000, "B","B","C","D"),
                ( 150000, "B","C","D","E"),
                ( 500000, "B","C","D","E"),
                (int.MaxValue,"C","C","D","F"),
            };
            foreach (var row in special)
                if (qty <= row.max)
                    return level switch { "S1"=>row.S1,"S2"=>row.S2,"S3"=>row.S3,_=>row.S4 };
            return "F";
        }

        // General Inspection Levels I, II, III
        var table = new (int max, string I, string II, string III)[]
        {
            (      8, "A","A","B"),
            (     15, "A","B","C"),
            (     25, "B","C","D"),
            (     50, "C","D","E"),
            (     90, "C","E","F"),
            (    150, "D","F","G"),
            (    280, "E","G","H"),
            (    500, "F","H","J"),
            (   1200, "G","J","K"),
            (   3200, "H","K","L"),
            (  10000, "J","L","M"),
            (  35000, "K","M","N"),
            ( 150000, "L","N","P"),
            ( 500000, "M","P","Q"),
            (int.MaxValue,"N","Q","R"),
        };
        foreach (var row in table)
            if (qty <= row.max)
                return level switch { "I"=>row.I, "III"=>row.III, _=>row.II };
        return "R";
    }

