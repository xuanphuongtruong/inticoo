    // FIX: xử lý lỗi đầy đủ, không nuốt exception
    private async Task OnReferenceFileSelected(InputFileChangeEventArgs e, int idx)
    {
        if (idx >= References.Count) return;

        // 1. Lấy file ra TRƯỚC khi làm bất cứ điều gì khác
        var file = e.File;
        if (file == null) return;

        var refItem = References[idx];
        refItem.FileName    = file.Name;
        refItem.UploadError = "";
        refItem.FileUrl     = "";

        // 2. Copy vào MemoryStream NGAY LẬP TỨC — cắt đứt liên kết với DOM trình duyệt
        //    Phải làm TRƯỚC StateHasChanged() để tránh lỗi _blazorFilesById
        var ms = new System.IO.MemoryStream();
        try
        {
            await file.OpenReadStream(maxAllowedSize: 20 * 1024 * 1024).CopyToAsync(ms);
        }
        catch (Exception ex)
        {
            refItem.UploadError = $"Không đọc được file: {ex.Message}";
            StateHasChanged();
            return;
        }
        ms.Position = 0;

        // 3. Bây giờ đã an toàn — gọi StateHasChanged sau khi đã có dữ liệu trong memory
        refItem.IsUploading = true;
        Waiting.Show($"Uploading: {file.Name}");
        StateHasChanged();

        try
        {
            using var content = new MultipartFormDataContent();
            var sc = new ByteArrayContent(ms.ToArray());
            sc.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(SafeContentType(file.ContentType));
            content.Add(sc, "file", file.Name);

            var token = await SessionStorage.GetItemAsync<string>("auth_token");
            if (!string.IsNullOrEmpty(token))
                Http.DefaultRequestHeaders.Authorization =
                    new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            var resp = await Http.PostAsync("api/files/upload", content);
            if (resp.IsSuccessStatusCode)
            {
                var rawBody = await resp.Content.ReadAsStringAsync();
                try
                {
                    using var doc = System.Text.Json.JsonDocument.Parse(rawBody);
                    string? url = null;
                    string? fileName = null;
                    foreach (var prop in doc.RootElement.EnumerateObject())
                    {
                        if (prop.Name.Equals("url", StringComparison.OrdinalIgnoreCase) ||
                            prop.Name.Equals("fileUrl", StringComparison.OrdinalIgnoreCase))
                            url = prop.Value.GetString();
                        if (prop.Name.Equals("fileName", StringComparison.OrdinalIgnoreCase) ||
                            prop.Name.Equals("name", StringComparison.OrdinalIgnoreCase))
                            fileName = prop.Value.GetString();
                    }
                    refItem.FileUrl     = url      ?? "";
                    refItem.FileName    = fileName ?? file.Name;
                    refItem.UploadError = string.IsNullOrEmpty(url)
                        ? $"Upload OK nhưng server không trả URL. Body: {rawBody}"
                        : "";
                }
                catch (Exception parseEx)
                {
                    refItem.UploadError = $"Parse error: {parseEx.Message}";
                }
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                refItem.UploadError = $"{(int)resp.StatusCode}: {body}";
            }
        }
        catch (Exception ex)
        {
            refItem.UploadError = ex.Message;
        }
        finally
        {
            refItem.IsUploading = false;
            Waiting.Hide();
            await ms.DisposeAsync();
            StateHasChanged();
        }
    }

    private class UploadResult
    {
        public string Url      { get; set; } = "";
        public string FileName { get; set; } = "";
    }

    private bool _saving = false;
    private string? _saveError;
    private List<string> _validationErrors = new();

    // ── Validation ──
    private bool ValidateForm()
    {
        _validationErrors.Clear();

        if (string.IsNullOrWhiteSpace(Model.CustomerId))
            _validationErrors.Add("Customer ID is required.");
        if (string.IsNullOrWhiteSpace(Model.InspectionLocation))
            _validationErrors.Add("Inspection Location is required.");
        if (Model.InspectionDate == null)
            _validationErrors.Add("Inspection Date is required.");
        if (string.IsNullOrWhiteSpace(Model.PoNumber))
            _validationErrors.Add("P.O. Number is required.");
        if (string.IsNullOrWhiteSpace(Model.ItemNumber))
            _validationErrors.Add("Item Number is required.");
        if (string.IsNullOrWhiteSpace(Model.ProductCode))
            _validationErrors.Add("Product ID is required.");
        if (Model.TotalShipmentQty <= 0)
            _validationErrors.Add("Total Shipment Quantity must be greater than 0.");

        if (AqlQuantity <= 0)
            _validationErrors.Add("AQL Quantity is required.");

        if (string.IsNullOrWhiteSpace(OfficeUse.InspectorId))
            _validationErrors.Add("Inspector is required (Office Use).");

        return _validationErrors.Count == 0;
    }

    private async Task HandleSave()
    {
        _saveError = null;
        _validationErrors.Clear();

        if (!ValidateForm())
        {
            _saveError = string.Join(" | ", _validationErrors);
            return;
        }

        if (_photoUploading)
        {
            _saveError = "Ảnh đang được tải lên, vui lòng chờ...";
            return;
        }
        if (!string.IsNullOrEmpty(_photoError))
        {
            _saveError = $"Ảnh chưa tải lên được: {_photoError}. Vui lòng thử lại hoặc xóa ảnh.";
            return;
        }

        _saving = true;
        Waiting.Show("Creating inspection...");
        try
        {
            var payload = new
            {
                title              = string.IsNullOrWhiteSpace(Model.ProductName) ? "Inspection" : Model.ProductName,
                description        = (string?)null,
                customerName       = Model.CustomerName,
                customerId         = Model.CustomerId,
                vendorName         = Model.VendorName,
                vendorId           = Model.VendorId,
                inspectionLocation = Model.InspectionLocation,
                poNumber           = Model.PoNumber,
                inspectionDate     = Model.InspectionDate,
                itemNumber         = Model.ItemNumber,
                inspectionType     = Model.InspectionType.ToString(),
                productName        = Model.ProductName,
                productType        = Model.ProductType,
                productCategory    = Model.ProductCategory,
                totalShipmentQty   = Model.TotalShipmentQty,
                totalCartonBoxes   = Model.TotalCartonBoxes,
                generalRemark      = Model.GeneralRemark,
                inspectorId        = OfficeUse.InspectorId,
                inspectorName      = OfficeUse.InspectorName,
                photo1Url          = Photo1ServerUrl,   // lưu server URL, không lưu data URL base64
                photo2Url          = (string?)null,
                // AQL
                aqlQuantity              = AqlQuantity,
                aqlLevel                 = AqlInspectionLevel,
                aqlCritical              = CriticalAql,
                aqlMajor                 = MajorAql,
                aqlMinor                 = MinorAql,
                aqlCriticalSampleSize    = CriticalSampleSize,
                aqlCriticalAccept        = CriticalAccept,
                aqlCriticalReject        = CriticalReject,
                aqlMajorSampleSize       = MajorSampleSize,
                aqlMajorAccept           = MajorAccept,
                aqlMajorReject           = MajorReject,
                aqlMinorSampleSize       = MinorSampleSize,
                aqlMinorAccept           = MinorAccept,
                aqlMinorReject           = MinorReject,

                // Packaging & Identification
                packaging = new
                {
                    itemNumber           = Packaging.ItemNumber,
                    cartonNumber         = Packaging.CartonNumber,
                    packagingType        = Packaging.PackagingType,
                    cartonColor          = Packaging.CartonColor,
                    cardboardType        = Packaging.CardboardType,
                    shippingMark         = Packaging.ShippingMark,
                    hasBarcode           = Packaging.HasBarcode,
                    innerPackingQty      = Packaging.InnerPackingQty,
                    innerL               = Packaging.InnerL,
                    innerW               = Packaging.InnerW,
                    innerH               = Packaging.InnerH,
                    innerWeight          = Packaging.InnerWeight,
                    innerPackingRemark   = Packaging.InnerPackingRemark,
                    outerL               = Packaging.OuterL,
                    outerW               = Packaging.OuterW,
                    outerH               = Packaging.OuterH,
                    outerWeight          = Packaging.OuterWeight,
                    assemblyInstruction  = Packaging.AssemblyInstruction,
                    hardware             = Packaging.Hardware
                },

                // Product Specification
                productSpec = new
                {
                    sizeL               = ProductSpec.SizeL,
                    sizeW               = ProductSpec.SizeW,
                    sizeH               = ProductSpec.SizeH,
                    weight              = ProductSpec.Weight,
                    compareGoldenSample = ProductSpec.CompareGoldenSample,
                    colourSwatches      = ColourSwatches
                                            .Where(s => !string.IsNullOrWhiteSpace(s))
                                            .ToArray()
                },

                // Performance Testing
                performanceTests = PerformanceTests
                    .Where(t => !string.IsNullOrWhiteSpace(t.Category) || !string.IsNullOrWhiteSpace(t.TestItem))
                    .Select(t => new
                    {
                        masterId        = t.MasterId,
                        category        = t.Category,
                        testItem        = t.TestItem,
                        testProtocol    = t.TestProtocol,
                        testRequirement = t.TestRequirement,
                        remark          = t.Remark
                    }).ToArray(),

                // References không lưu vào Inspection — đã lưu riêng vào Product
                references = Array.Empty<object>(),

                steps              = Array.Empty<object>(),
                overallConclusions = OverallConclusions.Select(o => new
                {
                    letter     = o.Letter,
                    label      = o.Label,
                    compliance = o.Compliance,
                    remark     = o.Remark
                }).ToArray()
            };

            var token = await SessionStorage.GetItemAsync<string>("auth_token");
            if (string.IsNullOrEmpty(token))
            {
                _saveError = "Phiên đăng nhập hết hạn. Vui lòng đăng nhập lại.";
                return;
            }

            Http.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            var resp = await Http.PostAsJsonAsync("api/inspections", payload);
            if (resp.IsSuccessStatusCode)
            {
                Navigation.NavigateTo("/inspections");
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                _saveError = $"Save failed ({(int)resp.StatusCode}): {body}";
            }
        }
        catch (Exception ex)
        {
            _saveError = ex.Message;
        }
        finally
        {
            _saving = false;
            Waiting.Hide();
        }
    }

    private void GoBack() => Navigation.NavigateTo("/inspections");

