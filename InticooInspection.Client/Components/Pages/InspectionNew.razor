            {
                <div style="color:#dc2626;font-size:12px;background:#fff5f5;border:1px solid #fecaca;border-radius:8px;padding:10px 14px;margin-bottom:12px;">
                    ⚠ @_perfMasterError
                </div>
                <div class="data-table">
                    <div class="data-table-header">
                        <div class="col-no">No</div>
                        <div class="col-flex">Category</div>
                        <div class="col-flex">Test Item</div>
                        <div class="col-flex">Test Protocol</div>
                        <div class="col-flex2">Test Requirement</div>
                        <div class="col-flex">Remark</div>
                    </div>
                    @for (int i = 0; i < PerformanceTests.Count; i++)
                    {
                        var idx  = i;
                        var test = PerformanceTests[idx];
                        <div class="data-table-row">
                            <div class="col-no">@(idx + 1)</div>
                            <div class="col-flex"><input @bind="test.Category" placeholder="Category..." class="table-input" /></div>
                            <div class="col-flex"><input @bind="test.TestItem" placeholder="Test item..." class="table-input" /></div>
                            <div class="col-flex"><input @bind="test.TestProtocol" placeholder="Protocol..." class="table-input" /></div>
                            <div class="col-flex2"><input @bind="test.TestRequirement" placeholder="Requirement..." class="table-input" /></div>
                            <div class="col-flex"><input @bind="test.Remark" placeholder="Remark..." class="table-input" /></div>
                        </div>
