@page "/inspections/new"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using InticooInspection.Client.Services
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using Microsoft.AspNetCore.Components.Forms
@inject HttpClient Http
@inject NavigationManager Navigation
@inject Blazored.SessionStorage.ISessionStorageService SessionStorage
@inject WaitingService Waiting

<PageTitle>New Inspection - Inticoo</PageTitle>

<div class="ni-page">

    <!-- Header -->
    <div class="ni-header">
        <button class="ni-back-btn" @onclick="GoBack">
            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M13 4l-6 6 6 6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </button>
        <div class="ni-title-block">
            <span class="ni-breadcrumb">Inspections</span>
            <h1 class="ni-title" style="color:#ffffff;">New Inspection</h1>
        </div>
        <div class="ni-header-actions">
        </div>
    </div>

    <div class="ni-body">

        <!-- General Information + Photo (gộp 1 card) -->
        <div class="ni-card">
            <div class="ni-section-title">General Information</div>
            <div class="gi-layout">

                <!-- Cột trái: Photo -->
                <div class="gi-photo-col">
                    <label class="photo-slot @(string.IsNullOrEmpty(PhotoPreview1) ? "" : "photo-slot--filled")">
                        @if (_photoUploading)
                        {
                            <div class="photo-placeholder">
                                <div class="spinner-lg" style="border-top-color:#1e90d6;width:32px;height:32px;"></div>
                                <span style="color:#1e90d6;font-size:12px;margin-top:8px;">Uploading...</span>
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(PhotoPreview1))
                        {
                            <img src="@PhotoPreview1" alt="Photo" />
                            <button class="photo-remove-btn" type="button"
                                    @onclick:stopPropagation="true" @onclick="RemovePhoto">
                                <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5">
                                    <path d="M5 5l10 10M15 5L5 15" stroke-linecap="round"/>
                                </svg>
                            </button>
                        }
                        else
                        {
                            <div class="photo-placeholder">
                                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <rect x="3" y="3" width="18" height="18" rx="3"/>
                                    <circle cx="8.5" cy="8.5" r="1.5"/>
                                    <path d="M21 15l-5-5L5 21"/>
                                </svg>
                                <span>Click to upload photo</span>
                                <span class="photo-hint">JPG, PNG, WEBP · max 5 MB</span>
                            </div>
                        }
                        <InputFile OnChange="OnPhotoSelected" accept="image/*" style="display:none" />
                    </label>
                    @* FIX: hiển thị lỗi upload photo *@
                    @if (!string.IsNullOrEmpty(_photoError))
                    {
                        <div style="color:#dc2626;font-size:11.5px;margin-top:6px;background:#fff5f5;border:1px solid #fecaca;border-radius:7px;padding:6px 10px;">
                            ⚠ @_photoError
                        </div>
                    }
                </div>

                <!-- Cột phải: Fields -->
                <div class="gi-fields-col">
                <div class="ni-grid-2">
                <div class="field-group">
                    <label>Customer ID <span class="field-required">*</span></label>
                    @if (_loadingCustomers)
                    {
                        <div class="field-loading">Loading...</div>
                    }
                    else
                    {
                        <select value="@Model.CustomerId" @onchange="OnCustomerChanged">
                            <option value="">-- Select Customer --</option>
                            @foreach (var c in _customers)
                            {
                                <option value="@c.CustomerId">@c.CustomerId — @c.CompanyName</option>
                            }
                        </select>
                    }
                </div>
                <div class="field-group">
                    <label>Customer Name</label>
                    <div class="readonly-field @(string.IsNullOrEmpty(Model.CustomerName) ? "" : "accent")">
                        @(string.IsNullOrEmpty(Model.CustomerName) ? "Auto-filled when selecting ID" : Model.CustomerName)
                    </div>
                </div>
                <div class="field-group">
                    <label>Vendor ID</label>
                    @if (_loadingVendors)
                    {
                        <div class="field-loading">Loading...</div>
                    }
                    else
                    {
                        <select value="@Model.VendorId" @onchange="OnVendorChanged">
                            <option value="">-- Select Vendor --</option>
                            @foreach (var v in _vendors)
                            {
                                <option value="@v.Code">@v.Code — @v.Name</option>
                            }
                        </select>
                    }
                </div>
                <div class="field-group">
                    <label>Vendor Name</label>
                    <div class="readonly-field @(string.IsNullOrEmpty(Model.VendorName) ? "" : "accent")">
                        @(string.IsNullOrEmpty(Model.VendorName) ? "Auto-filled when selecting ID" : Model.VendorName)
                    </div>
                </div>
                <div class="field-group">
                    <label>Inspection Location</label>
                    @if (_loadingCountries)
                    {
                        <div class="field-loading">Loading countries...</div>
                    }
                    else
                    {
                        <select value="@_selectedCountryId" @onchange="OnCountryChanged">
                            <option value="">-- Select Country --</option>
                            @foreach (var co in _countries)
                            {
                                <option value="@co.Id">@co.Name</option>
                            }
                        </select>
                    }
                </div>
                <div class="field-group">
                    <label>P.O. Number</label>
                    <input @bind="Model.PoNumber" placeholder="Enter PO number" />
                </div>
                <div class="field-group">
                    <label>Inspection Date</label>
                    <input type="date" @bind="Model.InspectionDate" />
                </div>
                <div class="field-group">
                    <label>Inspection Type</label>
                    <div class="radio-group">
                        <label class="radio-label">
                            <input type="radio" name="inspType" value="PPT"
                                   checked="@(Model.InspectionType == InspectionTypeEnum.PPT)"
                                   @onchange="() => Model.InspectionType = InspectionTypeEnum.PPT" />
                            <span>PPI: Pre-Production Inspection</span>
                        </label>
                        <label class="radio-label">
                            <input type="radio" name="inspType" value="DPI"
                                   checked="@(Model.InspectionType == InspectionTypeEnum.DPI)"
                                   @onchange="() => Model.InspectionType = InspectionTypeEnum.DPI" />
                            <span>DPI: During-Production Inspection</span>
                        </label>
                        <label class="radio-label">
                            <input type="radio" name="inspType" value="PST"
                                   checked="@(Model.InspectionType == InspectionTypeEnum.PST)"
                                   @onchange="() => Model.InspectionType = InspectionTypeEnum.PST" />
                            <span>PST: Pre-Shipment Inspection</span>
                        </label>
                    </div>
                </div>
                <div class="field-group">
                    <label>Item Number</label>
                    <input value="@Model.ItemNumber" @onchange="OnItemNumberChanged" placeholder="Enter item number" class="highlight-field" />
                </div>
                <div class="field-group">
                    <label>Product Name</label>
                    @if (_loadingProducts)
                    {
                        <div class="field-loading">Loading...</div>
                    }
                    else
                    {
                        <select value="@Model.ProductCode" @onchange="OnProductChanged">
                            <option value="">-- Select Product --</option>
                            @foreach (var p in _products)
                            {
                                <option value="@p.ProductCode">@p.ProductCode — @p.ProductName</option>
                            }
                        </select>
                    }
                </div>
                <div class="field-group">
                    <label>Product Type</label>
                    <div class="readonly-field @(string.IsNullOrEmpty(Model.ProductType) ? "" : "accent")">
                        @(string.IsNullOrEmpty(Model.ProductType) ? "Auto-filled from Product" : Model.ProductType)
                    </div>
                </div>
                <div class="field-group">
                    <label>Inspection Reference</label>
                    <div class="toggle-group">
                        <button class="@ToggleCss(Model.InspectionReference)" @onclick="() => Model.InspectionReference = true">Yes</button>
                        <button class="@ToggleCss(!Model.InspectionReference)" @onclick="() => Model.InspectionReference = false">No</button>
                    </div>
                </div>
                <div class="field-group">
                    <label>Total Shipment Quantity</label>
                    <input type="number" value="@Model.TotalShipmentQty" @onchange="OnTotalShipmentQtyChanged" placeholder="0" />
                </div>
                <div class="field-group">
                    <label>Product Category</label>
                    <div class="readonly-field @(string.IsNullOrEmpty(Model.ProductCategory) ? "" : "accent")">
                        @(string.IsNullOrEmpty(Model.ProductCategory) ? "Auto-filled from Product ID" : Model.ProductCategory)
                    </div>
                </div>
                <div class="field-group">
                    <label>Total Carton Boxes</label>
                    <input type="number" @bind="Model.TotalCartonBoxes" placeholder="0" />
                </div>
                </div>
                <!-- Remark row spanning full width -->
                <div class="field-group" style="margin-top:4px;">
                    <label>Remark</label>
                    <textarea @bind="Model.GeneralRemark" placeholder="Enter remark (e.g. Combine SKU number xxx, xxx &amp; xxxx)" rows="2"
                              style="width:100%;resize:vertical;border:1px solid #d0daea;border-radius:8px;padding:9px 12px;font-size:13px;font-family:inherit;color:#1a2d5a;outline:none;transition:border-color .15s;box-sizing:border-box;"
                              onfocus="this.style.borderColor='#1e90d6'" onblur="this.style.borderColor='#d0daea'"></textarea>
                </div>
                </div><!-- gi-fields-col -->
            </div><!-- gi-layout -->
        </div>

        <!-- Overall Conclusion -->
        <div class="ni-card">
            <div class="ni-section-title">Inspection Results</div>
            <table class="oc-table">
                <thead>
                    <tr>
                        <th class="oc-th-label">OVERALL CONCLUSION</th>
                        <th class="oc-th-compliance">COMPLIANCE</th>
                        <th class="oc-th-remark">REMARK</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in OverallConclusions)
                    {
                        var r = row;
                        <tr class="oc-row">
                            <td class="oc-td-label">@r.Letter. @r.Label</td>
                            <td class="oc-td-compliance">
                                <button class="@(r.Compliance == "Pass" ? "oc-btn oc-yes active" : "oc-btn oc-yes")"
                                        @onclick="@(() => ToggleCompliance(r, "Pass"))">YES</button>
                                <span class="oc-sep">/</span>
                                <button class="@(r.Compliance == "Fail" ? "oc-btn oc-no active" : "oc-btn oc-no")"
                                        @onclick="@(() => ToggleCompliance(r, "Fail"))">NO</button>
                            </td>
                            <td class="oc-td-remark">
                                <input class="oc-remark-input" @bind="r.Remark" placeholder="Remark..." />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- AQL Sampling Simulator -->
        <div class="ni-card">
            <div class="ni-section-title">AQL Sampling Simulator</div>
            @if (!string.IsNullOrEmpty(_currentCodeLetter))
            {
                <div style="margin-bottom:12px;font-size:13px;color:#4a6080;">
                    Lot Size <strong>@AqlQuantity</strong> · Level <strong>@AqlInspectionLevel</strong>
                    → Code Letter: <span style="font-size:16px;font-weight:700;color:#1e90d6;background:#e6f1fb;padding:2px 10px;border-radius:6px;">@_currentCodeLetter</span>
                </div>
            }
            <div class="ni-grid-2" style="margin-bottom:20px;">
                <div class="field-group">
                    <label>Quantity</label>
                    <input type="number" value="@AqlQuantity" @onchange="OnAqlQuantityChanged" placeholder="Enter quantity" />
                </div>
                <div class="field-group">
                    <label>Inspection Level</label>
                    <select value="@AqlInspectionLevel" @onchange="OnAqlLevelChanged">
                        <optgroup label="General Inspection">
                            <option value="I">Level I</option>
                            <option value="II">Level II</option>
                            <option value="III">Level III</option>
                        </optgroup>
                        <optgroup label="Special Inspection">
                            <option value="S1">S1</option>
                            <option value="S2">S2</option>
                            <option value="S3">S3</option>
                            <option value="S4">S4</option>
                        </optgroup>
                    </select>
                </div>
            </div>
            <div class="aql-defects-row">
                <div class="aql-defect-card critical">
                    <div class="aql-defect-header">Critical Defects</div>
                    <div class="field-group">
                        <label>Select AQL</label>
                        <select value="@CriticalAql" @onchange="OnCriticalAqlChanged">
                            <option value="0">Not Allowed</option>
                            <option value="0.065">0.065</option>
                            <option value="0.10">0.10</option>
                            <option value="0.15">0.15</option>
                            <option value="0.25">0.25</option>
                            <option value="0.40">0.40</option>
                            <option value="0.65">0.65</option>
                            <option value="1.0">1.0</option>
                            <option value="1.5">1.5</option>
                            <option value="2.5">2.5</option>
                            <option value="4.0">4.0</option>
                            <option value="6.5">6.5</option>
                        </select>
                    </div>
                    <div class="aql-stats">
                        <div class="aql-stat"><span>Sample Size</span><strong>@CriticalSampleSize</strong></div>
                        <div class="aql-stat"><span>Accept Point</span><strong class="accent-ok">@CriticalAccept</strong></div>
                        <div class="aql-stat"><span>Reject Point</span><strong class="accent-err">@CriticalReject</strong></div>
                    </div>
                </div>
                <div class="aql-defect-card major">
                    <div class="aql-defect-header">Major Defects</div>
                    <div class="field-group">
                        <label>Select AQL</label>
                        <select value="@MajorAql" @onchange="OnMajorAqlChanged">
                            <option value="0">Not Allowed</option>
                            <option value="0.065">0.065</option>
                            <option value="0.10">0.10</option>
                            <option value="0.15">0.15</option>
                            <option value="0.25">0.25</option>
                            <option value="0.40">0.40</option>
                            <option value="0.65">0.65</option>
                            <option value="1.0">1.0</option>
                            <option value="1.5">1.5</option>
                            <option value="2.5">2.5</option>
                            <option value="4.0">4.0</option>
                            <option value="6.5">6.5</option>
                        </select>
                    </div>
                    <div class="aql-stats">
                        <div class="aql-stat"><span>Sample Size</span><strong>@MajorSampleSize</strong></div>
                        <div class="aql-stat"><span>Accept Point</span><strong class="accent-ok">@MajorAccept</strong></div>
                        <div class="aql-stat"><span>Reject Point</span><strong class="accent-err">@MajorReject</strong></div>
                    </div>
                </div>
                <div class="aql-defect-card minor">
                    <div class="aql-defect-header">Minor Defects</div>
                    <div class="field-group">
                        <label>Select AQL</label>
                        <select value="@MinorAql" @onchange="OnMinorAqlChanged">
                            <option value="0">Not Allowed</option>
                            <option value="0.065">0.065</option>
                            <option value="0.10">0.10</option>
                            <option value="0.15">0.15</option>
                            <option value="0.25">0.25</option>
                            <option value="0.40">0.40</option>
                            <option value="0.65">0.65</option>
                            <option value="1.0">1.0</option>
                            <option value="1.5">1.5</option>
                            <option value="2.5">2.5</option>
                            <option value="4.0">4.0</option>
                            <option value="6.5">6.5</option>
                        </select>
                    </div>
                    <div class="aql-stats">
                        <div class="aql-stat"><span>Sample Size</span><strong>@MinorSampleSize</strong></div>
                        <div class="aql-stat"><span>Accept Point</span><strong class="accent-ok">@MinorAccept</strong></div>
                        <div class="aql-stat"><span>Reject Point</span><strong class="accent-err">@MinorReject</strong></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- A. Quantity Conformity -->
        <div class="ni-card">
            <div class="ni-section-title"><span class="section-alpha">A</span> Quantity Conformity</div>
            <div class="ni-grid-2">
                <div class="field-group">
                    <label>Total Shipment Quantity</label>
                    <div class="readonly-field">@(Model.TotalShipmentQty > 0 ? Model.TotalShipmentQty.ToString() : "Auto")</div>
                </div>
                <div class="field-group">
                    <label>Total Carton Boxes</label>
                    <div class="readonly-field">@(Model.TotalCartonBoxes > 0 ? Model.TotalCartonBoxes.ToString() : "Auto")</div>
                </div>
            </div>
        </div>

        <!-- B. Packaging & Identification -->
        <div class="ni-card">
            <div class="ni-section-title"><span class="section-alpha">B</span> Packaging &amp; Identification</div>

            <!-- Row 1: Item Number + Carton Number -->
            <div class="ni-grid-2" style="margin-bottom:14px;">
                <div class="field-group">
                    <label>Item Number</label>
                    <div class="readonly-field accent">@(string.IsNullOrEmpty(Packaging.ItemNumber) ? "Auto-filled from General Information" : Packaging.ItemNumber)</div>
                </div>
                <div class="field-group">
                    <label>Carton Number</label>
                    <input @bind="Packaging.CartonNumber" placeholder="Enter carton number" />
                </div>
            </div>

            <!-- Row 2: Radio options grid (2 col) -->
            <div class="pkg-grid">

                <div class="pkg2-row">
                    <span class="pkg2-label">Type of Packaging</span>
                    <div class="pkg2-options">
                        <label class="radio-label"><input type="radio" name="pkgType" checked="@(Packaging.PackagingType == PkgFsc)" @onchange="() => Packaging.PackagingType = PkgFsc" /><span>FSC Carton</span></label>
                        <label class="radio-label"><input type="radio" name="pkgType" checked="@(Packaging.PackagingType == PkgNonFsc)" @onchange="() => Packaging.PackagingType = PkgNonFsc" /><span>Non-FSC Carton</span></label>
                    </div>
                </div>

                <div class="pkg2-row">
                    <span class="pkg2-label">Shipping Mark</span>
                    <div class="pkg2-options">
                        <label class="radio-label"><input type="radio" name="shippingMark" checked="@(Packaging.ShippingMark == SmColorLabel)" @onchange="() => Packaging.ShippingMark = SmColorLabel" /><span>Color Label</span></label>
                        <label class="radio-label"><input type="radio" name="shippingMark" checked="@(Packaging.ShippingMark == SmPrinting)" @onchange="() => Packaging.ShippingMark = SmPrinting" /><span>Printing</span></label>
                    </div>
                </div>

                <div class="pkg2-row">
                    <span class="pkg2-label">Color of Carton</span>
                    <div class="pkg2-options">
                        <label class="radio-label"><input type="radio" name="cartonColor" checked="@(Packaging.CartonColor == ColWhite)" @onchange="() => Packaging.CartonColor = ColWhite" /><span>White</span></label>
                        <label class="radio-label"><input type="radio" name="cartonColor" checked="@(Packaging.CartonColor == ColBrown)" @onchange="() => Packaging.CartonColor = ColBrown" /><span>Brown</span></label>
                    </div>
                </div>

                <div class="pkg2-row">
                    <span class="pkg2-label">Barcode / QR Code</span>
                    <div class="pkg2-options">
                        <div class="toggle-group">
                            <button class="@ToggleCss(Packaging.HasBarcode)" @onclick="() => Packaging.HasBarcode = true">Yes</button>
                            <button class="@ToggleCss(!Packaging.HasBarcode)" @onclick="() => Packaging.HasBarcode = false">No</button>
                        </div>
                    </div>
                </div>

                <div class="pkg2-row">
                    <span class="pkg2-label">Type of Cardboard</span>
                    <div class="pkg2-options">
                        <label class="radio-label"><input type="radio" name="cardboard" checked="@(Packaging.CardboardType == CbSingleFace)" @onchange="() => Packaging.CardboardType = CbSingleFace" /><span>Single face</span></label>
                        <label class="radio-label"><input type="radio" name="cardboard" checked="@(Packaging.CardboardType == CbSingleWall)" @onchange="() => Packaging.CardboardType = CbSingleWall" /><span>Single Wall</span></label>
                        <label class="radio-label"><input type="radio" name="cardboard" checked="@(Packaging.CardboardType == CbDoubleWall)" @onchange="() => Packaging.CardboardType = CbDoubleWall" /><span>Double Wall</span></label>
                    </div>
                </div>

                <div class="pkg2-row">
                    <span class="pkg2-label">Assembly Instruction</span>
                    <div class="pkg2-options">
                        <div class="toggle-group">
                            <button class="@ToggleCss(Packaging.AssemblyInstruction)" @onclick="() => Packaging.AssemblyInstruction = true">Yes</button>
                            <button class="@ToggleCss(!Packaging.AssemblyInstruction)" @onclick="() => Packaging.AssemblyInstruction = false">No</button>
                        </div>
                    </div>
                </div>

                <div class="pkg2-row pkg2-span2">
                    <span class="pkg2-label">Hardware</span>
                    <div class="pkg2-options">
                        <div class="toggle-group">
                            <button class="@ToggleCss(Packaging.Hardware)" @onclick="() => Packaging.Hardware = true">Yes</button>
                            <button class="@ToggleCss(!Packaging.Hardware)" @onclick="() => Packaging.Hardware = false">No</button>
                        </div>
                    </div>
                </div>

            </div>

            <!-- Inner Packing -->
            <div class="pkg-sub-section">
                <span class="pkg-sub-title">Inner Packing</span>
                <div class="ni-grid-6">
                    <div class="field-group"><label>Quantity</label><input type="number" @bind="Packaging.InnerPackingQty" placeholder="0" /></div>
                    <div class="field-group"><label>L (mm)</label><input type="number" @bind="Packaging.InnerL" placeholder="0" /></div>
                    <div class="field-group"><label>W (mm)</label><input type="number" @bind="Packaging.InnerW" placeholder="0" /></div>
                    <div class="field-group"><label>H (mm)</label><input type="number" @bind="Packaging.InnerH" placeholder="0" /></div>
                    <div class="field-group"><label>Weight (Kgs)</label><input type="number" step="0.01" @bind="Packaging.InnerWeight" placeholder="0.00" /></div>
                    <div class="field-group"><label>Remark</label><input @bind="Packaging.InnerPackingRemark" placeholder="Remark..." /></div>
                </div>
            </div>

            <!-- Outer Packing -->
            <div class="pkg-sub-section">
                <span class="pkg-sub-title">Outer Packing</span>
                <div class="ni-grid-4">
                    <div class="field-group"><label>L (mm)</label><input type="number" @bind="Packaging.OuterL" placeholder="0" /></div>
                    <div class="field-group"><label>W (mm)</label><input type="number" @bind="Packaging.OuterW" placeholder="0" /></div>
                    <div class="field-group"><label>H (mm)</label><input type="number" @bind="Packaging.OuterH" placeholder="0" /></div>
                    <div class="field-group"><label>Weight (Kgs)</label><input type="number" step="0.01" @bind="Packaging.OuterWeight" placeholder="0.00" /></div>
                </div>
            </div>

        </div>

        <!-- C. Product Specification -->
        <div class="ni-card">
            <div class="ni-section-title"><span class="section-alpha">C</span> Product Specification</div>
            <div class="sub-section-label">i. Product Size</div>
            <div class="ni-grid-4" style="margin-bottom:20px;">
                <div class="field-group"><label>L (mm)</label><input type="number" @bind="ProductSpec.SizeL" placeholder="0" /></div>
                <div class="field-group"><label>W (mm)</label><input type="number" @bind="ProductSpec.SizeW" placeholder="0" /></div>
                <div class="field-group"><label>H (mm)</label><input type="number" @bind="ProductSpec.SizeH" placeholder="0" /></div>
                <div class="field-group"><label>Weight (Kgs)</label><input type="number" step="0.01" @bind="ProductSpec.Weight" placeholder="0.00" /></div>
            </div>
            <div class="compare-golden-row">
                <div class="sub-section-label" style="margin-bottom:0;">ii. Compare Golden Sample</div>
                <div class="toggle-group">
                    <button class="@ToggleCss(ProductSpec.CompareGoldenSample)" @onclick="() => ProductSpec.CompareGoldenSample = true">Yes</button>
                    <button class="@ToggleCss(!ProductSpec.CompareGoldenSample)" @onclick="() => ProductSpec.CompareGoldenSample = false">No</button>
                </div>
            </div>
            <div class="sub-section-label" style="margin-top:20px;">iii. Colour Swatch Comparison</div>
            <div class="data-table">
                <div class="data-table-header">
                    <div class="col-no">No</div>
                    <div class="col-flex">Material</div>
                </div>
                @for (int i = 0; i < ColourSwatches.Count; i++)
                {
                    var idx = i;
                    <div class="data-table-row">
                        <div class="col-no">@(idx + 1)</div>
                        <div class="col-flex"><input @bind="ColourSwatches[idx]" placeholder="Enter material..." class="table-input" /></div>
                    </div>
                }
                <button class="add-row-btn" @onclick="AddColourSwatch">+ Add Row</button>
            </div>
        </div>

        <!-- D. Performance Testing -->
        <div class="ni-card">
            <div class="ni-section-title"><span class="section-alpha">D</span> Performance Testing</div>
            @if (_loadingPerfMaster)
            {
                <div class="field-loading">Loading test master data...</div>
            }
