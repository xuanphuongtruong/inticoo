                    }
                    <button class="add-row-btn" @onclick="AddPerformanceTest">+ Add Row</button>
                </div>
            }
        </div>

        <!-- E. Reference -->
        <div class="ni-card">
            <div class="ni-section-title"><span class="section-alpha">E</span> Reference</div>
            @if (!string.IsNullOrEmpty(_mSaveRefError))
            {
                <div style="color:#dc2626;font-size:12px;margin-bottom:8px;">@_mSaveRefError</div>
            }
            <div class="data-table">
                <div class="data-table-header">
                    <div class="col-no">No</div>
                    <div class="col-flex2">Reference</div>
                    <div class="col-flex">Attached File</div>
                    <div class="col-flex">Remark</div>
                    <div style="width:80px;flex-shrink:0;"></div>
                </div>
                @for (int i = 0; i < References.Count; i++)
                {
                    var idx = i;
                    var refItem = References[idx];
                    <div class="data-table-row" @key="refItem.Id">
                        <div class="col-no">@(idx + 1)</div>
                        <div class="col-flex2">
                            @if (refItem.FromProduct)
                            {
                                <span class="table-input" style="color:#1a2d5a;display:block;padding:5px 4px;">@refItem.ReferenceName</span>
                            }
                            else
                            {
                                <input @bind="refItem.ReferenceName" placeholder="Reference name..." class="table-input" />
                            }
                        </div>
                        <div class="col-flex">
                            <span class="file-uploading" style="display:@(refItem.IsUploading ? "inline-flex" : "none")">⏳ Uploading...</span>
                            <div style="display:@(!refItem.IsUploading && !string.IsNullOrEmpty(refItem.UploadError) ? "flex" : "none");align-items:center;gap:6px;">
                                <span style="color:#dc2626;font-size:11.5px;max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@refItem.UploadError">⚠ @refItem.UploadError</span>
                                <label class="file-attach-btn" style="padding:3px 8px;font-size:11px;" title="Retry">
                                    Retry
                                    <InputFile OnChange="@(async e => await OnReferenceFileSelected(e, idx))" style="display:none;" />
                                </label>
                            </div>
                            <div style="display:@(!refItem.IsUploading && string.IsNullOrEmpty(refItem.UploadError) && !string.IsNullOrEmpty(refItem.FileUrl) ? "flex" : "none");align-items:center;gap:6px;">
                                @{ var fn = refItem.FileName ?? ""; }
                                <a href="@refItem.FileUrl" target="_blank" class="file-link-btn" title="@refItem.FileName">
                                    <svg width="12" height="12" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 17h12M10 3v10M6 13l4 4 4-4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                    @(fn.Length > 20 ? fn[..20] + "…" : (fn.Length > 0 ? fn : "(file)"))
                                </a>
                                @if (!refItem.FromProduct)
                                {
                                    <label class="file-reupload-btn" title="Change file">
                                        <svg width="11" height="11" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 3v10M6 7l4-4 4 4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                        <InputFile OnChange="@(async e => await OnReferenceFileSelected(e, idx))" style="display:none;" />
                                    </label>
                                }
                            </div>
                            @if (!refItem.FromProduct)
                            {
                                <label class="file-attach-btn" style="display:@(!refItem.IsUploading && string.IsNullOrEmpty(refItem.UploadError) && string.IsNullOrEmpty(refItem.FileUrl) ? "inline-flex" : "none");">
                                    <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 3v10M6 7l4-4 4 4" stroke-linecap="round" stroke-linejoin="round"/><path d="M4 17h12" stroke-linecap="round"/></svg>
                                    Attach File
                                    <InputFile OnChange="@(async e => await OnReferenceFileSelected(e, idx))" style="display:none;" />
                                </label>
                            }
                            else if (string.IsNullOrEmpty(refItem.FileUrl))
                            {
                                <span style="font-size:11px;color:#b0bdd4;font-style:italic;">No file</span>
                            }
                        </div>
                        <div class="col-flex">
                            @if (refItem.FromProduct)
                            {
                                <span style="font-size:12.5px;color:#4a6080;">@refItem.Remark</span>
                            }
                            else
                            {
                                <input @bind="refItem.Remark" placeholder="Remark..." class="table-input" />
                            }
                        </div>
                        <div style="width:80px;flex-shrink:0;display:flex;align-items:center;justify-content:center;">
                            @if (!refItem.FromProduct && _currentProductId > 0)
                            {
                                <button class="btn-ref-save" @onclick="() => SaveProductReference(idx)" disabled="@refItem.IsSaving">
                                    @(refItem.IsSaving ? "..." : "Save")
                                </button>
                            }
                            else if (refItem.FromProduct)
                            {
                                <span style="font-size:10px;color:#9baac8;">Product</span>
                            }
                        </div>
                    </div>
                }
                <button class="add-row-btn" @onclick="AddReference">+ Add Row</button>
            </div>
        </div>

        <!-- Office Use -->
        <div class="ni-card office-card">
            <div class="ni-section-title">Office Use</div>
            <div class="office-inline-row">
                <div class="field-group">
                    <label>Inspector ID</label>
                    @if (_loadingInspectors)
                    {
                        <div class="field-loading">Loading...</div>
                    }
                    else
                    {
                        <select value="@OfficeUse.InspectorId" @onchange="OnInspectorChanged" class="highlight-field">
                            <option value="">-- Select Inspector --</option>
                            @foreach (var u in _inspectors)
                            {
                                var key = !string.IsNullOrEmpty(u.InspectorId) ? u.InspectorId : u.Id;
                                <option value="@key">@(string.IsNullOrEmpty(u.InspectorId) ? u.FullName : $"{u.InspectorId} — {u.FullName}")</option>
                            }
                        </select>
                    }
                </div>
                <div class="field-group">
                    <label>Inspector Name</label>
                    <div class="readonly-field @(string.IsNullOrEmpty(OfficeUse.InspectorName) ? "" : "accent")">
                        @(string.IsNullOrEmpty(OfficeUse.InspectorName) ? "Auto-filled from ID" : OfficeUse.InspectorName)
                    </div>
                </div>
                <div class="field-group">
                    <label>Job Number</label>
                    <div class="readonly-field accent">Auto</div>
                </div>
            </div>
        </div>

        <!-- Submit row -->
        <div class="ni-submit-row">
            <button class="btn-cancel" @onclick="GoBack">Cancel</button>
            @if (_validationErrors.Count > 0)
            {
                <div class="ni-save-error">
                    <strong>Please fix the following errors:</strong>
                    <ul style="margin:6px 0 0 0;padding-left:18px;">
                        @foreach (var err in _validationErrors)
                        {
                            <li>@err</li>
                        }
                    </ul>
                </div>
            }
            else if (!string.IsNullOrEmpty(_saveError))
            {
                <div class="ni-save-error">@_saveError</div>
            }
            <button class="btn-save large" @onclick="HandleSave" disabled="@_saving">
                @if (_saving)
                {
                    <span class="ni-spinner"></span>
                    <span>Saving...</span>
                }
                else
                {
                    <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M5 10l4 4 8-8" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span>Save Inspection</span>
                }
            </button>
        </div>

    </div>
</div>

@code {
    // ── String constants — tránh inline string literals trong Razor attributes ──
    private const string PkgFsc       = "FSC Carton";
    private const string PkgNonFsc    = "Non-FSC Carton";
    private const string ColWhite     = "White";
    private const string ColBrown     = "Brown";
    private const string CbSingleFace = "Single face";
    private const string CbSingleWall = "Single Wall";
    private const string CbDoubleWall = "Double Wall";
    private const string SmColorLabel = "Color Label";
    private const string SmPrinting   = "Printing";

    // Helper CSS cho toggle button — tránh ternary với string literals trong attribute
    private static string ToggleCss(bool active) => active ? "toggle-btn active" : "toggle-btn";

    // ── State ──
    private InspectionModel  Model       = new();
    private PackagingModel   Packaging   = new();
    private ProductSpecModel ProductSpec = new();
    private OfficeUseModel   OfficeUse   = new();

    private List<string>             ColourSwatches   = new() { "", "", "" };
    private List<PerformanceTestRow> PerformanceTests = new() { new(), new(), new() };
    private List<ReferenceRow>       References       = new() { new(), new(), new(), new(), new() };

    private List<OverallConclusionRow> OverallConclusions = new()
    {
        new() { Letter = "A", Label = "Quantity Conformity" },
        new() { Letter = "B", Label = "Packaging & Identification" },
        new() { Letter = "C", Label = "Product Specification Compliance" },
        new() { Letter = "D", Label = "Performance Testing" },
        new() { Letter = "E", Label = "Appearance & Craftsmanship" },
        new() { Letter = "F", Label = "Details of Defect Found" },
    };

    private static string GetComplianceClass(string v) => v switch
    {
        "Pass" => "compliance-pass",
        "Fail" => "compliance-fail",
        "NA"   => "compliance-na",
        _      => ""
    };

    // ── Photos ──
    // PhotoPreview1  : data URL base64 dùng để preview ngay trên client (không phụ thuộc API base address)
    // Photo1ServerUrl: URL server trả về sau khi upload xong — dùng để lưu vào DB
    private string? PhotoPreview1   = null;
    private string? Photo1ServerUrl = null;
    private bool    _photoUploading = false;
    private string? _photoError     = null;

    // ── Helper upload chung — tránh ContentType null/empty gây crash ──
    private static string SafeContentType(string? ct) =>
        string.IsNullOrWhiteSpace(ct) ? "application/octet-stream" : ct;

    private async Task OnPhotoSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        _photoError      = null;
        Photo1ServerUrl  = null;

        // 1. Đọc bytes — giới hạn 5 MB
        byte[] bytes;
        try
        {
            using var s  = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var ms = new System.IO.MemoryStream();
            await s.CopyToAsync(ms);
            bytes = ms.ToArray();
        }
        catch (Exception ex)
        {
            _photoError = $"File quá lớn hoặc không đọc được: {ex.Message}";
            StateHasChanged();
            return;
        }

        // 2. Hiển thị preview ngay bằng data URL — không cần chờ upload
        var mime      = SafeContentType(file.ContentType);
        PhotoPreview1 = $"data:{mime};base64,{Convert.ToBase64String(bytes)}";
        _photoUploading = true;
        Waiting.Show("Uploading photo...");
        StateHasChanged();

        // 3. Upload lên server
        try
        {
            using var content = new MultipartFormDataContent();
            var sc = new ByteArrayContent(bytes);
            sc.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(mime);
            content.Add(sc, "file", file.Name);

            var token = await SessionStorage.GetItemAsync<string>("auth_token");
            if (!string.IsNullOrEmpty(token))
                Http.DefaultRequestHeaders.Authorization =
                    new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            var resp = await Http.PostAsync("api/files/upload-photo", content);
            if (resp.IsSuccessStatusCode)
            {
                var opts   = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var result = await resp.Content.ReadFromJsonAsync<UploadResult>(opts);
                Photo1ServerUrl = result?.Url ?? "";
                // Giữ nguyên PhotoPreview1 (data URL) để hiển thị ảnh — img src vẫn hoạt động
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                _photoError     = $"Upload thất bại ({(int)resp.StatusCode}): {body}";
                // Không xóa preview để user vẫn thấy ảnh đã chọn, nhưng biết chưa lưu được
            }
        }
        catch (Exception ex)
        {
            _photoError = $"Lỗi kết nối: {ex.Message}";
        }
        finally
        {
            _photoUploading = false;
            Waiting.Hide();
            StateHasChanged();
        }
    }

    private void RemovePhoto()
    {
        PhotoPreview1   = null;
        Photo1ServerUrl = null;
        _photoError     = null;
    }

    // ── Dropdowns ──
    private List<CustomerDropdownDto>  _customers  = new();
    private List<VendorDropdownDto>    _vendors    = new();
    private List<ProductDropdownDto>   _allProducts = new(); // toàn bộ
    private List<ProductDropdownDto>   _products    = new(); // đã lọc
    private List<InspectorDropdownDto> _inspectors  = new();
    private bool _loadingCustomers  = true;
    private bool _loadingVendors    = true;
    private bool _loadingProducts   = true;
    private bool _loadingInspectors = true;

    // Geo
    private List<CountryDto> _countries         = new();
    private int              _selectedCountryId = 0;
    private bool             _loadingCountries  = true;

    // ── Performance Test Master ──
    private List<PerformanceTestMasterDto> _perfMaster        = new();
    private List<string>                   _perfCategories    = new();
    private bool                           _loadingPerfMaster = true;
    private string                         _perfMasterError   = "";

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadCustomers(), LoadVendors(), LoadProducts(), LoadInspectors(), LoadCountries(), LoadPerformanceMaster());
        AqlQuantity = Model.TotalShipmentQty;
        if (AqlQuantity > 0) RecalcAql();
    }

    private async Task LoadCustomers()
    {
        try { _customers = await Http.GetFromJsonAsync<List<CustomerDropdownDto>>("api/customers/dropdown") ?? new(); }
        catch { _customers = new(); }
        finally { _loadingCustomers = false; }
    }

    private async Task LoadVendors()
    {
        try { _vendors = await Http.GetFromJsonAsync<List<VendorDropdownDto>>("api/vendors/dropdown") ?? new(); }
        catch { _vendors = new(); }
        finally { _loadingVendors = false; }
    }

    private void OnCustomerChanged(ChangeEventArgs e)
    {
        Model.CustomerId   = e.Value?.ToString() ?? "";
        var found          = _customers.FirstOrDefault(c => c.CustomerId == Model.CustomerId);
        Model.CustomerName = found?.CompanyName ?? "";
        FilterProducts();
    }

    private void OnVendorChanged(ChangeEventArgs e)
    {
        Model.VendorId   = e.Value?.ToString() ?? "";
        var found        = _vendors.FirstOrDefault(v => v.Code == Model.VendorId);
        Model.VendorName = found?.Name ?? "";
        FilterProducts();
    }

    private async Task LoadProducts()
    {
        try
        {
            _allProducts = await Http.GetFromJsonAsync<List<ProductDropdownDto>>("api/products/dropdown") ?? new();
            FilterProducts();
        }
        catch { _allProducts = new(); _products = new(); }
        finally { _loadingProducts = false; }
    }

    private void FilterProducts()
    {
        var list = _allProducts.AsEnumerable();
        if (!string.IsNullOrEmpty(Model.CustomerId))
            list = list.Where(p => p.CustomerId == Model.CustomerId);
        if (!string.IsNullOrEmpty(Model.VendorId))
            list = list.Where(p => p.VendorId == Model.VendorId);
        _products = list.ToList();
        // Reset product selection nếu product hiện tại không còn trong list
        if (!string.IsNullOrEmpty(Model.ProductCode) && !_products.Any(p => p.ProductCode == Model.ProductCode))
        {
            Model.ProductCode = "";
            Model.ProductName = "";
            Model.ProductCategory = "";
        }
    }

    private async Task OnItemNumberChanged(ChangeEventArgs e)
    {
        var itemNum = e.Value?.ToString()?.Trim() ?? "";
        Model.ItemNumber     = itemNum;
        Packaging.ItemNumber = itemNum;

        if (string.IsNullOrEmpty(itemNum)) return;

        // 1. Tìm trong _allProducts local trước
        var found = _allProducts.FirstOrDefault(p =>
            !string.IsNullOrEmpty(p.ItemNumber) &&
            p.ItemNumber.Equals(itemNum, StringComparison.OrdinalIgnoreCase));

        // 2. Nếu không có → gọi API search theo itemNumber
        if (found == null)
        {
            try
            {
                var opts = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var json = await Http.GetStringAsync($"api/products?pageSize=10&search={Uri.EscapeDataString(itemNum)}");
                using var doc = System.Text.Json.JsonDocument.Parse(json);
                var items = doc.RootElement.GetProperty("items");
                foreach (var item in items.EnumerateArray())
                {
                    var itNum = item.TryGetProperty("itemNumber", out var itProp) ? itProp.GetString() ?? "" : "";
                    if (itNum.Equals(itemNum, StringComparison.OrdinalIgnoreCase))
                    {
                        found = new ProductDropdownDto
                        {
                            Id          = item.TryGetProperty("id",          out var id) ? id.GetInt32()          : 0,
                            ProductCode = item.TryGetProperty("productCode", out var pc) ? pc.GetString() ?? ""   : "",
                            ProductName = item.TryGetProperty("productName", out var pn) ? pn.GetString() ?? ""   : "",
                            ItemNumber  = itNum,
                            ProductType = item.TryGetProperty("productType", out var pt) ? pt.GetString() ?? ""   : "",
                            Category    = item.TryGetProperty("category",    out var ca) ? ca.GetString() ?? ""   : "",
                            SizeL       = item.TryGetProperty("sizeL",   out var sl) && sl.ValueKind != System.Text.Json.JsonValueKind.Null ? sl.GetDouble() : null,
                            SizeW       = item.TryGetProperty("sizeW",   out var sw) && sw.ValueKind != System.Text.Json.JsonValueKind.Null ? sw.GetDouble() : null,
                            SizeH       = item.TryGetProperty("sizeH",   out var sh) && sh.ValueKind != System.Text.Json.JsonValueKind.Null ? sh.GetDouble() : null,
                            Weight      = item.TryGetProperty("weight",  out var wt) && wt.ValueKind != System.Text.Json.JsonValueKind.Null ? wt.GetDouble() : null,
                            PhotoUrl    = item.TryGetProperty("photoUrl",    out var ph) ? ph.GetString() ?? ""   : "",
                            CustomerId  = item.TryGetProperty("customerId",  out var ci) ? ci.GetString() ?? ""   : "",
                            VendorId    = item.TryGetProperty("vendorId",    out var vi) ? vi.GetString() ?? ""   : "",
                        };
                        break;
                    }
                }
            }
            catch { }
        }

        if (found != null)
        {
            ApplyProductToForm(found);
            StateHasChanged();
        }
    }

    private void OnProductChanged(ChangeEventArgs e)
    {
        Model.ProductCode = e.Value?.ToString() ?? "";
        var found = _products.FirstOrDefault(p => p.ProductCode == Model.ProductCode);
        if (found != null)
            ApplyProductToForm(found);
        else
        {
            Model.ProductName    = "";
            Model.ProductType    = "";
            Model.ProductCategory = "";
            Photo1ServerUrl      = null;
            PhotoPreview1        = null;
            ProductSpec.SizeL    = 0;
            ProductSpec.SizeW    = 0;
            ProductSpec.SizeH    = 0;
            ProductSpec.Weight   = 0;
        }
    }

    private int _currentProductId = 0;

    private void ApplyProductToForm(ProductDropdownDto p)
    {
        _currentProductId     = p.Id;
        Model.ProductCode     = p.ProductCode;
        Model.ProductName     = p.ProductName;
        Model.ProductType     = p.ProductType;
        Model.ProductCategory = p.Category;
        if (string.IsNullOrEmpty(Model.ItemNumber) && !string.IsNullOrEmpty(p.ItemNumber))
            Model.ItemNumber = p.ItemNumber;
        Packaging.ItemNumber = Model.ItemNumber;
        ProductSpec.SizeL   = p.SizeL   ?? 0;
        ProductSpec.SizeW   = p.SizeW   ?? 0;
        ProductSpec.SizeH   = p.SizeH   ?? 0;
        ProductSpec.Weight  = p.Weight  ?? 0;
        if (!string.IsNullOrEmpty(p.PhotoUrl))
        {
            var baseUrl = Http.BaseAddress?.ToString().TrimEnd('/') ?? "";
            PhotoPreview1   = p.PhotoUrl.StartsWith("http") ? p.PhotoUrl : $"{baseUrl}{p.PhotoUrl}";
            Photo1ServerUrl = PhotoPreview1;
        }
        // Load product references
        _ = LoadProductReferences(p.Id);
    }

    private async Task LoadProductReferences(int productId)
    {
        if (productId <= 0) return;
        try
        {
            var baseUrl = Http.BaseAddress?.ToString().TrimEnd('/') ?? "";
            var json = await Http.GetStringAsync($"api/products/{productId}");
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            var refs = new List<ReferenceRow>();
            if (doc.RootElement.TryGetProperty("references", out var refsEl))
            {
                int sort = 1;
                foreach (var r in refsEl.EnumerateArray())
                {
                    var rawUrl = r.TryGetProperty("fileUrl", out var rfu) ? rfu.GetString() ?? "" : "";
                    // Thêm base URL nếu là path tương đối
                    var fullUrl = !string.IsNullOrEmpty(rawUrl) && !rawUrl.StartsWith("http")
                        ? $"{baseUrl}{rawUrl}" : rawUrl;
                    refs.Add(new ReferenceRow
                    {
                        ProductRefId  = r.TryGetProperty("id",        out var rid)  ? rid.GetInt32()         : 0,
                        SortOrder     = sort++,
                        ReferenceName = r.TryGetProperty("name",      out var rn)   ? rn.GetString()  ?? ""  : "",
                        FileUrl       = fullUrl,
                        FileName      = r.TryGetProperty("fileName",  out var rfn)  ? rfn.GetString() ?? ""  : "",
                        FromProduct   = true
                    });
                }
            }
            // Giữ lại các row mới user đã thêm (không phải từ product)
            var newRows = References.Where(r => !r.FromProduct).ToList();
            References = refs.Concat(newRows).ToList();
            StateHasChanged();
        }
        catch { }
    }

    private async Task SaveProductReference(int idx)
    {
        if (_currentProductId <= 0 || idx >= References.Count) return;
        var row = References[idx];
        row.IsSaving = true;
        _mSaveRefError = "";
        StateHasChanged();
        try
        {
            // Lấy thông tin product hiện tại để giữ nguyên các field bắt buộc
            var prod = _allProducts.FirstOrDefault(p => p.Id == _currentProductId);
            if (prod == null)
            {
                _mSaveRefError = "Product not found.";
                return;
            }

            // Build updated references: all FromProduct rows + new row being saved
            var allRefs = References
                .Where(r => r.FromProduct || r == row)
                .Select((r, i) => new
                {
                    SortOrder = i + 1,
                    Name      = r.ReferenceName,
                    FileUrl   = r.FileUrl,
                    FileName  = r.FileName
                })
                .ToList();

            // PUT với đầy đủ fields bắt buộc
            var resp = await Http.PutAsJsonAsync($"api/products/{_currentProductId}", new
            {
                customerId   = prod.CustomerId,
                vendorId     = prod.VendorId,
                category     = prod.Category,
                productType  = prod.ProductType,
                productName  = prod.ProductName,
                productCode  = prod.ProductCode,
                itemNumber   = prod.ItemNumber,
                sizeL        = prod.SizeL,
                sizeW        = prod.SizeW,
                sizeH        = prod.SizeH,
                weight       = prod.Weight,
                photoUrl     = prod.PhotoUrl,
                references   = allRefs
            });

            if (resp.IsSuccessStatusCode)
            {
                row.FromProduct = true;
                await LoadProductReferences(_currentProductId);
            }
            else
            {
                var err = await resp.Content.ReadAsStringAsync();
                _mSaveRefError = $"Save failed: {err}";
            }
        }
        catch (Exception ex) { _mSaveRefError = ex.Message; }
        finally { row.IsSaving = false; StateHasChanged(); }
    }

