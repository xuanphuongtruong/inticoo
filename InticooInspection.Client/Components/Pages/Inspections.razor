@page "/inspections"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient Http
@inject NavigationManager Navigation
@inject Blazored.SessionStorage.ISessionStorageService SessionStorage
@inject AuthenticationStateProvider AuthStateProvider
@using InticooInspection.Client.Services
@inject WaitingService Waiting

<PageTitle>Inspection Plan Schedule - Inticoo</PageTitle>

<div class="page-container">

    <!-- Top bar -->
    <div class="top-bar">
        <div class="title-block">
            <h1 class="page-title">Inspection Plan Schedule</h1>
            <span class="page-sub">Manage and track all inspections</span>
        </div>
        <div class="sep"></div>
        <div class="search-wrap">
            <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="9" cy="9" r="6"/><path d="M15 15l-3.5-3.5" stroke-linecap="round"/>
            </svg>
            <input class="search-input" type="text" placeholder="Search job no, customer, product..."
                   @bind="_search" @bind:event="oninput" @onkeyup="OnSearchKeyUp" />
        </div>
        <select class="filter-select" @bind="_statusFilter" @bind:after="() => LoadPage(1)">
            <option value="">All Status</option>
            <option value="New">New</option>
            <option value="OnGoing">On Going</option>
            <option value="Completed">Completed</option>
            <option value="Pending">Pending</option>
            <option value="Cancel">Cancel</option>
        </select>
        <select class="filter-select" @bind="_categoryFilter" @bind:after="() => LoadPage(1)">
            <option value="">All Categories</option>
            <option value="Mechanical">Mechanical</option>
            <option value="Electrical">Electrical</option>
            <option value="Chemical">Chemical</option>
            <option value="Textile">Textile</option>
            <option value="Furniture">Furniture</option>
            <option value="Electronics">Electronics</option>
            <option value="Packaging">Packaging</option>
            <option value="Food &amp; Beverage">Food &amp; Beverage</option>
            <option value="Other">Other</option>
        </select>
        <button class="btn-add" @onclick="GoToNew">
            <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M10 4v12M4 10h12" stroke-linecap="round"/>
            </svg>
            New Inspection
        </button>
    </div>

    @if (!string.IsNullOrEmpty(_pageError))
    {
        <div class="alert-err">⚠ @_pageError</div>
    }

    @if (_loading)
    {
        <div class="loading-state">
            <div class="spinner-lg"></div>
            <span>Loading...</span>
        </div>
    }
    else
    {
        <!-- Table -->
        <div class="table-wrap">
            <table class="ptable">
                <thead>
                    <tr>
                        <th rowspan="2" class="th-no">No</th>
                        <th rowspan="2" class="th-y">Receive Date</th>
                        <th rowspan="2" class="th-y">Job No</th>
                        <th rowspan="2" class="th-y">Inspection Date</th>
                        <th rowspan="2" class="th-y">Customer Name</th>
                        <th rowspan="2" class="th-y">Category</th>
                        <th rowspan="2" class="th-y">Inspection Type</th>
                        <th rowspan="2" class="th-y">Vendor Name</th>
                        <th colspan="2" class="th-grp">Vendor Address</th>
                        <th rowspan="2" class="th-y">Inspector Name</th>
                        <th rowspan="2" class="th-y">Inspector ID</th>
                        <th rowspan="2" class="th-y">Status</th>
                        @if (!_isCustomer) { <th rowspan="2" class="th-act">Action</th> }
                    </tr>
                    <tr>
                        <th class="th-y">Address</th>
                        <th class="th-y">Country</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_inspections.Count == 0)
                    {
                        <tr><td colspan="15" class="td-empty">No inspections found.</td></tr>
                    }
                    else
                    {
                        int rowNo = (_page - 1) * _pageSize;
                        @foreach (var item in _inspections)
                        {
                            rowNo++;
                            var it = item;
                            <tr class="@(rowNo % 2 == 1 ? "" : "tr-alt")">
                                <td class="tc td-no">@rowNo</td>
                                <td class="tc">@it.CreatedAt.ToString("dd/MM/yyyy")</td>
                                <td class="tc mono">@(string.IsNullOrEmpty(it.JobNumber) ? "—" : it.JobNumber)</td>
                                <td class="tc">@(it.InspectionDate.HasValue ? it.InspectionDate.Value.ToString("dd/MM/yyyy") : "—")</td>
                                <td class="fw">@(string.IsNullOrEmpty(it.CustomerName) ? "—" : it.CustomerName)</td>
                                <td>@(string.IsNullOrEmpty(it.ProductCategory) ? "—" : it.ProductCategory)</td>
                                <td class="tc">
                                    @if (!string.IsNullOrEmpty(it.InspectionType))
                                    {
                                        <span class="type-badge">@it.InspectionType</span>
                                    }
                                    else { <span class="dash">—</span> }
                                </td>
                                <td>@(string.IsNullOrEmpty(it.VendorName) ? "—" : it.VendorName)</td>
                                <td class="addr-cell">@(string.IsNullOrEmpty(it.City) ? "—" : it.City)</td>
                                <td class="tc">@(string.IsNullOrEmpty(it.VendorCountry) ? "—" : it.VendorCountry)</td>
                                <td>@(string.IsNullOrEmpty(it.InspectorName) ? "—" : it.InspectorName)</td>
                                <td class="tc mono">@(string.IsNullOrEmpty(it.InspectorId) ? "—" : it.InspectorId)</td>
                                <td class="tc">
                                    <span class="@GetBadgeClass(it.Status)">@GetStatusLabel(it.Status)</span>
                                </td>
                                <td class="tc">
                                    @* Nếu status là New, OnGoing, Pending → cho phép Edit + Delete *@
                                    @if (!_isCustomer)
                                    {
                                        @if (CanEdit(it.Status))
                                        {
                                            <button class="bico bedit" @onclick="() => GoToEdit(it.Id)" title="Edit">
                                                <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
                                                    <path d="M14 2l4 4-10 10H4v-4L14 2z" stroke-linecap="round" stroke-linejoin="round"/>
                                                </svg>
                                            </button>
                                            <button class="bico bdel" @onclick="() => ConfirmDelete(it)" title="Delete">
                                                <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
                                                    <path d="M4 6h12M8 6V4h4v2M7 6v10h6V6" stroke-linecap="round" stroke-linejoin="round"/>
                                                </svg>
                                            </button>
                                            <button class="bico bcancel" @onclick="() => ConfirmCancel(it)" title="Cancel">
                                                <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                                                    <circle cx="10" cy="10" r="7.5"/>
                                                    <path d="M5.5 5.5l9 9" stroke-linecap="round"/>
                                                </svg>
                                            </button>
                                        }
                                        else
                                        {
                                            @* Completed → Inspection Report | Cancel → Detail *@
                                            @if (it.Status == "Completed")
                                            {
                                                <button class="bico bview bview-report" @onclick="() => GoToReport(it.Id)" title="View Report">
                                                    <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
                                                        <path d="M2 10s3-6 8-6 8 6 8 6-3 6-8 6-8-6-8-6z" stroke-linecap="round"/>
                                                        <circle cx="10" cy="10" r="2.5"/>
                                                    </svg>
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="bico bview" @onclick="() => GoToDetail(it.Id)" title="View">
                                                    <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
                                                        <path d="M2 10s3-6 8-6 8 6 8 6-3 6-8 6-8-6-8-6z" stroke-linecap="round"/>
                                                        <circle cx="10" cy="10" r="2.5"/>
                                                    </svg>
                                                </button>
                                            }
                                        }
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (_total > _pageSize)
        {
            <div class="pagination">
                <button class="page-btn" disabled="@(_page == 1)" @onclick="PrevPage">← Prev</button>
                <span class="page-info">Page @_page / @TotalPages() &nbsp;·&nbsp; @_total records</span>
                <button class="page-btn" disabled="@(_page >= TotalPages())" @onclick="NextPage">Next →</button>
            </div>
        }
        else if (_total > 0)
        {
            <div class="pagination">
                <span class="page-info">@_total record@(_total > 1 ? "s" : "")</span>
            </div>
        }
    }
</div>

<!-- Delete Confirmation Modal -->
@if (_deleteTarget != null)
{
    <div class="modal-backdrop" @onclick="CancelDelete">
        <div class="modal-box" @onclick:stopPropagation="true">
            <div class="modal-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2">
                    <path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
            <h3 class="modal-title">Delete Inspection</h3>
            <p class="modal-msg">
                Are you sure you want to delete
                <strong>@(string.IsNullOrEmpty(_deleteTarget.JobNumber) ? $"#{_deleteTarget.Id}" : _deleteTarget.JobNumber)</strong>?
                This action cannot be undone.
            </p>
            @if (!string.IsNullOrEmpty(_deleteError))
            {
                <div class="modal-err">@_deleteError</div>
            }
            <div class="modal-actions">
                <button class="btn-cancel-modal" @onclick="CancelDelete" disabled="@_deleting">Cancel</button>
                <button class="btn-del-confirm" @onclick="ExecuteDelete" disabled="@_deleting">
                    @if (_deleting) { <span>Deleting...</span> } else { <span>Delete</span> }
                </button>
            </div>
        </div>
    </div>
}

<!-- Cancel Confirmation Modal -->
@if (_cancelTarget != null)
{
    <div class="modal-backdrop" @onclick="CancelCancelAction">
        <div class="modal-box" @onclick:stopPropagation="true">
            <div class="modal-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="M8 8l8 8M16 8l-8 8" stroke-linecap="round"/>
                </svg>
            </div>
            <h3 class="modal-title">Cancel Inspection</h3>
            <p class="modal-msg">
                Are you sure you want to cancel
                <strong>@(string.IsNullOrEmpty(_cancelTarget.JobNumber) ? $"#{_cancelTarget.Id}" : _cancelTarget.JobNumber)</strong>?
                This will mark the inspection as <strong>Cancelled</strong>.
            </p>
            @if (!string.IsNullOrEmpty(_cancelError))
            {
                <div class="modal-err">@_cancelError</div>
            }
            <div class="modal-actions">
                <button class="btn-cancel-modal" @onclick="CancelCancelAction" disabled="@_cancelling">Back</button>
                <button class="btn-cancel-confirm" @onclick="ExecuteCancel" disabled="@_cancelling">
                    @if (_cancelling) { <span>Cancelling...</span> } else { <span>Confirm Cancel</span> }
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<InspectionRow> _inspections = new();
    private bool   _loading      = true;
    private string _search          = "";
    private string _statusFilter    = "";
    private string _categoryFilter  = "";
    private int    _page         = 1;
    private int    _pageSize     = 20;
    private int    _total        = 0;
    private string _pageError    = "";

    // Role-based filter — set khi init, truyền vào URL
    private string _filterInspectorId = "";
    private string _filterCustomerId  = "";
    private bool   _isCustomer        = false;  // dùng để ẩn Action column

    // Delete state
    private InspectionRow? _deleteTarget = null;
    private bool           _deleting     = false;
    private string         _deleteError  = "";

    // Cancel state
    private InspectionRow? _cancelTarget = null;
    private bool           _cancelling   = false;
    private string         _cancelError  = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user      = authState.User;

        if (user.IsInRole("Inspector") || user.IsInRole("Customer"))
        {
            _isCustomer = user.IsInRole("Customer");

            // Lấy username từ claims (tên chuẩn của Identity)
            var username = user.Identity?.Name
                        ?? user.FindFirst("name")?.Value
                        ?? user.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value
                        ?? "";

            Console.WriteLine($"[Inspections] Role filter — username={username}, isCustomer={_isCustomer}");

            if (!string.IsNullOrEmpty(username))
            {
                try
                {
                    var token = await SessionStorage.GetItemAsync<string>("auth_token");
                    if (!string.IsNullOrEmpty(token))
                        Http.DefaultRequestHeaders.Authorization =
                            new AuthenticationHeaderValue("Bearer", token);

                    // Tìm user theo username để lấy InspectorId / CustomerId
                    var opts = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                    var json = await Http.GetStringAsync(
                        $"api/users?search={Uri.EscapeDataString(username)}&pageSize=5");

                    Console.WriteLine($"[Inspections] api/users response: {json}");

                    var result = System.Text.Json.JsonSerializer.Deserialize<UserPageResult>(json, opts);
                    var me = result?.Items?.FirstOrDefault(u =>
                        string.Equals(u.Username, username, StringComparison.OrdinalIgnoreCase));

                    Console.WriteLine($"[Inspections] me={me?.Username}, InspectorId={me?.InspectorId}, CustomerId={me?.CustomerId}");

                    if (me != null)
                    {
                        if (user.IsInRole("Inspector"))
                            _filterInspectorId = me.InspectorId ?? "";
                        else if (user.IsInRole("Customer"))
                            _filterCustomerId = me.CustomerId ?? "";
                    }
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"[Inspections] Error resolving user filter: {ex.Message}");
                }
            }
        }
        // Admin: không filter, load hết

        await LoadPage(1);

        // Client-side fallback: lọc lại sau khi load phòng trường hợp backend chưa filter
        if (!string.IsNullOrEmpty(_filterCustomerId))
        {
            _inspections = _inspections.Where(i =>
                !string.IsNullOrEmpty(i.CustomerId) &&
                i.CustomerId.Equals(_filterCustomerId, StringComparison.OrdinalIgnoreCase)
            ).ToList();
            Console.WriteLine($"[Inspections] After client filter customerId={_filterCustomerId}: {_inspections.Count} rows");
        }
        else if (!string.IsNullOrEmpty(_filterInspectorId))
        {
            _inspections = _inspections.Where(i =>
                !string.IsNullOrEmpty(i.InspectorId) &&
                i.InspectorId.Equals(_filterInspectorId, StringComparison.OrdinalIgnoreCase)
            ).ToList();
            Console.WriteLine($"[Inspections] After client filter inspectorId={_filterInspectorId}: {_inspections.Count} rows");
        }
    }

    private void GoToNew()          => Navigation.NavigateTo("/inspections/new");
    private void GoToEdit(int id)   => Navigation.NavigateTo($"/inspections/{id}/edit");
    private void GoToDetail(int id) => Navigation.NavigateTo($"/inspections/{id}");
    private void GoToReport(int id)  => Navigation.NavigateTo($"/inspection-report/{id}");
    private async Task PrevPage()   => await LoadPage(_page - 1);
    private async Task NextPage()   => await LoadPage(_page + 1);
    private int TotalPages()        => (_total + _pageSize - 1) / _pageSize;

    // ── Status logic ──────────────────────────────────────────────
    // 0 = New | 1 = OnGoing | 2 = Completed | 3 = Pending | 4 = Cancel

    /// <summary>Map status string từ API về chuẩn hiển thị.</summary>
    private static string NormalizeStatus(string? raw) => raw?.ToLower() switch
    {
        "new"       => "New",
        "ongoing"   => "OnGoing",
        "completed" => "Completed",
        "pending"   => "Pending",
        "cancel"    => "Cancel",
        "cancelled" => "Cancel",
        _           => "New"
    };

    /// <summary>Cho phép Edit/Delete khi: New (0), OnGoing (1), Pending (3).</summary>
    private static bool CanEdit(string status) => status switch
    {
        "New"     => true,
        "OnGoing" => true,
        "Pending" => true,
        _         => false
    };

    private string GetBadgeClass(string status) => status switch
    {
        "New"       => "badge s-new",
        "OnGoing"   => "badge s-progress",
        "Completed" => "badge s-active",
        "Pending"   => "badge s-pending",
        "Cancel"    => "badge s-inactive",
        _           => "badge s-new"
    };

    private string GetStatusLabel(string status) => status switch
    {
        "New"       => "New",
        "OnGoing"   => "On Going",
        "Completed" => "Completed",
        "Pending"   => "Pending",
        "Cancel"    => "Cancel",
        _           => status
    };

    // ── Delete ────────────────────────────────────────────────────
    private void ConfirmDelete(InspectionRow item) { _deleteTarget = item; _deleteError = ""; }
    private void CancelDelete()                    { _deleteTarget = null; _deleteError = ""; }

    private async Task ExecuteDelete()
    {
        if (_deleteTarget == null) return;
        _deleting = true; _deleteError = "";
        Waiting.Show("Deleting inspection...");
        try
        {
            var token = await SessionStorage.GetItemAsync<string>("auth_token");
            if (string.IsNullOrEmpty(token)) { _deleteError = "Session expired. Please log in again."; return; }
            Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

            var resp = await Http.DeleteAsync($"api/inspections/{_deleteTarget.Id}");
            if (resp.IsSuccessStatusCode)          { _deleteTarget = null; await LoadPage(_page); }
            else if ((int)resp.StatusCode == 401)  _deleteError = "Unauthorized. Please log in again.";
            else if ((int)resp.StatusCode == 403)  _deleteError = "You do not have permission to delete this inspection.";
            else                                   _deleteError = $"Delete failed ({(int)resp.StatusCode})";
        }
        catch (Exception ex) { _deleteError = ex.Message; }
        finally { _deleting = false; Waiting.Hide(); }
    }

    // ── Cancel ────────────────────────────────────────────────────
    private void ConfirmCancel(InspectionRow item) { _cancelTarget = item; _cancelError = ""; }
    private void CancelCancelAction()              { _cancelTarget = null; _cancelError = ""; }

    private async Task ExecuteCancel()
    {
        if (_cancelTarget == null) return;
        _cancelling = true; _cancelError = "";
        Waiting.Show("Cancelling inspection...");
        try
        {
            var token = await SessionStorage.GetItemAsync<string>("auth_token");
            if (string.IsNullOrEmpty(token)) { _cancelError = "Session expired. Please log in again."; return; }
            Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

            // Backend enum: InspectionStatus.Cancelled
            var body = new { Status = "Cancelled" };
            var resp = await Http.PutAsJsonAsync($"api/inspections/{_cancelTarget.Id}/status", body);

            if (resp.IsSuccessStatusCode)          { _cancelTarget = null; await LoadPage(_page); }
            else if ((int)resp.StatusCode == 401)  _cancelError = "Unauthorized. Please log in again.";
            else if ((int)resp.StatusCode == 403)  _cancelError = "You do not have permission to cancel this inspection.";
            else                                   _cancelError = $"Cancel failed ({(int)resp.StatusCode})";
        }
        catch (Exception ex) { _cancelError = ex.Message; }
        finally { _cancelling = false; Waiting.Hide(); }
    }

    // ── Load ──────────────────────────────────────────────────────
    private async Task LoadPage(int page)
    {
        _loading = true; _page = page;
        try
        {
            var token = await SessionStorage.GetItemAsync<string>("auth_token");
            if (!string.IsNullOrEmpty(token))
                Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

            var url = $"api/inspections?page={page}&pageSize={_pageSize}" +
                      $"&status={Uri.EscapeDataString(_statusFilter)}" +
                      $"&search={Uri.EscapeDataString(_search)}" +
                      $"&category={Uri.EscapeDataString(_categoryFilter)}";

            // Role-based filter
            if (!string.IsNullOrEmpty(_filterInspectorId))
                url += $"&inspectorId={Uri.EscapeDataString(_filterInspectorId)}";
            else if (!string.IsNullOrEmpty(_filterCustomerId))
                url += $"&customerId={Uri.EscapeDataString(_filterCustomerId)}";
            var opts = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var resp = await Http.GetAsync(url);
            if (!resp.IsSuccessStatusCode) { _pageError = $"Load failed ({(int)resp.StatusCode})"; return; }

            var json   = await resp.Content.ReadAsStringAsync();
            var result = System.Text.Json.JsonSerializer.Deserialize<PageResult>(json, opts);
            if (result != null)
            {
                // Normalize status cho mỗi item
                foreach (var item in result.Items)
                    item.Status = NormalizeStatus(item.Status);

                // Client-side category filter (backup nếu backend chưa hỗ trợ param category)
                var items = result.Items.AsEnumerable();
                if (!string.IsNullOrEmpty(_categoryFilter))
                    items = items.Where(i =>
                        !string.IsNullOrEmpty(i.ProductCategory) &&
                        i.ProductCategory.Equals(_categoryFilter, StringComparison.OrdinalIgnoreCase));

                _inspections = items.ToList();
                _total       = result.Total;
                _pageError   = "";
            }
        }
        catch (Exception ex) { _pageError = ex.Message; }
        finally { _loading = false; }
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await LoadPage(1);
    }

    // ── DTOs ──────────────────────────────────────────────────────
    private class PageResult
    {
        public int Total { get; set; }
        public List<InspectionRow> Items { get; set; } = new();
    }

    private class InspectionRow
    {
        public int       Id              { get; set; }
        public string    Title           { get; set; } = "";
        public string    Status          { get; set; } = "";
        public DateTime  CreatedAt       { get; set; }
        public string?   CreatedByName   { get; set; }
        public string?   JobNumber       { get; set; }
        public DateTime? InspectionDate  { get; set; }
        public string?   CustomerName    { get; set; }
        public string?   CustomerId      { get; set; }
        public string?   VendorName      { get; set; }
        public string?   VendorId        { get; set; }
        public string?   VendorAddress   { get; set; }
        public string?   VendorCountry   { get; set; }
        public string?   ProductCategory { get; set; }
        public string?   ProductType     { get; set; }
        public string?   InspectionType  { get; set; }
        public string?   InspectorName   { get; set; }
        public string?   InspectorId     { get; set; }
    }

    // DTOs để resolve InspectorId/CustomerId từ api/users
    private class UserPageResult
    {
        public int Total { get; set; }
        public List<CurrentUserDto> Items { get; set; } = new();
    }
    private class CurrentUserDto
    {
        public string  Username    { get; set; } = "";
        public string? InspectorId { get; set; }
        public string? CustomerId  { get; set; }
    }
}

<style>
    @@import url("https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Sora:wght@600;700&display=swap");
    .page-container { font-family:"DM Sans",sans-serif; padding:16px; box-sizing:border-box; max-width:100%; overflow-x:hidden; }
    .page-container *, .page-container *::before, .page-container *::after { box-sizing:border-box; }

    /* Top bar */
    .top-bar { display:flex; align-items:center; gap:10px; margin-bottom:14px; flex-wrap:wrap; }
    .title-block { display:flex; align-items:baseline; gap:10px; flex-shrink:0; margin-right:4px; }
    .page-title { font-family:"Sora",sans-serif; font-size:18px; font-weight:700; color:#fff; margin:0; white-space:nowrap; }
    .page-sub { font-size:12px; color:rgba(255,255,255,.45); white-space:nowrap; }
    .sep { width:1px; height:20px; background:rgba(255,255,255,.15); flex-shrink:0; }
