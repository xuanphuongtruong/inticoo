@page "/change-password"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient Http
@inject NavigationManager Navigation
@inject Blazored.SessionStorage.ISessionStorageService SessionStorage
@inject AuthenticationStateProvider AuthStateProvider
@using InticooInspection.Client.Services
@inject WaitingService Waiting

<PageTitle>Change Password - Inticoo</PageTitle>

<div class="page-container">

    <!-- Top bar -->
    <div class="top-bar">
        <div class="title-block">
            <h1 class="page-title">Change Password</h1>
            <span class="page-sub">Update your account password</span>
        </div>
    </div>

    <div class="cp-card">
        <div class="cp-header">
            <div class="cp-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="4" y="10" width="16" height="11" rx="2"/>
                    <path d="M8 10V7a4 4 0 0 1 8 0v3" stroke-linecap="round"/>
                    <circle cx="12" cy="15.5" r="1.2" fill="currentColor"/>
                </svg>
            </div>
            <div>
                <h2 class="cp-title">Update Password</h2>
                <p class="cp-sub">For security, please enter your current password before choosing a new one.</p>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-err">
                <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="10" cy="10" r="8"/><path d="M10 6v5M10 14h.01" stroke-linecap="round"/>
                </svg>
                <span>@_error</span>
            </div>
        }

        @if (_success)
        {
            <div class="alert alert-ok">
                <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="10" cy="10" r="8"/><path d="M6 10l3 3 5-6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>Password changed successfully. You will be signed out in a moment...</span>
            </div>
        }

        <div class="cp-form">
            <!-- User info (read-only) -->
            <div class="cp-userinfo">
                <div class="cp-userinfo-avatar">@GetInitials(_username)</div>
                <div class="cp-userinfo-txt">
                    <span class="cp-userinfo-lbl">Signed in as</span>
                    <span class="cp-userinfo-name">@_username</span>
                </div>
            </div>

            <!-- Current Password -->
            <div class="cp-field">
                <label>Current Password <span class="req">*</span></label>
                <div class="pw-wrap">
                    <input class="form-input"
                           type="@(_showCurrent ? "text" : "password")"
                           placeholder="Enter current password"
                           @bind="_currentPassword" @bind:event="oninput"
                           disabled="@_saving" />
                    <button type="button" class="pw-toggle" @onclick="() => _showCurrent = !_showCurrent" tabindex="-1">
                        @if (_showCurrent)
                        {
                            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
                                <path d="M2 10s3-6 8-6 8 6 8 6-3 6-8 6-8-6-8-6z" stroke-linecap="round"/>
                                <circle cx="10" cy="10" r="2.5"/>
                                <line x1="3" y1="3" x2="17" y2="17" stroke-linecap="round"/>
                            </svg>
                        }
                        else
                        {
                            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
                                <path d="M2 10s3-6 8-6 8 6 8 6-3 6-8 6-8-6-8-6z" stroke-linecap="round"/>
                                <circle cx="10" cy="10" r="2.5"/>
                            </svg>
                        }
                    </button>
                </div>
            </div>

            <!-- New Password -->
            <div class="cp-field">
                <label>New Password <span class="req">*</span></label>
                <div class="pw-wrap">
                    <input class="form-input"
                           type="@(_showNew ? "text" : "password")"
                           placeholder="At least 6 characters"
                           @bind="_newPassword" @bind:event="oninput"
                           disabled="@_saving" />
                    <button type="button" class="pw-toggle" @onclick="() => _showNew = !_showNew" tabindex="-1">
                        @if (_showNew)
                        {
                            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
                                <path d="M2 10s3-6 8-6 8 6 8 6-3 6-8 6-8-6-8-6z" stroke-linecap="round"/>
                                <circle cx="10" cy="10" r="2.5"/>
                                <line x1="3" y1="3" x2="17" y2="17" stroke-linecap="round"/>
                            </svg>
                        }
                        else
                        {
                            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
                                <path d="M2 10s3-6 8-6 8 6 8 6-3 6-8 6-8-6-8-6z" stroke-linecap="round"/>
                                <circle cx="10" cy="10" r="2.5"/>
                            </svg>
                        }
                    </button>
                </div>
                @if (!string.IsNullOrEmpty(_newPassword))
                {
                    <div class="pw-strength">
                        <div class="pw-bar">
                            <div class="pw-bar-fill @GetStrengthClass()" style="width:@(GetStrengthPercent())%;"></div>
                        </div>
                        <span class="pw-strength-lbl @GetStrengthClass()">@GetStrengthLabel()</span>
                    </div>
                }
            </div>

            <!-- Confirm Password -->
            <div class="cp-field">
                <label>Confirm New Password <span class="req">*</span></label>
                <div class="pw-wrap">
                    <input class="form-input"
                           type="@(_showConfirm ? "text" : "password")"
                           placeholder="Re-type new password"
                           @bind="_confirmPassword" @bind:event="oninput"
                           disabled="@_saving" />
                    <button type="button" class="pw-toggle" @onclick="() => _showConfirm = !_showConfirm" tabindex="-1">
                        @if (_showConfirm)
                        {
                            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
                                <path d="M2 10s3-6 8-6 8 6 8 6-3 6-8 6-8-6-8-6z" stroke-linecap="round"/>
                                <circle cx="10" cy="10" r="2.5"/>
                                <line x1="3" y1="3" x2="17" y2="17" stroke-linecap="round"/>
                            </svg>
                        }
                        else
                        {
                            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
                                <path d="M2 10s3-6 8-6 8 6 8 6-3 6-8 6-8-6-8-6z" stroke-linecap="round"/>
                                <circle cx="10" cy="10" r="2.5"/>
                            </svg>
                        }
                    </button>
                </div>
                @if (!string.IsNullOrEmpty(_confirmPassword) && _confirmPassword != _newPassword)
                {
                    <span class="field-hint-err">Passwords do not match</span>
                }
            </div>

            <!-- Actions -->
            <div class="cp-actions">
                <button class="btn-cancel" @onclick="Cancel" disabled="@_saving" type="button">Cancel</button>
                <button class="btn-submit" @onclick="Submit" disabled="@(_saving || _success || !CanSubmit())" type="button">
                    @if (_saving) { <span>Updating...</span> } else { <span>Update Password</span> }
                </button>
            </div>

            <div class="cp-hint">
                <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6">
                    <circle cx="10" cy="10" r="8"/><path d="M10 6v5M10 14h.01" stroke-linecap="round"/>
                </svg>
                <span>Tip: use at least 8 characters with a mix of letters, numbers, and symbols.</span>
            </div>
        </div>
    </div>
</div>

@code {
    private string _username        = "";
    private string _currentPassword = "";
    private string _newPassword     = "";
    private string _confirmPassword = "";

    private bool _showCurrent = false;
    private bool _showNew     = false;
    private bool _showConfirm = false;

    private bool   _saving  = false;
    private bool   _success = false;
    private string _error   = "";

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _username = state.User.Identity?.Name ?? "";

        // Attach token for authenticated requests
        var token = await SessionStorage.GetItemAsync<string>("auth_token");
        if (!string.IsNullOrEmpty(token))
            Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
    }

    private bool CanSubmit()
    {
        return !string.IsNullOrWhiteSpace(_currentPassword)
            && !string.IsNullOrWhiteSpace(_newPassword)
            && _newPassword.Length >= 6
            && _newPassword == _confirmPassword
            && _newPassword != _currentPassword;
    }

    private async Task Submit()
    {
        _error = "";
        if (string.IsNullOrWhiteSpace(_currentPassword))  { _error = "Please enter your current password.";      return; }
        if (string.IsNullOrWhiteSpace(_newPassword))      { _error = "Please enter a new password.";             return; }
        if (_newPassword.Length < 6)                      { _error = "New password must be at least 6 characters."; return; }
        if (_newPassword == _currentPassword)             { _error = "New password must be different from current password."; return; }
        if (_newPassword != _confirmPassword)             { _error = "Passwords do not match.";                  return; }

        _saving = true;
        Waiting.Show("Updating password...");

        try
        {
            var body = new
            {
                username        = _username,
                currentPassword = _currentPassword,
                newPassword     = _newPassword
            };
            var resp = await Http.PostAsJsonAsync("api/users/change-password", body);

            if (resp.IsSuccessStatusCode)
            {
                _success = true;
                // Clear inputs so nothing lingers in DOM
                _currentPassword = ""; _newPassword = ""; _confirmPassword = "";
                StateHasChanged();

                // Đợi 2s rồi logout để user đăng nhập lại với password mới
                await Task.Delay(2000);
                await SessionStorage.RemoveItemAsync("auth_token");
                Navigation.NavigateTo("/login", forceLoad: true);
            }
            else
            {
                try
                {
                    var err = await resp.Content.ReadFromJsonAsync<ErrorResponse>();
                    _error = err?.Message ?? $"Failed to update password ({(int)resp.StatusCode}).";
                }
                catch { _error = $"Failed to update password ({(int)resp.StatusCode})."; }
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; Waiting.Hide(); }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/dashboard");
    }

    // ── Password strength helpers ─────────────────────────────────
    private int GetStrengthScore()
    {
        var pw = _newPassword ?? "";
        if (pw.Length == 0) return 0;
        int score = 0;
        if (pw.Length >= 6)  score++;
        if (pw.Length >= 10) score++;
        if (pw.Any(char.IsUpper) && pw.Any(char.IsLower)) score++;
        if (pw.Any(char.IsDigit)) score++;
        if (pw.Any(c => !char.IsLetterOrDigit(c))) score++;
        return score;  // 0..5
    }
    private int    GetStrengthPercent() => Math.Min(100, GetStrengthScore() * 20);
    private string GetStrengthLabel()   => GetStrengthScore() switch
    {
        <= 1 => "Very weak",
        2    => "Weak",
        3    => "Fair",
        4    => "Strong",
        _    => "Very strong"
    };
    private string GetStrengthClass() => GetStrengthScore() switch
    {
        <= 1 => "pw-very-weak",
        2    => "pw-weak",
        3    => "pw-fair",
        4    => "pw-strong",
        _    => "pw-very-strong"
    };

    private string GetInitials(string name)
        => string.Concat((name ?? "").Split(" ").Take(2).Select(w => w.Length > 0 ? w[0].ToString().ToUpper() : ""));

    private class ErrorResponse
    {
        public bool   Success { get; set; }
        public string? Message { get; set; }
    }
}

<style>
    @@import url("https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Sora:wght@600;700&display=swap");
    .page-container { font-family:"DM Sans",sans-serif; padding:16px; box-sizing:border-box; }
    .page-container *, .page-container *::before, .page-container *::after { box-sizing:border-box; }

    /* Top bar */
    .top-bar { display:flex; align-items:center; margin-bottom:18px; }
    .title-block { display:flex; align-items:baseline; gap:10px; }
    .page-title { font-family:"Sora",sans-serif; font-size:18px; font-weight:700; color:#fff; margin:0; }
    .page-sub   { font-size:12px; color:rgba(255,255,255,.45); }

    /* Card */
    .cp-card {
        max-width:540px; margin:0 auto;
        background:#fff; border-radius:14px; padding:28px;
        box-shadow:0 10px 40px rgba(0,0,0,.2);
    }

    /* Header */
    .cp-header { display:flex; align-items:center; gap:14px; margin-bottom:22px; }
    .cp-icon {
        width:52px; height:52px; border-radius:14px;
        background:#e6f1fb; color:#1e90d6;
        display:flex; align-items:center; justify-content:center; flex-shrink:0;
    }
    .cp-title { font-family:"Sora",sans-serif; font-size:18px; font-weight:700; color:#1a2d5a; margin:0 0 3px; }
    .cp-sub   { font-size:13px; color:#7a8fad; margin:0; line-height:1.45; }

    /* User info strip */
    .cp-userinfo {
        display:flex; align-items:center; gap:12px;
        background:#f7fafd; border:1px solid #e0e8f3;
        border-radius:10px; padding:10px 14px; margin-bottom:18px;
    }
    .cp-userinfo-avatar {
        width:36px; height:36px; border-radius:50%;
        background:linear-gradient(135deg,#1e90d6,#1565c0); color:#fff;
        display:flex; align-items:center; justify-content:center;
        font-size:13px; font-weight:700; font-family:"Sora",sans-serif;
    }
    .cp-userinfo-txt { display:flex; flex-direction:column; line-height:1.2; }
    .cp-userinfo-lbl { font-size:11px; color:#9baac8; text-transform:uppercase; letter-spacing:.06em; }
    .cp-userinfo-name { font-size:14px; font-weight:600; color:#1a2d5a; margin-top:2px; }

    /* Form */
    .cp-form { display:flex; flex-direction:column; gap:16px; }
    .cp-field { display:flex; flex-direction:column; gap:6px; }
    .cp-field label { font-size:12px; font-weight:600; color:#4a6080; text-transform:uppercase; letter-spacing:.06em; }
    .req { color:#e53935; }

    .form-input {
        width:100%; padding:11px 13px; background:#f7fafd;
        border:1.5px solid #c9d8ee; border-radius:9px;
        color:#1a2d5a; font-size:14px; outline:none;
        font-family:inherit; transition:border-color .15s,box-shadow .15s;
    }
    .form-input:focus { border-color:#1e90d6; background:#fff; box-shadow:0 0 0 3px rgba(30,144,214,0.1); }
    .form-input::placeholder { color:#b0bdd4; }
    .form-input:disabled { background:#f0f4f8; color:#9baac8; cursor:not-allowed; }

    /* Password input with toggle */
    .pw-wrap { position:relative; }
    .pw-wrap .form-input { padding-right:42px; }
    .pw-toggle {
        position:absolute; top:50%; right:6px; transform:translateY(-50%);
        width:32px; height:32px; padding:0;
        background:transparent; border:none; border-radius:6px;
        color:#7a8fad; cursor:pointer;
        display:flex; align-items:center; justify-content:center;
        transition:background .15s,color .15s;
    }
    .pw-toggle:hover { background:#f0f4fb; color:#1e90d6; }

    /* Strength bar */
    .pw-strength { display:flex; align-items:center; gap:10px; margin-top:4px; }
    .pw-bar { flex:1; height:4px; background:#e6ecf5; border-radius:3px; overflow:hidden; }
    .pw-bar-fill { height:100%; border-radius:3px; transition:width .25s,background .25s; }
    .pw-strength-lbl { font-size:11px; font-weight:600; white-space:nowrap; }
    .pw-very-weak, .pw-very-weak.pw-bar-fill   { background:#ef4444; color:#ef4444; }
    .pw-weak, .pw-weak.pw-bar-fill             { background:#f59e0b; color:#f59e0b; }
    .pw-fair, .pw-fair.pw-bar-fill             { background:#eab308; color:#ca8a04; }
    .pw-strong, .pw-strong.pw-bar-fill         { background:#10b981; color:#059669; }
    .pw-very-strong, .pw-very-strong.pw-bar-fill { background:#059669; color:#047857; }

    .field-hint-err { font-size:12px; color:#dc2626; margin-top:2px; }

    /* Alerts */
    .alert {
        display:flex; align-items:center; gap:10px;
        padding:11px 14px; border-radius:10px;
        font-size:13.5px; margin-bottom:16px;
    }
    .alert-err { background:#fff5f5; border:1px solid #fca5a5; color:#dc2626; }
    .alert-ok  { background:#ecfdf5; border:1px solid #86efac; color:#059669; }
    .alert svg { flex-shrink:0; }

    /* Actions */
    .cp-actions { display:flex; gap:10px; justify-content:flex-end; margin-top:8px; }
    .btn-cancel {
        padding:10px 22px; background:#f0f4fb; border:1px solid #c9d8ee;
        border-radius:10px; color:#4a6080; font-size:13.5px; font-weight:500;
        cursor:pointer; font-family:"DM Sans",sans-serif; transition:background .15s;
    }
    .btn-cancel:hover:not(:disabled) { background:#e0eaf7; }
    .btn-submit {
        padding:10px 24px; background:#1e90d6; border:none;
        border-radius:10px; color:#fff; font-size:13.5px; font-weight:600;
        cursor:pointer; font-family:"DM Sans",sans-serif; transition:background .15s;
    }
    .btn-submit:hover:not(:disabled) { background:#1565c0; }
    .btn-submit:disabled, .btn-cancel:disabled { opacity:.55; cursor:not-allowed; }

    /* Hint */
    .cp-hint {
        display:flex; align-items:center; gap:8px;
        font-size:12px; color:#9baac8; margin-top:8px;
        padding-top:14px; border-top:1px dashed #e0e8f3;
    }
    .cp-hint svg { flex-shrink:0; }

    /* Responsive */
    @@media (max-width: 768px) {
        .page-container { padding:12px; }
        .cp-card { padding:22px 18px; }
        .cp-header { gap:10px; }
        .cp-icon { width:44px; height:44px; border-radius:11px; }
        .cp-title { font-size:16px; }
        .cp-sub { font-size:12.5px; }
        .cp-actions { flex-direction:column-reverse; gap:8px; }
        .btn-cancel, .btn-submit { width:100%; padding:12px 16px; }
    }

    /* iOS: input >= 16px to prevent zoom */
    @@supports (-webkit-touch-callout: none) {
        @@media (max-width: 768px) {
            .form-input { font-size:16px; }
        }
    }
</style>
