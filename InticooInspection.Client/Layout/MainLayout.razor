@inherits LayoutComponentBase
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject WaitingService Waiting
@using InticooInspection.Client.Services

<div class="app-layout">
    <!-- TOP NAVBAR -->
    <header class="top-navbar">
        <div class="navbar-inner">

            <!-- Logo -->
            <div class="navbar-logo">
                <NavLink href="/dashboard" style="display:flex;align-items:center;text-decoration:none;">
                    <img src="logo.png" height="38" alt="Inticoo" style="object-fit:contain;" />
                </NavLink>
            </div>

            <!-- ═══════════════════════════════════════════════
                 DESKTOP NAV — phân quyền:
                 ─ Dashboard (link)  : Admin + Inspector
                 ─ Dashboard (link)  : Customer  (riêng)
                 ─ System (dropdown) : Admin only
                 ─ Customer (dd)     : Customer only
                 ─ Inspector (dd)    : Admin + Inspector
                 ═══════════════════════════════════════════════ -->
            <nav class="navbar-links">

                <!-- ── Dashboard: Admin only — link thẳng ── -->
                <AuthorizeView Roles="Admin">
                    <NavLink href="/dashboard" class="nav-link" Match="NavLinkMatch.All">
                        <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" style="vertical-align:-2px;margin-right:5px">
                            <rect x="2" y="2" width="7" height="7" rx="1"/>
                            <rect x="11" y="2" width="7" height="7" rx="1"/>
                            <rect x="2" y="11" width="7" height="7" rx="1"/>
                            <rect x="11" y="11" width="7" height="7" rx="1"/>
                        </svg>
                        Dashboard
                    </NavLink>
                    <div class="nav-divider"></div>
                </AuthorizeView>

                <!-- ── Inspector: Inspection Schedule link thẳng (thay Dashboard) ── -->
                <AuthorizeView Roles="Inspector">
                    <NavLink href="/inspection-schedule" class="nav-link" Match="NavLinkMatch.All">
                        <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" style="vertical-align:-2px;margin-right:5px">
                            <rect x="2" y="4" width="16" height="13" rx="2"/>
                            <path d="M6 2v4M14 2v4M2 9h16" stroke-linecap="round"/>
                            <circle cx="7" cy="13" r="1.2" fill="currentColor" stroke="none"/>
                            <circle cx="10" cy="13" r="1.2" fill="currentColor" stroke="none"/>
                            <circle cx="13" cy="13" r="1.2" fill="currentColor" stroke="none"/>
                        </svg>
                        Inspection Schedule
                    </NavLink>
                </AuthorizeView>

                <!-- ── Customer: Inspection List + Inspection Schedule ── -->
                <AuthorizeView Roles="Customer">
                    <NavLink href="/inspections" class="nav-link">
                        <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" style="vertical-align:-2px;margin-right:5px">
                            <path d="M4 3h12a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z"/>
                            <path d="M7 7l1.5 1.5L11 6M7 11l1.5 1.5L11 10" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M7 14.5h4" stroke-linecap="round"/>
                        </svg>
                        Inspection List
                    </NavLink>
                    <div class="nav-divider"></div>
                    <NavLink href="/inspection-schedule" class="nav-link">
                        <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" style="vertical-align:-2px;margin-right:5px">
                            <rect x="3" y="3" width="14" height="14" rx="2"/>
                            <path d="M7 7h6M7 10h6M7 13h4" stroke-linecap="round"/>
                        </svg>
                        Inspection Schedule
                    </NavLink>
                    <div class="nav-divider"></div>
                </AuthorizeView>

                <!-- ══════════════════════════════════════════════
                     ADMIN DESKTOP NAV
                     Directory | Job Request | Inspector | Summary | Performance
                     ══════════════════════════════════════════════ -->

                <!-- ── 1. DIRECTORY: Admin only ── -->
                <AuthorizeView Roles="Admin">
                    <div class="nav-dropdown">
                        <button class="nav-link nav-dropdown-btn">
                            <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" style="vertical-align:-2px;margin-right:5px">
                                <path d="M3 4h14M3 8h10M3 12h12M3 16h8" stroke-linecap="round"/>
                            </svg>
                            Directory
                            <svg width="10" height="10" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-left:3px">
                                <path d="M5 8l5 5 5-5"/>
                            </svg>
                        </button>
                        <div class="nav-dropdown-menu">
                            <NavLink href="/customers" class="nav-dropdown-item">
                                <svg width="15" height="15" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <circle cx="8" cy="7" r="3"/>
                                    <path d="M2 17c0-3.314 2.686-6 6-6s6 2.686 6 6"/>
                                    <circle cx="15" cy="7" r="2"/>
                                    <path d="M15 11c1.657 0 3 1.343 3 3v2" stroke-linecap="round"/>
                                </svg>
                                Customers Profile
                            </NavLink>
                            <NavLink href="/suppliers" class="nav-dropdown-item">
                                <svg width="15" height="15" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <path d="M3 9l7-6 7 6v9a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1z" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                                Vendors Profile
                            </NavLink>
                            <NavLink href="/users" class="nav-dropdown-item">
                                <svg width="15" height="15" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <circle cx="10" cy="7" r="3.5"/>
                                    <path d="M3 18c0-3.866 3.134-7 7-7s7 3.134 7 7" stroke-linecap="round"/>
                                    <path d="M14 12l2 2 3-3" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                                Inspectors Profile
                            </NavLink>
                            <NavLink href="/products" class="nav-dropdown-item">
                                <svg width="15" height="15" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <path d="M10 2L2 6v8l8 4 8-4V6L10 2z"/>
                                    <path d="M2 6l8 4 8-4M10 10v8" stroke-linecap="round"/>
                                </svg>
                                Products Profile
                            </NavLink>
                        </div>
                    </div>
                    <div class="nav-divider"></div>
                </AuthorizeView>

                <!-- ── 2. JOB REQUEST: Admin only ── -->
                <AuthorizeView Roles="Admin">
                    <div class="nav-dropdown">
                        <button class="nav-link nav-dropdown-btn">
                            <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" style="vertical-align:-2px;margin-right:5px">
                                <path d="M10 4v12M4 10h12" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            Job Request
                            <svg width="10" height="10" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-left:3px">
                                <path d="M5 8l5 5 5-5"/>
                            </svg>
                        </button>
                        <div class="nav-dropdown-menu">
                            <NavLink href="/inspections/new" class="nav-dropdown-item">
                                <svg width="15" height="15" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <path d="M10 4v12M4 10h12" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                                + New Inspection
                            </NavLink>
                        </div>
                    </div>
                    <div class="nav-divider"></div>
                </AuthorizeView>

                <!-- ── 3. INSPECTOR: Admin + Inspector ── -->
                <AuthorizeView Roles="Admin">
                    <div class="nav-dropdown">
                        <button class="nav-link nav-dropdown-btn">
                            <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" style="vertical-align:-2px;margin-right:5px">
                                <circle cx="10" cy="7" r="3.5"/>
                                <path d="M3 18c0-3.866 3.134-7 7-7s7 3.134 7 7" stroke-linecap="round"/>
                                <path d="M14 12l2 2 3-3" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            Inspector
                            <svg width="10" height="10" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-left:3px">
                                <path d="M5 8l5 5 5-5"/>
                            </svg>
                        </button>
                        <div class="nav-dropdown-menu">
                            <NavLink href="/inspection-schedule" class="nav-dropdown-item">
                                <svg width="15" height="15" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <rect x="2" y="4" width="16" height="13" rx="2"/>
                                    <path d="M6 2v4M14 2v4M2 9h16" stroke-linecap="round"/>
                                    <circle cx="7" cy="13" r="1.2" fill="currentColor" stroke="none"/>
                                    <circle cx="10" cy="13" r="1.2" fill="currentColor" stroke="none"/>
                                    <circle cx="13" cy="13" r="1.2" fill="currentColor" stroke="none"/>
                                </svg>
                                Inspection Schedule
                            </NavLink>
                        </div>
                    </div>
                    <div class="nav-divider"></div>
                </AuthorizeView>

                <!-- ── 4. SUMMARY INSPECTIONS: Admin only ── -->
                <AuthorizeView Roles="Admin">
                    <div class="nav-dropdown">
                        <button class="nav-link nav-dropdown-btn">
                            <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" style="vertical-align:-2px;margin-right:5px">
                                <path d="M4 3h12a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z"/>
                                <path d="M7 7l1.5 1.5L11 6M7 11l1.5 1.5L11 10" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            Summary
                            <svg width="10" height="10" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-left:3px">
                                <path d="M5 8l5 5 5-5"/>
                            </svg>
                        </button>
                        <div class="nav-dropdown-menu">
                            <NavLink href="/inspections" class="nav-dropdown-item">
                                <svg width="15" height="15" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <path d="M4 3h12a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z"/>
                                    <path d="M7 7h6M7 10h6M7 13h4" stroke-linecap="round"/>
                                </svg>
                                Inspection Lists
                            </NavLink>
                        </div>
                    </div>
                    <div class="nav-divider"></div>
                </AuthorizeView>

                <!-- ── 5. PERFORMANCE REVIEW: Admin only ── -->
                <AuthorizeView Roles="Admin">
                    <div class="nav-dropdown">
                        <button class="nav-link nav-dropdown-btn">
                            <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" style="vertical-align:-2px;margin-right:5px">
                                <path d="M2 16l4-8 4 4 3-5 5 9H2z"/>
                            </svg>
                            Performance
                            <svg width="10" height="10" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-left:3px">
                                <path d="M5 8l5 5 5-5"/>
                            </svg>
                        </button>
                        <div class="nav-dropdown-menu">
                            <NavLink href="/vendor-reviews" class="nav-dropdown-item">
                                <svg width="15" height="15" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <path d="M3 9l7-6 7 6v9a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1z" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                                Vendor Reviews
                            </NavLink>
                            <NavLink href="/inspector-reviews" class="nav-dropdown-item">
                                <svg width="15" height="15" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <circle cx="10" cy="7" r="3.5"/>
                                    <path d="M3 18c0-3.866 3.134-7 7-7s7 3.134 7 7" stroke-linecap="round"/>
                                    <path d="M10 12l1.5 3h3l-2.5 2 1 3L10 18l-3 2 1-3-2.5-2h3z" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                                Inspector Reviews
                            </NavLink>
                        </div>
                    </div>
                </AuthorizeView>

            </nav>

            <!-- Right: Welcome + User -->
            <div class="navbar-right">
                <AuthorizeView>
                    <span class="welcome-text">Welcome, @context.User.Identity?.Name</span>
                    <div class="nav-divider"></div>
                    <div class="user-dropdown">
                        <div class="user-avatar-btn">
                            <div class="user-avatar">@GetInitials(context.User.Identity?.Name ?? "")</div>
                            <svg class="chevron" width="12" height="12" viewBox="0 0 20 20" fill="currentColor">
                                <path d="M5 8l5 5 5-5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <div class="dropdown-menu">
                            <button class="dropdown-item logout-item" @onclick="Logout">
                                <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <path d="M13 15l4-5-4-5M17 10H7" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M7 3H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h3" stroke-linecap="round"/>
                                </svg>
                                Sign Out
                            </button>
                        </div>
                    </div>
                </AuthorizeView>
            </div>

            <!-- Hamburger button (mobile only) -->
            <button class="hamburger" @onclick="ToggleMobileMenu" aria-label="Menu">
                @if (_mobileMenuOpen)
                {
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                }
                else
                {
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                        <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
                    </svg>
                }
            </button>

        </div>

        <!-- ═══════════════════════════════════════════════
             MOBILE MENU
             ═══════════════════════════════════════════════ -->
        @if (_mobileMenuOpen)
        {
            <div class="mobile-menu">
                <!-- Drawer Header -->
                <div class="mobile-drawer-header">
                    <span class="mobile-drawer-title">Dashboard</span>
                    <button class="mobile-drawer-close" @onclick="CloseMobileMenu" aria-label="Close">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                        </svg>
                    </button>
                </div>

                <!-- ── Inspector role ── -->
                <AuthorizeView Roles="Inspector">
                    <div class="mobile-nav-group-label">Inspector</div>
                    <NavLink href="/inspection-schedule" class="mobile-nav-item" Match="NavLinkMatch.All" @onclick="CloseMobileMenu">
                        Inspection Schedule
                    </NavLink>
                </AuthorizeView>

                <!-- ── Customer role ── -->
                <AuthorizeView Roles="Customer">
                    <div class="mobile-nav-group-label">Summary Inspections</div>
                    <NavLink href="/inspections" class="mobile-nav-item" @onclick="CloseMobileMenu">Inspection Lists</NavLink>
                    <NavLink href="/inspection-schedule" class="mobile-nav-item" @onclick="CloseMobileMenu">Inspection Schedule</NavLink>
                </AuthorizeView>

                <!-- ══════════════════════════════════════
                     ADMIN FULL MENU
                     ══════════════════════════════════════ -->
                <AuthorizeView Roles="Admin">

                    <!-- DIRECTORY -->
                    <div class="mobile-nav-group-label">Directory</div>
                    <NavLink href="/customers"  class="mobile-nav-item" @onclick="CloseMobileMenu">Customers Profile</NavLink>
                    <NavLink href="/suppliers"  class="mobile-nav-item" @onclick="CloseMobileMenu">Vendors Profile</NavLink>
                    <NavLink href="/users"      class="mobile-nav-item" @onclick="CloseMobileMenu">Inspectors Profile</NavLink>
                    <NavLink href="/products"   class="mobile-nav-item" @onclick="CloseMobileMenu">Products Profile</NavLink>

                    <!-- JOB REQUEST -->
                    <div class="mobile-nav-group-label">Job Request</div>
                    <NavLink href="/inspections/new" class="mobile-nav-item" @onclick="CloseMobileMenu">+ New Inspection</NavLink>

                    <!-- INSPECTOR -->
                    <div class="mobile-nav-group-label">Inspector</div>
                    <NavLink href="/inspection-schedule" class="mobile-nav-item" @onclick="CloseMobileMenu">Inspection Schedule</NavLink>

                    <!-- SUMMARY INSPECTIONS -->
                    <div class="mobile-nav-group-label">Summary Inspections</div>
                    <NavLink href="/inspections" class="mobile-nav-item" @onclick="CloseMobileMenu">Inspection Lists</NavLink>

                    <!-- PERFORMANCE REVIEW -->
                    <div class="mobile-nav-group-label">Performance Review</div>
                    <NavLink href="/vendor-reviews"    class="mobile-nav-item" @onclick="CloseMobileMenu">Vendor Reviews</NavLink>
                    <NavLink href="/inspector-reviews" class="mobile-nav-item" @onclick="CloseMobileMenu">Inspector Reviews</NavLink>

                </AuthorizeView>

                <!-- Sign Out -->
                <AuthorizeView>
                    <div class="mobile-nav-divider" style="margin-top:auto;margin-bottom:16px;"></div>
                    <button class="mobile-nav-item mobile-logout" @onclick="Logout">
                        Sign Out
                    </button>
                </AuthorizeView>

            </div>
        }
    </header>

    <!-- MAIN CONTENT -->
    <main class="main-content">
        @Body
    </main>

    <!-- BOTTOM FOOTER -->
    <footer class="bottom-footer">
        <div class="footer-inner">
            <div class="footer-copy">
                <span>© 2026 Inticoo. All Rights Reserved.</span>
                <div class="footer-socials">
                    <a href="#" class="social-icon" title="Facebook">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
                        </svg>
                    </a>
                    <a href="#" class="social-icon" title="Twitter">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/>
                        </svg>
                    </a>
                    <a href="#" class="social-icon" title="Info">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="12" y1="8" x2="12" y2="12"/>
                            <line x1="12" y1="16" x2="12.01" y2="16"/>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </footer>
</div>

<WaitingOverlay />

@code {
    private bool _mobileMenuOpen = false;

    private void ToggleMobileMenu() => _mobileMenuOpen = !_mobileMenuOpen;
    private void CloseMobileMenu() => _mobileMenuOpen = false;

    private async Task Logout()
    {
        Waiting.Show("Logging out...");
        await AuthService.LogoutAsync();
        Waiting.Hide();
        Navigation.NavigateTo("/login");
    }

    private string GetInitials(string name)
        => string.Concat(name.Split(" ").Take(2).Select(w => w.Length > 0 ? w[0].ToString().ToUpper() : ""));
}

<style>
    @@import url("https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700&family=DM+Sans:wght@300;400;500&display=swap");

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
        background: linear-gradient(160deg, #1a3a6b 0%, #1565c0 40%, #1976d2 70%, #1e88e5 100%);
        min-height: 100vh;
        color: #fff;
        font-family: "DM Sans", sans-serif;
        position: relative;
    }

    .app-layout {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        isolation: auto;
    }

    /* ─── TOP NAVBAR ─── */
    .top-navbar {
        background: rgba(255, 255, 255, 0.96);
        border-bottom: 1px solid rgba(255,255,255,0.2);
        position: sticky;
        top: 0;
        z-index: 40;
        box-shadow: 0 2px 12px rgba(0,0,0,0.15);
    }

    .navbar-inner {
        max-width: 1280px;
        margin: 0 auto;
        padding: 0 24px;
        height: 60px;
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .navbar-logo {
        display: flex;
        align-items: center;
        flex-shrink: 0;
        margin-right: 8px;
    }

    .navbar-links {
        display: flex;
        align-items: center;
        gap: 0;
        flex: 1;
    }

    .nav-link {
        color: #1a3a6b;
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
        padding: 6px 18px;
        transition: color .2s;
        white-space: nowrap;
        font-family: "DM Sans", sans-serif;
    }

    .nav-link:hover { color: #1565c0; }
    .nav-link.active { color: #1565c0; font-weight: 600; }

    .nav-divider {
        width: 1px;
        height: 18px;
        background: rgba(26, 58, 107, 0.25);
        flex-shrink: 0;
    }

    /* Right section */
    .navbar-right {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-shrink: 0;
        margin-left: auto;
    }

    .welcome-text {
        font-size: 14px;
        font-weight: 500;
        color: #1a3a6b;
        white-space: nowrap;
    }

    /* User avatar + dropdown */
    .user-dropdown { position: relative; }

    .user-avatar-btn {
        display: flex;
        align-items: center;
        gap: 5px;
        cursor: pointer;
        padding: 4px;
        border-radius: 8px;
        transition: background .2s;
    }

    .user-avatar-btn:hover { background: rgba(26,58,107,0.08); }

    .user-avatar {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: linear-gradient(135deg, #1565c0, #42a5f5);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 700;
        color: #fff;
        border: 2px solid #1565c0;
    }

    .chevron { color: #1a3a6b; }

    .dropdown-menu {
        display: none;
        position: absolute;
        right: 0;
        top: calc(100% + 8px);
        background: #fff;
        border: 1px solid rgba(0,0,0,0.1);
