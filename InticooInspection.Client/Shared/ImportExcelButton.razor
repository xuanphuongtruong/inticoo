@*
============================================================================
    Reusable Blazor component: Import Excel + Download Template
    Path: Client/Shared/ImportExcelButton.razor
============================================================================

    USAGE (chỉ 1 dòng trong từng màn hình):

        <ImportExcelButton ApiBase="api/users"     OnImported="LoadCurrentPage" />
        <ImportExcelButton ApiBase="api/customers" OnImported="LoadCurrentPage" />
        <ImportExcelButton ApiBase="api/vendors"   OnImported="LoadCurrentPage" />
        <ImportExcelButton ApiBase="api/products"  OnImported="LoadCurrentPage" />

    PARAMETERS:
      - ApiBase     : "api/customers", "api/vendors", "api/products", "api/users"
      - ButtonLabel : (optional) đổi label nút Upload (mặc định "Import Excel")
      - TemplateName: (optional) tên file Excel khi download (mặc định auto-detect)
      - OnImported  : EventCallback gọi sau khi import thành công ≥ 1 row
                      (parent dùng để reload list)

    BACKEND CONTRACT (cùng pattern cho cả 4 module):
      GET  {ApiBase}/template  → trả file Excel template
      POST {ApiBase}/import    → multipart/form-data, field "file" → trả ImportResult JSON

    RESPONSE SHAPE (chuẩn hóa):
      {
        "success":   true,
        "totalRows": 10,
        "created":   8,           ← số dòng đã insert thành công
        "failed":    2,           ← số dòng lỗi
        "errors": [
          {
            "row": 5,
            "key": "ABC Trading Co.",   ← identifier dễ nhìn (CompanyName/Name/...)
            "errors": ["Email format is invalid."]
          }
        ]
      }
============================================================================
*@
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Forms
@inject HttpClient Http
@inject IJSRuntime JS

<div class="ie-wrap">
    <button class="ie-btn ie-btn-dl" @onclick="DownloadTemplate" disabled="@_uploading" title="Download Excel template">
        <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10 3v10m0 0l-4-4m4 4l4-4M4 17h12"/>
        </svg>
        Template
    </button>

    <label class="ie-btn ie-btn-up @(_uploading ? "disabled" : "")">
        @if (_uploading)
        {
            <span class="ie-spinner"></span>
            <span>Uploading...</span>
        }
        else
        {
            <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10 17V7m0 0l-4 4m4-4l4 4M4 3h12"/>
            </svg>
            <span>@ButtonLabel</span>
        }
        <InputFile OnChange="OnFileSelected" accept=".xlsx,.xlsm" style="display:none" disabled="@_uploading" />
    </label>
</div>

@if (_result != null)
{
    <div class="ie-result-overlay" @onclick="CloseResult">
        <div class="ie-result-card" @onclick:stopPropagation="true">
            <div class="ie-result-header">
                <h3>
                    @if (_result.Success)
                    {
                        <span class="ie-ok">✓ Import Successful</span>
                    }
                    else
                    {
                        <span class="ie-warn">⚠ Import Completed with Errors</span>
                    }
                </h3>
                <button class="ie-close-x" @onclick="CloseResult">×</button>
            </div>

            <div class="ie-summary">
                <div class="ie-stat-card">
                    <div class="ie-stat-num">@_result.TotalRows</div>
                    <div class="ie-stat-lbl">Total Rows</div>
                </div>
                <div class="ie-stat-card ie-stat-ok-card">
                    <div class="ie-stat-num">@_result.Created</div>
                    <div class="ie-stat-lbl">Created</div>
                </div>
                <div class="ie-stat-card ie-stat-fail-card">
                    <div class="ie-stat-num">@_result.Failed</div>
                    <div class="ie-stat-lbl">Failed</div>
                </div>
            </div>

            @if (_result.Errors != null && _result.Errors.Count > 0)
            {
                <div class="ie-err-list">
                    <div class="ie-err-title">Error Details (@_result.Errors.Count)</div>
                    <div class="ie-err-table-wrap">
                        <table>
                            <thead>
                                <tr>
                                    <th class="ie-col-row">Row</th>
                                    <th class="ie-col-key">Identifier</th>
                                    <th class="ie-col-msg">Errors</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var e in _result.Errors)
                                {
                                    <tr>
                                        <td class="ie-col-row">@e.Row</td>
                                        <td class="ie-col-key">@(string.IsNullOrEmpty(e.Key) ? "—" : e.Key)</td>
                                        <td class="ie-col-msg">
                                            <ul>
                                                @foreach (var msg in e.Errors) { <li>@msg</li> }
                                            </ul>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            <div class="ie-actions">
                <button class="ie-close" @onclick="CloseResult">Close</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public string ApiBase     { get; set; } = "";
    [Parameter] public string                 ButtonLabel { get; set; } = "Import Excel";
    [Parameter] public string?                TemplateName { get; set; }
    [Parameter] public EventCallback          OnImported  { get; set; }

    private bool          _uploading;
    private ImportResult? _result;

    private static readonly long MaxBytes = 20 * 1024 * 1024; // 20 MB

    private async Task DownloadTemplate()
    {
        try
        {
            var response = await Http.GetAsync($"{ApiBase}/template");
            if (!response.IsSuccessStatusCode)
            {
                await JS.InvokeVoidAsync("alert", "Cannot download template. Please contact administrator.");
                return;
            }
            var bytes  = await response.Content.ReadAsByteArrayAsync();
            var b64    = Convert.ToBase64String(bytes);
            var name   = !string.IsNullOrWhiteSpace(TemplateName)
                              ? TemplateName
                              : DefaultTemplateName();
            await JS.InvokeVoidAsync("downloadFileFromBase64",
                name,
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                b64);
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", "Download failed: " + ex.Message);
        }
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        var ext = Path.GetExtension(file.Name).ToLowerInvariant();
        if (ext != ".xlsx" && ext != ".xlsm")
        {
            await JS.InvokeVoidAsync("alert", "Only .xlsx or .xlsm files are allowed.");
            return;
        }
        if (file.Size > MaxBytes)
        {
            await JS.InvokeVoidAsync("alert", $"File is too large. Maximum size is {MaxBytes / (1024 * 1024)}MB.");
            return;
        }

        _uploading = true;
        StateHasChanged();
        try
        {
            using var content = new MultipartFormDataContent();
            var stream = file.OpenReadStream(MaxBytes);
            var sc     = new StreamContent(stream);
            sc.Headers.ContentType = new MediaTypeHeaderValue(
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
            content.Add(sc, "file", file.Name);

            var res = await Http.PostAsync($"{ApiBase}/import", content);
            // Cố gắng parse response body, kể cả khi status không phải 2xx
            // (backend có thể trả 400 với { message } khi validation fail toàn file)
            ImportResult? parsed = null;
            try { parsed = await res.Content.ReadFromJsonAsync<ImportResult>(); }
            catch { /* ignore */ }

            if (!res.IsSuccessStatusCode)
            {
                var msg = parsed?.Message ?? await res.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("alert", "Import failed: " + msg);
                return;
            }

            _result = parsed;
            if (_result != null && _result.Created > 0)
                await OnImported.InvokeAsync();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", "Import error: " + ex.Message);
        }
        finally
        {
            _uploading = false;
            StateHasChanged();
        }
    }

    private void CloseResult() => _result = null;

    // Tự sinh tên file template từ ApiBase nếu không truyền vào
    private string DefaultTemplateName()
    {
        var seg  = ApiBase.TrimEnd('/').Split('/').Last();
        if (string.IsNullOrEmpty(seg)) return "import_template.xlsx";
        // "users" -> "Users", "customers" -> "Customers"
        var pretty = char.ToUpper(seg[0]) + seg.Substring(1);
        return $"{pretty}_Import_Template.xlsx";
    }

    // ── DTOs (PascalCase với JSON property name fallback để match cả camelCase từ backend) ──
    private class ImportResult
    {
        public bool                  Success   { get; set; }
        public string?               Message   { get; set; }
        public int                   TotalRows { get; set; }
        public int                   Created   { get; set; }
        public int                   Failed    { get; set; }
        public List<ImportRowError>? Errors    { get; set; }
    }

    private class ImportRowError
    {
        public int          Row    { get; set; }
        public string?      Key    { get; set; }
        public List<string> Errors { get; set; } = new();
    }
}

<style>
    .ie-wrap { display:inline-flex; gap:8px; align-items:center; }

    .ie-btn {
        display:inline-flex; align-items:center; gap:6px;
        padding:8px 14px; border-radius:8px; font-size:13px; font-weight:600;
        cursor:pointer; border:none; white-space:nowrap;
        font-family:"DM Sans",sans-serif; transition:background .2s,transform .1s;
    }
    .ie-btn:disabled { opacity:.6; cursor:not-allowed; }
    .ie-btn-dl { background:#0f766e; color:#fff; }
    .ie-btn-dl:hover:not(:disabled) { background:#115e59; transform:translateY(-1px); }
    .ie-btn-up { background:#16a34a; color:#fff; }
    .ie-btn-up:hover:not(.disabled) { background:#15803d; transform:translateY(-1px); }
    .ie-btn-up.disabled { opacity:.6; pointer-events:none; }

    .ie-spinner {
        width:12px; height:12px; border:2px solid rgba(255,255,255,.4);
        border-top-color:#fff; border-radius:50%;
        animation: ie-spin 0.7s linear infinite;
    }
    @@keyframes ie-spin { to { transform: rotate(360deg); } }

    .ie-result-overlay {
        position:fixed; inset:0; background:rgba(0,0,0,.55);
        display:flex; align-items:center; justify-content:center; z-index:9999;
    }
    .ie-result-card {
        background:#fff; color:#1f2937; border-radius:12px;
        min-width:480px; max-width:780px; width:92%; max-height:85vh;
        display:flex; flex-direction:column;
        box-shadow:0 20px 40px rgba(0,0,0,.5); font-family:"DM Sans",sans-serif;
    }
    .ie-result-header {
        display:flex; align-items:center; justify-content:space-between;
        padding:18px 24px 14px; border-bottom:1px solid #e5e7eb;
    }
    .ie-result-header h3 { margin:0; font-size:16px; font-weight:700; }
    .ie-ok   { color:#16a34a; }
    .ie-warn { color:#d97706; }
    .ie-close-x {
        background:transparent; border:none; font-size:22px; line-height:1;
        color:#6b7280; cursor:pointer; padding:0 4px;
    }
    .ie-close-x:hover { color:#111827; }

    .ie-summary { display:flex; gap:12px; padding:16px 24px 8px; }
    .ie-stat-card {
        flex:1; padding:14px;
        background:#f8f9fb; border:1px solid #e5e7eb;
        border-radius:8px; text-align:center;
    }
    .ie-stat-num { font-size:24px; font-weight:700; color:#111827; line-height:1; }
    .ie-stat-lbl {
        font-size:11px; color:#6b7280; margin-top:6px;
        text-transform:uppercase; letter-spacing:.5px;
    }
    .ie-stat-ok-card   { background:#f0fdf4; border-color:#bbf7d0; }
    .ie-stat-ok-card   .ie-stat-num { color:#16a34a; }
    .ie-stat-fail-card { background:#fef2f2; border-color:#fecaca; }
    .ie-stat-fail-card .ie-stat-num { color:#dc2626; }

    .ie-err-list { padding:8px 24px 16px; overflow:hidden; display:flex; flex-direction:column; min-height:0; }
    .ie-err-title { font-weight:600; margin:8px 0; color:#374151; font-size:13px; }
    .ie-err-table-wrap {
        overflow:auto; max-height:340px;
        border:1px solid #e5e7eb; border-radius:8px;
    }
    .ie-err-list table { width:100%; border-collapse:collapse; font-size:12px; }
    .ie-err-list thead th {
        position:sticky; top:0; background:#f3f4f6;
        padding:8px 10px; text-align:left; font-weight:600;
        color:#374151; border-bottom:1px solid #e5e7eb;
    }
    .ie-err-list tbody td {
        padding:8px 10px; border-bottom:1px solid #f1f1f1; vertical-align:top;
    }
    .ie-col-row { width:50px; text-align:center; }
    .ie-col-key { width:200px; font-weight:500; color:#111827; }
    .ie-err-list ul { margin:0; padding-left:16px; color:#dc2626; }
    .ie-err-list li { line-height:1.5; }

    .ie-actions {
        display:flex; justify-content:flex-end;
        padding:12px 24px 18px; border-top:1px solid #e5e7eb;
    }
    .ie-close {
        padding:8px 18px; background:#374151; color:#fff; border:none;
        border-radius:6px; cursor:pointer; font-size:13px; font-weight:600;
    }
    .ie-close:hover { background:#4b5563; }
</style>
