@inject WaitingService WaitingService
@implements IDisposable

@if (WaitingService.IsVisible)
{
    <div class="wait-overlay">
        <div class="wait-card">
            <div class="wait-spinner"></div>
            <div class="wait-msg">@WaitingService.Message</div>
        </div>
    </div>
}

@code {
    protected override void OnInitialized()
        => WaitingService.OnChange += OnServiceChanged;

    void OnServiceChanged()
        => InvokeAsync(StateHasChanged);

    public void Dispose()
        => WaitingService.OnChange -= OnServiceChanged;
}

<style>
    .wait-overlay {
        position: fixed; inset: 0;
        background: rgba(0,0,0,0.5);
        backdrop-filter: blur(3px);
        display: flex; align-items: center; justify-content: center;
        z-index: 9999;
    }
    .wait-card {
        background: #fff;
        border-radius: 16px;
        padding: 32px 48px;
        display: flex; flex-direction: column; align-items: center; gap: 18px;
        box-shadow: 0 24px 60px rgba(0,0,0,0.2);
        min-width: 240px;
        animation: waitFadeIn .2s ease;
    }
    .wait-spinner {
        width: 44px; height: 44px;
        border: 4px solid #e0eaf7;
        border-top-color: #1e90d6;
        border-radius: 50%;
        animation: waitSpin .7s linear infinite;
    }
    .wait-msg {
        font-size: 14px; font-weight: 600;
        color: #1a2d5a; text-align: center;
        max-width: 260px; line-height: 1.5;
    }
    @@keyframes waitSpin    { to { transform: rotate(360deg); } }
    @@keyframes waitFadeIn  { from { opacity: 0; transform: scale(.92); } to { opacity: 1; transform: scale(1); } }
</style>
